@model FabricaHilos.Models.Ventas.Cliente

@{
    ViewData["Title"] = "Nuevo Cliente";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Ventas</a></li>
    <li class="breadcrumb-item"><a asp-action="Clientes">Clientes</a></li>
    <li class="breadcrumb-item active">Nuevo</li>
}

<h4 class="section-title"><i class="bi bi-plus-circle me-2"></i>Nuevo Cliente</h4>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="CrearCliente" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Nombre" class="form-label fw-semibold"></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="RucDni" class="form-label fw-semibold"></label>
                            <input asp-for="RucDni" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label fw-semibold"></label>
                            <input asp-for="Telefono" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Correo" class="form-label fw-semibold"></label>
                            <input asp-for="Correo" class="form-control" type="email" />
                            <span asp-validation-for="Correo" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Activo" class="form-label fw-semibold"></label>
                            <select asp-for="Activo" class="form-select">
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Direccion" class="form-label fw-semibold"></label>
                            <input asp-for="Direccion" class="form-control" />
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-action="Clientes" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
