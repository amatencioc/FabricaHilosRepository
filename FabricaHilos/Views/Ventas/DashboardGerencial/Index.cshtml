            const p = buildParams(); p.set('mercado', mercado);
            const data = await apiFetch('/DashboardGerencial/DatosDetallePorPais?' + p); _detallePaisData = data;
            const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD'; const total = data.reduce((s, d) => s + (d.importe ?? 0), 0);
            const tbody = document.getElementById('tablaDetallePais');
            if (data.length === 0) { tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">Sin datos</td></tr>'; }
            else { tbody.innerHTML = data.map((d, i) => { const pct = total > 0 ? ((d.importe / total) * 100).toFixed(1) : '0.0'; const isClickable = d.codigoPais !== '01'; const isHighlight = hlNorm && (d.pais ?? '').toUpperCase().trim() === hlNorm; const classes = (isClickable ? 'clickable-row' : '') + (isHighlight ? ' highlight-row' : ''); const rowId = isHighlight ? ' id="highlightedRow"' : ''; const rowClick = isClickable ? ' onclick="loadCiudadesPais(\'' + (d.codigoPais ?? '').replace(/'/g, "\\'") + '\', \'' + (d.pais ?? '').replace(/'/g, "\\'") + '\')"' : ''; const hint = isClickable ? ' title="Clic para ver ciudades de ' + (d.pais ?? '') + '"' : ''; return '<tr' + rowId + ' class="' + classes.trim() + '"' + rowClick + hint + '><td>' + (i + 1) + '</td><td>' + (d.codigoPais ?? '') + '</td><td>' + (d.pais ?? '') + '</td><td class="text-end">' + monLabel + ' ' + fmt(d.importe) + '</td><td class="text-end">' + pct + '%</td></tr>'; }).join(''); }
