                data: { labels: top10.map(d => d.pais ?? d.codigoPais), datasets: [{ data: top10.map(d => d.importe ?? 0), backgroundColor: PAIS_COLORS.slice(0, top10.length), borderWidth: 2, borderColor: '#fff', hoverOffset: 8 }] },
                options: { responsive: true, maintainAspectRatio: false, cutout: '55%',
