@model FabricaHilos.Models.Seguridad.Inspeccion.AccionCorrectivaViewModel

@{
    ViewData["Title"] = "Acción Correctiva";
    var inspeccion = ViewBag.Inspeccion as FabricaHilos.Services.Seguridad.Inspeccion.InspeccionListDto;
    var itemNum = (int)(ViewBag.Item ?? 0);
    var fotoHallazgo = ViewBag.FotoHallazgo as FabricaHilos.Services.Seguridad.Inspeccion.InspeccionFotoDto;
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Seguridad" asp-action="Index">Seguridad</a></li>
    <li class="breadcrumb-item"><a asp-controller="Inspeccion" asp-action="Index">Inspecciones</a></li>
    <li class="breadcrumb-item active">Acción Correctiva</li>
}

<style>
    .preview-container {
        border: 2px dashed var(--color-border, #dee2e6);
        border-radius: 0.5rem;
        padding: 1rem;
        background: var(--color-bg-light, #f8f9fa);
        min-height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .preview-container.has-image {
        border-color: #28a745;
        background: #fff;
    }
</style>

<h4 class="section-title"><i class="bi bi-file-earmark-check me-2"></i>Acción Correctiva</h4>

@if (inspeccion != null)
{
    <div class="row justify-content-center">
        <div class="col-md-8">
            <!-- Información de la inspección -->
            <div class="card shadow-sm mb-3">
                <div class="card-body p-4">
                    <h6 class="fw-semibold mb-3">
                        <i class="bi bi-info-circle me-2"></i>Inspección N° @inspeccion.Numero
                    </h6>
                    <table class="table table-sm table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted" style="width:140px;">Fecha</td>
                                <td class="fw-semibold">@inspeccion.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Tipo</td>
                                <td>
                                    @if (inspeccion.Tipo == "P")
                                    {
                                        <span class="badge bg-info">Planeada</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">No Planeada</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">Centro de Costo</td>
                                <td>@inspeccion.NombreCentroCosto</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Resp. Inspección</td>
                                <td>@inspeccion.NombreRespInspeccion</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Resp. Área</td>
                                <td>@inspeccion.NombreRespArea</td>
                            </tr>
                            @if (fotoHallazgo != null && !string.IsNullOrEmpty(fotoHallazgo.UbicaFotoH))
                            {
                                <tr>
                                    <td class="text-muted">Hallazgo (Ítem @fotoHallazgo.Item)</td>
                                    <td>
                                        @fotoHallazgo.UbicaFotoH
                                        <small class="text-muted ms-2">(@fotoHallazgo.FechaFotoH?.ToString("dd/MM/yyyy"))</small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Formulario -->
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="AccionCorrectiva" asp-controller="Inspeccion" asp-route-numero="@inspeccion.Numero" asp-route-item="@itemNum" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="UbicacionFoto" class="form-label fw-semibold">
                                    Ubicación de la Acción Correctiva
                                </label>
                                <input asp-for="UbicacionFoto" 
                                       type="text" 
                                       class="form-control" 
                                       placeholder="Ej: Se corrigió en Área de Producción" 
                                       maxlength="100" 
                                       required />
                                <span asp-validation-for="UbicacionFoto" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">
                                    Foto de Evidencia
                                </label>
                                <input asp-for="Foto" type="file" accept="image/*" id="foto" class="d-none" required />
                                <input type="file" accept="image/*" capture="environment" id="cameraInput" class="d-none" />
                                <div class="d-flex gap-2 mb-2">
                                    <button type="button" class="btn btn-outline-primary" onclick="document.getElementById('cameraInput').click()">
                                        <i class="bi bi-camera-fill me-1"></i>Tomar Foto
                                    </button>
                                    <button type="button" class="btn btn-outline-secondary" onclick="document.getElementById('foto').click()">
                                        <i class="bi bi-image me-1"></i>Elegir Archivo
                                    </button>
                                </div>
                                <small id="fotoNombre" class="text-muted"></small>
                                <div class="form-text">JPG, JPEG, PNG o WebP. La imagen se optimizará automáticamente.</div>
                                <span asp-validation-for="Foto" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <div id="previewContainer" class="preview-container d-none">
                                    <img id="previewImg" src="#" alt="Vista previa" class="img-fluid rounded" style="max-height: 300px;" />
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Registrar Acción Correctiva
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function mostrarPreview(file) {
            const container = document.getElementById('previewContainer');
            const img = document.getElementById('previewImg');
            const nombre = document.getElementById('fotoNombre');

            if (file && file.type.startsWith('image/')) {
                nombre.textContent = file.name;
                const reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    container.classList.remove('d-none');
                    container.classList.add('has-image');
                };
                reader.readAsDataURL(file);
            } else {
                container.classList.add('d-none');
                container.classList.remove('has-image');
                nombre.textContent = '';
            }
        }

        // Cámara → copiar archivo al input del formulario + preview
        document.getElementById('cameraInput').addEventListener('change', function () {
            const file = this.files[0];
            if (!file) return;
            // Intentar DataTransfer (no disponible en Safari/iOS)
            try {
                const dt = new DataTransfer();
                dt.items.add(file);
                document.getElementById('foto').files = dt.files;
                mostrarPreview(file);
            } catch (e) {
                // Fallback iOS: renombrar inputs para que el form envíe el de la cámara
                const cam = document.getElementById('cameraInput');
                cam.name = 'Foto';
                document.getElementById('foto').name = '_Foto_disabled';
                mostrarPreview(file);
            }
        });

        // Galería/archivo → preview directo
        document.getElementById('foto').addEventListener('change', function () {
            mostrarPreview(this.files[0]);
        });
    </script>
}
