@model IEnumerable<FabricaHilos.Models.Logistica.RequisicionDto>

@{
    ViewData["Title"] = "Requerimientos";
    string? buscar      = ViewBag.Buscar      as string;
    string? fechaInicio = ViewBag.FechaInicio as string;
    string? fechaFin    = ViewBag.FechaFin    as string;
    string? estado      = ViewBag.Estado      as string;
    bool    hayFiltros  = !string.IsNullOrEmpty(buscar) || !string.IsNullOrEmpty(estado)
                       || Context.Request.Query.ContainsKey("fechaInicio") || Context.Request.Query.ContainsKey("fechaFin");
    int currentPage = ViewBag.Page      != null ? Convert.ToInt32(ViewBag.Page)      : 1;
    int totalPages  = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
    int totalCount  = ViewBag.TotalCount != null ? Convert.ToInt32(ViewBag.TotalCount) : 0;
    int pgSize      = ViewBag.PageSize   != null ? Convert.ToInt32(ViewBag.PageSize)   : 10;
    int startItem   = totalCount == 0 ? 0 : (currentPage - 1) * pgSize + 1;
    int endItem     = Math.Min(currentPage * pgSize, totalCount);
    var nombres      = ViewBag.Nombres      as Dictionary<string, string> ?? new Dictionary<string, string>();
    var prioridades  = ViewBag.Prioridades  as Dictionary<string, string> ?? new Dictionary<string, string>();
    var centrosCosto = ViewBag.CentrosCosto as Dictionary<string, string> ?? new Dictionary<string, string>();
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Logistica" asp-action="Index">Logística</a></li>
    <li class="breadcrumb-item active">Requerimientos</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-clipboard-check me-2"></i>Requerimientos</h4>
    <span class="text-muted small">@(ViewBag.TotalCount ?? 0) registro(s) encontrado(s)</span>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" asp-action="Index" class="d-flex gap-2 flex-wrap align-items-center">
            <input type="text" name="buscar" value="@buscar"
                   class="form-control form-control-sm"
                   placeholder="Buscar por proveedor, N° req. o centro costo..."
                   style="max-width:280px;" />

            <div class="d-flex align-items-center gap-1">
                <label class="form-label mb-0 text-nowrap small text-muted">Fecha desde:</label>
                <input type="date" name="fechaInicio" value="@fechaInicio"
                       class="form-control form-control-sm" style="max-width:155px;" />
            </div>
            <div class="d-flex align-items-center gap-1">
                <label class="form-label mb-0 text-nowrap small text-muted">hasta:</label>
                <input type="date" name="fechaFin" value="@fechaFin"
                       class="form-control form-control-sm" style="max-width:155px;" />
            </div>

            <select name="estado" class="form-select form-select-sm" style="max-width:160px;">
                <option value="">-- Todos los estados --</option>
                <option value="0" selected="@(estado == "0")">Emitido</option>
                <option value="1" selected="@(estado == "1")">Autorizado</option>
                <option value="2" selected="@(estado == "2")">Recibido</option>
                <option value="6" selected="@(estado == "6")">Cerrado</option>
                <option value="9" selected="@(estado == "9")">Anulado</option>
            </select>

            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i> Buscar
            </button>
            @if (hayFiltros)
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Limpiar</a>
            }
            <button type="button" id="btnExportarPendientes"
                    class="btn btn-sm btn-success ms-auto"
                    title="Exporta todos los ítems de requerimientos Autorizados y Recibidos"
                    onclick="exportarPendientes()">
                <i class="bi bi-file-earmark-excel me-1"></i>Requerimientos Pendientes
            </button>
        </form>
    </div>
</div>

<!-- Tabla -->
<form id="frmCambiarEstado" method="post" asp-action="CambiarEstado">
    @Html.AntiForgeryToken()
    <input type="hidden" name="buscar" value="@buscar" />
    <input type="hidden" name="fechaInicio" value="@fechaInicio" />
    <input type="hidden" name="fechaFin" value="@fechaFin" />
    <input type="hidden" name="estado" value="@estado" />
    <input type="hidden" name="page" value="@currentPage" />
    <div class="mb-2 d-flex gap-2">
        <button type="button" id="btnAnularSeleccionados"
                class="btn btn-sm btn-danger" @(estado == "9" || estado == "6" ? "disabled" : "")>
            <i class="bi bi-slash-circle me-1"></i>Anular seleccionados
        </button>
    </div>
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width:40px;">
                            <input type="checkbox" id="chkAll" title="Seleccionar todos" @(estado == "9" || estado == "6" ? "disabled" : "") />
                        </th>
                        <th class="text-center">TipDoc</th>
                        <th class="text-center">N° Req.</th>
                        <th>Centro Costo</th>
                        <th>Proveedor(es)</th>
                        <th class="text-center">Fecha</th>
                        <th class="text-center">F. Entrega</th>
                        <th class="text-center">Prioridad / Resp.</th>
                        <th class="text-center">Autoriza / F. Autoriza</th>
                        <th class="text-center" style="min-width:120px;" title="Ítems con documento adjunto aprobado">Progreso<br/><small class="fw-normal text-white-50">ítems aprobados</small></th>
                        <th class="text-center" style="min-width:160px;" title="Situación general del requerimiento en el flujo logístico">Situación<br/><small class="fw-normal text-white-50">flujo logístico</small></th>
                        <th class="text-center" style="min-width:110px;" title="Número(s) de orden de compra">O/C<br/><small class="fw-normal text-white-50">orden compra</small></th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in Model)
                    {
                        <tr>
                            <td class="text-center">
                                @if (req.Estado != "9")
                                {
                                    <input type="checkbox" name="seleccion" class="chk-req"
                                           value="@req.TipDoc|@req.Serie|@req.NumReq"
                                           @(estado == "9" || estado == "6" ? "disabled" : "") />
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-center">@(req.TipDoc ?? "-")</td>
                            <td class="text-center fw-semibold">@req.NumReq</td>
                            <td>
                                @{
                                    var ccDesc = !string.IsNullOrEmpty(req.CentroCosto) && centrosCosto.TryGetValue(req.CentroCosto, out var ccD) && !string.IsNullOrWhiteSpace(ccD)
                                        ? ccD : req.CentroCosto;
                                }
                                @(ccDesc ?? "-")
                            </td>
                            <td>@(req.Proveedores ?? "-")</td>
                            <td class="text-center">@(req.Fecha?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="text-center">@(req.FEntrega?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(req.Prioridad))
                                {
                                    var descPrio = prioridades.TryGetValue(req.Prioridad, out var dp) && !string.IsNullOrWhiteSpace(dp) ? dp : req.Prioridad;
                                    <span class="badge bg-secondary" title="@req.Prioridad">@descPrio</span>
                                }
                                @if (req.Responsable != null && nombres.TryGetValue(req.Responsable, out var nomResp))
                                {
                                    <br /><span class="text-muted small">@nomResp</span>
                                }
                                else if (!string.IsNullOrEmpty(req.Responsable))
                                {
                                    <br /><span class="text-muted small">@req.Responsable</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrEmpty(req.Autoriza) || req.FAutoriza.HasValue)
                                {
                                    @if (req.Autoriza != null && nombres.TryGetValue(req.Autoriza, out var nomAutoriza))
                                    {
                                        <span class="text-muted small">@nomAutoriza</span>
                                    }
                                    else if (!string.IsNullOrEmpty(req.Autoriza))
                                    {
                                        <span class="text-muted small">@req.Autoriza</span>
                                    }
                                    @if (req.FAutoriza.HasValue)
                                    {
                                        <br /><span class="text-muted small">@req.FAutoriza.Value.ToString("dd/MM/yyyy HH:mm")</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @{
                                    // Progreso = ítems con ID_GRUPO (documento adjunto) / total ítems
                                    int pct      = req.Progreso;
                                    string pctColor = pct == 100 ? "bg-success" : "bg-success";
                                    int pctRayadoItems = req.TotalItems > 0
                                        ? (int)Math.Round((req.TotalItems - req.ItemsConGrupo) * 100.0 / req.TotalItems)
                                        : 0;
                                }
                                <div class="progress" style="height:14px;min-width:80px;"
                                     title="@req.ItemsConGrupo de @req.TotalItems ítem(s) con documento adjunto">
                                    @if (pct > 0)
                                    {
                                        <div class="progress-bar bg-success" role="progressbar"
                                             style="width:@pct%"
                                             aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                        </div>
                                    }
                                    @if (pct > 0 && pct < 100 && pctRayadoItems > 0)
                                    {
                                        <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar"
                                             style="width:@pctRayadoItems%; opacity:.4;"
                                             aria-valuenow="@pctRayadoItems" aria-valuemin="0" aria-valuemax="100">
                                        </div>
                                    }
                                </div>
                                <small class="text-muted">@req.ItemsConGrupo/@req.TotalItems (@pct%)</small>
                            </td>
                            @* ── Columna: Situación general (4 etapas) ── *@
                            <td class="text-center">
                                @{
                                    var pg = req.ProgresoGeneral;

                                    // Etapa 1: progreso parcial por grupos aprobados/total
                                    int e1Total    = pg.Etapa1GruposTotal;
                                    int e1Aprob    = pg.Etapa1GruposAprobados;
                                    bool e1Ok      = pg.Etapa1Aprobada;
                                    int e1Solido   = e1Total > 0 ? (int)Math.Round(e1Aprob         * 100.0 / e1Total) : 0;
                                    int e1Rayado   = e1Total > 0 ? (int)Math.Round((e1Total - e1Aprob) * 100.0 / e1Total) : 0;

                                    // Etapa 2: progreso parcial por ítems con O/C / total ítems
                                    int e2Total    = pg.Etapa2ItemsTotal;
                                    int e2ConOC    = pg.Etapa2ItemsConOC;
                                    bool e2Ok      = pg.Etapa2Aprobada;
                                    int e2Solido   = e2Total > 0 ? (int)Math.Round(e2ConOC          * 100.0 / e2Total) : 0;
                                    int e2Rayado   = e2Total > 0 ? (int)Math.Round((e2Total - e2ConOC)  * 100.0 / e2Total) : 0;

                                    // Etapa 3: progreso parcial por O/C facturadas / total O/C
                                    int e3Total    = pg.Etapa3OcTotal;
                                    int e3Fact     = pg.Etapa3OcFacturadas;
                                    bool e3Ok      = pg.Etapa3Aprobada;
                                    int e3Solido   = e3Total > 0 ? (int)Math.Round(e3Fact          * 100.0 / e3Total) : 0;
                                    int e3Rayado   = e3Total > 0 ? (int)Math.Round((e3Total - e3Fact) * 100.0 / e3Total) : 0;

                                    // Etapa 4: progreso parcial por facturas pagadas / total facturas
                                    int e4Total    = pg.Etapa4FacturasTotal;
                                    int e4Pagadas  = pg.Etapa4FacturasPagadas;
                                    bool e4Ok      = pg.Etapa4Aprobada;
                                    int e4Solido   = e4Total > 0 ? (int)Math.Round(e4Pagadas          * 100.0 / e4Total) : 0;
                                    int e4Rayado   = e4Total > 0 ? (int)Math.Round((e4Total - e4Pagadas) * 100.0 / e4Total) : 0;

                                    string e1Title = $"Etapa 1 - Aprobación: {e1Aprob}/{e1Total} grupo(s)";
                                    string e2Title = $"Etapa 2 - Orden compra: {e2ConOC}/{e2Total} ítem(s) con O/C aprobado(s)";
                                    string e3Title = $"Etapa 3 - Facturado: {e3Fact}/{e3Total} O/C facturada(s)";
                                    string e4Title = $"Etapa 4 - Pago: {e4Pagadas}/{e4Total} factura(s) pagada(s)";
                                }
                                @* Barra dividida en 4 segmentos de 25% cada uno *@
                                <div class="d-flex mb-1" style="height:10px;min-width:140px;gap:2px;">
                                    @* Segmento 1 — sólido + rayado según grupos aprobados *@
                                    <div class="progress flex-fill" style="height:10px;" title="@e1Title">
                                        @if (e1Solido > 0)
                                        {
                                            <div class="progress-bar bg-success" style="width:@e1Solido%"></div>
                                        }
                                        @if (e1Rayado > 0 && e1Aprob > 0)
                                        {
                                            <div class="progress-bar bg-success progress-bar-striped progress-bar-animated"
                                                 style="width:@e1Rayado%; opacity:.5;"></div>
                                        }
                                    </div>
                                    @* Segmento 2 — sólido + rayado según ítems con O/C *@
                                    <div class="progress flex-fill" style="height:10px;" title="@e2Title">
                                        @if (e2Solido > 0)
                                        {
                                            <div class="progress-bar bg-primary" style="width:@e2Solido%"></div>
                                        }
                                        @if (e2Rayado > 0 && e2ConOC > 0)
                                        {
                                            <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated"
                                                 style="width:@e2Rayado%; opacity:.5;"></div>
                                        }
                                    </div>
                                    @* Segmento 3 — sólido + rayado según O/C facturadas *@
                                    <div class="progress flex-fill" style="height:10px;" title="@e3Title">
                                        @if (e3Solido > 0)
                                        {
                                            <div class="progress-bar bg-warning" style="width:@e3Solido%"></div>
                                        }
                                        @if (e3Rayado > 0 && e3Fact > 0)
                                        {
                                            <div class="progress-bar bg-warning progress-bar-striped progress-bar-animated"
                                                 style="width:@e3Rayado%; opacity:.5;"></div>
                                        }
                                    </div>
                                    @* Segmento 4 — sólido + rayado según facturas pagadas *@
                                    <div class="progress flex-fill" style="height:10px;" title="@e4Title">
                                        @if (e4Solido > 0)
                                        {
                                            <div class="progress-bar bg-success" style="width:@e4Solido%"></div>
                                        }
                                        @if (e4Rayado > 0 && e4Pagadas > 0)
                                        {
                                            <div class="progress-bar bg-success progress-bar-striped progress-bar-animated"
                                                 style="width:@e4Rayado%; opacity:.5;"></div>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex justify-content-center gap-1 flex-wrap">
                                    @{
                                        string c1 = e1Ok ? "bg-success" : (e1Aprob > 0 ? "bg-warning" : "bg-light text-secondary border");
                                        string c2 = e2Ok ? "bg-primary"  : (e2ConOC > 0 ? "bg-warning" : "bg-light text-secondary border");
                                        string c3 = e3Ok ? "bg-warning"  : (e3Fact > 0 ? "bg-info" : "bg-light text-secondary border");
                                        string c4 = e4Ok ? "bg-success" : (e4Pagadas > 0 ? "bg-warning" : "bg-light text-secondary border");
                                    }
                                    <span class="badge @c1" style="font-size:.65rem;" title="@e1Title">1</span>
                                    <span class="badge @c2" style="font-size:.65rem;" title="@e2Title">2</span>
                                    <span class="badge @c3" style="font-size:.65rem;" title="@e3Title">3</span>
                                    <span class="badge @c4" style="font-size:.65rem;" title="@e4Title">4</span>
                                </div>
                            </td>
                            @* ── Columna: O/C ── *@
                            <td class="text-center">
                                @if (req.OrdenesCompra.Any())
                                {
                                    foreach (var oc in req.OrdenesCompra)
                                    {
                                        <span class="badge bg-info text-dark d-block mb-1" style="font-size:.7rem;" title="Orden de compra @oc">@oc</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @{
                                    var (badge, texto) = req.Estado switch
                                    {
                                        "0" => ("bg-secondary", "Emitido"),
                                        "1" => ("bg-success",   "Autorizado"),
                                        "2" => ("bg-primary",   "Recibido"),
                                        "6" => ("bg-dark",      "Cerrado"),
                                        "9" => ("bg-danger",    "Anulado"),
                                        _   => ("bg-light text-dark", req.Estado ?? "-")
                                    };
                                }
                                <span class="badge @badge">@texto</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Detalle"
                                   asp-route-tipDoc="@req.TipDoc"
                                   asp-route-serie="@req.Serie"
                                   asp-route-numReq="@req.NumReq"
                                   asp-route-buscar="@buscar"
                                   asp-route-fechaInicio="@fechaInicio"
                                   asp-route-fechaFin="@fechaFin"
                                   asp-route-estado="@estado"
                                   asp-route-page="@currentPage"
                                   class="btn btn-sm btn-outline-primary"
                                   title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (req.Estado == "9")
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-outline-success ms-1 btn-activar"
                                            title="Activar requerimiento"
                                            data-clave="@req.TipDoc|@req.Serie|@req.NumReq"
                                            data-numreq="@req.NumReq">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                    <input type="checkbox" name="seleccion" value="@req.TipDoc|@req.Serie|@req.NumReq"
                                           class="d-none chk-activar-@req.NumReq" />
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="12" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-4 d-block mb-1"></i>
                                No se encontraron requerimientos.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


<div class="d-flex justify-content-between align-items-center mt-2 px-1">
    <small class="text-muted">
        @(totalCount == 0 ? "Sin registros" : $"Mostrando {startItem}–{endItem} de {totalCount} requerimientos")
    </small>
    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-buscar="@buscar"
                       asp-route-fechaInicio="@fechaInicio"
                       asp-route-fechaFin="@fechaFin"
                       asp-route-estado="@estado"
                       asp-route-page="@(currentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
                {
                    <li class="page-item @(pg == currentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-buscar="@buscar"
                           asp-route-fechaInicio="@fechaInicio"
                           asp-route-fechaFin="@fechaFin"
                           asp-route-estado="@estado"
                           asp-route-page="@pg">@pg</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-buscar="@buscar"
                       asp-route-fechaInicio="@fechaInicio"
                       asp-route-fechaFin="@fechaFin"
                       asp-route-estado="@estado"
                       asp-route-page="@(currentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>
</form>

<!-- Modal: Advertencia -->
<div class="modal fade" id="modalAdvertencia" tabindex="-1" aria-labelledby="modalAdvertenciaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="modalAdvertenciaLabel"><i class="bi bi-exclamation-triangle me-2"></i>Atención</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalAdvertenciaMsg"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning" data-bs-dismiss="modal">Aceptar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Confirmar Anular -->
<div class="modal fade" id="modalCerrar" tabindex="-1" aria-labelledby="modalCerrarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalCerrarLabel"><i class="bi bi-slash-circle me-2"></i>Anular requerimientos</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">¿Está seguro de <strong>anular</strong> los requerimientos seleccionados?</p>
                <p class="text-muted small mb-0">El estado cambiará a <span class="badge bg-danger">Anulado</span>.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmarCerrar" class="btn btn-danger">
                    <i class="bi bi-slash-circle me-1"></i>Sí, anular
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Confirmar Activar -->
<div class="modal fade" id="modalActivar" tabindex="-1" aria-labelledby="modalActivarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="modalActivarLabel"><i class="bi bi-arrow-counterclockwise me-2"></i>Activar requerimiento</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-1">¿Está seguro de <strong>activar</strong> el requerimiento <strong id="modalActivarNumReq"></strong>?</p>
                <p class="text-muted small mb-0">El estado cambiará a <span class="badge bg-success">Autorizado</span> o <span class="badge bg-primary">Recibido</span> según corresponda.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnConfirmarActivar" class="btn btn-success">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Sí, activar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const modalCerrar      = new bootstrap.Modal(document.getElementById('modalCerrar'));
    const modalActivar     = new bootstrap.Modal(document.getElementById('modalActivar'));
    const modalAdvertencia = new bootstrap.Modal(document.getElementById('modalAdvertencia'));
    const form = document.getElementById('frmCambiarEstado');

    function mostrarAdvertencia(msg) {
        document.getElementById('modalAdvertenciaMsg').textContent = msg;
        modalAdvertencia.show();
    }

    function exportarPendientes() {
        const url = '/Logistica/Requerimiento/ExportarPendientes';
        const a = document.createElement('a');
        a.href = url;
        a.download = '';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
    }

    // Seleccionar todos
    document.getElementById('chkAll').addEventListener('change', function () {
        document.querySelectorAll('.chk-req').forEach(c => c.checked = this.checked);
    });

    // Botón Anular seleccionados → abrir modal
    document.getElementById('btnAnularSeleccionados').addEventListener('click', function () {
        const seleccionados = document.querySelectorAll('.chk-req:checked');
        if (seleccionados.length === 0) {
            mostrarAdvertencia('Seleccione al menos un requerimiento.');
            return;
        }
        modalCerrar.show();
    });

    // Confirmar anular → submit
    document.getElementById('btnConfirmarCerrar').addEventListener('click', function () {
        modalCerrar.hide();
        setAccionYSubmit('anular');
    });

    // Botón Activar por fila → abrir modal
    document.querySelectorAll('.btn-activar').forEach(btn => {
        btn.addEventListener('click', function () {
            const clave  = this.dataset.clave;
            const numreq = this.dataset.numreq;
            document.getElementById('modalActivarNumReq').textContent = 'N° ' + numreq;
            document.getElementById('btnConfirmarActivar').dataset.clave  = clave;
            document.getElementById('btnConfirmarActivar').dataset.numreq = numreq;
            modalActivar.show();
        });
    });

    // Confirmar activar → marcar checkbox oculto y submit
    document.getElementById('btnConfirmarActivar').addEventListener('click', function () {
        const numreq = this.dataset.numreq;
        const chk = document.querySelector('.chk-activar-' + numreq);
        if (chk) chk.checked = true;
        modalActivar.hide();
        setAccionYSubmit('activar');
    });

    function setAccionYSubmit(accion) {
        let input = form.querySelector('input[name="accion"]');
        if (!input) {
            input = document.createElement('input');
            input.type  = 'hidden';
            input.name  = 'accion';
            form.appendChild(input);
        }
        input.value = accion;
        form.submit();
    }
</script>
}
