    function renderEvolucion(data) {
        destroyChart('evolucion');
        if (!data || data.length === 0) return;

        const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';

        const periodos = [...new Set(data.map(d => d.periodo))].sort();
        const mercados = [...new Set(data.map(d => d.mercado))];

        const datasets = mercados.map(m => {
            const values = periodos.map(p => {
                const item = data.find(d => d.periodo === p && d.mercado === m);
                return item ? item.importe : 0;
            });
            return {
                label: m,
                data: values,
                borderColor: MERCADO_COLORS[m] || '#999',
                backgroundColor: (MERCADO_COLORS[m] || '#999') + '22',
                borderWidth: 2.5,
                pointRadius: 4,
                pointHoverRadius: 6,
                tension: 0.3,
                fill: true
            };
        });

        charts['evolucion'] = new Chart(document.getElementById('chartEvolucion').getContext('2d'), {
            type: 'line',
            data: { labels: periodos, datasets: datasets },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'top', labels: { boxWidth: 14, font: { size: 12 }, padding: 14 } },
                    tooltip: {
                        callbacks: {
                            label: c => c.dataset.label + ': ' + monLabel + ' ' + fmt(c.raw)
                        }
                    },
                    datalabels: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, ticks: { callback: v => fmtMil(v) } },
                    x: { grid: { display: false } }
                }
            }
        });
    }

