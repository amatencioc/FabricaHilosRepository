@model FabricaHilos.Models.RecursosHumanos.Empleado

@{
    ViewData["Title"] = "Nuevo Empleado";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Recursos Humanos</a></li>
    <li class="breadcrumb-item"><a asp-action="Empleados">Empleados</a></li>
    <li class="breadcrumb-item active">Nuevo</li>
}

<h4 class="section-title"><i class="bi bi-plus-circle me-2"></i>Nuevo Empleado</h4>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="CrearEmpleado" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="NombreCompleto" class="form-label fw-semibold"></label>
                            <input asp-for="NombreCompleto" class="form-control" />
                            <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Dni" class="form-label fw-semibold"></label>
                            <input asp-for="Dni" class="form-control" />
                            <span asp-validation-for="Dni" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Cargo" class="form-label fw-semibold"></label>
                            <input asp-for="Cargo" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Area" class="form-label fw-semibold"></label>
                            <select asp-for="Area" class="form-select">
                                <option value="">-- Seleccionar área --</option>
                                <option>Producción</option>
                                <option>Ventas</option>
                                <option>Administración</option>
                                <option>Almacén</option>
                                <option>Gerencia</option>
                                <option>Otro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FechaIngreso" class="form-label fw-semibold"></label>
                            <input asp-for="FechaIngreso" class="form-control" type="date" />
                            <span asp-validation-for="FechaIngreso" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Salario" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">S/</span>
                                <input asp-for="Salario" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Telefono" class="form-label fw-semibold"></label>
                            <input asp-for="Telefono" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Correo" class="form-label fw-semibold"></label>
                            <input asp-for="Correo" class="form-control" type="email" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Activo" class="form-label fw-semibold"></label>
                            <select asp-for="Activo" class="form-select">
                                <option value="true">Activo</option>
                                <option value="false">Inactivo</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-action="Empleados" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
