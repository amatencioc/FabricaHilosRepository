            const tbody = document.getElementById('tablaDetalleDistrito');
            if (!data || data.length === 0) { tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">Sin datos de distritos</td></tr>'; }
            else { tbody.innerHTML = data.map((d, i) => { const pct = total > 0 ? ((d.importe / total) * 100).toFixed(1) : '0.0'; return '<tr><td>' + (i + 1) + '</td><td>' + (d.distrito ?? '') + '</td><td class="text-end">' + monLabel + ' ' + fmt(d.importe) + '</td><td class="text-end">' + pct + '%</td></tr>'; }).join(''); }
            destroyChart('detalleDistrito'); const top10 = (data || []).slice(0, 10);
            if (top10.length > 0) { charts['detalleDistrito'] = new Chart(document.getElementById('chartDetalleDistrito').getContext('2d'), { type: 'bar', data: { labels: top10.map(d => d.distrito ?? 'Sin Distrito'), datasets: [{ label: 'Importe', data: top10.map(d => d.importe ?? 0), backgroundColor: PAIS_COLORS.slice(0, top10.length), borderRadius: 4 }] }, options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => monLabel + ' ' + fmt(c.raw) } }, datalabels: { anchor: 'end', align: 'right', font: { size: 9, weight: '600' }, color: '#333', formatter: v => monLabel + ' ' + fmtMil(v) } }, scales: { x: { beginAtZero: true, ticks: { callback: v => fmtMil(v) } } } } }); }
            document.getElementById('detalleDistritoPanel').scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (e) { showToast('Error al cargar distritos: ' + e.message); } finally { hideSpin('spinnerDetalleDistrito'); }
    };
    window.cerrarDetalleDistrito = function () { document.getElementById('detalleDistritoPanel').style.display = 'none'; destroyChart('detalleDistrito'); };

    /* ── Evolución Mensual ── */
    async function loadEvolucion() {
        showSpin('spinnerEvolucion');
        try { const data = await apiFetch('/DashboardGerencial/DatosEvolucionMensual?' + buildParams()); renderEvolucion(data); renderImporteTotalMes(data); } catch (e) { showToast('Error al cargar evolución mensual: ' + e.message); } finally { hideSpin('spinnerEvolucion'); }
    }
    function renderEvolucion(data) {
        destroyChart('evolucion'); if (!data || data.length === 0) return;
        const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        const MESES_CORTO = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
        const mercadoOrder = ['Perú', 'LATAM', 'Global'];
        const mercadoColors = { 'Perú': '#1a237e', 'LATAM': '#fb8c00', 'Global': '#1565c0' };

        /* Reagrupar data: mapear Europa/Asia/Oceanía/Otros → Global */
        const mappedData = data.map(d => ({ ...d, mercado: mapMercado(d.mercado) }));
        /* Sumar importes por periodo + mercado mapeado */
        const aggMap = {};
        mappedData.forEach(d => { const key = d.periodo + '|' + d.mercado; aggMap[key] = (aggMap[key] || 0) + (d.importe ?? 0); });
        const aggData = Object.entries(aggMap).map(([k, v]) => { const [periodo, mercado] = k.split('|'); return { periodo, mercado, importe: v }; });

        /* Extraer años, meses y mercados */
        const years = [...new Set(aggData.map(d => d.periodo.substring(0, 4)))].sort();
        const months = [...new Set(aggData.map(d => d.periodo.substring(5, 7)))].sort();
        const allMercados = [...new Set(aggData.map(d => d.mercado))];
        const mercados = mercadoOrder.filter(m => allMercados.includes(m));
        const xLabels = months.map(m => MESES_CORTO[parseInt(m) - 1] || m);

        /* Mapa: periodo|mercado → importe (ya agregado) */
        const map = {};
        aggData.forEach(d => { map[d.periodo + '|' + d.mercado] = (map[d.periodo + '|' + d.mercado] || 0) + (d.importe ?? 0); });

        /* Estilos de línea por año: sólida el más reciente, dash los anteriores */
        const dashPatterns = [[],  [8, 4], [4, 4], [2, 3], [12, 4, 2, 4], [6, 2]];
        const widths = years.map((_, i) => i === years.length - 1 ? 2.5 : 1.8);
        const radii  = years.map((_, i) => i === years.length - 1 ? 4 : 2.5);

        /* Una línea por cada combinación mercado + año */
        const datasets = [];
        mercados.forEach(m => {
            const baseColor = mercadoColors[m] || '#999';
            years.forEach((yr, yi) => {
                const values = months.map(mo => map[yr + '-' + mo + '|' + m] ?? 0);
                datasets.push({
                    label: m + ' ' + yr,
                    data: values,
                    borderColor: baseColor,
                    backgroundColor: baseColor,
                    borderWidth: widths[yi],
                    borderDash: dashPatterns[yi % dashPatterns.length],
                    pointRadius: radii[yi],
                    pointHoverRadius: radii[yi] + 3,
                    pointBackgroundColor: baseColor,
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    tension: 0.3,
                    fill: false
                });
            });
        });

        charts['evolucion'] = new Chart(document.getElementById('chartEvolucion').getContext('2d'), {
            type: 'line',
            data: { labels: xLabels, datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { left: 6, right: 6 } },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        position: 'top',
                        labels: {
                            usePointStyle: false,
                            boxWidth: 28,
                            boxHeight: 2,
                            font: { size: 11 },
                            padding: 14,
                            generateLabels: function (chart) {
                                return chart.data.datasets.map(function (ds, i) {
                                    return {
                                        text: ds.label,
                                        fillStyle: 'transparent',
                                        strokeStyle: ds.borderColor,
                                        lineWidth: ds.borderWidth || 2,
                                        lineDash: ds.borderDash || [],
                                        hidden: !chart.isDatasetVisible(i),
                                        datasetIndex: i,
                                        pointStyle: 'line'
                                    };
                                });
                            }
                        }
                    },
                    tooltip: { callbacks: { label: c => c.dataset.label + ': ' + monLabel + ' ' + fmt(c.raw) } },
                    datalabels: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, border: { display: false }, grid: { color: '#eee' }, ticks: { callback: v => fmtMil(v), font: { size: 11 }, color: '#888' } },
                    x: { border: { display: false }, grid: { display: false }, ticks: { font: { size: 12, weight: '600' }, color: '#555' } }
                }
            }
        });
    }

    /* ── Importe Total por Mes / Año ── */
    function renderImporteTotalMes(data) {
        destroyChart('importeTotalMes'); if (!data || data.length === 0) return;
        const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        const MESES_CORTO = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
        const yearColors = ['#1a237e', '#fb8c00', '#6a1b9a', '#1565c0', '#00695c', '#c62828', '#2e7d32', '#e65100'];
        /* Agrupar: sumar todos los mercados por periodo */
        const totalMap = {};
        data.forEach(d => { totalMap[d.periodo] = (totalMap[d.periodo] || 0) + (d.importe ?? 0); });
        /* Extraer años y meses */
        const years = [...new Set(Object.keys(totalMap).map(p => p.substring(0, 4)))].sort();
        const months = [...new Set(Object.keys(totalMap).map(p => p.substring(5, 7)))].sort();
        const xLabels = months.map(m => MESES_CORTO[parseInt(m) - 1] || m);
        /* Un dataset (línea) por cada año */
        const datasets = years.map((yr, i) => {
            const c = yearColors[i % yearColors.length];
            return {
                label: yr,
                data: months.map(m => totalMap[yr + '-' + m] ?? 0),
                borderColor: c,
                backgroundColor: c,
                borderWidth: 2.5,
                pointRadius: 4,
                pointHoverRadius: 7,
                pointBackgroundColor: c,
                pointBorderColor: '#fff',
                pointBorderWidth: 1.5,
                tension: 0.3,
                fill: false
            };
        });
        charts['importeTotalMes'] = new Chart(document.getElementById('chartImporteTotalMes').getContext('2d'), {
            type: 'line',
            data: { labels: xLabels, datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { left: 6, right: 6 } },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'top', labels: { usePointStyle: true, pointStyle: 'circle', boxWidth: 8, font: { size: 12 }, padding: 18 } },
                    tooltip: { callbacks: { label: c => c.dataset.label + ': ' + monLabel + ' ' + fmt(c.raw) } },
                    datalabels: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, border: { display: false }, grid: { color: '#eee' }, ticks: { callback: v => fmtMil(v), font: { size: 11 }, color: '#888' } },
                    x: { border: { display: false }, grid: { display: false }, ticks: { font: { size: 12, weight: '600' }, color: '#555' } }
                }
            }
        });
    }

    /* ── KG Total por Mes / Año ── */
    async function loadKgMensual() {
        showSpin('spinnerKgTotalMes');
        try { const data = await apiFetch('/DashboardGerencial/DatosKgMensual?' + buildParams()); renderKgTotalMes(data); } catch (e) { showToast('Error al cargar KG mensual: ' + e.message); } finally { hideSpin('spinnerKgTotalMes'); }
    }
    function renderKgTotalMes(data) {
        destroyChart('kgTotalMes'); if (!data || data.length === 0) return;
        const MESES_CORTO = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
        const yearColors = ['#1a237e', '#fb8c00', '#6a1b9a', '#1565c0', '#00695c', '#c62828', '#2e7d32', '#e65100'];
        const years = [...new Set(data.map(d => d.periodo.substring(0, 4)))].sort();
        const months = [...new Set(data.map(d => d.periodo.substring(5, 7)))].sort();
        const xLabels = months.map(m => MESES_CORTO[parseInt(m) - 1] || m);
