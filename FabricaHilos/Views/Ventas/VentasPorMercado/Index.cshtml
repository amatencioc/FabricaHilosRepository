    async function loadEvolucion() {
        showSpin('spinnerEvolucion');
        try {
            const data = await apiFetch('/VentasPorMercado/DatosEvolucionMensual?' + buildParams());
            renderEvolucion(data);
        } catch (e) {
            showToast('Error al cargar evolución mensual: ' + e.message);
