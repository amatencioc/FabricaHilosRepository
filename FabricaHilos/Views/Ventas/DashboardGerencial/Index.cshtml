                pointBackgroundColor: c, pointBorderColor: '#fff', pointBorderWidth: 1.5,
                tension: 0.3, fill: false
            };
        });
        charts['kgTotalMes'] = new Chart(document.getElementById('chartKgTotalMes').getContext('2d'), {
            type: 'line',
            data: { labels: xLabels, datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { left: 6, right: 6 } },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'top', labels: { usePointStyle: true, pointStyle: 'circle', boxWidth: 8, font: { size: 12 }, padding: 18 } },
                    tooltip: { callbacks: { label: c => c.dataset.label + ': ' + fmtMil(c.raw) + ' KG' } },
                    datalabels: { display: false }
                },
                scales: {
                    y: { beginAtZero: true, border: { display: false }, grid: { color: '#eee' }, ticks: { callback: v => fmtMil(v), font: { size: 11 }, color: '#888' } },
                    x: { border: { display: false }, grid: { display: false }, ticks: { font: { size: 12, weight: '600' }, color: '#555' } }
                }
            }
        });
