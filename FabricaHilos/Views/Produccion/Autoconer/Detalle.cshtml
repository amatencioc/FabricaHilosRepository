@model FabricaHilos.Models.Produccion.RegistroAutoconer
@using FabricaHilos.Helpers
@using FabricaHilos.Models.Produccion

@{
    ViewData["Title"] = "Detalle Registro Autoconer";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Produccion" asp-action="Index">Producción</a></li>
    <li class="breadcrumb-item"><a asp-action="Index">Control Autoconer</a></li>
    <li class="breadcrumb-item active">Detalle</li>
}

<div class="d-flex align-items-center mb-4" style="border-bottom: 3px solid var(--color-secondary); padding-bottom: 10px;">
    <i class="bi bi-eye fs-3 me-3 text-success"></i>
    <h4 class="mb-0 fw-bold">Detalle Registro Autoconer #@Model.Id</h4>
</div>

@{
    var estadoBadge = Model.Estado switch
    {
        EstadoOrden.EnProceso => new { Clase = "bg-primary",   Texto = "En Proceso",  Icono = "bi-gear-fill" },
        EstadoOrden.Terminado => new { Clase = "bg-success",   Texto = "Terminado",   Icono = "bi-check-circle" },
        EstadoOrden.Anulado   => new { Clase = "bg-danger",    Texto = "Anulado",     Icono = "bi-x-circle" },
        _                     => new { Clase = "bg-secondary", Texto = "Desconocido", Icono = "bi-question-circle" }
    };

    var tramosMarcados = new List<int>();
    if (Model.Tramo1) tramosMarcados.Add(1);
    if (Model.Tramo2) tramosMarcados.Add(2);
    if (Model.Tramo3) tramosMarcados.Add(3);
    if (Model.Tramo4) tramosMarcados.Add(4);
    if (Model.Tramo5) tramosMarcados.Add(5);
    if (Model.Tramo6) tramosMarcados.Add(6);

    var destinoDescripcion = Model.Destino switch
    {
        "CM"  => "CM - Crudo Materiales",
        "MM"  => "MM - Melange Materiales",
        "CV"  => "CV - Crudo Venta",
        "MV"  => "MV - Melange Venta",
        "COV" => "COV - Color Venta",
        "VS"  => "VS - Venta Servicio",
        "T"   => "T - Tintorería",
        "S"   => "S - Servicio",
        _     => Model.Destino ?? "-"
    };
}

<!-- Estado actual -->
<div class="mb-3">
    <span class="badge @estadoBadge.Clase fs-6 px-3 py-2">
        <i class="bi @estadoBadge.Icono me-2"></i>@estadoBadge.Texto
    </span>
    @if (Model.Cerrado)
    {
        <span class="badge bg-secondary fs-6 px-3 py-2 ms-2">
            <i class="bi bi-lock-fill me-1"></i>Cerrado
        </span>
    }
</div>

<!-- ===== CABECERA ===== -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white fw-bold">
        <i class="bi bi-info-circle me-2"></i>Cabecera
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="text-muted small">Autoconer N°</div>
                <div class="fw-semibold">@(Model.NumeroAutoconer ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Operador</div>
                <div class="fw-semibold">
                    @if (!string.IsNullOrEmpty(ViewBag.NombreOperario as string))
                    {
                        <span>@ViewBag.NombreOperario</span>
                        <span class="text-muted"> (@Model.CodigoOperador)</span>
                    }
                    else
                    {
                        <span>@(Model.CodigoOperador ?? "-")</span>
                    }
                </div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Fecha</div>
                <div class="fw-semibold">@Model.Fecha.ToString("dd/MM/yyyy HH:mm:ss")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Turno</div>
                <div class="fw-semibold">@ProduccionLookups.GetTurno(Model.Turno)</div>
            </div>
        </div>
    </div>
</div>

<!-- ===== DATOS DE PRODUCCIÓN ===== -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white fw-bold">
        <i class="bi bi-clipboard-data me-2"></i>Datos de Producción
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="text-muted small">Receta</div>
                <div class="fw-semibold">@(Model.CodigoReceta ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Lote / Partida</div>
                <div class="fw-semibold">@(Model.Lote ?? "-")</div>
            </div>
            <div class="col-md-6">
                <div class="text-muted small">Material</div>
                <div class="fw-semibold">@(Model.DescripcionMaterial ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">V (m/min)</div>
                <div class="fw-semibold">@(Model.VelocidadMMin?.ToString("0.00") ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Título</div>
                <div class="fw-semibold">@(Model.Titulo ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">H Inicio</div>
                <div class="fw-semibold">@(Model.HoraInicio?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">H Final</div>
                <div class="fw-semibold">@(Model.HoraFinal?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
            </div>
                    </div>
                </div>
            </div>

            <!-- ===== RESULTADOS ===== -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white fw-bold">
        <i class="bi bi-bar-chart-line me-2"></i>Resultados
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="text-muted small">P. Bruto (Peso Bruto)</div>
                <div class="fw-semibold">@(Model.PesoBruto?.ToString("0.00") ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Q (Cantidad)</div>
                <div class="fw-semibold">@(Model.Cantidad?.ToString() ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Puntaje (PUNT)</div>
                <div class="fw-semibold">@(Model.Puntaje?.ToString() ?? "-")</div>
            </div>
            <div class="col-md-12">
                <div class="text-muted small">Tramos</div>
                <div class="d-flex gap-2 flex-wrap mt-1">
                    @for (int i = 1; i <= 6; i++)
                    {
                        bool marcado = tramosMarcados.Contains(i);
                        <span class="badge @(marcado ? "bg-success" : "bg-light text-muted border") fs-6 px-3">
                            @i
                            @if (marcado)
                            {
                                <i class="bi bi-check-lg ms-1"></i>
                            }
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== DESTINO Y OBSERVACIONES ===== -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white fw-bold">
        <i class="bi bi-box-arrow-right me-2"></i>Destino y Observaciones
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="text-muted small">Destino</div>
                <div class="fw-semibold">@destinoDescripcion</div>
            </div>
            <div class="col-md-5">
                <div class="text-muted small">Cliente</div>
                <div class="fw-semibold">@(Model.Cliente ?? "-")</div>
            </div>
            <div class="col-md-2">
                <div class="text-muted small">Reproceso (R)</div>
                <div class="fw-semibold">
                    @if (Model.Reproceso)
                    {
                        <span class="badge bg-warning text-dark"><i class="bi bi-arrow-repeat me-1"></i>Sí</span>
                    }
                    else
                    {
                        <span class="text-muted">No</span>
                    }
                </div>
            </div>
            <div class="col-md-12">
                <div class="text-muted small">Motivo de Paralización</div>
                <div class="fw-semibold">@(Model.MotivoParalizacion ?? "-")</div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary px-4">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    @if (Model.Estado == EstadoOrden.EnProceso)
    {
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-success px-4">
            <i class="bi bi-pencil me-1"></i>Editar
        </a>
    }
</div>
