                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold">Peso Bruto <span class="text-danger">*</span></label>
                        <input type="number" id="rolloPesoBruto" class="form-control" step="0.01" min="0.01" placeholder="Ingrese el peso bruto" />
                        <div id="errRolloPesoBruto" class="text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Varilla</label>
                        <div class="input-group">
                            <input type="number" id="rolloVarilla" class="form-control" value="1.2" readonly style="background-color: var(--color-bg-light);" />
                            <span class="input-group-text">Kg</span>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Peso Neto</label>
                        <input type="number" id="rolloPesoNeto" class="form-control" readonly step="0.01" style="background-color: var(--color-bg-light);" placeholder="-" />
