        const setKpi = (id, val) => { document.getElementById('kpi' + id).textContent = monLabel + ' ' + fmtMil(val); document.getElementById('kpi' + id + 'Pct').textContent = total > 0 ? ((val / total) * 100).toFixed(1) + '% del total' : '—'; };
        setKpi('Peru', getVal('Perú')); setKpi('Latam', getVal('LATAM')); setKpi('Global', getVal('Global'));
