    /* ── Iconos por keyword para hilados ── */
    /* IMPORTANTE: las reglas más específicas van PRIMERO para evitar
       que un keyword genérico (TANGUIS, PIMA) capture todo. */
    function getHiladoIcon(name) {
        const n = (name ?? '').toUpperCase();
        /* ── Mezclas y compuestos (antes que fibras simples) ── */
        if (n.includes('MOULINE'))  return '🌀';
        if (n.includes('MEZCLA') || n.includes('BLEND'))  return '🔀';
        if (n.includes('ORGANICO') || n.includes('ORGÁNICO')) return '♻️';
        if (n.includes('TENCEL') || n.includes('LYOCELL')) return '🌱';
        /* ── Fibras base ── */
        if (n.includes('TANGUIS'))  return '🌾';
        if (n.includes('PIMA'))     return '🏅';
        if (n.includes('ALGODON') || n.includes('ALGODÓN')) return '☁️';
        if (n.includes('POLYESTER') || n.includes('POLIESTER') || n.includes('PET')) return '🔷';
        if (n.includes('VISCOSA') || n.includes('RAYON') || n.includes('MODAL')) return '🍃';
        if (n.includes('ACRIL') || n.includes('ACRYL')) return '💎';
        if (n.includes('NYLON') || n.includes('POLIAMIDA')) return '⚡';
        if (n.includes('LANA') || n.includes('WOOL')) return '🐑';
        if (n.includes('SEDA') || n.includes('SILK')) return '✨';
        if (n.includes('LYCRA') || n.includes('SPANDEX') || n.includes('ELASTAN')) return '🔄';
        if (n.includes('CRUDO')) return '🪵';
        if (n.includes('BLANCO')) return '⬜';
        if (n.includes('PREMIUM')) return '⭐';
        return '🧶';
    }
    /* ── Iconos por keyword para giros ── */
    function getGiroIcon(name) {
        const n = (name ?? '').toUpperCase();
        if (n.includes('CHOMPER'))  return '🧥';
        if (n.includes('PUNTO'))    return '🧶';
        if (n.includes('MEDIER'))   return '🧦';
        if (n.includes('COSTUR'))   return '✂️';
        if (n.includes('LABOR'))    return '🪡';
        if (n.includes('PLANO'))    return '🪟';
        if (n.includes('TEJIDO'))   return '🧵';
        if (n.includes('CALCET'))   return '🧦';
        if (n.includes('BORDA'))    return '🎨';
        if (n.includes('CONFEC'))   return '👔';
        if (n.includes('TELA'))     return '🪡';
        if (n.includes('EXPORT'))   return '🌍';
        if (n.includes('SIN GIRO')) return '❓';
        return '🏭';
    }
    /* ── Plugin: icono dentro de barras verticales ── */
    const barIconPlugin = {
        id: 'barIconPlugin',
        afterDatasetDraw(chart) {
            const { ctx, data, chartArea } = chart;
            const meta = chart.getDatasetMeta(0);
            const icons = data._icons;
            if (!icons) return;
            meta.data.forEach((bar, i) => {
                if (!icons[i]) return;
                const x = bar.x;
                const y = bar.y;
                const bottom = chartArea.bottom;
                const barH = bottom - y;
                if (barH < 30) return;
                const centerY = y + barH * 0.45;
                ctx.save();
                ctx.font = '22px sans-serif';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'middle';
                ctx.globalAlpha = 0.35;
                ctx.fillText(icons[i], x, centerY);
                ctx.restore();
            });
        }
    };

    /* ── TOP 5 Hilados más Facturados (barras verticales con icono) ── */
    async function loadTopHiladosImporte() {
        showSpin('spinnerTopHiladosImporte');
        try { const p = buildParams(); p.set('top', '5'); const data = await apiFetch('/DashboardGerencial/DatosTopHiladosImporte?' + p); renderTopHiladosImporte(data); } catch (e) { showToast('Error al cargar top hilados importe: ' + e.message); } finally { hideSpin('spinnerTopHiladosImporte'); }
    }
    function renderTopHiladosImporte(data) {
        destroyChart('topHiladosImporte');
        if (!data || data.length === 0) return;
        const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        const barColors = ['#2d3436', '#3d4a4c', '#4d5c5e', '#636e72', '#7a8a8e'];
        const icons = data.map(d => getHiladoIcon(d.familia));
        const chartData = {
            labels: data.map(d => {
                const lbl = (d.familia ?? '');
                const words = lbl.split(' ');
                const lines = []; let cur = '';
                words.forEach(w => {
                    if (cur && (cur + ' ' + w).length > 14) { lines.push(cur); cur = w; }
                    else { cur = cur ? cur + ' ' + w : w; }
                });
                if (cur) lines.push(cur);
                return lines.length > 1 ? lines : lbl;
            }),
            datasets: [{
                label: 'Importe',
                data: data.map(d => d.importe ?? 0),
                backgroundColor: data.map((_, i) => barColors[i % barColors.length]),
                borderRadius: 6,
                barPercentage: 0.72,
                categoryPercentage: 0.85
            }]
        };
        chartData._icons = icons;
        charts['topHiladosImporte'] = new Chart(document.getElementById('chartTopHiladosImporte').getContext('2d'), {
            type: 'bar',
            data: chartData,
            plugins: [barIconPlugin],
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { top: 30 } },
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: c => monLabel + ' ' + fmt(c.raw) } },
                    datalabels: {
                        anchor: 'end', align: 'top', clip: false,
                        font: { size: 12, weight: '700' },
                        color: '#2d3436',
                        formatter: v => monLabel + ' ' + fmtMil(v)
                    }
                },
                scales: {
                    x: { border: { display: false }, grid: { display: false }, ticks: { font: { size: 9, weight: '600' }, color: '#555', maxRotation: 0 } },
                    y: { display: false, beginAtZero: true }
                }
            }
        });
    }

    /* ── Ventas por Giro (Funnel HTML con icono) ── */
    async function loadVentasGiro() {
        showSpin('spinnerVentasGiro');
        try { const data = await apiFetch('/DashboardGerencial/DatosVentasPorGiro?' + buildParams()); renderVentasGiro(data); } catch (e) { showToast('Error al cargar ventas por giro: ' + e.message); } finally { hideSpin('spinnerVentasGiro'); }
    }
    function renderVentasGiro(data) {
        const container = document.getElementById('funnelVentasGiro');
        container.innerHTML = '';
        if (!data || data.length === 0) { container.innerHTML = '<p class="text-muted text-center m-0">Sin datos</p>'; return; }
        const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        const total = data.reduce((s, d) => s + (d.importe ?? 0), 0);
        const colors = ['#1B4D3E','#265e4a','#317056','#3d8263','#4a9470','#57a67d','#65b88b','#74ca99','#84dca8','#95eeb7'];
        const maxItems = Math.min(data.length, 8);
        const items = data.slice(0, maxItems);
        const widthMin = 50;
        const widthMax = 100;

        let html = '';
        items.forEach((d, i) => {
            const name = (d.descGiro ?? d.codigoGiro ?? 'Sin Giro').substring(0, 18);
            const icon = getGiroIcon(name);
            const pct = total > 0 ? ((d.importe / total) * 100).toFixed(1) : '0.0';
            const w = widthMax - ((widthMax - widthMin) * i / Math.max(maxItems - 1, 1));
            const bg = colors[i % colors.length];
            const isFirst = i === 0;
            const isLast = i === maxItems - 1;
            const radius = isFirst ? 'border-radius: 6px 6px 0 0;' : (isLast ? 'border-radius: 0 0 6px 6px;' : '');
            html += `<div style="width:${w}%; margin:0 auto 3px auto; background:${bg}; color:#fff; padding:9px 14px; display:flex; justify-content:space-between; align-items:center; ${radius}">
                <div style="display:flex; align-items:center; gap:8px; min-width:0;">
                    <span style="font-size:16px; flex-shrink:0;">${icon}</span>
                    <span style="font-weight:700; font-size:12px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${name}</span>
                </div>
                <div style="text-align:right; flex-shrink:0; margin-left:8px;">
                    <span style="font-weight:700; font-size:13px;">${fmtMil(d.importe)}</span>
                    <span style="font-size:10px; opacity:0.8; margin-left:4px;">${pct}%</span>
                </div>
            </div>`;
        });
        container.innerHTML = html;
    }

    /* ── TOP 5 Hilados por KG (barras HTML con icono) ── */
    async function loadTopHiladosKg() {
        showSpin('spinnerTopHiladosKg');
        try { const p = buildParams(); p.set('top', '5'); const data = await apiFetch('/DashboardGerencial/DatosTopHiladosKg?' + p); renderTopHiladosKg(data); } catch (e) { showToast('Error al cargar top hilados KG: ' + e.message); } finally { hideSpin('spinnerTopHiladosKg'); }
    }
    function renderTopHiladosKg(data) {
        const container = document.getElementById('barsTopHiladosKg');
        container.innerHTML = '';
        if (!data || data.length === 0) { container.innerHTML = '<p class="text-muted text-center m-0">Sin datos</p>'; return; }
        const maxVal = Math.max(...data.map(d => d.kilos ?? 0), 1);
        const colors = ['#1a237e', '#283593', '#3949ab', '#5c6bc0', '#7986cb'];

        let html = '';
        data.forEach((d, i) => {
            const name = (d.familia ?? '').substring(0, 30);
            const icon = getHiladoIcon(d.familia);
            const pct = Math.max(((d.kilos ?? 0) / maxVal) * 100, 8);
            const bg = colors[i % colors.length];
            html += `<div style="margin-bottom:10px;">
                <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:3px;">
                    <span style="font-size:12px; font-weight:600; color:#333; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:60%;">${icon} ${name}</span>
                    <span style="font-size:12px; font-weight:700; color:${bg}; flex-shrink:0;">${fmtMil(d.kilos)} KG</span>
                </div>
                <div style="background:#e9ecef; border-radius:4px; height:18px; overflow:hidden;">
                    <div style="width:${pct}%; height:100%; background:${bg}; border-radius:4px; transition:width 0.6s ease;"></div>
                </div>
            </div>`;
        });
        container.innerHTML = html;
    }

    /* ── Load all ── */
    async function loadMercado() { showSpin('spinnerMercado'); try { const data = await apiFetch('/DashboardGerencial/DatosVentasPorMercado?' + buildParams()); renderMercado(data); } catch (e) { showToast('Error al cargar datos de mercado: ' + e.message); } finally { hideSpin('spinnerMercado'); } }

    window.loadAll = function () { cerrarDetallePais(); cerrarDetalleDpto(); cerrarDetalleDistrito(); cerrarDetalleCiudadPais(); loadMercado(); loadEvolucion(); loadKgMensual(); loadTopHiladosImporte(); loadVentasGiro(); loadTopHiladosKg(); };
    window.clearFilters = function () { setDefaultDates(); document.getElementById('moneda').value = 'D'; buildYearCheckboxes(); loadAll(); };

    /* ── Inicio ── */
    buildYearCheckboxes();
    setDefaultDates();
    (async function () { await cargarMapeoPaises(); loadAll(); })();
})();
</script>
