@model FabricaHilos.Models.Ventas.Pedido
@using FabricaHilos.Models.Ventas

@{
    ViewData["Title"] = "Editar Pedido";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Ventas</a></li>
    <li class="breadcrumb-item"><a asp-action="Pedidos">Pedidos</a></li>
    <li class="breadcrumb-item active">Editar</li>
}

<h4 class="section-title"><i class="bi bi-plus-circle me-2"></i>Editar Pedido</h4>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="EditarPedido" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="NumeroPedido" class="form-label fw-semibold"></label>
                            <input asp-for="NumeroPedido" class="form-control" value="@ViewBag.NumeroPedido" />
                            <span asp-validation-for="NumeroPedido" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ClienteId" class="form-label fw-semibold"></label>
                            <select asp-for="ClienteId" class="form-select">
                                <option value="">-- Seleccionar cliente --</option>
                                @if (ViewBag.Clientes != null)
                                {
                                    @foreach (var c in ViewBag.Clientes)
                                    {
                                        <option value="@c.Id">@c.Nombre</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ClienteId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Fecha" class="form-label fw-semibold"></label>
                            <input asp-for="Fecha" class="form-control" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="Fecha" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Estado" class="form-label fw-semibold"></label>
                            <select asp-for="Estado" class="form-select">
                                @foreach (var e in Enum.GetValues<EstadoPedido>())
                                {
                                    <option value="@e">@e</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Productos y cantidades del pedido..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Total" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">S/</span>
                                <input asp-for="Total" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="Total" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Observaciones" class="form-label fw-semibold"></label>
                            <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-action="Pedidos" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
