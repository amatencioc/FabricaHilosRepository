@using FabricaHilos.Services
@inject IMenuService MenuService
@inject IEmpresaTemaService EmpresaTemaService
@{ 
    var menus = MenuService.GetMenusActuales();
    var tema  = EmpresaTemaService.GetTemaActual();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @tema.TituloSistema</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/flatpickr/dist/flatpickr.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/@tema.VariablesCssPath" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="bg-corporate text-white">
            <div class="sidebar-header p-3 border-bottom border-secondary">
                <div class="d-flex align-items-center gap-2">
                    <img src="~/@tema.LogoIconPath" alt="@tema.LogoAlt" style="height: 38px; width: auto; flex-shrink: 0;" />
                    <div>
                        <div class="fw-bold">@tema.NombreCorto</div>
                        <small class="text-light opacity-75">@tema.NombreCompleto</small>
                    </div>
                </div>
            </div>
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                var act  = ViewContext.RouteData.Values["action"]?.ToString();
            }
            <ul class="list-unstyled p-2 sidebar-menu">
                <!-- Dashboard -->
                @if (menus.Dashboard)
                {
                <li>
                    <a asp-controller="Home" asp-action="Index" class="sidebar-link @(ctrl == "Home" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> Inicio
                    </a>
                </li>
                }

                @if (menus.Produccion)
                {
                <li class="sidebar-section">OPERACIONES</li>
                }
                @if (menus.Produccion)
                {
                <li>
                    <a asp-controller="Produccion" asp-action="Index" class="sidebar-link @(ctrl == "Produccion" || ctrl == "RegistroPreparatoria" || ctrl == "Autoconer" ? "active" : "")">
                        <i class="bi bi-gear-wide-connected"></i> Producción
                    </a>
                    <ul class="list-unstyled ps-3">
                        @if (menus.ProduccionRegistroPreparatoria)
                        {
                        <li>
                            <a asp-controller="RegistroPreparatoria" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "RegistroPreparatoria" ? "active" : "")">
                                <i class="bi bi-clipboard-data"></i> Registro de Preparatoria
                            </a>
                        </li>
                        }
                        @if (menus.ProduccionAutoconer)
                        {
                        <li>
                            <a class="sidebar-link sidebar-sublink @(ctrl == "Autoconer" ? "active" : "")" data-bs-toggle="collapse" href="#submenuAutoconer" role="button" aria-expanded="@(ctrl == "Autoconer" ? "true" : "false")" aria-controls="submenuAutoconer">
                                <i class="bi bi-speedometer2"></i> Control Autoconer
                            </a>
                            <ul class="collapse @(ctrl == "Autoconer" ? "show" : "") list-unstyled ps-3" id="submenuAutoconer">
                                @if (menus.ProduccionAutoconerPorPartida)
                                {
                                <li>
                                    <a asp-controller="Autoconer" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "Autoconer" && (act == "Index" || act == "Crear" || act == "Editar" || act == "Detalle") ? "active" : "")">
                                        <i class="bi bi-folder"></i> por Partida
                                    </a>
                                </li>
                                }
                                @if (menus.ProduccionAutoconerPorCanillas)
                                {
                                <li>
                                    <a asp-controller="Autoconer" asp-action="PorCanillas" class="sidebar-link sidebar-sublink @(ctrl == "Autoconer" && act == "PorCanillas" ? "active" : "")">
                                        <i class="bi bi-list-columns"></i> por Canillas
                                    </a>
                                </li>
                                }
                            </ul>
                        </li>
                        }
                    </ul>
                </li>
                }
                @if (menus.Sgc)
                {
                <li class="sidebar-section">GESTIÓN DE CALIDAD</li>
                <li>
                    <a asp-controller="Sgc" asp-action="Index" class="sidebar-link @(ctrl == "Sgc" || ctrl == "RelacionFacCli" || ctrl == "CargaTc" ? "active" : "")">
                        <i class="bi bi-file-earmark-text"></i> SGC
                    </a>
                    <ul class="list-unstyled ps-3">
                        @if (menus.SgcPedidos)
                        {
                        <li>
                            <a asp-controller="Sgc" asp-action="Pedidos" class="sidebar-link sidebar-sublink @(ctrl == "Sgc" && act == "Pedidos" ? "active" : "")">
                                <i class="bi bi-cart-check"></i> Pedidos
                            </a>
                        </li>
                        }
                        @if (menus.SgcDespachos)
                        {
                        <li>
                            <a class="sidebar-link sidebar-sublink @(ctrl == "RelacionFacCli" || ctrl == "CargaTc" ? "active" : "")" 
                               data-bs-toggle="collapse" href="#submenuDespachos" role="button" 
                               aria-expanded="@(ctrl == "RelacionFacCli" || ctrl == "CargaTc" ? "true" : "false")" 
                               aria-controls="submenuDespachos">
                                <i class="bi bi-truck"></i> Despachos
                            </a>
                            <ul class="collapse @(ctrl == "RelacionFacCli" || ctrl == "CargaTc" ? "show" : "") list-unstyled ps-3" id="submenuDespachos">
                                @if (menus.SgcDespachosRelacionFacCli)
                                {
                                <li>
                                    <a asp-controller="RelacionFacCli" asp-action="ListadoDespachos" class="sidebar-link sidebar-sublink @(ctrl == "RelacionFacCli" ? "active" : "")">
                                        <i class="bi bi-file-earmark-text"></i> Relación Factura-Cliente
                                    </a>
                                </li>
                                }
                                @if (menus.SgcDespachosCargarTC)
                                {
                                <li>
                                    <a asp-controller="CargaTc" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "CargaTc" ? "active" : "")">
                                        <i class="bi bi-file-earmark-arrow-up"></i> Cargar TC
                                    </a>
                                </li>
                                }
                            </ul>
                        </li>
                        }
                    </ul>
                </li>
                }
                @if (menus.Facturacion)
                {
                <li class="sidebar-section">FINANZAS</li>
                <li>
                    <a asp-controller="Facturacion" asp-action="Index" class="sidebar-link @(ctrl == "Facturacion" ? "active" : "")">
                        <i class="bi bi-receipt"></i> Facturación
                    </a>
                    <ul class="list-unstyled ps-3">
                        @if (menus.FacturacionImportarFacturas)
                        {
                        <li>
                            <a asp-controller="Facturacion" asp-action="ImportarFacturas" class="sidebar-link sidebar-sublink @(ctrl == "Facturacion" && act == "ImportarFacturas" ? "active" : "")">
                                <i class="bi bi-file-earmark-arrow-up"></i> Importar Facturas
                            </a>
                        </li>
                        }
                        @if (menus.FacturacionListaDocumentos)
                        {
                        <li>
                            <a asp-controller="Facturacion" asp-action="ListaDocumentos" class="sidebar-link sidebar-sublink @(ctrl == "Facturacion" && act == "ListaDocumentos" ? "active" : "")">
                                <i class="bi bi-list-ul"></i> Lista de Documentos
                            </a>
                        </li>
                        }
                    </ul>
                </li>
                }
                @if (menus.Ventas)
                {
                <li class="sidebar-section">COMERCIAL</li>
                <li>
                    <a asp-controller="Ventas" asp-action="Index" class="sidebar-link @(ctrl == "Ventas" || ctrl == "ConsultaTc" || ctrl == "IndicadoresComerciales" || ctrl == "VentasPorMercado" || ctrl == "DashboardComercial" || ctrl == "DashboardComercialMaestro" || ctrl == "DashboardGerencial" ? "active" : "")">
                        <i class="bi bi-cash-coin"></i> Ventas
                    </a>
                    <ul class="list-unstyled ps-3">
                        @if (menus.VentasConsultaTC)
                        {
                        <li>
                            <a asp-controller="ConsultaTc" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "ConsultaTc" ? "active" : "")">
                                <i class="bi bi-file-earmark-text"></i> Consulta TC
                            </a>
                        </li>
                        }
                        @if (menus.VentasIndicadoresComerciales)
                        {
                        <li>
                            <a asp-controller="IndicadoresComerciales" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "IndicadoresComerciales" ? "active" : "")">
                                <i class="bi bi-bar-chart-line"></i> Indicadores Comerciales
                            </a>
                        </li>
                        }
                        @if (menus.VentasVentasPorMercado)
                        {
                        <li>
                            <a asp-controller="VentasPorMercado" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "VentasPorMercado" ? "active" : "")">
                                <i class="bi bi-globe-americas"></i> Ventas por Mercado
                            </a>
                        </li>
                        }
                        @if (menus.VentasDashboardComercial)
                        {
                        <li>
                            <a asp-controller="DashboardComercial" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "DashboardComercial" ? "active" : "")">
                                <i class="bi bi-speedometer2"></i> Dashboard Comercial
                            </a>
                        </li>
                        }
                        @if (menus.VentasDashboardComercialMaestro)
                        {
                        <li>
                            <a asp-controller="DashboardComercialMaestro" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "DashboardComercialMaestro" ? "active" : "")">
                                <i class="bi bi-graph-up-arrow"></i> Dashboard Com. Maestro
                            </a>
                        </li>
                        }
                        @if (menus.VentasDashboardGerencial)
                        {
                        <li>
                            <a asp-controller="DashboardGerencial" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "DashboardGerencial" ? "active" : "")">
                                <i class="bi bi-graph-up-arrow"></i> Dashboard Gerencial
                            </a>
                        </li>
                        }
                    </ul>
                </li>
                }


                @if (menus.Seguridad)
                {
                    <!-- SEGURIDAD -->
                    <li class="sidebar-section">SEGURIDAD</li>
                    <li>
                        <a asp-controller="Seguridad" asp-action="Index" class="sidebar-link @(ctrl == "Seguridad" || ctrl == "Inspeccion" ? "active" : "")">
                            <i class="bi bi-shield-check"></i> Seguridad
                        </a>
                        <ul class="list-unstyled ps-3">
                            @if (menus.SeguridadInspecciones)
                            {
                            <li>
                                <a asp-controller="Inspeccion" asp-action="Index" class="sidebar-link sidebar-sublink @(ctrl == "Inspeccion" ? "active" : "")">
                                    <i class="bi bi-clipboard-check"></i> Inspecciones
                                </a>
                            </li>
                            }
                        </ul>
                    </li>
                }

                @if (menus.RecursosHumanos)
                {
                    <!-- RECURSOS HUMANOS -->
                    <li class="sidebar-section">RECURSOS HUMANOS</li>                    <li>
                        <a asp-controller="RecursosHumanos" asp-action="Index"
                           class="sidebar-link @(ctrl == "RecursosHumanos" || ctrl == "Marcaciones" ? "active" : "")">
                            <i class="bi bi-people"></i> Recursos Humanos
                        </a>
                        <ul class="list-unstyled ps-3">
                            <li>
                                <a class="sidebar-link sidebar-sublink @(ctrl == "Marcaciones" ? "active" : "")"
                                   data-bs-toggle="collapse" href="#submenuAquarius" role="button"
                                   aria-expanded="@(ctrl == "Marcaciones" ? "true" : "false")"
                                   aria-controls="submenuAquarius">
                                    <i class="bi bi-people-fill"></i> Aquarius
                                </a>
                                <ul class="collapse @(ctrl == "Marcaciones" ? "show" : "") list-unstyled ps-3" id="submenuAquarius">
                                    @if (menus.RhMarcaciones)
                                    {
                                    <li>
                                        <a href="/RecursosHumanos/Aquarius/Marcaciones" class="sidebar-link sidebar-sublink @(ctrl == "Marcaciones" ? "active" : "")">
                                            <i class="bi bi-clock-history"></i> Marcaciones
                                        </a>
                                    </li>
                                    }
                                </ul>
                            </li>
                        </ul>
                    </li>
                }

                @if (menus.Logistica)
                {
                    <!-- LOGÍSTICA -->
                    <li class="sidebar-section">LOGÍSTICA</li>
                    <li>
                        <a href="/Logistica" class="sidebar-link @(ctrl == "Logistica" ? "active" : "")">
                            <i class="bi bi-box-seam"></i> Logística
                        </a>
                        <ul class="list-unstyled ps-3">
                            @if (menus.LogisticaRequerimiento)
                            {
                            <li>
                                <a href="/Logistica/Requerimiento" class="sidebar-link sidebar-sublink @(ctrl == "Requisicion" ? "active" : "")">
                                    <i class="bi bi-clipboard-check"></i> Requerimientos
                                </a>
                            </li>
                            }
                            @if (menus.LogisticaOrdenCompra)
                            {
                            <li>
                                <a href="/Logistica/OrdenCompra" class="sidebar-link sidebar-sublink @(ctrl == "OrdenCompra" ? "active" : "")">
                                    <i class="bi bi-cart-check"></i> Órdenes de Compra
                                </a>
                            </li>
                            }
                        </ul>
                    </li>
                }

                @if (menus.CreditosCobranza)
                {
                    <!-- CRÉDITOS Y COBRANZAS -->
                    <li class="sidebar-section">CRÉDITOS Y COBRANZAS</li>
                    <li>
                        <a asp-controller="CreditosCobranza" asp-action="Index" class="sidebar-link @(ctrl == "CreditosCobranza" ? "active" : "")">
                            <i class="bi bi-graph-down-arrow"></i> Créditos y Cobranzas
                        </a>
                        <ul class="list-unstyled ps-3">
                            @if (menus.CcNivelMorosidad)
                            {
                            <li>
                                <a asp-controller="CreditosCobranza" asp-action="NivelMorosidad" class="sidebar-link sidebar-sublink @(ctrl == "CreditosCobranza" && act == "NivelMorosidad" ? "active" : "")">
                                    <i class="bi bi-bar-chart-line"></i> Nivel de Morosidad
                                </a>
                            </li>
                            }
                            @if (menus.CcNivelTiempo)
                            {
                            <li>
                                <a asp-controller="CreditosCobranza" asp-action="NivelTiempo" class="sidebar-link sidebar-sublink @(ctrl == "CreditosCobranza" && act == "NivelTiempo" ? "active" : "")">
                                    <i class="bi bi-clock-history"></i> Tiempo Promedio CxC
                                </a>
                            </li>
                            }
                        </ul>
                    </li>
                }
            </ul>
        </nav>

        <!-- Contenido principal -->
        <div id="content" class="flex-grow-1 d-flex flex-column">
            <!-- Header -->
            <header class="bg-white shadow-sm border-bottom px-4 py-2 d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-sm btn-outline-secondary" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 small">
                            @RenderSection("Breadcrumb", required: false)
                        </ol>
                    </nav>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="text-muted small">
                        <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
                    </span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-box-arrow-right"></i> Salir
                        </button>
                    </form>
                </div>
            </header>

            <!-- Alertas globales -->
            <div class="px-4 pt-2">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Warning"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
            </div>

            <!-- Contenido de la página -->
            <main class="flex-grow-1 p-4">
                @RenderBody()
            </main>

            <footer class="bg-light border-top text-center py-2">
                <small class="text-muted">&copy; @DateTime.Now.Year @tema.TextoFooter — Sistema de Gestión Empresarial</small>
            </footer>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<!-- Overlay de Carga Global -->
<div id="globalLoadingOverlay" class="global-loading-overlay">
    <div class="global-loading-spinner"></div>
    <div class="global-loading-text">
        <i class="bi bi-hourglass-split me-2"></i><span id="loadingMessage">Cargando...</span>
    </div>
    <div class="global-loading-subtext">Por favor espere</div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
<script src="~/lib/chart.js/dist/chart.umd.min.js" asp-append-version="true"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/lib/flatpickr/dist/flatpickr.min.js" asp-append-version="true"></script>
<script src="~/lib/flatpickr/dist/l10n/es.js" asp-append-version="true"></script>
<script src="~/js/flatpickr-init.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
