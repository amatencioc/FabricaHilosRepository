@{
    ViewData["Title"] = "Empresa";
    ViewData["ActivePage"] = "Empresa";
    ViewData["Description"] = "Conoce La Colonial Fábrica de Hilos S.A. — Historia, misión, visión y valores de la empresa textil peruana líder desde 1945.";
}

<!-- HERO EMPRESA -->
<section style="
    position:relative;
    margin-top:var(--navbar-height-mobile);
    background: var(--gradient-primary);
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
    text-align:center;
    overflow:hidden;"
    aria-labelledby="empresa-hero-heading">
    <div style="position:absolute;inset:0;background-image:url('/images/logos/fon_mision.jpg');background-size:cover;background-position:center;opacity:0.15;"></div>
    <div class="container" style="position:relative;z-index:1;">
        <div class="section-divider centered"></div>
        <h1 id="empresa-hero-heading" style="font-size:clamp(2rem,5vw,3.5rem);font-weight:700;color:var(--color-white);margin-bottom:var(--spacing-sm);">
            Nuestra Empresa
        </h1>
        <p style="color:rgba(255,255,255,0.85);max-width:560px;margin:0 auto;font-size:var(--font-size-md);">
            Desde 1945 fabricamos hilados y hilos de la más alta calidad para la industria textil de Perú y el mundo.
        </p>
    </div>
</section>

<!-- HISTORIA -->
<section class="section-pad" aria-labelledby="historia-heading">
    <div class="container">
        <div style="display:grid;grid-template-columns:1fr;gap:var(--spacing-xl);align-items:center;">
            <div data-aos="fade-up">
                <div class="section-divider"></div>
                <h2 class="section-title" id="historia-heading">Historia</h2>
                <p style="color:var(--color-text-medium);margin-bottom:var(--spacing-sm);line-height:1.8;">
                    La Colonial Fábrica de Hilos S.A. fue fundada en 1945 con la misión de proveer hilados y hilos de alta calidad a la naciente industria textil peruana. A lo largo de más de ocho décadas hemos crecido de manera sostenida, incorporando tecnología de clase mundial y ampliando nuestra capacidad productiva.
                </p>
                <p style="color:var(--color-text-medium);margin-bottom:var(--spacing-md);line-height:1.8;">
                    Nuestra planta, ubicada en Av. Argentina 4151, Callao, opera con maquinaria de última generación y cuenta con un equipo humano altamente capacitado. Hoy exportamos a más de 20 países y seguimos invirtiendo en investigación y desarrollo para ofrecer soluciones textiles innovadoras.
                </p>
                <div style="display:flex;gap:var(--spacing-md);flex-wrap:wrap;">
                    <div style="text-align:center;padding:var(--spacing-sm);background:var(--color-bg-light);border-radius:var(--border-radius-lg);min-width:100px;">
                        <span style="font-size:2rem;font-weight:700;color:var(--color-secondary);display:block;">1945</span>
                        <span style="font-size:var(--font-size-xs);color:var(--color-text-medium);text-transform:uppercase;letter-spacing:1px;">Fundación</span>
                    </div>
                    <div style="text-align:center;padding:var(--spacing-sm);background:var(--color-bg-light);border-radius:var(--border-radius-lg);min-width:100px;">
                        <span style="font-size:2rem;font-weight:700;color:var(--color-secondary);display:block;">80+</span>
                        <span style="font-size:var(--font-size-xs);color:var(--color-text-medium);text-transform:uppercase;letter-spacing:1px;">Años</span>
                    </div>
                    <div style="text-align:center;padding:var(--spacing-sm);background:var(--color-bg-light);border-radius:var(--border-radius-lg);min-width:100px;">
                        <span style="font-size:2rem;font-weight:700;color:var(--color-secondary);display:block;">20+</span>
                        <span style="font-size:var(--font-size-xs);color:var(--color-text-medium);text-transform:uppercase;letter-spacing:1px;">Países</span>
                    </div>
                </div>
            </div>
            <div data-aos="fade-up" data-aos-delay="100">
                <img src="~/images/logos/empresa_p1.jpg" alt="Planta industrial La Colonial"
                     style="width:100%;border-radius:var(--border-radius-xl);box-shadow:var(--shadow-xl);"
                     loading="lazy" />
            </div>
        </div>
    </div>
</section>

<!-- MISIÓN Y VISIÓN -->
<section class="section-pad" style="background:var(--color-bg-light);" aria-labelledby="mision-heading">
    <div class="container">
        <div style="display:grid;grid-template-columns:1fr;gap:var(--spacing-lg);">
            <div style="
                background:var(--color-white);
                border-radius:var(--border-radius-xl);
                padding:var(--spacing-xl);
                box-shadow:var(--shadow-md);
                border-top:4px solid var(--color-secondary);
                position:relative;overflow:hidden;"
                data-aos="fade-up" data-aos-delay="0">
                <div style="position:absolute;top:-20px;right:-20px;width:120px;height:120px;background:var(--color-secondary);opacity:0.06;border-radius:50%;"></div>
                <div style="width:56px;height:56px;background:var(--gradient-primary);border-radius:var(--border-radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:var(--spacing-sm);">
                    <i class="fa-solid fa-bullseye" style="color:var(--color-secondary);font-size:24px;" aria-hidden="true"></i>
                </div>
                <h2 class="section-title" id="mision-heading" style="font-size:var(--font-size-xl);">Misión</h2>
                <p style="color:var(--color-text-medium);line-height:1.8;">
                    Fabricar y comercializar hilados y hilos de alta calidad, satisfaciendo las necesidades de la industria textil y confecciones nacional e internacional, con tecnología de vanguardia, personal calificado y procesos sostenibles, generando valor para nuestros clientes, colaboradores y accionistas.
                </p>
            </div>
            <div style="
                background:var(--color-white);
                border-radius:var(--border-radius-xl);
                padding:var(--spacing-xl);
                box-shadow:var(--shadow-md);
                border-top:4px solid var(--color-primary);
                position:relative;overflow:hidden;"
                data-aos="fade-up" data-aos-delay="100">
                <div style="position:absolute;top:-20px;right:-20px;width:120px;height:120px;background:var(--color-primary);opacity:0.06;border-radius:50%;"></div>
                <div style="width:56px;height:56px;background:var(--gradient-gold);border-radius:var(--border-radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:var(--spacing-sm);">
                    <i class="fa-solid fa-eye" style="color:var(--color-primary-dark);font-size:24px;" aria-hidden="true"></i>
                </div>
                <h2 class="section-title" style="font-size:var(--font-size-xl);">Visión</h2>
                <p style="color:var(--color-text-medium);line-height:1.8;">
                    Ser reconocidos como la empresa peruana líder en fabricación de hilados y hilos a nivel latinoamericano, destacando por nuestra innovación tecnológica, calidad certificada internacionalmente y compromiso con el desarrollo sostenible de la industria textil.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- VALORES -->
<section class="section-pad" aria-labelledby="valores-heading">
    <div class="container">
        <div style="text-align:center;margin-bottom:var(--spacing-xl);">
            <div class="section-divider centered"></div>
            <h2 class="section-title" id="valores-heading" style="margin:0 auto;">Nuestros valores</h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:var(--spacing-md);">
            @{
                var valores = new[] {
                    new { Icon = "fa-gem", Titulo = "Calidad", Desc = "Excelencia en cada hilo que fabricamos" },
                    new { Icon = "fa-handshake", Titulo = "Integridad", Desc = "Honestidad y transparencia en todo momento" },
                    new { Icon = "fa-lightbulb", Titulo = "Innovación", Desc = "Investigación continua de nuevas tecnologías" },
                    new { Icon = "fa-leaf", Titulo = "Sostenibilidad", Desc = "Responsabilidad ambiental en cada proceso" },
                    new { Icon = "fa-users", Titulo = "Equipo", Desc = "Personas comprometidas con la misión de la empresa" },
                    new { Icon = "fa-trophy", Titulo = "Excelencia", Desc = "Superamos expectativas en cada entrega" },
                };
            }
            @foreach (var v in valores)
            {
                <div style="text-align:center;padding:var(--spacing-lg) var(--spacing-md);background:var(--color-bg-light);border-radius:var(--border-radius-lg);" data-aos="fade-up">
                    <div style="width:60px;height:60px;background:var(--gradient-primary);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto var(--spacing-sm);">
                        <i class="fa-solid @v.Icon" style="color:var(--color-secondary);font-size:22px;" aria-hidden="true"></i>
                    </div>
                    <h3 style="font-size:var(--font-size-md);font-weight:700;color:var(--color-primary);margin-bottom:6px;">@v.Titulo</h3>
                    <p style="font-size:var(--font-size-sm);color:var(--color-text-medium);">@v.Desc</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- CERTIFICACIONES -->
<section class="cert-section section-pad" id="certificaciones" aria-labelledby="cert-empresa-heading">
    <div class="container">
        <div style="text-align:center;margin-bottom:var(--spacing-lg);">
            <div class="section-divider centered"></div>
            <h2 class="section-title" id="cert-empresa-heading" style="margin:0 auto var(--spacing-xs);">Certificaciones internacionales</h2>
            <p class="section-subtitle" style="margin:0 auto;">Respaldados por los organismos certificadores más exigentes del mundo textil</p>
        </div>
        <div class="cert-grid">
            <a class="cert-item" href="https://www.sgs.com/" target="_blank" rel="noopener noreferrer" data-aos="zoom-in" data-aos-delay="0" aria-label="Ver certificación SGS (abre en nueva pestaña)">
                <img src="~/images/certificaciones/certificacion-sgs.png" alt="Certificación SGS" loading="lazy" />
                <span>SGS</span>
                <p style="font-size:var(--font-size-xs);color:var(--color-text-light);text-align:center;">Sociedad General de Vigilancia — Pruebas y certificaciones internacionales</p>
            </a>
            <a class="cert-item" href="https://www.oeko-tex.com/en/our-standards/oeko-tex-standard-100" target="_blank" rel="noopener noreferrer" data-aos="zoom-in" data-aos-delay="100" aria-label="Ver certificación OEKO-TEX Standard 100 (abre en nueva pestaña)">
                <img src="~/images/certificaciones/certificacion-oeko.png" alt="OEKO-TEX Standard 100" loading="lazy" />
                <span>OEKO-TEX Std 100</span>
                <p style="font-size:var(--font-size-xs);color:var(--color-text-light);text-align:center;">Textiles probados contra sustancias nocivas</p>
            </a>
            <a class="cert-item" href="https://www.global-standard.org/find-suppliers-shops-and-inputs/certified-suppliers/database/search_result/782" target="_blank" rel="noopener noreferrer" data-aos="zoom-in" data-aos-delay="200" aria-label="Ver certificación GOTS de La Colonial (abre en nueva pestaña)">
                <img src="~/images/certificaciones/certificacion-gots.png" alt="GOTS - Global Organic Textile Standard" loading="lazy" />
                <span>GOTS</span>
                <p style="font-size:var(--font-size-xs);color:var(--color-text-light);text-align:center;">Estándar global para textiles orgánicos</p>
            </a>
        </div>
    </div>
</section>

<!-- POLÍTICAS DE CALIDAD -->
<section class="section-pad" aria-labelledby="politicas-heading">
    <div class="container">
        <div data-aos="fade-up" style="
            background:var(--color-primary);
            border-radius:var(--border-radius-xl);
            padding:var(--spacing-2xl) var(--spacing-xl);
            color:var(--color-white);
            position:relative;
            overflow:hidden;">
            <div style="position:absolute;top:-40px;right:-40px;width:200px;height:200px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
            <div style="position:absolute;bottom:-60px;left:-30px;width:250px;height:250px;background:rgba(255,255,255,0.04);border-radius:50%;"></div>
            <div style="position:relative;z-index:1;">
                <div class="section-divider" style="background:var(--color-secondary);"></div>
                <h2 class="section-title" id="politicas-heading" style="color:var(--color-white);font-size:clamp(1.4rem,3vw,2rem);margin-bottom:var(--spacing-lg);">Políticas de Calidad</h2>
                <div style="display:grid;grid-template-columns:1fr;gap:var(--spacing-md);max-width:860px;">
                    <p style="color:rgba(255,255,255,0.9);line-height:1.8;">
                        En La Colonial Fábrica de Hilos S.A., empresa peruana dedicada a la Producción y Servicio de Hilandería y Tintorería de Algodón, se mantiene un fuerte compromiso con:
                    </p>
                    <ul style="color:rgba(255,255,255,0.88);line-height:2;padding-left:var(--spacing-md);display:flex;flex-direction:column;gap:4px;">
                        <li>El cumplimiento cabal de los requisitos aplicables a la organización a través de la medición, revisión y actualización constante de los objetivos y metas del sistema, los cuales están alineadas a los objetivos estratégicos de la organización.</li>
                        <li>La ejecución de los procesos de la forma más eficiente y simple posible, siguiendo nuestra filosofía de línea recta.</li>
                        <li>La innovación y la mejora continua de nuestro Sistema de Gestión de Calidad, lo cual incluye la comprensión del contexto interno y externo de la organización, así como de las necesidades y expectativas de sus partes interesadas.</li>
                        <li>Buscando, dentro de un marco ético y de compromiso legal, consolidar nuestro liderazgo en el mercado nacional e internacional y ser la mejor opción de compra, ofreciendo a nuestros clientes productos de calidad, variedad y estilo, los cuales se encuentran en constante innovación de acuerdo a las tendencias del mercado.</li>
                    </ul>
                    <p style="color:rgba(255,255,255,0.7);font-size:var(--font-size-sm);font-style:italic;">Aprobado por Gerencia General v.03</p>
                    <div style="display:flex;flex-direction:column;gap:var(--spacing-xs);margin-top:var(--spacing-sm);">
                        <p style="color:var(--color-secondary);font-weight:600;font-size:var(--font-size-sm);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Documentos de política:</p>
                        <a href="/docs/politicas/Politica_DDHH_y_trabajo_infantil.pdf"
                           target="_blank" rel="noopener noreferrer"
                           style="color:var(--color-secondary);text-decoration:underline;font-size:var(--font-size-sm);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-file-pdf" aria-hidden="true"></i> Política de DD.HH. y trabajo infantil
                        </a>
                        <a href="/docs/politicas/Politica_contra_trabajo_infantil.pdf"
                           target="_blank" rel="noopener noreferrer"
                           style="color:var(--color-secondary);text-decoration:underline;font-size:var(--font-size-sm);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-file-pdf" aria-hidden="true"></i> Política en contra del trabajo infantil
                        </a>
                        <a href="/docs/politicas/Politica_de_Atencion_a_Reclamos.pdf"
                           target="_blank" rel="noopener noreferrer"
                           style="color:var(--color-secondary);text-decoration:underline;font-size:var(--font-size-sm);display:flex;align-items:center;gap:8px;">
                            <i class="fa-solid fa-file-pdf" aria-hidden="true"></i> Política de Atención a Reclamos
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section style="padding:var(--spacing-2xl) 0;background:var(--gradient-primary);text-align:center;" aria-labelledby="cta-empresa-heading">
    <div class="container" data-aos="fade-up">
        <h2 id="cta-empresa-heading" style="font-size:clamp(1.4rem,3.5vw,2.2rem);font-weight:700;color:var(--color-white);margin-bottom:var(--spacing-sm);">
            ¿Desea conocer más sobre nuestros productos?
        </h2>
        <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:var(--spacing-md);">
            <a href="/productos" class="btn-colonial btn-primary-col">
                <i class="fa-solid fa-boxes-stacked" aria-hidden="true"></i> Ver productos
            </a>
            <a href="/contacto" class="btn-colonial btn-secondary-col">
                <i class="fa-solid fa-envelope" aria-hidden="true"></i> Contactar
            </a>
        </div>
    </div>
</section>

@section Styles {
    <style>
        @@media (min-width: 768px) {
            .historia-grid { grid-template-columns: 1fr 1fr !important; }
            .mision-grid   { grid-template-columns: 1fr 1fr !important; }
        }
    </style>
}
