@model IEnumerable<FabricaHilos.Models.Sgc.KardexGDto>
@using FabricaHilos.Models.Sgc
@inject FabricaHilos.Services.INavTokenService NavToken

@{
    ViewData["Title"] = "Guías";
    int pedSerie = ViewBag.PedSerie;
    int numPed   = ViewBag.NumPed;
    int itemNro  = ViewBag.ItemNro;
    var pedido   = ViewBag.Pedido  as PedidoSgcDto;
    var itemPed  = ViewBag.ItemPed as ItemPedDto;
    string? buscar = ViewBag.Buscar as string;
    string navToken     = ViewBag.NavToken as string ?? "";
    string pedidosToken = NavToken.Protect(new Dictionary<string, string?> {
        ["buscar"] = buscar
    });
    string detPedToken = NavToken.Protect(new Dictionary<string, string?> {
        ["serie"]  = pedSerie.ToString(),
        ["numPed"] = numPed.ToString(),
        ["buscar"] = buscar
    });
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item"><a asp-action="Pedidos" asp-route-t="@pedidosToken">Pedidos</a></li>
    <li class="breadcrumb-item">
        <a asp-action="DetallePedido" asp-route-t="@detPedToken">
            Pedido @numPed
        </a>
    </li>
    <li class="breadcrumb-item active">Guías (Ítem @itemNro)</li>
}

<div class="mb-3">
    <h4 class="section-title mb-1">
        <i class="bi bi-truck me-2"></i>Guías del Pedido @numPed — Ítem @itemNro
    </h4>
    <a asp-action="DetallePedido" asp-route-t="@detPedToken" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver al pedido
    </a>
</div>

<input type="hidden" id="tipCompSunat" value="01" />

@if (pedido != null || itemPed != null)
{
    <div class="card mb-3">
        <div class="card-body py-2 small">
            <div class="row row-cols-2 row-cols-md-3 g-2">
                <div><span class="text-muted">RUC:</span> <span class="fw-semibold">@(pedido?.Ruc ?? "-")</span></div>
                <div><span class="text-muted">Cliente:</span> <span class="fw-semibold">@(pedido?.Nombre ?? pedido?.CodCliente ?? "-")</span></div>
                <div><span class="text-muted">Descripción:</span> <span class="fw-semibold">@(itemPed?.Descripcion ?? "-")</span></div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center">Almacén</th>
                        <th class="text-center">Transacción</th>
                        <th class="text-center">Serie</th>
                        <th class="text-center">N° Guía</th>
                        <th class="text-center">Fec. Transacción</th>
                        <th class="text-center">Glosa</th>
                        <th class="text-center">Facturado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr data-serie-sunat="@(item.SerieSunat ?? "")">
                            <td>@item.CodAlm</td>
                            <td>@item.TpTransac</td>
                            <td class="text-center">@item.Serie</td>
                            <td class="fw-semibold text-center">@item.Numero</td>
                            <td>@(item.FchTransac?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>@(item.Glosa ?? "-")</td>
                            <td class="text-center">
                                @if (item.IndFact == "S" || item.IndFact == "1")
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Sí</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                     <a asp-action="DescargarGuiaPdf"
                                       asp-route-codAlm="@item.CodAlm"
                                       asp-route-tpTransac="@item.TpTransac"
                                       asp-route-serie="@item.Serie"
                                       asp-route-numero="@item.Numero"
                                       asp-route-pedSerie="@pedSerie"
                                       asp-route-numPed="@numPed"
                                       asp-route-nro="@itemNro"
                                       asp-route-codArt="@itemPed?.CodArt"
                                       class="btn btn-sm btn-outline-danger btn-accion"
                                       onclick="descargarPdf(event, this)"
                                       title="Descargar PDF">
                                        <i class="bi bi-file-pdf"></i> PDF
                                    </a>
                                    @if (item.TieneDetalle)
                                    {
                                        string detGuiaToken = NavToken.Protect(new Dictionary<string, string?> {
                                            ["codAlm"]    = item.CodAlm,
                                            ["tpTransac"] = item.TpTransac,
                                            ["serie"]     = item.Serie.ToString(),
                                            ["numero"]    = item.Numero.ToString(),
                                            ["pedSerie"]  = pedSerie.ToString(),
                                            ["numPed"]    = numPed.ToString(),
                                            ["nro"]       = itemNro.ToString(),
                                            ["codArt"]    = itemPed?.CodArt,
                                            ["buscar"]    = buscar
                                        });
                                    <a asp-action="DetalleGuia"
                                       asp-route-t="@detGuiaToken"
                                       class="btn btn-sm btn-outline-primary btn-accion"
                                       title="Ver detalle de la guía">
                                        <i class="bi bi-list-columns-reverse"></i> Detalle
                                    </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-inbox me-2"></i>No se encontraron guías para este pedido.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer py-2">
        @{
            int currentPage = ViewBag.Page       != null ? Convert.ToInt32(ViewBag.Page)       : 1;
            int totalPages  = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
            int totalCount  = ViewBag.TotalCount != null ? Convert.ToInt32(ViewBag.TotalCount) : 0;
            int pgSize      = ViewBag.PageSize   != null ? Convert.ToInt32(ViewBag.PageSize)   : 10;
            int startItem   = totalCount == 0 ? 0 : (currentPage - 1) * pgSize + 1;
            int endItem     = Math.Min(currentPage * pgSize, totalCount);
        }
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @(totalCount == 0 ? "Sin registros" : $"Mostrando {startItem}\u2013{endItem} de {totalCount} registros")
            </small>
            @if (totalPages > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Guias" asp-route-t="@navToken" asp-route-page="@(currentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                        </li>
                        @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
                        {
                            <li class="page-item @(pg == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="Guias" asp-route-t="@navToken" asp-route-page="@pg">@pg</a>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Guias" asp-route-t="@navToken" asp-route-page="@(currentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="pdfModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header" id="pdfModalHeader">
                <h5 class="modal-title d-flex align-items-center">
                    <i class="bi me-2" id="pdfModalIcono"></i>
                    <span id="pdfModalTitulo"></span>
                </h5>
                <button type="button" class="btn-close" id="pdfModalCloseBtn"
                        data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0" id="pdfModalMensaje" style="white-space: pre-wrap; word-break: break-all;"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cerrar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function descargarPdf(event, anchor) {
        event.preventDefault();
        try {
            const resp = await fetch(anchor.href, { credentials: 'include' });
            const ct = resp.headers.get('Content-Type') ?? '';
            if (ct.includes('application/json')) {
                const data = await resp.json();
                mostrarPdfModal(data.tipo, data.mensaje);
            } else {
                                const blob = await resp.blob();
                                const url  = URL.createObjectURL(blob);
                                window.open(url, '_blank');
                                setTimeout(() => URL.revokeObjectURL(url), 60000);
            }
        } catch {
            mostrarPdfModal('Error', 'Ocurrió un error inesperado al obtener el PDF.');
        }
    }

    function mostrarPdfModal(tipo, mensaje) {
        const esError = tipo === 'Error';
        document.getElementById('pdfModalHeader').className =
            'modal-header ' + (esError ? 'bg-danger text-white' : 'bg-warning text-dark');
        const closeBtn = document.getElementById('pdfModalCloseBtn');
        closeBtn.className = 'btn-close' + (esError ? ' btn-close-white' : '');
        document.getElementById('pdfModalIcono').className =
            'bi me-2 ' + (esError ? 'bi-x-circle-fill' : 'bi-exclamation-triangle-fill');
        document.getElementById('pdfModalTitulo').textContent = tipo;
        document.getElementById('pdfModalMensaje').textContent = mensaje;
        bootstrap.Modal.getOrCreateInstance(document.getElementById('pdfModal')).show();
    }
</script>
}
