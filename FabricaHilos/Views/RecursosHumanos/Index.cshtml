@{
    ViewData["Title"] = "Recursos Humanos";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Recursos Humanos</li>
}

<h4 class="section-title"><i class="bi bi-person-badge me-2"></i>Módulo de Recursos Humanos</h4>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card card-dashboard h-100">
            <div class="card-body text-center p-5">
                <i class="bi bi-person-lines-fill display-4 text-primary mb-3"></i>
                <h5 class="fw-bold">Empleados</h5>
                <p class="text-muted">Gestión del personal activo e inactivo.</p>
                <a asp-action="Empleados" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-1"></i>Ver Empleados
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-dashboard h-100">
            <div class="card-body text-center p-5">
                <i class="bi bi-calendar-check display-4 text-success mb-3"></i>
                <h5 class="fw-bold">Asistencia</h5>
                <p class="text-muted">Control de asistencia diaria del personal.</p>
                <a asp-action="Asistencia" class="btn btn-success">
                    <i class="bi bi-arrow-right me-1"></i>Ver Asistencia
                </a>
            </div>
        </div>
    </div>
</div>
