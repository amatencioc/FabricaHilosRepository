@model IEnumerable<FabricaHilos.Models.Sgc.ReqCertDDto>

@{
    ViewData["Title"] = "Detalle de Requerimiento TC";
    var requerimiento = ViewBag.Requerimiento as FabricaHilos.Models.Sgc.ReqCertDto;
    string? navToken = ViewBag.NavToken as string;
}

@section Styles {
<style>
    /* Overlay de carga */
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.7);
        z-index: 9999;
        display: none;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .loading-overlay.show {
        display: flex;
    }

    .loading-spinner {
        width: 4rem;
        height: 4rem;
        border: 0.4rem solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spinner-rotate 0.8s linear infinite;
    }

    @@keyframes spinner-rotate {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .loading-text {
        color: #fff;
        font-size: 1.25rem;
        font-weight: 500;
        margin-top: 1.5rem;
        text-align: center;
    }
</style>
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">Despachos</a></li>
    <li class="breadcrumb-item"><a asp-controller="CargaTc" asp-action="Index" asp-route-t="@navToken">Cargar TC</a></li>
    <li class="breadcrumb-item active">Detalle #@requerimiento.NumReq</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0">
        <i class="bi bi-file-earmark-text me-2"></i>
        Detalle del Requerimiento #@requerimiento.NumReq
    </h4>
    <a href="@Url.Action("Index", new { t = navToken })" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<!-- Información del Requerimiento -->
<div class="card shadow-sm mb-3">
    <div class="card-header">
        <h6 class="mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Información del Requerimiento
        </h6>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <p><strong>Nº Requerimiento:</strong> @requerimiento.NumReq</p>
                <p><strong>Fecha:</strong> @requerimiento.Fecha?.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>RUC:</strong> @requerimiento.Ruc</p>
                <p><strong>Cliente:</strong> @requerimiento.RazonSocial</p>
            </div>
            <div class="col-md-6">
                <p><strong>Nº Certificado:</strong> 
                    @if (!string.IsNullOrEmpty(requerimiento.NumCer))
                    {
                        <span class="badge bg-success">@requerimiento.NumCer</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Sin certificado</span>
                    }
                </p>
                <p><strong>Documento:</strong> 
                    @if (!string.IsNullOrEmpty(requerimiento.TipoDoc))
                    {
                        <span>@requerimiento.TipoDoc-@requerimiento.Serie-@requerimiento.Numero</span>
                    }
                    else
                    {
                        <span class="text-muted">No asignado</span>
                    }
                </p>
            </div>
        </div>
    </div>
</div>

<!-- Formulario para Cargar Certificado -->
<div class="card shadow-sm mb-3">
    <div class="card-header">
        <h6 class="mb-0">
            <i class="bi bi-upload me-2"></i>
            Cargar Certificado y PDF
        </h6>
    </div>
    <div class="card-body">
        <form id="formCertificado" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" id="numReq" name="numReq" value="@requerimiento.NumReq" />

            <div class="row g-3">
                <div class="col-md-12">
                    <label for="numCer" class="form-label">Nº Certificado <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="numCer" name="numCer" value="@requerimiento.NumCer"
                           placeholder="Requerido" maxlength="30" required>
                    <div class="d-flex justify-content-between">
                        <small class="text-muted">Máximo 30 caracteres (límite de base de datos).</small>
                        <small id="numCerContador" class="text-muted">@((requerimiento.NumCer?.Length ?? 0))/30</small>
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-9">
                    <label for="archivo" class="form-label">Archivo PDF del Certificado <span class="text-danger">*</span></label>
                    <input type="file" class="form-control" id="archivo" name="archivo" accept=".pdf" required>
                    <small class="text-muted">Debe cargar el archivo PDF del certificado</small>
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="button" id="btnGuardar" class="btn btn-success w-100">
                        <i class="bi bi-save me-1"></i>Guardar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Documentos Asociados -->
<div class="card shadow-sm">
    <div class="card-header">
        <h6 class="mb-0">
            <i class="bi bi-file-earmark-text me-2"></i>
            Documentos Asociados al Requerimiento
        </h6>
    </div>
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-corporate table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Tipo Doc.</th>
                            <th>Serie</th>
                            <th>Número</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detalle in Model)
                        {
                            <tr>
                                <td>@detalle.TipoDoc</td>
                                <td>@detalle.Serie</td>
                                <td>@detalle.Numero</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body">
                <div class="alert alert-warning text-center mb-0">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    No se encontraron documentos asociados a este requerimiento.
                </div>
            </div>
        }
    </div>
</div>

<!-- Overlay de carga -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="loading-spinner"></div>
    <div class="loading-text">
        <i class="bi bi-hourglass-split me-2"></i>Guardando certificado y PDF, por favor espere...
    </div>
</div>

@section Scripts {
    <script>
        // Usar vanilla JavaScript para evitar problemas con jQuery
        document.addEventListener('DOMContentLoaded', function () {
            const btnGuardar = document.getElementById('btnGuardar');
            const loadingOverlay = document.getElementById('loadingOverlay');
            const numCerInput = document.getElementById('numCer');
            const numCerContador = document.getElementById('numCerContador');

            // Contador de caracteres en tiempo real
            if (numCerInput && numCerContador) {
                numCerInput.addEventListener('input', function () {
                    const len = this.value.length;
                    numCerContador.textContent = `${len}/30`;
                    numCerContador.classList.toggle('text-danger', len >= 30);
                    numCerContador.classList.toggle('text-muted', len < 30);
                });
            }

            if (btnGuardar) {
                btnGuardar.addEventListener('click', function () {
                    const numReq = document.getElementById('numReq').value;
                    const numCer = document.getElementById('numCer').value.trim();
                    const archivoInput = document.getElementById('archivo');
                    const archivo = archivoInput.files[0];

                    // Validar que Nº Certificado sea obligatorio
                    if (!numCer) {
                        AppAlert('El Nº Certificado es obligatorio.', 'Aviso', 'warning');
                        return;
                    }

                    // Validar que el archivo PDF sea obligatorio
                    if (!archivo) {
                        AppAlert('El Archivo PDF del certificado es obligatorio.', 'Aviso', 'warning');
                        return;
                    }

                    // Mostrar overlay de carga LOCAL (para este caso específico)
                    loadingOverlay.classList.add('show');

                    // Cargar PDF + actualizar datos
                    const formData = new FormData();
                    formData.append('numReq', numReq);
                    formData.append('archivo', archivo);
                    formData.append('numCer', numCer);

                    const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
                    if (tokenInput) {
                        formData.append('__RequestVerificationToken', tokenInput.value);
                    }

                    // Usar noLoading: true para evitar el overlay global
                    fetch('@Url.Action("CargarPdf", "CargaTc")', {
                        method: 'POST',
                        body: formData,
                        noLoading: true  // No usar overlay global
                    })
                    .then(response => response.json())
                    .then(data => {
                        loadingOverlay.classList.remove('show');

                        if (data.tipo === 'Exito') {
                            // El overlay global se mostrará automáticamente en la navegación
                            window.location.href = data.redirectUrl;
                        } else if (data.tipo === 'Advertencia') {
                            AppAlert(data.mensaje, 'Advertencia', 'warning');
                        } else {
                            AppAlert(data.mensaje || 'Error al guardar el certificado', 'Error', 'danger');
                        }
                    })
                    .catch(error => {
                        loadingOverlay.classList.remove('show');
                        console.error('Error:', error);
                        AppAlert('Error al procesar la solicitud. Por favor, intente nuevamente.', 'Error', 'danger');
                    });
                });
            }
        });
    </script>
}
