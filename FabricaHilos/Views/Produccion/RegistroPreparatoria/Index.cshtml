</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Utilidades compartidas (accesibles a todos los handlers en este scope)
        function formatDt(val) {
            if (!val) return '-';
            var d = new Date(val);
            if (isNaN(d)) return val;
            var pad = function (n) { return String(n).padStart(2, '0'); };
            return pad(d.getDate()) + '/' + pad(d.getMonth() + 1) + '/' + d.getFullYear() +
                   ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
        }
        function escHtml(s) {
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }
        function diffTiempo(ini, fin) {
            if (!ini || !fin) return '-';
            var dIni = new Date(ini);
            var dFin = new Date(fin);
            if (isNaN(dIni) || isNaN(dFin)) return '-';
            var diffMs = dFin - dIni;
            if (diffMs < 0) return '-';
            var totalMin = Math.floor(diffMs / 60000);
            var hrs = Math.floor(totalMin / 60);
            var min = totalMin % 60;
            return hrs + ' hrs. ' + min + ' min.';
        }
        function getTurnoDesc(t) {
            var map = { '1': '1er Turno', '2': '2do Turno', '3': '3er Turno', '4': '12 Hrs Da', '5': '12 Hrs Noche' };
            return map[t] || (t || '-');
        }
        function getFechaTurno() {
            var now   = new Date();
            var fecha = now.getHours() < 7 ? new Date(now.getTime() - 86400000) : now;
            var y = fecha.getFullYear();
            var m = String(fecha.getMonth() + 1).padStart(2, '0');
            var d = String(fecha.getDate()).padStart(2, '0');
            return y + '-' + m + '-' + d;
        }

        // === Modal de confirmación Anular ===
        var formIdToSubmit = null;
        var modalAnular = new bootstrap.Modal(document.getElementById('modalConfirmarAnular'));

        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-anular');
            if (btn) {
                formIdToSubmit = btn.getAttribute('data-form-id');
                modalAnular.show();
            }
        });

        document.getElementById('modalConfirmarAnular').addEventListener('shown.bs.modal', function () {
            document.getElementById('btnCancelarAnularModal').focus();
        });

        document.getElementById('btnAceptarAnularModal').addEventListener('click', function () {
            if (formIdToSubmit) {
                document.getElementById(formIdToSubmit).submit();
            }
        });

        // === Combo multi-estado ===
        (function () {
            var btnEstado   = document.getElementById('btnEstado');
            var panelEstado = document.getElementById('panelEstado');
            var spanTexto   = document.getElementById('spanEstadoTexto');
            var names = { '1': 'En Proceso', '3': 'Terminado', '9': 'Anulado' };

            function updateEstadoText() {
                var checks = document.querySelectorAll('.estado-chk');
                var sel = Array.from(checks).filter(function (c) { return c.checked; }).map(function (c) { return names[c.value]; });
                if (sel.length === 0)      spanTexto.textContent = 'Seleccionar...';
                else if (sel.length === 3) spanTexto.textContent = 'Todos los estados';
                else                       spanTexto.textContent = sel.join(', ');
            }

            btnEstado.addEventListener('click', function (e) {
                e.stopPropagation();
                panelEstado.style.display = panelEstado.style.display === 'none' ? 'block' : 'none';
            });

            document.querySelectorAll('.estado-chk').forEach(function (chk) {
                chk.addEventListener('change', updateEstadoText);
            });

            document.addEventListener('click', function (e) {
                if (!document.getElementById('divEstado').contains(e.target)) {
                    panelEstado.style.display = 'none';
                }
            });

            updateEstadoText();
        })();

        // === Paginación ===
        document.querySelectorAll('.btn-pagina').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var li = this.closest('.page-item');
                if (li && li.classList.contains('disabled')) return;
                var p = parseInt(this.getAttribute('data-page'));
                if (isNaN(p)) return;
                document.getElementById('hiddenPage').value = p;
                document.querySelector('form[method="get"]').submit();
            });
        });

        // === Modal Ver Detalle ===
        var modalVerDetalle = new bootstrap.Modal(document.getElementById('modalVerDetalle'));

        // === Modal Registrar Paro ===
        (function () {
            var modalRegistrarParo         = new bootstrap.Modal(document.getElementById('modalRegistrarParo'));
            var modalConfirmarEliminarParo = new bootstrap.Modal(document.getElementById('modalConfirmarEliminarParo'));
            var paroLista        = [];        // lista en memoria
            var paroEditIdx      = -1;        // índice de la fila seleccionada para editar (-1 = ninguna)
            var pendingDeleteIdx = -1;        // índice BD paro pendiente de confirmación
            var paroTpMaq     = '';
            var paroCodMaq    = '';
            var paroTurno     = '';
            var motivosCache  = null;

            function showParoError(msg) {
                var el = document.getElementById('paroAlerta');
                el.textContent = msg;
                el.style.display = '';
            }
            function hideParoError() {
                document.getElementById('paroAlerta').style.display = 'none';
            }
            function clearParoFieldErrors() {
                ['errParoFechaIni', 'errParoMotivo', 'errParoFechaFin'].forEach(function (id) {
                    document.getElementById(id).style.display = 'none';
                });
                ['paroFechaIni', 'paroMotivoInput', 'paroFechaFin'].forEach(function (id) {
                    document.getElementById(id).classList.remove('is-invalid');
                });
            }
            function setParoFieldError(fieldId, errId, msg) {
                var el = document.getElementById(fieldId);
                el.classList.add('is-invalid');
                var err = document.getElementById(errId);
                err.textContent = msg;
                err.style.display = '';
            }

            function getSelectedTurnos() {
                return Array.from(document.querySelectorAll('.turno-filtro-chk:checked')).map(function (c) { return c.value; });
            }

            function getTurnoDesc(t) {
                var map = { '1': '1er Turno', '2': '2do Turno', '3': '3er Turno', '4': '12 Hrs Da', '5': '12 Hrs Noche' };
                return map[t] || (t || '-');
            }

            function renderTablaParos() {
                var tbody = document.getElementById('tablaParosCuerpo');
                tbody.innerHTML = '';
                var turnosFiltro = getSelectedTurnos();
                var lista = (turnosFiltro.length === 0
                    ? paroLista.slice()
                    : paroLista.filter(function (p) { return !p.turno || turnosFiltro.indexOf(p.turno) >= 0; }))
                    .sort(function (a, b) {
                        var da = a.fechaIni || '';
                        var db = b.fechaIni || '';
                        return db < da ? -1 : (db > da ? 1 : 0);
                    });

                if (lista.length === 0) {
                    tbody.innerHTML = '<tr id="paroFilaVacia"><td colspan="6" class="text-center text-muted py-3"><i class="bi bi-inbox me-1"></i>Sin paros agregados</td></tr>';
                    return;
                }
                lista.forEach(function (p, i) {
                    var realIdx = paroLista.indexOf(p);
                    var tr = document.createElement('tr');
                    if (realIdx === paroEditIdx) tr.classList.add('table-warning');
                    var motivoDisplay = escHtml(p.motivoDesc || p.motivoTexto || p.motivo || '');
                    var botonesHtml;
                    if (!p.esGuardado) {
                        botonesHtml = '<div class="d-flex gap-1 justify-content-end">' +
                                      '<button type="button" class="btn btn-xs btn-outline-primary btn-paro-editar" data-idx="' + realIdx + '" title="Editar"><i class="bi bi-pencil"></i></button>' +
                                      '<button type="button" class="btn btn-xs btn-outline-danger btn-paro-eliminar" data-idx="' + realIdx + '" title="Eliminar"><i class="bi bi-trash"></i></button>' +
                                      '</div>' +
                                      '<div class="text-end mt-1"><span class="badge bg-success">Nuevo</span></div>';
                    } else if (p.esAbierto) {
                        botonesHtml = '<div class="d-flex gap-1 justify-content-end">' +
                                      '<button type="button" class="btn btn-xs btn-outline-primary btn-paro-editar" data-idx="' + realIdx + '" title="Editar"><i class="bi bi-pencil"></i></button>' +
                                      '<button type="button" class="btn btn-xs btn-outline-danger btn-paro-eliminar" data-idx="' + realIdx + '" data-es-bd="true" title="Eliminar de BD"><i class="bi bi-trash"></i></button>' +
                                      '</div>' +
                                      '<div class="text-end mt-1"><span class="badge bg-warning text-dark">Abierto</span></div>';
                    } else {
                        botonesHtml = '<div class="d-flex gap-1 justify-content-end">' +
                                      '<button type="button" class="btn btn-xs btn-outline-danger btn-paro-eliminar" data-idx="' + realIdx + '" data-es-bd="true" title="Eliminar de BD"><i class="bi bi-trash"></i></button>' +
                                      '</div>' +
                                      '<div class="text-end mt-1"><span class="badge bg-secondary">Guardado</span></div>';
                    }
                    tr.innerHTML =
                        '<td>' + (i + 1) + '</td>' +
                        '<td>' + motivoDisplay + '</td>' +
                        '<td>' + escHtml(getTurnoDesc(p.turno)) + '</td>' +
                        '<td class="text-nowrap">' + formatDt(p.fechaIni) + '</td>' +
                        '<td class="text-nowrap">' + (p.fechaFin ? formatDt(p.fechaFin) : '<span class="text-muted">-</span>') + '</td>' +
                        '<td class="text-end">' + botonesHtml + '</td>';
                    tbody.appendChild(tr);
                });
            }

            function formatDt(val) {
                if (!val) return '-';
                // val es "yyyy-MM-ddTHH:mm:ss" o similar
                var d = new Date(val);
                if (isNaN(d)) return val;
                var pad = function (n) { return String(n).padStart(2, '0'); };
                return pad(d.getDate()) + '/' + pad(d.getMonth() + 1) + '/' + d.getFullYear() +
                       ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes());
            }

            function escHtml(s) {
                return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }

            function getLocalDateTimeInputValue() {
                var d = new Date();
                var pad = function (n) { return String(n).padStart(2, '0'); };
                return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate()) + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
            }

            function resetParoForm() {
                paroEditIdx = -1;
                document.getElementById('paroFechaIni').readOnly = false;
                document.getElementById('paroFechaIni').value    = getLocalDateTimeInputValue();
                document.getElementById('paroMotivoInput').value = '';
                document.getElementById('paroMotivo').value      = '';
                document.getElementById('paroFechaFin').value    = getLocalDateTimeInputValue();
                document.getElementById('spanBtnParoTexto').textContent = 'Agregar';
                document.getElementById('btnParoCancelarEdicion').style.display = 'none';
                clearParoFieldErrors();
                hideParoError();
                renderTablaParos();
            }

            function cargarParosBD() {
                var selectedTurnos = getSelectedTurnos();
                if (selectedTurnos.length === 0) {
                    paroLista = paroLista.filter(function (p) { return !p.esGuardado; });
                    renderTablaParos();
                    return;
                }
                var url = '@Url.Action("GetParosPorMaquina", "RegistroPreparatoria")?tpMaq=' + encodeURIComponent(paroTpMaq) + '&codMaq=' + encodeURIComponent(paroCodMaq) + '&fechaTurno=' + encodeURIComponent(getFechaTurno());
                selectedTurnos.forEach(function (t) { url += '&turnos=' + encodeURIComponent(t); });
                fetch(url)
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        paroLista = paroLista.filter(function (p) { return !p.esGuardado; });
                        data.forEach(function (p) {
                            paroLista.push({
                                fechaIni:   p.fechaIni,
                                motivo:     p.motivo,
                                motivoDesc: p.motivoDesc,
                                fechaFin:   p.fechaFin || null,
                                esGuardado: true,
                                esAbierto:  p.esAbierto,
                                turno:      p.turno || ''
                            });
                        });
                        renderTablaParos();
                    })
                    .catch(function () { /* ignorar, mostrar vacío */ });
            }

            function filtrarMotivosDropdown(texto) {
                var ul = document.getElementById('paroMotivoDropdown');
                if (!motivosCache) { ul.style.display = 'none'; return; }
                var items = motivosCache.filter(function (m) {
                    return !texto || m.texto.toUpperCase().indexOf(texto.toUpperCase()) >= 0 || m.codigo.toUpperCase().indexOf(texto.toUpperCase()) >= 0;
                });
                ul.innerHTML = '';
                if (items.length === 0) { ul.style.display = 'none'; return; }
                items.forEach(function (m) {
                    var li = document.createElement('li');
                    li.className = 'list-group-item list-group-item-action py-1 px-2 small';
                    li.textContent = m.texto;
                    li.style.cursor = 'pointer';
                    li.addEventListener('mousedown', function (e) { e.preventDefault(); seleccionarMotivo(m); });
                    ul.appendChild(li);
                });
                ul.style.display = '';
            }

            function seleccionarMotivo(m) {
                document.getElementById('paroMotivoInput').value = m.texto;
                document.getElementById('paroMotivo').value      = m.codigo;
                document.getElementById('paroMotivoInput').classList.remove('is-invalid');
                document.getElementById('errParoMotivo').style.display = 'none';
                document.getElementById('paroMotivoDropdown').style.display = 'none';
            }

            function cargarMotivos() {
                if (motivosCache !== null) return;
                fetch('@Url.Action("GetMotivosParaModal", "RegistroPreparatoria")')
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        motivosCache = data;
                    })
                    .catch(function () { /* silenciar */ });
            }

            // Abrir modal desde botón de la fila
            document.addEventListener('click', function (e) {
                var btn = e.target.closest('.btn-registrar-paro');
                if (!btn) return;
                paroTpMaq  = btn.getAttribute('data-tp-maq')  || '';
                paroCodMaq = btn.getAttribute('data-cod-maq') || '';
                paroTurno  = btn.getAttribute('data-turno')   || '';
                document.getElementById('paroCabMaquina').textContent = btn.getAttribute('data-maquina') || paroCodMaq;
                paroLista   = [];
                paroEditIdx = -1;
                clearParoFieldErrors();
                hideParoError();
                document.getElementById('paroFechaIni').value    = getLocalDateTimeInputValue();
                document.getElementById('paroMotivoInput').value = '';
                document.getElementById('paroMotivo').value      = '';
                document.getElementById('paroFechaFin').value    = getLocalDateTimeInputValue();
                document.getElementById('paroMotivoDropdown').style.display = 'none';
                document.getElementById('spanBtnParoTexto').textContent = 'Agregar';
                document.getElementById('btnParoCancelarEdicion').style.display = 'none';
                renderTablaParos();
                cargarMotivos();
                // Marcar solo el turno de la preparatoria; desmarcar el resto
                document.querySelectorAll('.turno-filtro-chk').forEach(function (chk) { chk.checked = (chk.value === paroTurno); });
                modalRegistrarParo.show();
                // Cargar paros ya guardados en BD
                cargarParosBD();
            });

            // Combobox de motivo: mostrar dropdown al escribir
            document.getElementById('paroMotivoInput').addEventListener('input', function () {
                filtrarMotivosDropdown(this.value);
            });
            document.getElementById('paroMotivoInput').addEventListener('focus', function () {
                filtrarMotivosDropdown(this.value);
            });
            document.getElementById('paroMotivoInput').addEventListener('blur', function () {
                setTimeout(function () { document.getElementById('paroMotivoDropdown').style.display = 'none'; }, 150);
            });

            // Filtros turno redibujan la tabla
            document.querySelectorAll('.turno-filtro-chk').forEach(function (chk) {
                chk.addEventListener('change', cargarParosBD);
            });

            // Botón Agregar / Actualizar
            document.getElementById('btnParoAgregar').addEventListener('click', function () {
                clearParoFieldErrors();
                hideParoError();
                var fechaIni  = document.getElementById('paroFechaIni').value.trim();
                var motivoCod = document.getElementById('paroMotivo').value.trim();
                var motivoTxt = document.getElementById('paroMotivoInput').value.trim();
                var fechaFin  = document.getElementById('paroFechaFin').value.trim();
                var ok = true;

                // Change 1: bloquear si el último paro no tiene fecha fin
                if (paroEditIdx < 0 && paroLista.length > 0) {
                    var ultimo = paroLista[paroLista.length - 1];
                    if (!ultimo.fechaFin) {
                        showParoError('El último paro registrado no tiene Fecha Fin. Debe completarla antes de agregar uno nuevo.');
                        return;
                    }
                }

                if (!fechaIni) {
                    setParoFieldError('paroFechaIni', 'errParoFechaIni', 'La Fecha Inicio es obligatoria.');
                    ok = false;
                }
                if (!motivoCod) {
                    setParoFieldError('paroMotivoInput', 'errParoMotivo', 'Debe seleccionar un motivo.');
                    ok = false;
                }
                if (!ok) return;

                if (fechaFin) {
                    var dIni = new Date(fechaIni);
                    var dFin = new Date(fechaFin);
                    var ahora = new Date();
                    if (dFin <= dIni) {
                        setParoFieldError('paroFechaFin', 'errParoFechaFin', 'La Fecha Fin debe ser mayor a la Fecha Inicio.');
                        return;
                    }
                    if (dFin > ahora) {
                        setParoFieldError('paroFechaFin', 'errParoFechaFin', 'La Fecha Fin no puede ser mayor a la fecha y hora actual.');
                        return;
                    }
                }

                var esGuardadoExistente = paroEditIdx >= 0 && !!(paroLista[paroEditIdx]?.esGuardado);
                var item;
                if (esGuardadoExistente) {
                    var orig = paroLista[paroEditIdx];
                    item = {
                        fechaIni:         fechaIni,
                        motivo:           motivoCod,
                        motivoDesc:       motivoTxt,
                        fechaFin:         fechaFin || null,
                        esGuardado:       true,
                        esAbierto:        !fechaFin,
                        esModificado:     true,
                        originalFechaIni: orig.originalFechaIni || orig.fechaIni,
                        nuevaFechaIni:    fechaIni,
                        turno:            orig.turno || ''
                    };
                } else {
                    item = { fechaIni: fechaIni, motivo: motivoCod, motivoDesc: motivoTxt, fechaFin: fechaFin || null, esGuardado: false, turno: paroTurno };
                }

                if (paroEditIdx >= 0) {
                    paroLista[paroEditIdx] = item;
                } else {
                    paroLista.push(item);
                }
                resetParoForm();
            });

            // Cancelar edición
            document.getElementById('btnParoCancelarEdicion').addEventListener('click', function () {
                resetParoForm();
            });

            // Editar / eliminar filas de la grilla
            document.getElementById('tablaParosCuerpo').addEventListener('click', function (e) {
                var btnEdit = e.target.closest('.btn-paro-editar');
                var btnDel  = e.target.closest('.btn-paro-eliminar');

                if (btnEdit) {
                    var idx = parseInt(btnEdit.getAttribute('data-idx'));
                    var p   = paroLista[idx];
                    paroEditIdx = idx;
                    document.getElementById('paroFechaIni').value    = (p.fechaIni || '').slice(0, 16);
                    document.getElementById('paroFechaIni').readOnly = false;
                    document.getElementById('paroMotivoInput').value = p.motivoDesc || p.motivo || '';
                    document.getElementById('paroMotivo').value      = p.motivo   || '';
                    document.getElementById('paroFechaFin').value    = (p.fechaFin || '').slice(0, 16);
                    document.getElementById('spanBtnParoTexto').textContent = 'Actualizar';
                    document.getElementById('btnParoCancelarEdicion').style.display = '';
                    clearParoFieldErrors();
                    hideParoError();
                    renderTablaParos();
                }

                if (btnDel) {
                    var idx = parseInt(btnDel.getAttribute('data-idx'));
                    var p   = paroLista[idx];
                    if (p.esGuardado) {
                        pendingDeleteIdx = idx;
                        modalConfirmarEliminarParo.show();
                    } else {
                        if (paroEditIdx === idx) resetParoForm();
                        paroLista.splice(idx, 1);
                        if (paroEditIdx > idx) paroEditIdx--;
                        renderTablaParos();
                    }
                }
            });

            document.getElementById('btnAceptarEliminarParo').addEventListener('click', function () {
                if (pendingDeleteIdx < 0) return;
                var idx = pendingDeleteIdx;
                var p   = paroLista[idx];
                if (!p || !p.esGuardado) { modalConfirmarEliminarParo.hide(); return; }
                modalConfirmarEliminarParo.hide();
                fetch('@Url.Action("EliminarParoBD", "RegistroPreparatoria")', {
                    method:  'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ tpMaq: paroTpMaq, codMaq: paroCodMaq, fechaIni: p.fechaIni })
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    if (d.success) {
                        if (paroEditIdx === idx) resetParoForm(); else if (paroEditIdx > idx) paroEditIdx--;
                        paroLista.splice(idx, 1);
                        pendingDeleteIdx = -1;
                        renderTablaParos();
                    } else {
                        showParoError(d.message || 'Error al eliminar el paro de la base de datos.');
                    }
                })
                .catch(function () {
                    showParoError('Error de red al eliminar el paro. Intente nuevamente.');
                });
            });

            document.getElementById('modalConfirmarEliminarParo').addEventListener('hidden.bs.modal', function () {
                pendingDeleteIdx = -1;
            });

            // Botón Guardar
            document.getElementById('btnParoGuardar').addEventListener('click', function () {
                hideParoError();
                var nuevosParos = paroLista.filter(function (p) { return !p.esGuardado; });
                var parosModif  = paroLista.filter(function (p) { return p.esGuardado && p.esModificado; });
                if (nuevosParos.length === 0 && parosModif.length === 0) {
                    var tieneBD = paroLista.some(function (p) { return p.esGuardado; });
                    showParoError(tieneBD
                        ? 'No hay paros nuevos ni modificaciones para guardar. Agregue un nuevo paro o edite uno existente.'
                        : 'Debe agregar al menos un paro antes de guardar.');
                    return;
                }

                var btn = document.getElementById('btnParoGuardar');
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>Guardando...';

                var payload = {
                    tpMaq:  paroTpMaq,
                    codMaq: paroCodMaq,
                    turno:  paroTurno,
                    paros:  nuevosParos.map(function (p) {
                        return { fechaIni: p.fechaIni, motivo: p.motivo, fechaFin: p.fechaFin || null };
                    }),
                    parosActualizar: parosModif.map(function (p) {
                        return { originalFechaIni: p.originalFechaIni || p.fechaIni, nuevaFechaIni: p.nuevaFechaIni || null, motivo: p.motivo, fechaFin: p.fechaFin || null };
                    })
                };

                fetch('@Url.Action("GuardarParos", "RegistroPreparatoria")', {
                    method:  'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify(payload)
                })
                .then(function (r) { return r.json(); })
                .then(function (d) {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-save me-1"></i>Guardar';
                    if (d.success) {
                        modalRegistrarParo.hide();
                        // Mostrar alerta de éxito reutilizando el sistema existente
                        var alerta = document.createElement('div');
                        alerta.className = 'alert alert-success alert-dismissible fade show mt-2';
                        alerta.innerHTML = '<i class="bi bi-check-circle me-2"></i>' + d.message +
                            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                        document.querySelector('.card.mb-3')?.before(alerta);
                        setTimeout(function () { alerta.remove(); }, 5000);
                    } else {
                        showParoError(d.message || 'Error al guardar los paros.');
                    }
                })
                .catch(function () {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-save me-1"></i>Guardar';
                    showParoError('Error de red al guardar los paros. Intente nuevamente.');
                });
            });
        })();

        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-ver-paros');
            if (!btn) return;
            var tpMaq   = btn.getAttribute('data-tp-maq')  || '';
            var codMaq  = btn.getAttribute('data-cod-maq') || '';
            var maquina = btn.getAttribute('data-maquina') || codMaq;

            document.getElementById('verParosCabMaquina').textContent = maquina;
            document.getElementById('verParosLoading').style.display  = '';
            document.getElementById('verParosContent').style.display  = 'none';
            var modalVerParos = new bootstrap.Modal(document.getElementById('modalVerParos'));
            modalVerParos.show();

            var verParosUrl = '@Url.Action("GetParosPorMaquina", "RegistroPreparatoria")?tpMaq=' + encodeURIComponent(tpMaq) + '&codMaq=' + encodeURIComponent(codMaq) + '&fechaTurno=' + encodeURIComponent(getFechaTurno()) + '&turnos=1&turnos=2&turnos=3&turnos=4&turnos=5';
            fetch(verParosUrl)
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    var tbody = document.getElementById('verParosCuerpo');
                    tbody.innerHTML = '';
                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3"><i class="bi bi-inbox me-1"></i>Sin paros registrados</td></tr>';
                    } else {
                        data.forEach(function (p, i) {
                            var tr = document.createElement('tr');
                            tr.innerHTML =
                                '<td>' + (i + 1) + '</td>' +
                                    '<td>' + escHtml(p.motivoDesc || p.motivo) + '</td>' +
                                    '<td>' + escHtml(getTurnoDesc(p.turno)) + '</td>' +
                                    '<td class="text-nowrap">' + (p.fechaIni ? formatDt(p.fechaIni) : '-') + '</td>' +
                                    '<td class="text-nowrap">' + (p.fechaFin ? formatDt(p.fechaFin) : '<span class="text-muted">-</span>') + '</td>' +
                                    '<td class="text-nowrap">' + diffTiempo(p.fechaIni, p.fechaFin) + '</td>';
                            tbody.appendChild(tr);
                        });
                    }
                    document.getElementById('verParosLoading').style.display = 'none';
                    document.getElementById('verParosContent').style.display = '';
                })
                .catch(function () {
                    document.getElementById('verParosLoading').style.display = 'none';
                    document.getElementById('verParosContent').innerHTML = '<p class="text-danger">Error al cargar los paros.</p>';
                    document.getElementById('verParosContent').style.display = '';
                });
        });

        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-ver-detalle');
            if (!btn) return;
            var id = btn.getAttribute('data-id');

            document.getElementById('modalVerDetalleLoading').style.display = '';
            document.getElementById('modalVerDetalleContent').style.display = 'none';
            document.getElementById('modalVerDetalleError').style.display = 'none';
            modalVerDetalle.show();

            fetch('@Url.Action("GetDetallePreparatoria", "RegistroPreparatoria")?id=' + encodeURIComponent(id))
                .then(function (r) {
                    if (!r.ok) throw new Error('No se pudo obtener el detalle.');
                    return r.json();
                })
                .then(function (d) {
                    document.getElementById('det_receta').textContent        = d.receta || '-';
                    document.getElementById('det_lote').textContent          = d.lote || '-';
                    document.getElementById('det_material').textContent      = d.material || '-';
                    document.getElementById('det_tipoMaquina').textContent   = d.tipoMaquina || '-';
                    document.getElementById('det_maquina').textContent       = d.maquina || '-';
                    document.getElementById('det_titulo').textContent        = d.titulo || '-';
                    document.getElementById('det_fechaInicio').textContent   = d.fechaInicio || '-';
                    var estadoBadgeMap = {
                        '1': '<span class="badge bg-primary"><i class="bi bi-gear-fill me-1"></i>En Proceso</span>',
                        '3': '<span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Terminado</span>',
                        '9': '<span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Anulado</span>'
                    };
                    document.getElementById('det_estado').innerHTML = estadoBadgeMap[d.estadoCodigo] || '<span class="badge bg-secondary">' + escHtml(d.estado || '-') + '</span>';
                    document.getElementById('det_operario').textContent      = d.operario || '-';
                    document.getElementById('det_turno').textContent         = d.turno || '-';
                    document.getElementById('det_pasoManuar').textContent    = d.pasoManuar || '-';
                    document.getElementById('det_grupoPasoManuar').style.display = d.esPabilera ? 'none' : '';

                    // Sección producción vs rollos BATAN
                    var secProduccion = document.getElementById('det_seccionProduccion');
                    var secRollos     = document.getElementById('det_seccionRollos');
                    if (d.esBatan) {
                        secProduccion.style.display = 'none';
                        secRollos.style.display     = '';
                        // Cargar rollos vía AJAX
                        document.getElementById('det_rollosLoading').style.display   = '';
                        document.getElementById('det_tablaRollosCuerpo').innerHTML   = '';
                        document.getElementById('det_rollosTotalNeto').textContent    = '-';
                        fetch('@Url.Action("GetRollosBatan", "RegistroPreparatoria")?id=' + encodeURIComponent(id))
                            .then(function (r) { return r.json(); })
                            .then(function (rollos) {
                                document.getElementById('det_rollosLoading').style.display = 'none';
                                var tbody = document.getElementById('det_tablaRollosCuerpo');
                                if (!rollos || rollos.length === 0) {
                                    tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3"><i class="bi bi-inbox me-1"></i>Sin rollos registrados</td></tr>';
                                    document.getElementById('det_rollosTotalNeto').textContent = '0.00';
                                } else {
                                    var total = 0;
                                    rollos.forEach(function (r, i) {
                                        var diffStr = '-';
                                        if (i > 0 && rollos[i - 1].fechaHora && r.fechaHora) {
                                            var prev = new Date(rollos[i - 1].fechaHora);
                                            var curr = new Date(r.fechaHora);
                                            var diffMs = curr - prev;
                                            if (diffMs >= 0) {
                                                var totalSec = Math.floor(diffMs / 1000);
                                                var hrs  = Math.floor(totalSec / 3600);
                                                var mins = Math.floor((totalSec % 3600) / 60);
                                                var secs = totalSec % 60;
                                                diffStr = hrs + 'hrs. ' + mins + 'min. ' + secs + 'seg.';
                                            }
                                        }
                                        var tr = document.createElement('tr');
                                        tr.innerHTML = '<td>' + (i + 1) + '</td>' +
                                                       '<td class="text-end">' + parseFloat(r.neto).toFixed(2) + '</td>' +
                                                       '<td class="text-end text-muted small">' + diffStr + '</td>';
                                        tbody.appendChild(tr);
                                        total += parseFloat(r.neto) || 0;
                                    });
                                    document.getElementById('det_rollosTotalNeto').textContent = total.toFixed(2);
                                }
                            })
                            .catch(function () {
                                document.getElementById('det_rollosLoading').style.display = 'none';
                                document.getElementById('det_tablaRollosCuerpo').innerHTML = '<tr><td colspan="2" class="text-danger text-center py-2">Error al cargar rollos.</td></tr>';
                            });
                    } else {
                        secProduccion.style.display = '';
                        secRollos.style.display     = 'none';
                        document.getElementById('det_velocidad').textContent      = d.velocidad != null ? d.velocidad : '-';
                        document.getElementById('det_metraje').textContent        = d.metraje != null ? d.metraje : '-';
                        document.getElementById('det_rolloTacho').textContent     = d.rolloTacho != null ? d.rolloTacho : '-';
                        document.getElementById('det_kgNeto').textContent         = d.kgNeto != null ? d.kgNeto : '-';
                        document.getElementById('det_fechaFin').textContent       = d.fechaFin || '-';
                        document.getElementById('det_producTeorico').textContent  = d.producTeorico != null ? d.producTeorico : '-';
                        document.getElementById('det_eficiencTeorico').textContent = d.eficiencTeorico != null ? d.eficiencTeorico : '-';

                        var secPabilera = document.getElementById('det_seccionPabilera');
                        secPabilera.style.display = d.esPabilera ? '' : 'none';
                        if (d.esPabilera) {
                            document.getElementById('det_contadorInicial').textContent = d.contadorInicial != null ? d.contadorInicial : '-';
                            document.getElementById('det_husosInactivas').textContent  = d.husosInactivas != null ? d.husosInactivas : '-';
                            document.getElementById('det_contadorFinal').textContent   = d.contadorFinal != null ? d.contadorFinal : '-';
                            document.getElementById('det_nroParada').textContent       = d.nroParada != null ? d.nroParada : '-';
                        }
                    }

                    document.getElementById('modalVerDetalleLoading').style.display = 'none';
                    document.getElementById('modalVerDetalleContent').style.display = '';
                })
                .catch(function (err) {
                    document.getElementById('modalVerDetalleLoading').style.display = 'none';
                    var errEl = document.getElementById('modalVerDetalleError');
                    errEl.textContent = err.message || 'Error al cargar los datos.';
                    errEl.style.display = '';
                });
        });
    });
</script>
<script>
    // === Modal Agregar Rollo ===
    (function () {
        var rolloTpMaq = '', rolloCodMaq = '', rolloTurno = '', rolloFechaTurno = '';
        var rolloCantRollosActual = 0, rolloTotalNetoActual = 0;
        var modalAgregarRollo = new bootstrap.Modal(document.getElementById('modalAgregarRollo'));

        function actualizarRolloResumen() {
            document.getElementById('rolloCantRollos').textContent = rolloCantRollosActual;
            document.getElementById('rolloTotalNeto').textContent  = rolloTotalNetoActual.toFixed(2);
        }

        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-agregar-rollo');
            if (!btn) return;
            rolloTpMaq            = btn.getAttribute('data-tp-maq')      || '';
            rolloCodMaq           = btn.getAttribute('data-cod-maq')     || '';
            rolloTurno            = btn.getAttribute('data-turno')       || '';
            rolloFechaTurno       = btn.getAttribute('data-fecha-turno') || '';
            rolloCantRollosActual = parseInt(btn.getAttribute('data-cant-rollos') || '0', 10);
            rolloTotalNetoActual  = parseFloat(btn.getAttribute('data-total-neto') || '0');
            document.getElementById('rolloPesoBruto').value = '';
            document.getElementById('rolloPesoNeto').value  = '';
            document.getElementById('rolloAlerta').style.display = 'none';
            document.getElementById('errRolloPesoBruto').style.display = 'none';
            actualizarRolloResumen();
            modalAgregarRollo.show();
        });

        document.getElementById('rolloPesoBruto').addEventListener('input', function () {
            var bruto   = parseFloat(this.value);
            var varilla = 1.2;
            document.getElementById('rolloPesoNeto').value = !isNaN(bruto)
                ? (Math.round((bruto - varilla) * 100) / 100).toFixed(2)
                : '';
        });

        document.getElementById('rolloPesoBruto').addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('btnRolloGuardar').click();
            }
        });

        document.getElementById('modalAgregarRollo').addEventListener('shown.bs.modal', function () {
            document.getElementById('rolloPesoBruto').focus();
        });

        document.getElementById('btnRolloGuardar').addEventListener('click', function () {
            var errDiv    = document.getElementById('errRolloPesoBruto');
            var alerta    = document.getElementById('rolloAlerta');
            var pesoBruto = parseFloat(document.getElementById('rolloPesoBruto').value);
            errDiv.style.display = 'none';
            alerta.style.display = 'none';

            if (isNaN(pesoBruto) || pesoBruto <= 0) {
                errDiv.textContent   = 'Ingrese un peso bruto válido mayor a 0.';
                errDiv.style.display = '';
                return;
            }

            var btn = this;
            btn.disabled  = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>Guardando...';

            fetch('@Url.Action("AgregarRollo", "RegistroPreparatoria")', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    pesoBruto:  pesoBruto,
                    fechaTurno: rolloFechaTurno,
                    turno:      rolloTurno,
                    tpMaq:      rolloTpMaq,
                    codMaq:     rolloCodMaq
                })
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                alerta.className     = 'alert mt-3 ' + (d.success ? 'alert-success' : 'alert-danger');
                alerta.textContent   = d.message;
                alerta.style.display = '';
                if (d.success) {
                    var neto = Math.round((pesoBruto - 1.2) * 100) / 100;
                    rolloCantRollosActual += 1;
                    rolloTotalNetoActual   = Math.round((rolloTotalNetoActual + neto) * 100) / 100;
                    actualizarRolloResumen();
                    document.getElementById('rolloPesoBruto').value = '';
                    document.getElementById('rolloPesoNeto').value  = '';
                    document.getElementById('rolloPesoBruto').focus();
                }
            })
            .catch(function () {
                alerta.className     = 'alert mt-3 alert-danger';
                alerta.textContent   = 'Error al registrar el rollo. Intente nuevamente.';
                alerta.style.display = '';
            })
            .finally(function () {
                btn.disabled  = false;
                btn.innerHTML = '<i class="bi bi-save me-1"></i>Guardar';
            });
        });
    })();
</script>
<script>
    // === Cerrar Preparatoria BATAN ===
    (function () {
        var cerrarBatanId = null;
        var modalCerrarBatan = new bootstrap.Modal(document.getElementById('modalConfirmarCerrarBatan'));

        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.btn-cerrar-batan');
            if (!btn) return;
            cerrarBatanId = btn.getAttribute('data-id');
            modalCerrarBatan.show();
        });

        document.getElementById('btnAceptarCerrarBatan').addEventListener('click', function () {
            if (!cerrarBatanId) return;
            var btn = this;
            btn.disabled  = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status"></span>Cerrando...';

            fetch('@Url.Action("CerrarPreparatoriaBatan", "RegistroPreparatoria")', {
                method:  'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify({ id: parseInt(cerrarBatanId) })
            })
            .then(function (r) { return r.json(); })
            .then(function (d) {
                modalCerrarBatan.hide();
                if (d.success) {
                    location.reload();
                } else {
                    var alerta = document.createElement('div');
                    alerta.className = 'alert alert-danger alert-dismissible fade show mt-2';
                    alerta.innerHTML = '<i class="bi bi-exclamation-circle me-2"></i>' + (d.message || 'Error al cerrar la preparatoria.') +
                        '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                    document.querySelector('.card.mb-3')?.before(alerta);
                    setTimeout(function () { alerta.remove(); }, 6000);
                }
            })
            .catch(function () {
                modalCerrarBatan.hide();
                var alerta = document.createElement('div');
                alerta.className = 'alert alert-danger alert-dismissible fade show mt-2';
                alerta.innerHTML = '<i class="bi bi-exclamation-circle me-2"></i>Error de red al cerrar la preparatoria.' +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
                document.querySelector('.card.mb-3')?.before(alerta);
                setTimeout(function () { alerta.remove(); }, 6000);
            })
            .finally(function () {
                btn.disabled  = false;
                btn.innerHTML = '<i class="bi bi-check-circle me-1"></i>Cerrar Preparatoria';
                cerrarBatanId = null;
            });
        });

        document.getElementById('modalConfirmarCerrarBatan').addEventListener('hidden.bs.modal', function () {
            cerrarBatanId = null;
        });
    })();
</script>
<style>
    .panel-estado-item:hover { background-color: var(--color-bg-light); }
</style>
}

