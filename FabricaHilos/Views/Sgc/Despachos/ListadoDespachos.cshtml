@model IEnumerable<FabricaHilos.Models.Sgc.DespachoListadoDto>

@{
    ViewData["Title"] = "Listado de Despachos";
    string? guia        = ViewBag.Guia        as string;
    string? pedido      = ViewBag.Pedido      as string;
    string? factura     = ViewBag.Factura     as string;
    string? razonSocial = ViewBag.RazonSocial as string;
    string? fechaInicio = ViewBag.FechaInicio as string;
    string? fechaFin    = ViewBag.FechaFin    as string;
    bool gots           = ViewBag.Gots        ?? false;
    bool ocs            = ViewBag.Ocs         ?? false;
    string? navToken    = ViewBag.NavToken    as string;
    int page            = ViewBag.Page        ?? 1;
    int pageSize        = ViewBag.PageSize    ?? 10;
    int totalCount      = ViewBag.TotalCount  ?? 0;
    int totalPages      = ViewBag.TotalPages  ?? 1;

    decimal sumCantidad      = Model.Sum(x => x.Cantidad      ?? 0m);
    decimal sumCantFacturada = Model.Sum(x => x.CantFacturada ?? 0m);
    decimal sumPrecio        = Model.Sum(x => x.Precio        ?? 0m);

    string excelUrl = Url.Action("ExportarDespachosExcel", "Sgc", new { guia, pedido, factura, razonSocial, fechaInicio, fechaFin, gots, ocs }) ?? "#";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item active">Listado de Despachos</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-truck me-2"></i>Listado de Despachos</h4>
    <a href="@excelUrl" class="btn btn-success btn-sm">
        <i class="bi bi-file-earmark-excel me-1"></i>Exportar a Excel
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">Nro. Guía</label>
                <input type="text" name="guia" value="@guia"
                       class="form-control form-control-sm"
                       placeholder="Nro. Guía"
                       style="width: 110px;" />
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">Pedido</label>
                <input type="text" name="pedido" value="@pedido"
                       class="form-control form-control-sm"
                       placeholder="Ej: 87110-4"
                       style="width: 110px;" />
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">Factura</label>
                <input type="text" name="factura" value="@factura"
                       class="form-control form-control-sm"
                       placeholder="Nro. Factura"
                       style="width: 110px;" />
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">RUC / Razón Social</label>
                <input type="text" name="razonSocial" value="@razonSocial"
                       class="form-control form-control-sm"
                       placeholder="RUC o Razón Social"
                       style="width: 200px;" />
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">Fecha Inicio</label>
                <input type="date" name="fechaInicio" value="@fechaInicio"
                       class="form-control form-control-sm"
                       style="width: 145px;" />
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">Fecha Fin</label>
                <input type="date" name="fechaFin" value="@fechaFin"
                       class="form-control form-control-sm"
                       style="width: 145px;" />
            </div>
            <div class="col-auto">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" name="gots" value="true" id="checkGots" @(gots ? "checked" : "") />
                    <label class="form-check-label" for="checkGots">GOTS</label>
                </div>
            </div>
            <div class="col-auto">
                <div class="form-check mt-4">
                    <input class="form-check-input" type="checkbox" name="ocs" value="true" id="checkOcs" @(ocs ? "checked" : "") />
                    <label class="form-check-label" for="checkOcs">OCS</label>
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-search"></i> Buscar
                </button>
            </div>
            @if (!string.IsNullOrEmpty(guia) || !string.IsNullOrEmpty(pedido) || !string.IsNullOrEmpty(factura) || !string.IsNullOrEmpty(razonSocial) || !string.IsNullOrEmpty(fechaInicio) || !string.IsNullOrEmpty(fechaFin) || gots || ocs)
            {
                <div class="col-auto">
                    <a asp-action="ListadoDespachos" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </a>
                </div>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center">#</th>
                        <th>RAZON SOCIAL</th>
                        <th class="text-center">OC</th>
                        <th class="text-center">PEDIDO</th>
                        <th class="text-center">FACTURA</th>
                        <th class="text-center">FECHA.DOC</th>
                        <th>ARTICULO</th>
                        <th class="text-end">CANTIDAD</th>
                        <th class="text-end">CANT. FACT.</th>
                        <th class="text-end">PRECIO</th>
                        <th class="text-center" style="width: 120px;">GUIA</th>
                        <th>OBS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@item.Correlativo</td>
                            <td>@(item.RazonSocial ?? "-")</td>
                            <td class="text-center">@(item.Oc ?? "-")</td>
                            <td class="text-center">@(item.Pedido ?? "-")</td>
                            <td class="text-start" style="background-color: #e3f2fd;">
                                @if (!string.IsNullOrEmpty(item.Factura) && !string.IsNullOrEmpty(item.FacturaTipo) && !string.IsNullOrEmpty(item.FacturaSerie))
                                {
                                    <a asp-controller="Sgc"
                                       asp-action="DescargarFacturaPdf"
                                       asp-route-tipo="@item.FacturaTipo"
                                       asp-route-serie="@item.FacturaSerie"
                                       asp-route-numero="@item.Factura"
                                       onclick="descargarPdf(event, this)"
                                       class="text-danger me-2"
                                       title="Descargar PDF de Factura">
                                        <i class="bi bi-file-earmark-pdf-fill" style="font-size: 1.1rem;"></i>
                                    </a>
                                }
                                @item.Factura
                            </td>
                            <td class="text-center">@(item.FechaDoc.HasValue ? item.FechaDoc.Value.ToString("dd/MM/yyyy") : "-")</td>
                            <td>@(item.Articulo ?? "-")</td>
                            <td class="text-end">@(item.Cantidad.HasValue ? item.Cantidad.Value.ToString("N2") : "-")</td>
                            <td class="text-end">@(item.CantFacturada.HasValue ? item.CantFacturada.Value.ToString("N2") : "-")</td>
                            <td class="text-end">@(item.Precio.HasValue ? item.Precio.Value.ToString("N2") : "-")</td>
                            <td class="text-start" style="width: 120px;">
                                @if (item.Guia.HasValue && !string.IsNullOrEmpty(item.GuiaCodAlm) && !string.IsNullOrEmpty(item.GuiaTpTransac) && item.GuiaSerie.HasValue)
                                {
                                    <a asp-controller="Sgc"
                                       asp-action="DescargarGuiaPdf"
                                       asp-route-codAlm="@item.GuiaCodAlm"
                                       asp-route-tpTransac="@item.GuiaTpTransac"
                                       asp-route-serie="@item.GuiaSerie"
                                       asp-route-numero="@item.Guia"
                                       onclick="descargarPdf(event, this)"
                                       class="text-danger me-2"
                                       title="Descargar PDF de Guía">
                                        <i class="bi bi-file-earmark-pdf-fill" style="font-size: 1.1rem;"></i>
                                    </a>
                                }
                                @(item.Guia.HasValue ? item.Guia.Value.ToString() : string.Empty)
                            </td>
                            <td>@(item.Obs ?? "-")</td>
                        </tr>
                    }
                    @if (Model.Any())
                    {
                        <tr class="table-secondary fw-semibold border-top">
                            <td colspan="7" class="text-end pe-3">Totales:</td>
                            <td class="text-end">@sumCantidad.ToString("N2")</td>
                            <td class="text-end">@sumCantFacturada.ToString("N2")</td>
                            <td class="text-end">@sumPrecio.ToString("N2")</td>
                            <td colspan="2"></td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="12" class="text-center text-muted py-4">
                                <i class="bi bi-inbox me-2"></i>No se encontraron registros.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">
            @if (page > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="ListadoDespachos" asp-route-t="@navToken" asp-route-page="@(page - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link"><i class="bi bi-chevron-left"></i></span></li>
            }

            @{
                int startPage = Math.Max(1, page - 2);
                int endPage = Math.Min(totalPages, page + 2);

                if (startPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="ListadoDespachos" asp-route-t="@navToken" asp-route-page="1">1</a>
                    </li>
                    if (startPage > 2)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                }

                for (int i = startPage; i <= endPage; i++)
                {
                    if (i == page)
                    {
                        <li class="page-item active"><span class="page-link">@i</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="ListadoDespachos" asp-route-t="@navToken" asp-route-page="@i">@i</a>
                        </li>
                    }
                }

                if (endPage < totalPages)
                {
                    if (endPage < totalPages - 1)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    <li class="page-item">
                        <a class="page-link" asp-action="ListadoDespachos" asp-route-t="@navToken" asp-route-page="@totalPages">@totalPages</a>
                    </li>
                }
            }

            @if (page < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-action="ListadoDespachos" asp-route-t="@navToken" asp-route-page="@(page + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link"><i class="bi bi-chevron-right"></i></span></li>
            }
        </ul>
    </nav>

    <div class="text-center text-muted small mt-2">
        Mostrando página @(page) de @(totalPages) (@(totalCount) registros totales)
    </div>
}

<!-- Modal para mensajes de PDF -->
<div class="modal fade" id="pdfModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div id="pdfModalHeader" class="modal-header bg-warning text-dark">
                <h5 class="modal-title">
                    <i id="pdfModalIcono" class="bi bi-exclamation-triangle-fill me-2"></i>
                    <span id="pdfModalTitulo">Advertencia</span>
                </h5>
                <button id="pdfModalCloseBtn" type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="pdfModalMensaje" class="mb-0" style="white-space: pre-line;"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function descargarPdf(event, anchor) {
        event.preventDefault();
        try {
            const resp = await fetch(anchor.href, { credentials: 'include' });
            const ct = resp.headers.get('Content-Type') ?? '';
            if (ct.includes('application/json')) {
                const data = await resp.json();
                mostrarPdfModal(data.tipo, data.mensaje);
            } else {
                const blob = await resp.blob();
                const url  = URL.createObjectURL(blob);
                window.open(url, '_blank');
                setTimeout(() => URL.revokeObjectURL(url), 60000);
            }
        } catch {
            mostrarPdfModal('Error', 'Ocurrió un error inesperado al obtener el PDF.');
        }
    }

    function mostrarPdfModal(tipo, mensaje) {
        const esError = tipo === 'Error';
        document.getElementById('pdfModalHeader').className =
            'modal-header ' + (esError ? 'bg-danger text-white' : 'bg-warning text-dark');
        const closeBtn = document.getElementById('pdfModalCloseBtn');
        closeBtn.className = 'btn-close' + (esError ? ' btn-close-white' : '');
        document.getElementById('pdfModalIcono').className =
            'bi me-2 ' + (esError ? 'bi-x-circle-fill' : 'bi-exclamation-triangle-fill');
        document.getElementById('pdfModalTitulo').textContent = tipo;
        document.getElementById('pdfModalMensaje').textContent = mensaje;
        bootstrap.Modal.getOrCreateInstance(document.getElementById('pdfModal')).show();
    }
</script>
}
