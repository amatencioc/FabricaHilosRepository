@model IEnumerable<FabricaHilos.Models.Sgc.PedidoSgcDto>

@{
    ViewData["Title"] = "Pedidos";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item active">Pedidos</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-cart-check me-2"></i>Pedidos</h4>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap align-items-center">
            <input type="text" name="buscar" value="@ViewBag.Buscar"
                   class="form-control form-control-sm"
                   placeholder="Buscar por nombre, RUC o N° pedido..."
                   style="max-width: 280px;" />
            <div class="d-flex align-items-center gap-1">
                <label class="form-label mb-0 text-nowrap small text-muted">Despacho desde:</label>
                <input type="date" name="fechaInicio" value="@ViewBag.FechaInicio"
                       class="form-control form-control-sm" style="max-width: 155px;" />
            </div>
            <div class="d-flex align-items-center gap-1">
                <label class="form-label mb-0 text-nowrap small text-muted">hasta:</label>
                <input type="date" name="fechaFin" value="@ViewBag.FechaFin"
                       class="form-control form-control-sm" style="max-width: 155px;" />
            </div>
            <input type="hidden" name="page" id="hiddenPage" value="@(ViewBag.Page ?? 1)" />
            <button type="submit" class="btn btn-sm btn-outline-primary" onclick="document.getElementById('hiddenPage').value='1';">
                <i class="bi bi-search"></i> Buscar
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.Buscar as string) || !string.IsNullOrEmpty(ViewBag.FechaInicio as string) || !string.IsNullOrEmpty(ViewBag.FechaFin as string))
            {
                <a asp-action="Pedidos" class="btn btn-sm btn-outline-secondary">Limpiar</a>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center">Serie</th>
                        <th class="text-center">N° Pedido</th>
                        <th class="text-center">RUC</th>
                        <th class="text-center">Cliente</th>
                        <th class="text-center">Moneda</th>
                        <th class="text-center">T. Pedido</th>
                        <th class="text-center">T. Facturado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@item.Serie</td>
                            <td class="fw-semibold text-center">@item.NumPed</td>
                            <td>@(item.Ruc ?? "-")</td>
                            <td>@(item.Nombre ?? item.CodCliente ?? "-")</td>
                            <td class="text-center">@(item.Moneda == "D" ? "Dólares ($)" : item.Moneda == "S" ? "Soles (S/)" : (item.Moneda ?? "-"))</td>
                            <td class="text-end">@(item.TotalPedido?.ToString("N2") ?? "-")</td>
                            <td class="text-end">@(item.TotalFacturado?.ToString("N2") ?? "-")</td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                @if (item.TieneDetalle)
                                {
                                    <a asp-action="DetallePedido"
                                      asp-route-serie="@item.Serie"
                                      asp-route-numPed="@item.NumPed"
                                      asp-route-buscar="@ViewBag.Buscar"
                                      asp-route-fechaInicio="@ViewBag.FechaInicio"
                                      asp-route-fechaFin="@ViewBag.FechaFin"
                                      class="btn btn-sm btn-outline-primary btn-accion"
                                      title="Ver detalle del pedido">
                                        <i class="bi bi-list-ul"></i> Detalle
                                    </a>
                                }
                                @if (item.TienePacking)
                                {
                                    <a asp-action="Packing"
                                      asp-route-pedSerie="@item.Serie"
                                      asp-route-numPed="@item.NumPed"
                                      asp-route-buscar="@ViewBag.Buscar"
                                      asp-route-fechaInicio="@ViewBag.FechaInicio"
                                      asp-route-fechaFin="@ViewBag.FechaFin"
                                      class="btn btn-sm btn-outline-warning btn-accion"
                                      title="Ver packing">
                                        <i class="bi bi-box-seam"></i> Packing
                                    </a>
                                }
                                </div>
                            </td>
                        </tr>
                    }
                    @if ((ViewBag.TieneFiltroPedido as bool?) == true && Model.Any())
                    {
                        decimal sumPed = (decimal)(ViewBag.SumTotalPedido ?? 0m);
                        decimal sumFac = (decimal)(ViewBag.SumTotalFacturado ?? 0m);
                        <tr class="table-secondary fw-semibold border-top">
                            <td colspan="5" class="text-end pe-3">Totales:</td>
                            <td class="text-end">@sumPed.ToString("N2")</td>
                            <td class="text-end">@sumFac.ToString("N2")</td>
                            <td></td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-inbox me-2"></i>No se encontraron pedidos.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@{
    int currentPage = ViewBag.Page       != null ? Convert.ToInt32(ViewBag.Page)       : 1;
    int totalPages  = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
    int totalCount  = ViewBag.TotalCount != null ? Convert.ToInt32(ViewBag.TotalCount) : 0;
    int pgSize      = ViewBag.PageSize   != null ? Convert.ToInt32(ViewBag.PageSize)   : 10;
    int startItem   = totalCount == 0 ? 0 : (currentPage - 1) * pgSize + 1;
    int endItem     = Math.Min(currentPage * pgSize, totalCount);
}
<div class="d-flex justify-content-between align-items-center mt-2 px-1">
    <small class="text-muted">
        @(totalCount == 0 ? "Sin registros" : $"Mostrando {startItem}\u2013{endItem} de {totalCount} pedidos")
    </small>
    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button type="button" class="page-link btn-pagina" data-page="@(currentPage - 1)"><i class="bi bi-chevron-left"></i></button>
                </li>
                @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
                {
                    <li class="page-item @(pg == currentPage ? "active" : "")">
                        <button type="button" class="page-link btn-pagina" data-page="@pg">@pg</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button type="button" class="page-link btn-pagina" data-page="@(currentPage + 1)"><i class="bi bi-chevron-right"></i></button>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {
<script>
    document.querySelectorAll('.btn-pagina').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var li = this.closest('.page-item');
            if (li && li.classList.contains('disabled')) return;
            var p = parseInt(this.getAttribute('data-page'));
            if (isNaN(p)) return;
            document.getElementById('hiddenPage').value = p;
            document.querySelector('form[method="get"]').submit();
        });
    });
</script>
}
