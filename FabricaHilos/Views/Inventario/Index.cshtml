@{
    ViewData["Title"] = "Inventario";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Inventario</li>
}

<h4 class="section-title"><i class="bi bi-box-seam me-2"></i>Módulo de Inventario</h4>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card card-dashboard h-100">
            <div class="card-body text-center p-5">
                <i class="bi bi-archive display-4 text-primary mb-3"></i>
                <h5 class="fw-bold">Materia Prima</h5>
                <p class="text-muted">Gestión de materias primas, stock y proveedores.</p>
                <a asp-controller="Inventario" asp-action="MateriaPrima" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Materia Prima
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-dashboard h-100">
            <div class="card-body text-center p-5">
                <i class="bi bi-boxes display-4 text-success mb-3"></i>
                <h5 class="fw-bold">Producto Terminado</h5>
                <p class="text-muted">Control de hilos terminados, precios y stock.</p>
                <a asp-controller="Inventario" asp-action="ProductoTerminado" class="btn btn-success">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Productos
                </a>
            </div>
        </div>
    </div>
</div>
