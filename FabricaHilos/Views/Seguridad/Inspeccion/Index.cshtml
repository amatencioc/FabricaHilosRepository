@model IEnumerable<FabricaHilos.Services.Seguridad.Inspeccion.InspeccionListDto>

@{
    ViewData["Title"] = "Inspecciones de Seguridad";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Seguridad</li>
    <li class="breadcrumb-item active">Inspecciones</li>
}

<style>
    .mobile-card {
        border-left: 4px solid var(--color-primary, #1B4D3E);
        margin-bottom: 1rem;
    }
    .mobile-card-header {
        background-color: var(--color-primary, #1B4D3E);
        color: white;
        padding: 0.75rem 1rem;
        border-radius: 0.25rem 0.25rem 0 0;
    }
    .fab-button {
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background-color: var(--color-primary, #1B4D3E);
        color: white;
        border: none;
        box-shadow: var(--shadow-md);
        font-size: 24px;
        z-index: 1000;
    }
    .filter-panel {
        background: var(--color-bg-light, #f8f9fa);
        border-radius: 0.5rem;
        padding: 1rem;
        margin-bottom: 1rem;
    }
    .info-badge {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
        font-size: 0.875rem;
        font-weight: 500;
    }
</style>

<div class="container-fluid px-2 px-md-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">
            <i class="bi bi-shield-check me-2"></i>Inspecciones
        </h5>
    </div>

    <!-- Filtros -->
    <div class="filter-panel">
        <form method="get" class="row g-2">
            <div class="col-12 col-md-6">
                <input type="text" name="buscar" value="@ViewBag.Buscar" 
                       class="form-control" 
                       placeholder="Buscar por centro de costo o nombre..." />
            </div>
            <div class="col-12 col-md-4">
                <select name="tipo" class="form-select">
                    <option value="">Todos los tipos</option>
                    <option value="P" selected="@(ViewBag.TipoFiltro == "P")">📋 Planeada</option>
                    <option value="N" selected="@(ViewBag.TipoFiltro == "N")">⚡ No Planeada</option>
                </select>
            </div>
            <div class="col-12 col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Filtrar
                </button>
            </div>
        </form>
        @if (!string.IsNullOrEmpty(ViewBag.Buscar as string) || !string.IsNullOrEmpty(ViewBag.TipoFiltro as string))
        {
            <div class="mt-2">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x-circle"></i> Limpiar
                </a>
            </div>
        }
    </div>

    <!-- Vista móvil (cards) -->
    <div class="d-md-none">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="card mobile-card">
                    <div class="mobile-card-header">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold">
                                <i class="bi bi-hash"></i>@item.Numero
                            </span>
                            <span>
                                @if (item.Tipo == "P")
                                {
                                    <span class="badge bg-light text-dark">📋 Planeada</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">⚡ No Planeada</span>
                                }
                            </span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-2">
                            <small class="text-muted">
                                <i class="bi bi-calendar3"></i> @item.Fecha.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>

                        <div class="mb-2">
                            <strong>Centro Costo:</strong><br/>
                            @item.NombreCentroCosto
                        </div>

                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <small class="text-muted d-block">Resp. Inspección</small>
                                <strong class="small">@item.NombreRespInspeccion</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">Resp. Área</small>
                                <strong class="small">@item.NombreRespArea</strong>
                            </div>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-6 text-center">
                                <div class="info-badge @(string.IsNullOrEmpty(item.UbicaFotoH) ? "bg-light" : "bg-success text-white")">
                                    <i class="bi bi-@(string.IsNullOrEmpty(item.UbicaFotoH) ? "x-circle" : "camera-fill")"></i>
                                    Hallazgo (H)
                                </div>
                                @if (!string.IsNullOrEmpty(item.UbicaFotoH))
                                {
                                    <div><small class="text-muted">@item.FechaFotoH?.ToString("dd/MM/yy")</small></div>
                                }
                            </div>
                            <div class="col-6 text-center">
                                <div class="info-badge @(item.TieneAccionCorrectiva ? "bg-success text-white" : "bg-light")">
                                    <i class="bi bi-@(item.TieneAccionCorrectiva ? "check-circle-fill" : "clock")"></i>
                                    AC
                                </div>
                                @if (item.TieneAccionCorrectiva)
                                {
                                    <div><small class="text-muted">@item.FechaFotoAc?.ToString("dd/MM/yy")</small></div>
                                }
                            </div>
                        </div>

                        @if (!item.TieneAccionCorrectiva)
                        {
                            <a asp-action="AccionCorrectiva" asp-route-numero="@item.Numero" 
                               class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-file-earmark-plus"></i> Agregar Acción Correctiva
                            </a>
                        }
                        else
                        {
                            <div class="text-center text-success">
                                <i class="bi bi-check-circle-fill"></i> <strong>Completado</strong>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                <p class="text-muted mt-3">No hay inspecciones registradas</p>
            </div>
        }
    </div>

    <!-- Vista desktop (tabla) -->
    <div class="d-none d-md-block">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>N°</th>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Centro Costo</th>
                                <th>Resp. Inspección</th>
                                <th>Resp. Área</th>
                                <th class="text-center">H</th>
                                <th class="text-center">AC</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="fw-semibold">@item.Numero</td>
                                        <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @if (item.Tipo == "P")
                                            {
                                                <span class="badge bg-info">Planeada</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">No Planeada</span>
                                            }
                                        </td>
                                        <td>@item.NombreCentroCosto</td>
                                        <td>@item.NombreRespInspeccion</td>
                                        <td>@item.NombreRespArea</td>
                                        <td class="text-center">
                                            @if (!string.IsNullOrEmpty(item.UbicaFotoH))
                                            {
                                                <i class="bi bi-camera-fill text-success"></i>
                                                <div><small class="text-muted">@item.FechaFotoH?.ToString("dd/MM/yy")</small></div>
                                            }
                                            else
                                            {
                                                <i class="bi bi-x-circle text-muted"></i>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (item.TieneAccionCorrectiva)
                                            {
                                                <i class="bi bi-check-circle-fill text-success"></i>
                                                <div><small class="text-muted">@item.FechaFotoAc?.ToString("dd/MM/yy")</small></div>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Pendiente</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!item.TieneAccionCorrectiva)
                                            {
                                                <a asp-action="AccionCorrectiva" asp-route-numero="@item.Numero" 
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-file-earmark-plus"></i> AC
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="text-success"><i class="bi bi-check-lg"></i></span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        No se encontraron inspecciones
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Botón flotante para agregar (móvil) -->
    <a asp-action="Crear" class="fab-button d-md-none" title="Nuevo Hallazgo">
        <i class="bi bi-plus-lg"></i>
    </a>

    <!-- Botón normal para agregar (desktop) -->
    <div class="d-none d-md-block mt-3">
        <a asp-action="Crear" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Hallazgo
        </a>
    </div>

    <div class="mt-3">
        <small class="text-muted">
            <i class="bi bi-info-circle me-1"></i>
            <strong>H:</strong> Hallazgo | <strong>AC:</strong> Acción Correctiva
        </small>
    </div>
</div>
