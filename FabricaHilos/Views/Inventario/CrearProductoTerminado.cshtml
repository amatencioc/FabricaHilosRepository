@model FabricaHilos.Models.Inventario.ProductoTerminado

@{
    ViewData["Title"] = "Nuevo Producto Terminado";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Inventario" asp-action="Index">Inventario</a></li>
    <li class="breadcrumb-item"><a asp-action="ProductoTerminado">Productos</a></li>
    <li class="breadcrumb-item active">Nuevo</li>
}

<h4 class="section-title"><i class="bi bi-plus-circle me-2"></i>Nuevo Producto Terminado</h4>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="CrearProductoTerminado" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label fw-semibold"></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Tipo" class="form-label fw-semibold"></label>
                            <select asp-for="Tipo" class="form-select">
                                <option value="">-- Seleccionar --</option>
                                <option>Hilo de Algodón</option>
                                <option>Hilo Sintético</option>
                                <option>Hilo de Lana</option>
                                <option>Hilo Mixto</option>
                                <option>Otro</option>
                            </select>
                            <span asp-validation-for="Tipo" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Color" class="form-label fw-semibold"></label>
                            <input asp-for="Color" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Calibre" class="form-label fw-semibold"></label>
                            <input asp-for="Calibre" class="form-control" placeholder="ej: Ne 30/1" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Unidad" class="form-label fw-semibold"></label>
                            <select asp-for="Unidad" class="form-select">
                                <option value="">-- Seleccionar --</option>
                                <option>kg</option>
                                <option>cono</option>
                                <option>rollo</option>
                                <option>unid</option>
                            </select>
                            <span asp-validation-for="Unidad" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Cantidad" class="form-label fw-semibold"></label>
                            <input asp-for="Cantidad" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="Cantidad" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PrecioUnitario" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">S/</span>
                                <input asp-for="PrecioUnitario" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="PrecioUnitario" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                            <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-action="ProductoTerminado" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
