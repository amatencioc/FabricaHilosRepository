@model IEnumerable<FabricaHilos.Models.Facturacion.FhLcDocumento>

@{
    ViewData["Title"] = "Lista de Documentos";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="RegistroPreparatoria" asp-action="Index">Inicio</a></li>
    <li class="breadcrumb-item"><a asp-controller="Facturacion" asp-action="Index">Facturación</a></li>
    <li class="breadcrumb-item active">Lista de Documentos</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-list-ul me-2"></i>Documentos Importados</h4>
    <a asp-action="ImportarFacturas" class="btn btn-primary btn-sm">
        <i class="bi bi-upload me-1"></i> Importar Nuevo
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>No hay documentos registrados aún.
        <a asp-action="ImportarFacturas" class="alert-link ms-1">Importar el primero</a>.
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>N° Documento</th>
                            <th>Tipo</th>
                            <th>Emisor</th>
                            <th>Fecha Emisión</th>
                            <th>Moneda</th>
                            <th class="text-end">Total a Pagar</th>
                            <th>Estado</th>
                            <th>Confianza</th>
                            <th>Procesado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model)
                        {
                            <tr>
                                <td><strong>@(doc.NumeroDocumento ?? doc.NombreArchivo)</strong></td>
                                <td>@doc.TipoDocumento</td>
                                <td>
                                    <div>@doc.RazonSocialEmisor</div>
                                    <small class="text-muted">@doc.RucEmisor</small>
                                </td>
                                <td>@doc.FechaEmision?.ToString("dd/MM/yyyy")</td>
                                <td>@doc.Moneda</td>
                                <td class="text-end fw-bold">@doc.TotalPagar?.ToString("N2")</td>
                                <td>
                                    <span class="badge @(doc.Estado == "PENDIENTE" ? "bg-warning text-dark" : "bg-success")">
                                        @doc.Estado
                                    </span>
                                </td>
                                <td>
                                    @{
                                        int pct = (int)(doc.Confianza * 100);
                                        string bc = pct >= 80 ? "bg-success" : pct >= 50 ? "bg-warning text-dark" : "bg-danger";
                                    }
                                    <span class="badge @bc">@pct%</span>
                                </td>
                                <td><small class="text-muted">@doc.FechaProcesamiento.ToString("dd/MM/yyyy HH:mm")</small></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
