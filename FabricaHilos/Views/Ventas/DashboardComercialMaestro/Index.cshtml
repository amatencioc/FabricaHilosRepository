@{
    ViewData["Title"] = "Dashboard Comercial Maestro";
}

@section Styles {
<style>
    .chart-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.08);
        height: 100%;
        background: #f5f5f2;
    }
    .chart-card .card-body {
        background: #f0f0ec;
        border-radius: 0 0 12px 12px;
    }
    .chart-card .card-header {
        background: transparent;
        color: #1B4D3E;
        font-weight: 600;
        border-bottom: 1px solid #e0e0e0;
        border-radius: 12px 12px 0 0 !important;
    }
    .chart-spinner {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,.75);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        z-index: 10;
    }
    .filter-bar {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        padding: .85rem 1.25rem;
        margin-bottom: 1.4rem;
    }
    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1B4D3E;
        margin: 1.2rem 0 .4rem;
        border-left: 4px solid #1B4D3E;
        padding-left: .5rem;
    }
    .report-desc {
        font-size: .78rem;
        color: #637381;
        margin: 0 0 .9rem .65rem;
        line-height: 1.55;
    }
    .year-check-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .5rem;
        margin-top: .6rem;
        padding-top: .6rem;
        border-top: 1px solid #e9ecef;
    }
    .year-check-bar .form-check-input:checked {
        background-color: #1B4D3E;
        border-color: #1B4D3E;
    }
</style>
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Ventas" asp-action="Index">Ventas</a></li>
    <li class="breadcrumb-item active">Dashboard Comercial Maestro</li>
}

<!-- ── Filtros ─────────────────────────────────────────── -->
<div class="filter-bar">
    <div class="d-flex flex-wrap align-items-end gap-3">
        <div>
            <label class="form-label mb-1 small fw-semibold">Fecha Inicio</label>
            <input type="date" id="fechaInicio" class="form-control form-control-sm" style="min-width:135px">
        </div>
        <div>
            <label class="form-label mb-1 small fw-semibold">Fecha Fin</label>
            <input type="date" id="fechaFin" class="form-control form-control-sm" style="min-width:135px">
        </div>
        <div>
            <label class="form-label mb-1 small fw-semibold">Moneda</label>
            <select id="moneda" class="form-select form-select-sm" style="min-width:110px">
                <option value="D" selected>Dólares (USD)</option>
                <option value="S">Soles (PEN)</option>
            </select>
        </div>
        <button class="btn btn-sm btn-success" onclick="loadAll()">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
        <button class="btn btn-sm btn-outline-secondary" onclick="clearFilters()">
            <i class="bi bi-x-circle me-1"></i>Limpiar
        </button>
    </div>
</div>

<!-- ── Sección 1: Cartera por Asesor ───────────────── -->
<div class="section-title"><i class="bi bi-briefcase me-1"></i>Cartera por Asesor</div>
<p class="report-desc">Venta total (S/ o USD) y producción en kilogramos por asesor, con porcentaje de participación.</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div class="card-header small">Cartera por Asesor — Venta, Producción y % Participación</div>
            <div class="card-body" style="height:420px"><canvas id="chartCartera"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 2: Top 3 Clientes por Asesor (Importe) ── -->
<div class="section-title"><i class="bi bi-currency-dollar me-1"></i>Resumen por Asesor y Cliente (Importe) — TOP 3</div>
<p class="report-desc">Los <strong>3 clientes con mayor facturación</strong> de cada asesor en el período.</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerTopImporte" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Top 3 Clientes por Asesor (Importe)</div>
            <div class="card-body" style="min-height:420px"><canvas id="chartTopImporte"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 3: Top 3 Clientes por Asesor (Kilos) ── -->
<div class="section-title"><i class="bi bi-box-seam me-1"></i>Resumen por Asesor y Cliente (Kilos) — TOP 3</div>
<p class="report-desc">Los <strong>3 clientes con mayor volumen en kilogramos</strong> de cada asesor en el período.</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerTopKg" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Top 3 Clientes por Asesor (Kilos)</div>
            <div class="card-body" style="min-height:420px"><canvas id="chartTopKg"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 4: Total y % de Clientes por Asesor ─── -->
<div class="section-title"><i class="bi bi-pie-chart me-1"></i>¿Cómo se distribuyen los clientes entre asesores?</div>
<p class="report-desc">Cantidad y porcentaje de clientes por asesor. <strong>Haga clic en un sector</strong> para ver el detalle.</p>
<div class="row g-3 mb-3">
    <div class="col-lg-5">
        <div class="card chart-card position-relative">
            <div class="card-header small d-flex justify-content-between align-items-center">
                <span>Total de Clientes por Asesor</span>
                <button class="btn btn-sm btn-outline-success py-0" onclick="exportarTodosClientesExcel()"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
            </div>
            <div class="card-body" style="height:380px"><canvas id="chartClientesPie"></canvas></div>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="card chart-card position-relative">
            <div class="card-header small">% de Clientes por Asesor</div>
            <div class="card-body" style="height:380px"><canvas id="chartClientesPct"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Detalle: Clientes del Asesor ──────────────────── -->
<div id="panelClientesAsesor" style="display:none" class="mb-4">
    <div class="card chart-card">
        <div class="card-header d-flex justify-content-between align-items-center small">
            <span><i class="bi bi-list-ul me-1"></i>Clientes del Asesor — <strong id="lblAsesorDetalle"></strong></span>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-success py-0" onclick="exportarClientesAsesorExcel()"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                <button class="btn btn-sm btn-outline-secondary py-0" onclick="cerrarDetalleClientes()"><i class="bi bi-x-circle me-1"></i>Cerrar</button>
            </div>
        </div>
        <div class="card-body p-0">
            <div id="spinnerClientesAsesor" class="chart-spinner" style="display:none"><div class="spinner-border text-success"></div></div>
            <div class="table-responsive" style="max-height:420px; overflow-y:auto;">
                <table class="table table-sm table-hover table-striped table-corporate mb-0" id="tablaClientesAsesor">
                    <thead class="sticky-top">
                        <tr>
                            <th style="width:36px">#</th>
                            <th>RUC</th>
                            <th>Razón Social</th>
                            <th>Giro</th>
                            <th class="text-end">N° Docs</th>
                            <th class="text-end">Kilos</th>
                            <th class="text-end">Importe</th>
                            <th class="text-end">IGV</th>
                            <th class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody id="bodyClientesAsesor"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 5: Ranking y Participación por Asesor ── -->
<div class="section-title"><i class="bi bi-trophy me-1"></i>¿Quién vendió más y qué porcentaje representa?</div>
<p class="report-desc">Ranking de asesores por importe total y su participación porcentual en las ventas del período.</p>
<div class="row g-3 mb-3">
    <div class="col-lg-7">
        <div class="card chart-card position-relative">
            <div class="card-header small">Ranking de Asesores (Importe Total)</div>
            <div class="card-body" style="height:380px"><canvas id="chartRanking"></canvas></div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card chart-card position-relative">
            <div class="card-header small">Participación por Asesor (%)</div>
            <div class="card-body" style="height:380px"><canvas id="chartParticipacion"></canvas></div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/chartjs-plugin-datalabels/dist/chartjs-plugin-datalabels.min.js" asp-append-version="true"></script>
<script src="~/js/dashboard-comercial-maestro-export.js" asp-append-version="true"></script>
<script>
(function () {
    'use strict';

    /* ── Registrar plugin datalabels ───────────────── */
    if (typeof ChartDataLabels !== 'undefined') Chart.register(ChartDataLabels);

    /* ── Fuente global ─────────────────────────────── */
    Chart.defaults.font.family = "'Segoe UI', 'Helvetica Neue', Arial, sans-serif";
    Chart.defaults.font.size   = 12;
    Chart.defaults.color       = '#374151';

    /* ── Paleta ────────────────────────────────────── */
    const COLORS = [
        '#1B4D3E','#1565C0','#2e7d32','#e65100','#6a1b9a',
        '#00838f','#c62828','#4e342e','#37474f','#f9a825',
        '#00695c','#ad1457','#283593','#ef6c00','#2e7d5e'
    ];

    /* ── Formato números ───────────────────────────── */
    const fmtPE = new Intl.NumberFormat('es-PE', { minimumFractionDigits: 2 });
    const fmt   = n => fmtPE.format(n ?? 0);

    /* ── Instancias de charts ──────────────────────── */
    const charts = {};
    function destroyChart(k) { if (charts[k]) { charts[k].destroy(); delete charts[k]; } }

    /* ── Toast ─────────────────────────────────────── */
    function showToast(msg, type) {
        type = type || 'danger';
        let c = document.getElementById('toastContainer');
        if (!c) {
            c = document.createElement('div');
            c.id = 'toastContainer';
            c.style.cssText = 'position:fixed;top:1rem;right:1rem;z-index:9999;';
            document.body.appendChild(c);
        }
        const t = document.createElement('div');
        t.className = 'alert alert-' + type + ' alert-dismissible fade show shadow';
        t.style.cssText = 'min-width:300px;font-size:.85rem;margin-bottom:.5rem;';
        t.innerHTML = msg + '<button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>';
        c.appendChild(t);
        setTimeout(function() { if (t.parentNode) t.remove(); }, 6000);
    }

    /* ── Fechas por defecto ────────────────────────── */
    function setDefaultDates() {
        var hoy = new Date();
        var ini = new Date(hoy.getFullYear(), 0, 1);
        var toISO = function(d) { return d.toISOString().slice(0, 10); };
        document.getElementById('fechaInicio').value = toISO(ini);
        document.getElementById('fechaFin').value    = toISO(hoy);
    }

    /* ── Parámetros ────────────────────────────────── */
    function buildParams() {
        var fi  = document.getElementById('fechaInicio').value;
        var ff  = document.getElementById('fechaFin').value;
        var mon = document.getElementById('moneda').value;
        var p   = new URLSearchParams();
        if (fi)  p.set('fechaInicio', fi);
        if (ff)  p.set('fechaFin',    ff);
        if (mon) p.set('moneda',      mon);
        return p;
    }
    window.buildParams = buildParams;

    /* ── Datos compartidos ─────────────────────────── */
    let clientesTodosData = [];
    let topClientesData   = [];

    /* ── Export URL ────────────────────────────────── */
    window._dcExportUrl = '@Url.Action("DatosDashboard", "DashboardComercialMaestro")';

    /* ═══════════════════════════════════════════════
       CHART: Total de Clientes por Asesor (pie)
       ═══════════════════════════════════════════════ */
    function renderClientesPie() {
        destroyChart('clientesPie');

        var map = {};
        clientesTodosData.forEach(function(d) {
            var key = (d.asesor && d.asesor !== 'null') ? d.asesor : 'Sin Asesor';
            map[key] = (map[key] || 0) + 1;
        });
        if (Object.keys(map).length === 0) return;

        var sorted = Object.entries(map)
            .map(function([a, t]) { return { asesor: a, total: t }; })
            .sort(function(a, b) { return b.total - a.total; });

        var gran = sorted.reduce(function(s, r) { return s + r.total; }, 0);

        charts['clientesPie'] = new Chart(
            document.getElementById('chartClientesPie').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: sorted.map(r => r.asesor),
                datasets: [{
                    data: sorted.map(r => r.total),
                    backgroundColor: sorted.map(function(_, i) { return COLORS[i % COLORS.length]; }),
                    borderWidth: 2,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                cutout: '55%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 13, font: { size: 12, weight: '600' }, padding: 14 }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(c) {
                                var pct = gran > 0 ? (c.raw / gran * 100).toFixed(1) : 0;
                                return c.raw + ' clientes (' + pct + '%)';
                            }
                        }
                    },
                    datalabels: {
                        display: function(ctx) {
                            return gran > 0 && (ctx.dataset.data[ctx.dataIndex] / gran * 100) >= 5;
                        },
                        color: '#fff',
                        font: { size: 12, weight: '700', family: "'Segoe UI', Arial, sans-serif" },
                        textStrokeColor: 'rgba(0,0,0,.4)',
                        textStrokeWidth: 2,
                        formatter: function(v, ctx) {
                            var pct = gran > 0 ? (v / gran * 100).toFixed(1) : 0;
                            return ctx.chart.data.labels[ctx.dataIndex] + '\n' + v + ' (' + pct + '%)';
                        }
                    }
                },
                onClick: function(evt, elements) {
                    if (!elements || elements.length === 0) return;
                    var asesor = sorted[elements[0].index].asesor;
                    if (asesor !== 'Sin Asesor') loadDetalleClientesAsesor(asesor);
                }
            }
        });
    }

    /* ═══════════════════════════════════════════════
       CHART: % de Clientes por Asesor (horizontal bar)
       ═══════════════════════════════════════════════ */
    function renderClientesPct() {
        destroyChart('clientesPct');

        var map = {};
        clientesTodosData.forEach(function(d) {
            var key = (d.asesor && d.asesor !== 'null') ? d.asesor : 'Sin Asesor';
            map[key] = (map[key] || 0) + 1;
        });
        if (Object.keys(map).length === 0) return;

        var gran = Object.values(map).reduce(function(s, v) { return s + v; }, 0);
        var sorted = Object.entries(map)
            .map(function([a, t]) { return { asesor: a, pct: gran > 0 ? (t / gran * 100) : 0 }; })
            .sort(function(a, b) { return a.pct - b.pct; });

        charts['clientesPct'] = new Chart(
            document.getElementById('chartClientesPct').getContext('2d'), {
            type: 'bar',
            data: {
                labels: sorted.map(r => r.asesor),
                datasets: [{
                    label: '% de Clientes',
                    data: sorted.map(r => r.pct),
                    backgroundColor: sorted.map(function(_, i) { return COLORS[i % COLORS.length]; }),
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: function(c) { return c.raw.toFixed(1) + '%'; } } },
                    datalabels: {
                        display: true,
                        anchor: 'end', align: 'right',
                        font: { size: 12, weight: '700', family: "'Segoe UI', Arial, sans-serif" },
                        color: '#374151',
                        textStrokeColor: 'rgba(255,255,255,.8)',
                        textStrokeWidth: 3,
                        formatter: function(v, ctx) {
                            return v.toFixed(0) + '%';
                        }
                    }
                },
                layout: { padding: { right: 160 } },
                scales: { x: { beginAtZero: true, max: 100, ticks: { callback: function(v) { return v + '%'; }, font: { size: 11 } } } }
            }
        });
    }

    /* ═══════════════════════════════════════════════
       CHART: Cartera por Asesor (mixed: bar + line)
       ═══════════════════════════════════════════════ */
    function renderCartera() {
        destroyChart('cartera');

        var monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';

        // Agregar por asesor desde clientesTodosData
        var map = {};
        clientesTodosData.forEach(function(d) {
            var key = (d.asesor && d.asesor !== 'null') ? d.asesor : 'Sin Asesor';
            if (!map[key]) map[key] = { importe: 0, kg: 0 };
            map[key].importe += (d.total       || 0);
            map[key].kg      += (d.cantidadKg || 0);
        });
        if (Object.keys(map).length === 0) return;

        var totalImp = Object.values(map).reduce(function(s, v) { return s + v.importe; }, 0);

        var sorted = Object.entries(map)
            .map(function([a, v]) { return { asesor: a, importe: v.importe, kg: v.kg, pct: totalImp > 0 ? (v.importe / totalImp * 100) : 0 }; })
            .sort(function(a, b) { return b.importe - a.importe; });

        var fmtMil = function(n) {
            n = n || 0;
            if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
            if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
            return fmtPE.format(n);
        };

        charts['cartera'] = new Chart(
            document.getElementById('chartCartera').getContext('2d'), {
            type: 'bar',
            data: {
                labels: sorted.map(r => r.asesor),
                datasets: [
                    {
                        type: 'bar',
                        label: 'Venta (' + monLabel + ')',
                        data: sorted.map(r => r.importe),
                        backgroundColor: sorted.map(function(_, i) { return COLORS[i % COLORS.length] + 'CC'; }),
                        borderColor:     sorted.map(function(_, i) { return COLORS[i % COLORS.length]; }),
                        borderWidth: 1,
                        borderRadius: 4,
                        yAxisID: 'yImp',
                        order: 2,
                        datalabels: {
                            display: true,
                            anchor: 'end', align: 'top',
                            color: '#1B4D3E',
                            font: { size: 11, weight: '700' },
                            formatter: function(v) { return monLabel + ' ' + fmtMil(v); }
                        }
                    },
                    {
                        type: 'bar',
                        label: 'Producción (KG)',
                        data: sorted.map(r => r.kg),
                        backgroundColor: 'rgba(255,193,7,0.55)',
                        borderColor: 'rgba(255,193,7,1)',
                        borderWidth: 1,
                        borderRadius: 4,
                        yAxisID: 'yKg',
                        order: 3,
                        datalabels: {
                            display: true,
                            anchor: 'end', align: 'top',
                            color: '#b07d00',
                            font: { size: 11, weight: '700' },
                            formatter: function(v) { return fmtMil(v) + ' KG'; }
                        }
                    },
                    {
                        type: 'line',
                        label: '% Participación',
                        data: sorted.map(r => r.pct),
                        borderColor: '#e53935',
                        backgroundColor: 'rgba(229,57,53,.15)',
                        borderWidth: 2,
                        pointRadius: 5,
                        pointBackgroundColor: '#e53935',
                        tension: 0.3,
                        fill: false,
                        yAxisID: 'yPct',
                        order: 1,
                        datalabels: {
                            display: true,
                            align: 'top',
                            color: '#c62828',
                            font: { size: 11, weight: '700' },
                            formatter: function(v) { return v.toFixed(1) + '%'; }
                        }
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'top', labels: { boxWidth: 14, font: { size: 12 } } },
                    tooltip: {
                        callbacks: {
                            label: function(c) {
                                if (c.dataset.label.startsWith('Venta'))        return c.dataset.label + ': ' + monLabel + ' ' + fmtPE.format(c.raw);
                                if (c.dataset.label.startsWith('Producción'))   return c.dataset.label + ': ' + fmtMil(c.raw) + ' KG';
                                if (c.dataset.label.startsWith('%'))            return c.dataset.label + ': ' + c.raw.toFixed(1) + '%';
                                return c.dataset.label + ': ' + c.raw;
                            }
                        }
                    }
                },
                scales: {
                    yImp: {
                        type: 'linear', position: 'left',
                        beginAtZero: true,
                        title: { display: true, text: 'Venta (' + monLabel + ')', color: '#1B4D3E', font: { size: 11 } },
                        ticks: { callback: function(v) { return fmtMil(v); }, color: '#1B4D3E' },
                        grid: { color: 'rgba(0,0,0,.06)' }
                    },
                    yKg: {
                        type: 'linear', position: 'right',
                        beginAtZero: true,
                        title: { display: true, text: 'KG', color: '#f9a825', font: { size: 11 } },
                        ticks: { callback: function(v) { return fmtMil(v); }, color: '#f9a825' },
                        grid: { drawOnChartArea: false }
                    },
                    yPct: {
                        type: 'linear', position: 'right',
                        beginAtZero: true, max: 100,
                        display: false
                    }
                }
            }
        });
    }

    /* ═══════════════════════════════════════════════
       CHART: Participación por Asesor (%) — doughnut
       ═══════════════════════════════════════════════ */
    function renderParticipacion() {
        destroyChart('participacion');

        var monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        var map = {};
        clientesTodosData.forEach(function(d) {
            var key = (d.asesor && d.asesor !== 'null') ? d.asesor : 'Sin Asesor';
            map[key] = (map[key] || 0) + (d.total || 0);
        });
        if (Object.keys(map).length === 0) return;

        var total = Object.values(map).reduce(function(s, v) { return s + v; }, 0);
        var sorted = Object.entries(map)
            .map(function([a, v]) { return { asesor: a, importe: v, pct: total > 0 ? (v / total * 100) : 0 }; })
            .sort(function(a, b) { return b.importe - a.importe; });

        var fmtMil = function(n) {
            n = n || 0;
            if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
            if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
            return fmtPE.format(n);
        };

        charts['participacion'] = new Chart(
            document.getElementById('chartParticipacion').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: sorted.map(r => r.asesor),
                datasets: [{
                    data: sorted.map(r => r.importe),
                    backgroundColor: sorted.map(function(_, i) { return COLORS[i % COLORS.length]; }),
                    borderWidth: 2,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                cutout: '55%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 13, font: { size: 12, weight: '600' }, padding: 14 }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(c) {
                                var pct = total > 0 ? (c.raw / total * 100).toFixed(1) : 0;
                                return monLabel + ' ' + fmtMil(c.raw) + ' (' + pct + '%)';
                            }
                        }
                    },
                    datalabels: {
                        display: function(ctx) {
                            return total > 0 && (ctx.dataset.data[ctx.dataIndex] / total * 100) >= 5;
                        },
                        color: '#fff',
                        font: { size: 12, weight: '700', family: "'Segoe UI', Arial, sans-serif" },
                        textStrokeColor: 'rgba(0,0,0,.4)',
                        textStrokeWidth: 2,
                        formatter: function(v, ctx) {
                            var pct = total > 0 ? (v / total * 100).toFixed(1) : 0;
                            return ctx.chart.data.labels[ctx.dataIndex] + '\n' + pct + '%';
                        }
                    }
                }
            }
        });
    }

    /* ═══════════════════════════════════════════════
       CHART: Top N Clientes por Asesor — Importe
       ═══════════════════════════════════════════════ */
    function renderTopImporte() {
        destroyChart('topImporte');
        document.getElementById('spinnerTopImporte').style.display = 'none';

        var monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        var rows = topClientesData.filter(function(r) { return r.topType === 'importe' || r.topType === 'both'; });
        if (!rows.length) return;

        var asesores = [...new Set(rows.map(r => r.asesor))].sort();

        var fmtMil = function(n) {
            n = n || 0;
            if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
            if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
            return fmtPE.format(n);
        };

        // Colores por posicion (1°=azul, 2°=rojo, 3°=verde) dentro de cada asesor
        var TOP_COLORS = ['#1565C0', '#c62828', '#2e7d32'];
        var TOP_COLORS_BG = ['rgba(21,101,192,.75)', 'rgba(198,40,40,.75)', 'rgba(46,125,50,.75)'];
        var datasets = [0, 1, 2].map(function(pos) {
            return {
                label: (pos + 1) + 'º lugar',
                data: asesores.map(function(asesor) {
                    var clientesAsesor = rows
                        .filter(function(r) { return r.asesor === asesor; })
                        .sort(function(a, b) { return b.importe - a.importe; });
                    return clientesAsesor[pos] ? clientesAsesor[pos].importe : null;
                }),
                backgroundColor: TOP_COLORS_BG[pos],
                borderColor:     TOP_COLORS[pos],
                borderWidth: 1,
                borderRadius: 4,
                skipNull: true,
                datalabels: {
                    display: function(ctx) { return ctx.dataset.data[ctx.dataIndex] > 0; },
                    anchor: 'end', align: 'top',
                    color: TOP_COLORS[pos],
                    font: { size: 10, weight: '700' },
                    formatter: function(v, ctx) {
                        var asesor = asesores[ctx.dataIndex];
                        var clientesAsesor = rows
                            .filter(function(r) { return r.asesor === asesor; })
                            .sort(function(a, b) { return b.importe - a.importe; });
                        var cli = clientesAsesor[pos];
                        return cli ? cli.razonSocial.substring(0, 18) + '\n' + fmtMil(v) : fmtMil(v);
                    }
                }
            };
        });

        var canvasH = Math.max(380, asesores.length * 90);
        document.getElementById('chartTopImporte').parentElement.style.minHeight = canvasH + 'px';

        charts['topImporte'] = new Chart(
            document.getElementById('chartTopImporte').getContext('2d'), {
            type: 'bar',
            data: { labels: asesores, datasets: datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12, font: { size: 11, weight: '600' }, padding: 10 } },
                    tooltip: {
                        callbacks: {
                            title: function(items) {
                                var c = items[0];
                                var pos = c.datasetIndex;
                                var asesor = asesores[c.dataIndex];
                                var clientesAsesor = rows
                                    .filter(function(r) { return r.asesor === asesor; })
                                    .sort(function(a, b) { return b.importe - a.importe; });
                                var cli = clientesAsesor[pos];
                                return cli ? cli.razonSocial : asesor;
                            },
                            label: function(c) { return c.dataset.label + ': ' + monLabel + ' ' + fmtPE.format(c.raw); }
                        }
                    }
                },
                layout: { padding: { top: 24 } },
                scales: {
                    x: { ticks: { font: { size: 11, weight: '600' } } },
                    y: {
                        beginAtZero: true,
                        ticks: { callback: function(v) { return fmtMil(v); }, font: { size: 11 } }
                    }
                }
            }
        });
    }

