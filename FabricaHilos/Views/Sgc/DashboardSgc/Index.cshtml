@{
    ViewData["Title"] = "Dashboard SGC";
}

@section Styles {
<style>
    /* KPI Cards */
    .kpi-card {
        border-radius: 12px;
        color: #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,.18);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .kpi-card .kpi-icon { font-size: 2.4rem; opacity: .85; }
    .kpi-card .kpi-label { font-size: .78rem; opacity: .85; text-transform: uppercase; letter-spacing: .5px; }
    .kpi-card .kpi-value { font-size: 1.55rem; font-weight: 700; line-height: 1.1; }
    .kpi-card .kpi-sub   { font-size: .75rem; opacity: .8; margin-top: 2px; }
    .bg-kpi-1 { background: linear-gradient(135deg, #1B4D3E, #2e7d5e); }
    .bg-kpi-2 { background: linear-gradient(135deg, #1565C0, #1e88e5); }
    .bg-kpi-3 { background: linear-gradient(135deg, #2e7d32, #43a047); }
    .bg-kpi-4 { background: linear-gradient(135deg, #e65100, #fb8c00); }

    /* Chart cards */
    .chart-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.08);
        height: 100%;
    }
    .chart-card .card-header {
        background: transparent;
        color: #1B4D3E;
        font-weight: 600;
        border-bottom: 1px solid #e0e0e0;
        border-radius: 12px 12px 0 0 !important;
    }

    /* Spinner overlay */
    .chart-spinner {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,.75);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        z-index: 10;
    }

    /* Filter bar */
    .filter-bar {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        padding: .85rem 1.25rem;
        margin-bottom: 1.4rem;
    }

    /* Top table */
    .top-table thead th {
        background: #1B4D3E;
        color: #fff;
        font-weight: 600;
        font-size: .82rem;
        white-space: nowrap;
    }
    .top-table td { font-size: .83rem; vertical-align: middle; }

    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1B4D3E;
        margin: 1.2rem 0 .4rem;
        border-left: 4px solid #1B4D3E;
        padding-left: .5rem;
    }
    .report-desc {
        font-size: .78rem;
        color: #637381;
        margin: 0 0 .9rem .65rem;
        line-height: 1.55;
    }
    .risk-high  { background: #ffebee !important; color: #c62828; font-weight: 600; }
    .risk-mid   { background: #fff3e0 !important; color: #e65100; }
    .risk-badge { font-size: .72rem; padding: 2px 8px; border-radius: 10px; white-space: nowrap; display: inline-block; }
</style>
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item active">Dashboard</li>
}

<!-- ── Filtros ─────────────────────────────────────────── -->
<div class="filter-bar d-flex flex-wrap align-items-end gap-3">
    <div>
        <label class="form-label mb-1 small fw-semibold">Fecha Inicio</label>
        <input type="date" id="fechaInicio" class="form-control form-control-sm" style="min-width:135px">
    </div>
    <div>
        <label class="form-label mb-1 small fw-semibold">Fecha Fin</label>
        <input type="date" id="fechaFin" class="form-control form-control-sm" style="min-width:135px">
    </div>
    <div>
        <label class="form-label mb-1 small fw-semibold">Top</label>
        <select id="topN" class="form-select form-select-sm" style="min-width:75px">
            <option value="5">5</option>
            <option value="10" selected>10</option>
            <option value="15">15</option>
        </select>
    </div>
    <button class="btn btn-sm btn-success" onclick="loadAll()">
        <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
    </button>
    <button class="btn btn-sm btn-outline-secondary" onclick="clearFilters()">
        <i class="bi bi-x-circle me-1"></i>Limpiar
    </button>
</div>

<!-- ── Sección 1: KPI Cards ───────────────────────────── -->
<div class="row g-3 mb-3" id="kpiRow">
    <div class="col-sm-6 col-xl-3">
        <div class="kpi-card bg-kpi-1">
            <i class="bi bi-cart3 kpi-icon"></i>
            <div>
                <div class="kpi-label">Total Pedidos</div>
                <div class="kpi-value" id="kpiTotalPedidos">—</div>
                <div class="kpi-sub">pedidos en el período</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kpi-card bg-kpi-2">
            <i class="bi bi-currency-dollar kpi-icon"></i>
            <div>
                <div class="kpi-label">Total Pedido S/</div>
                <div class="kpi-value" id="kpiTotalPedido">—</div>
                <div class="kpi-sub">facturación bruta</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kpi-card bg-kpi-4">
            <i class="bi bi-hourglass-split kpi-icon"></i>
            <div>
                <div class="kpi-label">Pendiente S/</div>
                <div class="kpi-value" id="kpiPendiente">—</div>
                <div class="kpi-sub">emitidos + aprobados</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="kpi-card bg-kpi-3">
            <i class="bi bi-graph-up kpi-icon"></i>
            <div>
                <div class="kpi-label">Ticket Promedio S/</div>
                <div class="kpi-value" id="kpiTicket">—</div>
                <div class="kpi-sub">monto promedio por pedido</div>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 2: Distribución por Estado ───────────── -->
<div class="section-title">Distribución por Estado de Pedidos</div>
<p class="report-desc">Compara la cantidad de pedidos y el monto total para los estados <strong>Aprobado</strong> y <strong>Cerrado</strong>. Permite identificar cuánto hay comprometido vs. ya atendido dentro del período seleccionado.</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerEstado" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Pedidos por Estado</div>
            <div class="card-body"><canvas id="chartEstado" style="max-height:260px"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 3: Evolución mensual ──────────────────── -->
<div class="section-title">Evolución Mensual de Pedidos</div>
<p class="report-desc">Muestra la tendencia mes a mes del monto total facturado en <strong>Soles</strong> y <strong>Dólares</strong> (barras apiladas) junto con el número de pedidos (línea naranja). Permite detectar picos estacionales, ciclos de compra y caídas en la demanda para anticipar la producción.</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerEvolucion" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Total Pedido &amp; N° Pedidos</div>
            <div class="card-body"><canvas id="chartEvolucion" style="max-height:280px"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 4: Top Clientes + Top Artículos ────────── -->
<div class="section-title">Top Clientes y Artículos — Análisis Pareto 80/20</div>
<p class="report-desc">
    El <strong>principio Pareto 80/20</strong> sostiene que, en ventas, el <strong>80 % del ingreso proviene del 20 % de los clientes</strong>.
    Identificar ese grupo prioritario permite enfocar la atención comercial, anticipar riesgos de dependencia y tomar decisiones más inteligentes.
    Los gráficos de barras muestran el ranking por monto; en la tabla <em>Top Clientes — Detalle</em> (más abajo en esta sección)
    la columna <em>Acum. %</em> indica el porcentaje acumulado del total — los clientes resaltados en
    <span class="badge" style="background:#1B4D3E;font-size:.75rem;">verde</span> son los que concentran hasta el 80 % del monto total y representan su cartera crítica.
</p>
<div class="row g-3 mb-3">
    <div class="col-md-6">
        <div class="card chart-card position-relative">
            <div id="spinnerClientes" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Top Clientes por Monto</div>
            <div class="card-body"><canvas id="chartClientes" style="max-height:320px"></canvas></div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card chart-card position-relative">
            <div id="spinnerArticulos" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Top Artículos (Despachado | Pendiente)</div>
            <div class="card-body"><canvas id="chartArticulos" style="max-height:320px"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 5: Vendedores · Moneda · Despachos ───────── -->
<div class="section-title">Rendimiento de Vendedores · Moneda · Despachos</div>
<p class="report-desc">Evalúa el desempeño de cada vendedor: monto total pedido (barras) y número de pedidos gestionados (línea). Incluye la distribución por moneda (Soles / Dólares) y la evolución mensual de despachos físicos en guías y peso (kg).</p>
<div class="row g-3 mb-3">
    <div class="col-md-5">
        <div class="card chart-card position-relative">
            <div id="spinnerVendedor" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Monto S/ y N° Pedidos por Vendedor</div>
            <div class="card-body"><canvas id="chartVendedor" style="max-height:280px"></canvas></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card chart-card position-relative">
            <div id="spinnerMoneda" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Pedidos por Moneda</div>
            <div class="card-body"><canvas id="chartMoneda" style="max-height:280px"></canvas></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card chart-card position-relative">
            <div id="spinnerDespachos" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Despachos Mensuales</div>
            <div class="card-body"><canvas id="chartDespachos" style="max-height:280px"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 6: Sucursales + Detalle de Clientes ──────── -->
<div class="section-title">Sucursales del Cliente &amp; Detalle</div>
<p class="report-desc">Muestra qué sucursales de los clientes concentran el mayor monto pedido. Útil para enfocar esfuerzos comerciales y logísticos en los puntos de entrega más estratégicos.</p>
<div class="row g-3 mb-4">
    <div class="col-md-7">
        <div class="card chart-card position-relative">
            <div id="spinnerSucursal" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Top Sucursales del Cliente</div>
            <div class="card-body"><canvas id="chartSucursal" style="max-height:320px"></canvas></div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card chart-card">
            <div class="card-header small">Top Clientes — Detalle</div>
            <div class="card-body p-0" style="overflow-x:auto">
                <table class="table table-hover table-sm mb-0 top-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th class="text-end">Pedidos</th>
                            <th class="text-end">Total S/</th>
                            <th class="text-end">Peso (kg)</th>
                            <th class="text-end">Acum. %</th>
                        </tr>
                    </thead>
                    <tbody id="tablaClientes"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 7: Pedidos en Riesgo ──────────────────── -->
<div class="section-title"><i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>Pedidos en Riesgo</div>
<p class="report-desc">Lista los pedidos con estado <strong>Emitido</strong> que llevan más días de los indicados sin avanzar a Aprobado ni ser despachados. Permite al equipo comercial actuar de forma preventiva antes de que el cliente se inconforme. <span class="badge" style="background:#ffebee;color:#c62828">Rojo</span> = más de 90 días · <span class="badge" style="background:#fff3e0;color:#e65100">Naranja</span> = más de 30 días.</p>
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerRiesgo" class="chart-spinner"><div class="spinner-border text-warning"></div></div>
            <div class="card-header small d-flex justify-content-between align-items-center">
                <span>Pedidos Emitidos Sin Avance</span>
                <div class="d-flex align-items-center gap-2">
                    <label class="mb-0 small fw-semibold">Días mínimos:</label>
                    <input type="number" id="diasRiesgo" class="form-control form-control-sm" style="width:70px" value="30" min="1" max="365">
                    <button class="btn btn-sm btn-warning" onclick="recargarRiesgo()"><i class="bi bi-search"></i></button>
                </div>
            </div>
            <div class="card-body p-0" style="max-height:340px; overflow-y:auto; overflow-x:auto">
                <table class="table table-hover table-sm mb-0 top-table">
                    <thead>
                        <tr>
                            <th>N° Ped</th>
                            <th>Serie</th>
                            <th>Cliente</th>
                            <th class="text-center">Fecha Emisión</th>
                            <th class="text-center">Días</th>
                            <th class="text-end">Total S/</th>
                            <th>Vendedor</th>
                        </tr>
                    </thead>
                    <tbody id="tablaRiesgo"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 8: Ticket Promedio por Cliente ────────── -->
<div class="section-title">📊 Ticket Promedio por Cliente</div>
<p class="report-desc">Identifica cuánto gasta en promedio cada cliente por pedido (pricing analytics). Un ticket alto con baja frecuencia puede indicar un cliente de alto valor que merece atención personalizada para aumentar su recurrencia.</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerTicket" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Top Clientes por Ticket Promedio S/</div>
            <div class="card-body" style="height:320px">
                <canvas id="chartTicket"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 9: Ciclo de Cierre + Recompra ─────────── -->
<div class="section-title">📅 Ciclo de Cierre &amp; 🔁 Tasa de Recompra</div>
<p class="report-desc"><strong>Ciclo de Cierre:</strong> días promedio desde la emisión hasta el primer despacho (pedidos Aprobados y Cerrados). Reducir este tiempo mejora la satisfacción del cliente. &nbsp;|&nbsp; <strong>Recompra:</strong> segmenta a los clientes según su frecuencia de compra en el período — base clave para campañas de retención y fidelización.</p>
<div class="row g-3 mb-3">
    <div class="col-md-7">
        <div class="card chart-card position-relative">
            <div id="spinnerCiclo" class="chart-spinner"><div class="spinner-border text-primary"></div></div>
            <div class="card-header small">Días Promedio de Cierre por Mes</div>
            <div class="card-body" style="height:280px">
                <canvas id="chartCiclo"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card chart-card position-relative">
            <div id="spinnerRecompra" class="chart-spinner"><div class="spinner-border text-warning"></div></div>
            <div class="card-header small">Segmentación por Frecuencia de Compra</div>
            <div class="card-body d-flex align-items-center justify-content-center" style="height:280px">
                <canvas id="chartRecompra"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 10: Concentración de Riesgo + Zona ───── -->
<div class="section-title">📦 Concentración de Riesgo Comercial &amp; 🌍 Distribución por Ciudad</div>
<p class="report-desc"><strong>Concentración:</strong> qué porcentaje del monto total está en manos de los principales clientes — dependencia elevada en pocos representa un riesgo crítico para la continuidad del negocio. &nbsp;|&nbsp; <strong>Ciudad:</strong> dónde se genera el volumen de pedidos para enfocar la fuerza comercial y logística.</p>
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="card chart-card position-relative">
            <div id="spinnerConcentracion" class="chart-spinner"><div class="spinner-border text-danger"></div></div>
            <div class="card-header small">Concentración de Ventas por Segmento</div>
            <div class="card-body d-flex align-items-center justify-content-center" style="height:300px">
                <canvas id="chartConcentracion"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card chart-card position-relative">
            <div id="spinnerZona" class="chart-spinner"><div class="spinner-border text-info"></div></div>
            <div class="card-header small">Pedidos y Monto por Ciudad</div>
            <div class="card-body" style="height:300px">
                <canvas id="chartZona"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 11: Mix de Producto ───────────────────── -->
<div class="section-title">🧶 Mix de Producto: Fibra · Color · Presentación</div>
<p class="report-desc">Descompone el portafolio vendido según las tres dimensiones del producto. Permite a producción e inventario anticipar la mezcla de materiales, y al área comercial detectar las combinaciones de mayor demanda para ofertas y descuentos focalizados.</p>
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card chart-card position-relative">
            <div id="spinnerMixFibra" class="chart-spinner"><div class="spinner-border" style="color:#1B4D3E"></div></div>
            <div class="card-header small">Por Tipo de Fibra</div>
            <div class="card-body d-flex align-items-center justify-content-center" style="height:280px">
                <canvas id="chartMixFibra"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card chart-card position-relative">
            <div id="spinnerMixColor" class="chart-spinner"><div class="spinner-border text-secondary"></div></div>
            <div class="card-header small">Por Color</div>
            <div class="card-body d-flex align-items-center justify-content-center" style="height:280px">
                <canvas id="chartMixColor"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card chart-card position-relative">
            <div id="spinnerMixPres" class="chart-spinner"><div class="spinner-border text-warning"></div></div>
            <div class="card-header small">Por Presentación</div>
            <div class="card-body d-flex align-items-center justify-content-center" style="height:280px">
                <canvas id="chartMixPres"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';

    /* ── Formato de números ─────────────────────────── */
    const fmtPE = new Intl.NumberFormat('es-PE', { minimumFractionDigits: 2 });
    const fmt  = n => fmtPE.format(n ?? 0);
    const fmtMil = n => {
        n = n ?? 0;
        if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
        if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
        return fmt(n);
    };

    /* ── Constantes de truncado de etiquetas ────────── */
    const MAX_LABEL_CLIENTE  = 22;
    const MAX_LABEL_TABLA    = 18;
    const MAX_LABEL_ARTICULO = 20;
    const C = {
        verde:    '#1B4D3E',
        verde2:   '#2e7d5e',
        azul:     '#1565C0',
        azul2:    '#1e88e5',
        exito:    '#2e7d32',
        exito2:   '#43a047',
        naranja:  '#e65100',
        naranja2: '#fb8c00',
        gris:     '#9e9e9e',
        alpha: (hex, a) => hex + Math.round(a * 255).toString(16).padStart(2, '0')
    };

    /* ── Instancias de charts ──────────────────────── */
    const charts = {};
    function destroyChart(key) {
        if (charts[key]) { charts[key].destroy(); delete charts[key]; }
    }

    /* ── Spinner helpers ───────────────────────────── */
    function showSpin(id)  { const el = document.getElementById(id); if (el) el.style.display = 'flex'; }
    function hideSpin(id)  { const el = document.getElementById(id); if (el) el.style.display = 'none'; }

    /* ── Fechas por defecto (1° del mes actual → hoy) ── */
    function setDefaultDates() {
        const hoy  = new Date();
        const ini  = new Date(hoy.getFullYear(), hoy.getMonth(), 1);
        const toISO = d => d.toISOString().slice(0, 10);
        fpSetDate('#fechaInicio', toISO(ini));
        fpSetDate('#fechaFin',    toISO(hoy));
    }

    /* ── Parámetros del query string ────────────────── */
    function buildParams() {
        const fi  = document.getElementById('fechaInicio').value;
        const ff  = document.getElementById('fechaFin').value;
        const top = document.getElementById('topN').value;
        const p   = new URLSearchParams();
        if (fi)  p.set('fechaInicio', fi);
        if (ff)  p.set('fechaFin',    ff);
        p.set('top', top);
        return p;
    }

    /* ── Fetch genérico ─────────────────────────────── */
    async function apiFetch(url) {
        const r = await fetch(url);
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
    }

    /* ── Render KPI ─────────────────────────────────── */
    function renderKpi(d) {
        document.getElementById('kpiTotalPedidos').textContent = d.totalPedidos ?? 0;
        document.getElementById('kpiTotalPedido').textContent  = fmtMil(d.totalPedido);
        document.getElementById('kpiPendiente').textContent    = fmtMil(d.totalPendiente);
        const ticket = (d.totalPedidos > 0) ? d.totalPedido / d.totalPedidos : 0;
        document.getElementById('kpiTicket').textContent       = fmtMil(ticket);
    }

    /* ── Render Por Estado ──────────────────────────── */
    function renderEstado(data) {
        destroyChart('estado');
        const labels  = data.map(d => d.descEstado || d.estado);
        const counts  = data.map(d => d.cantidad);
        const totales = data.map(d => d.total);
        const ctx = document.getElementById('chartEstado').getContext('2d');
        charts['estado'] = new Chart(ctx, {
            data: {
                labels,
                datasets: [
                    {
                        type: 'bar',
                        label: 'N° Pedidos',
                        data: counts,
                        backgroundColor: C.alpha(C.verde, .8),
                        borderColor: C.verde,
                        borderWidth: 1,
                        yAxisID: 'y'
                    },
                    {
                        type: 'line',
                        label: 'Total S/',
                        data: totales,
                        borderColor: C.naranja,
                        backgroundColor: C.alpha(C.naranja, .15),
                        fill: true,
                        tension: .3,
                        yAxisID: 'y2',
                        pointRadius: 4
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: true,
                plugins: { legend: { position: 'bottom' } },
                scales: {
                    y:  { beginAtZero: true, title: { display: true, text: 'Pedidos' } },
                    y2: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false },
                          title: { display: true, text: 'Total S/' },
                          ticks: { callback: v => fmtMil(v) } }
                }
            }
        });
    }

    /* ── Render Evolución mensual ──────────────────── */
    function renderEvolucion(data) {
        destroyChart('evolucion');

        // Pivota por mes y moneda
        const meses      = [...new Set(data.map(d => d.mes))].sort();
        const currencies = [...new Set(data.map(d => d.moneda))].sort(); // ['D','S']

        const barDatasets = currencies.map(mon => ({
            type: 'bar',
            label: monedaLabel(mon),
            data: meses.map(m => {
                const r = data.find(d => d.mes === m && d.moneda === mon);
                return r ? r.totalPedido : 0;
            }),
            backgroundColor: mon === 'S' ? C.alpha(C.verde, .65) : C.alpha(C.azul, .65),
            borderColor:     mon === 'S' ? C.verde : C.azul,
            borderWidth: 1,
            yAxisID: 'y',
            stack: 'moneda'
        }));

        // Línea: N° Pedidos total por mes (suma de monedas)
        barDatasets.push({
            type: 'line',
            label: 'N° Pedidos (total)',
            data: meses.map(m => data.filter(d => d.mes === m).reduce((s, d) => s + d.numPedidos, 0)),
            borderColor: C.naranja,
            backgroundColor: 'transparent',
            fill: false, tension: .3, yAxisID: 'y2', pointRadius: 4, borderWidth: 2
        });

        const ctx = document.getElementById('chartEvolucion').getContext('2d');
        charts['evolucion'] = new Chart(ctx, {
            data: { labels: meses, datasets: barDatasets },
            options: {
                responsive: true, maintainAspectRatio: true,
                plugins: { legend: { position: 'bottom' } },
                scales: {
                    y:  { beginAtZero: true, stacked: true, ticks: { callback: v => fmtMil(v) } },
                    y2: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false },
                          title: { display: true, text: 'N° Pedidos' } }
                }
            }
        });
    }

    /* ── Render Top Clientes (barras H) ─────────────── */
    function renderClientes(data) {
        destroyChart('clientes');
        const labels = data.map(d => d.nombre ? d.nombre.substring(0, MAX_LABEL_CLIENTE) : d.codCliente);
        const pedido = data.map(d => d.totalPedido);
        const ctx = document.getElementById('chartClientes').getContext('2d');
        charts['clientes'] = new Chart(ctx, {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    { label: 'Total Pedido S/', data: pedido, backgroundColor: C.alpha(C.azul, .75) }
                ]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } },
                scales: { x: { beginAtZero: true, ticks: { callback: v => fmtMil(v) } } }
            }
        });

        /* tabla lateral */
        const tbody = document.getElementById('tablaClientes');
        const grandTotal = data.reduce((s, d) => s + (d.totalPedido ?? 0), 0);
        let acum = 0;
        tbody.innerHTML = data.map((d, i) => {
            acum += d.totalPedido ?? 0;
            const pct = grandTotal > 0 ? (acum / grandTotal * 100).toFixed(1) : '—';
            const paretoClass = grandTotal > 0 && parseFloat(pct) <= 80 ? 'text-success fw-semibold' : '';
            return `<tr>
                <td>${i + 1}</td>
                <td title="${d.nombre || ''}">${(d.nombre || d.codCliente || '').substring(0, MAX_LABEL_TABLA)}</td>
                <td class="text-end">${d.numPedidos}</td>
                <td class="text-end">${fmtMil(d.totalPedido)}</td>
                <td class="text-end">${fmt(d.pesoTotal ?? 0)}</td>
                <td class="text-end ${paretoClass}">${pct}%</td>
            </tr>`;
        }).join('');
    }

    /* ── Render Top Artículos (barras apiladas H) ──── */
    function renderArticulos(data) {
        destroyChart('articulos');
        const labels  = data.map(d => d.descripcion ? d.descripcion.substring(0, MAX_LABEL_ARTICULO) : d.codArt);
        const desp    = data.map(d => d.cantDespachada);
        const pend    = data.map(d => d.cantPendiente);
        const ctx = document.getElementById('chartArticulos').getContext('2d');
        charts['articulos'] = new Chart(ctx, {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    { label: 'Despachado', data: desp, backgroundColor: C.alpha(C.exito, .78), stack: 'total' },
                    { label: 'Pendiente',  data: pend, backgroundColor: C.alpha(C.naranja, .78), stack: 'total' }
                ]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } },
                scales: { x: { stacked: true, beginAtZero: true }, y: { stacked: true } }
            }
        });
    }

    /* ── Render Vendedores (barras agrupadas S/ y D/) ── */
    function renderVendedor(data) {
        destroyChart('vendedor');

        // Deduplica vendedores manteniendo el orden (SQL ya los ordena por total DESC)
        const vendMap = new Map();
        data.forEach(d => { if (!vendMap.has(d.codVende)) vendMap.set(d.codVende, d.nombreVendedor || d.codVende || '—'); });
        const vendors    = [...vendMap.entries()];
        const currencies = [...new Set(data.map(d => d.moneda))].sort(); // ['D','S']
        const labels     = vendors.map(([, n]) => n.substring(0, MAX_LABEL_CLIENTE));

        const barDatasets = currencies.map(mon => ({
            type: 'bar',
            label: monedaLabel(mon),
            data: vendors.map(([cod]) => {
                const row = data.find(d => d.codVende === cod && d.moneda === mon);
                return row ? row.totalPedido : 0;
            }),
            backgroundColor: mon === 'S' ? C.alpha(C.verde, .80) : C.alpha(C.azul, .78),
            yAxisID: 'y'
        }));

        // Línea: N° Pedidos total por vendedor (suma de monedas)
        barDatasets.push({
            type: 'line',
            label: 'N° Pedidos (total)',
            data: vendors.map(([cod]) => data.filter(d => d.codVende === cod).reduce((s, d) => s + d.numPedidos, 0)),
            borderColor: C.naranja,
            backgroundColor: 'transparent',
            tension: .3, yAxisID: 'y2', pointRadius: 5, borderWidth: 2
        });

        const ctx = document.getElementById('chartVendedor').getContext('2d');
        charts['vendedor'] = new Chart(ctx, {
            data: { labels, datasets: barDatasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } },
                scales: {
                    y:  { beginAtZero: true, ticks: { callback: v => fmtMil(v) }, title: { display: true, text: 'Total' } },
                    y2: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: 'N° Pedidos' } }
                }
            }
        });
    }

    /* ── Render Moneda (dona pequeña) ───────────────── */
    const monedaLabel = c => c === 'D' ? 'Dólares' : c === 'S' ? 'Soles' : c || '—';

    function renderMoneda(data) {
        destroyChart('moneda');
        const ctx = document.getElementById('chartMoneda').getContext('2d');
        charts['moneda'] = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: data.map(d => monedaLabel(d.moneda)),
                datasets: [{
                    data: data.map(d => d.totalPedido),
                    backgroundColor: [C.verde, C.azul2, C.naranja, C.gris],
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: { callbacks: { label: ctx => ' S/ ' + fmt(ctx.raw) } }
                },
                cutout: '55%'
            }
        });
    }

    /* ── Render Despachos (área doble) ─────────────── */
    function renderDespachos(data) {
        destroyChart('despachos');
        const labels = data.map(d => d.mes);
        const guias  = data.map(d => d.numGuias);
        const pesos  = data.map(d => d.pesoTotal);
        const ctx = document.getElementById('chartDespachos').getContext('2d');
        charts['despachos'] = new Chart(ctx, {
            data: {
                labels,
                datasets: [
                    {
                        type: 'line',
                        label: 'N° Guías',
                        data: guias,
                        borderColor: C.azul,
                        backgroundColor: C.alpha(C.azul, .15),
                        fill: true, tension: .3, yAxisID: 'y',
                        pointRadius: 4
                    },
                    {
                        type: 'line',
                        label: 'Peso Total (kg)',
                        data: pesos,
                        borderColor: C.naranja,
                        backgroundColor: C.alpha(C.naranja, .12),
                        fill: true, tension: .3, yAxisID: 'y2',
                        pointRadius: 4
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } },
                scales: {
                    y:  { beginAtZero: true, title: { display: true, text: 'Guías' } },
                    y2: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false },
                          title: { display: true, text: 'Peso (kg)' }, ticks: { callback: v => fmtMil(v) } }
                }
            }
        });
    }

    /* ── Render Sucursal Cliente (barras H) ─────────── */
    function renderSucursal(data) {
        destroyChart('sucursal');
        const labels = data.map(d => d.nombreSucursal || ('Suc. ' + d.nroSucur));
        const pedido = data.map(d => d.totalPedido);
        const ctx = document.getElementById('chartSucursal').getContext('2d');
        charts['sucursal'] = new Chart(ctx, {
            type: 'bar',
            data: {
                labels,
                datasets: [
                    { label: 'Total Pedido S/', data: pedido, backgroundColor: C.alpha(C.verde, .75) }
                ]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } },
                scales: { x: { beginAtZero: true, ticks: { callback: v => fmtMil(v) } } }
            }
        });
    }

    /* ── Render Pedidos en Riesgo ───────────────────── */
    function renderRiesgo(data) {
        const tbody = document.getElementById('tablaRiesgo');
        if (!data || data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-3"><i class="bi bi-check-circle-fill text-success me-1"></i>Sin pedidos en riesgo para los parámetros seleccionados.</td></tr>';
            return;
        }
        tbody.innerHTML = data.map(d => {
            const dias     = d.diasEmitido ?? 0;
            const rowCls   = dias > 90 ? 'risk-high' : dias > 30 ? 'risk-mid' : '';
            const badgeCls = dias > 90 ? 'risk-high risk-badge' : 'risk-mid risk-badge';
            const fech     = d.fecha ? d.fecha.substring(0, 10) : '—';
            return `<tr class="${rowCls}">
                <td>${d.numPed}</td>
                <td>${d.serie}</td>
                <td title="${d.nombre || ''}">${(d.nombre || '—').substring(0, 30)}</td>
                <td class="text-center">${fech}</td>
                <td class="text-center"><span class="${badgeCls}">${dias} días</span></td>
                <td class="text-end">${fmtMil(d.totalPedido)}</td>
                <td>${d.codVende || '—'}</td>
            </tr>`;
        }).join('');
    }

    async function recargarRiesgo() {
        showSpin('spinnerRiesgo');
        try {
            const dias = document.getElementById('diasRiesgo').value || 30;
            const data = await apiFetch('/DashboardSgc/DatosRiesgo?dias=' + dias);
            renderRiesgo(data);
        } catch (err) {
            console.error('Error cargando riesgo:', err);
        } finally {
            hideSpin('spinnerRiesgo');
        }
    }
    window.recargarRiesgo = recargarRiesgo;

    /* ── Render Ticket Promedio por Cliente ─────────── */
    function renderTicket(data) {
        destroyChart('ticket');
        const labels = data.map(d => (d.nombre || d.codCliente || '—').substring(0, 24));
        const ticket = data.map(d => d.ticketPromedio);
        const npeds  = data.map(d => d.numPedidos);
        const ctx = document.getElementById('chartTicket').getContext('2d');
        charts['ticket'] = new Chart(ctx, {
            type: 'bar',
            data: {
                labels,
                datasets: [{ label: 'Ticket Promedio S/', data: ticket, backgroundColor: C.alpha(C.azul, .78) }]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: { callbacks: {
                        label: ctx => ' S/ ' + fmtMil(ctx.raw),
                        afterLabel: ctx => ' Pedidos: ' + (npeds[ctx.dataIndex] || 0)
                    }}
                },
                scales: { x: { beginAtZero: true, ticks: { callback: v => fmtMil(v) } } }
            }
        });
    }

    /* ── Render Ciclo de Cierre ──────────────────────── */
    function renderCiclo(data) {
        destroyChart('ciclo');
        const labels = data.map(d => d.mes);
        const dias   = data.map(d => d.diasPromCierre);
        const ctx = document.getElementById('chartCiclo').getContext('2d');
        charts['ciclo'] = new Chart(ctx, {
            type: 'line',
            data: {
                labels,
                datasets: [{
                    label: 'Días promedio de cierre',
                    data: dias,
                    borderColor: C.azul,
                    backgroundColor: C.alpha(C.azul, .12),
                    fill: true, tension: .3, pointRadius: 5
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } },
                scales: { y: { beginAtZero: true, title: { display: true, text: 'Días' } } }
            }
        });
    }

    /* ── Render Recompra (donut frecuencia) ──────────── */
    function renderRecompra(data) {
        destroyChart('recompra');
        const ctx = document.getElementById('chartRecompra').getContext('2d');
        charts['recompra'] = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: data.map(d => d.frecuencia),
                datasets: [{ data: data.map(d => d.numClientes),
                    backgroundColor: [C.gris, C.azul2, C.naranja, C.verde], borderWidth: 2 }]
            },
            options: {
                responsive: true, maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 11 } } },
                    tooltip: { callbacks: { label: ctx => ' ' + ctx.label + ': ' + ctx.raw + ' clientes' } }
                },
                cutout: '55%'
            }
        });
    }

    /* ── Render Concentración de Riesgo (donut) ──────── */
    function renderConcentracion(data) {
        destroyChart('concentracion');
        const ctx   = document.getElementById('chartConcentracion').getContext('2d');
        const total = data.reduce((s, d) => s + d.totalPedido, 0);
        charts['concentracion'] = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: data.map(d => d.segmento),
                datasets: [{ data: data.map(d => d.totalPedido),
                    backgroundColor: ['#c62828','#e65100','#f9a825','#1565C0','#424242'],
                    borderWidth: 2 }]
            },
            options: {
                responsive: true, maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 11 } } },
                    tooltip: { callbacks: { label: ctx => {
                        const pct = total > 0 ? (ctx.raw / total * 100).toFixed(1) : 0;
                        return ' ' + ctx.label + ': S/ ' + fmtMil(ctx.raw) + ' (' + pct + '%)';
                    }}}
                },
                cutout: '50%'
            }
        });
    }

    /* ── Render Zona / Ciudad (bar+line dual-axis) ────── */
    function renderZona(data) {
        destroyChart('zona');
        const labels = data.map(d => d.ciudad || '—');
        const pedido = data.map(d => d.totalPedido);
        const npeds  = data.map(d => d.numPedidos);
        const ctx = document.getElementById('chartZona').getContext('2d');
        charts['zona'] = new Chart(ctx, {
            data: {
                labels,
                datasets: [
                    { type: 'bar',  label: 'Total S/', data: pedido,
                      backgroundColor: C.alpha(C.azul, .72), yAxisID: 'y' },
                    { type: 'line', label: 'N° Pedidos', data: npeds,
                      borderColor: C.naranja, backgroundColor: 'transparent',
                      tension: .3, yAxisID: 'y2', pointRadius: 4, borderWidth: 2 }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } },
                scales: {
                    y:  { beginAtZero: true, ticks: { callback: v => fmtMil(v) }, title: { display: true, text: 'Total S/' } },
                    y2: { beginAtZero: true, position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: 'N° Pedidos' } }
                }
            }
        });
    }

    /* ── Render Mix de Producto (3 donuts) ───────────── */
    const MIX_PALETTE = [C.verde, C.azul, C.naranja, C.azul2, C.gris,
                         '#8e24aa','#00838f','#e53935','#fb8c00','#43a047'];

    function buildMixDonut(canvasId, data) {
        destroyChart(canvasId);
        const ctx   = document.getElementById(canvasId).getContext('2d');
        const total = data.reduce((s, d) => s + d.cantPedida, 0);
        charts[canvasId] = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: data.map(d => d.categoria || '—'),
                datasets: [{ data: data.map(d => d.cantPedida),
                    backgroundColor: MIX_PALETTE.slice(0, data.length), borderWidth: 2 }]
            },
            options: {
                responsive: true, maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 10 } } },
                    tooltip: { callbacks: { label: ctx => {
                        const pct = total > 0 ? (ctx.raw / total * 100).toFixed(1) : 0;
                        return ' ' + ctx.label + ': ' + fmt(ctx.raw) + ' (' + pct + '%)';
                    }}}
                },
                cutout: '52%'
            }
        });
    }

    function renderMix(data) {
        buildMixDonut('chartMixFibra', data.fibra        || []);
        buildMixDonut('chartMixColor', data.color        || []);
        buildMixDonut('chartMixPres',  data.presentacion || []);
        hideSpin('spinnerMixFibra');
        hideSpin('spinnerMixColor');
        hideSpin('spinnerMixPres');
    }

    /* ── loadAll: carga todos los datos en paralelo ── */
    async function loadAll() {
        const p = buildParams();
        const base = url => '/DashboardSgc/' + url + '?' + p;

        /* mostrar spinners */
        ['spinnerEstado','spinnerEvolucion','spinnerClientes',
         'spinnerArticulos','spinnerVendedor','spinnerMoneda','spinnerDespachos',
         'spinnerSucursal','spinnerRiesgo',
         'spinnerTicket','spinnerCiclo','spinnerRecompra',
         'spinnerConcentracion','spinnerZona',
         'spinnerMixFibra','spinnerMixColor','spinnerMixPres'].forEach(showSpin);

        try {
            const dias = document.getElementById('diasRiesgo')?.value || 30;
            const [kpi, estados, evolucion, clientes, articulos, vendedores, monedas,
                   sucursales, despachos, riesgo,
                   ticket, ciclo, recompra, concentracion, zona, mix] =
                await Promise.all([
                    apiFetch(base('DatosKpi')),
                    apiFetch(base('DatosPorEstado')),
                    apiFetch(base('DatosEvolucionMensual')),
                    apiFetch(base('DatosTopClientes')),
                    apiFetch(base('DatosTopArticulos')),
                    apiFetch(base('DatosPorVendedor')),
                    apiFetch(base('DatosPorMoneda')),
                    apiFetch(base('DatosSucursalCliente')),
                    apiFetch(base('DatosDespachos')),
                    apiFetch('/DashboardSgc/DatosRiesgo?dias=' + dias),
                    apiFetch(base('DatosTicketCliente')),
                    apiFetch(base('DatosCicloCierre')),
                    apiFetch(base('DatosRecompra')),
                    apiFetch(base('DatosConcentracion')),
                    apiFetch(base('DatosPorZona')),
                    apiFetch(base('DatosMixProducto'))
                ]);

            renderKpi(kpi);
            renderEstado(estados);          hideSpin('spinnerEstado');
            renderEvolucion(evolucion);     hideSpin('spinnerEvolucion');
            renderClientes(clientes);       hideSpin('spinnerClientes');
            renderArticulos(articulos);     hideSpin('spinnerArticulos');
            renderVendedor(vendedores);     hideSpin('spinnerVendedor');
            renderMoneda(monedas);          hideSpin('spinnerMoneda');
            renderDespachos(despachos);     hideSpin('spinnerDespachos');
            renderSucursal(sucursales);     hideSpin('spinnerSucursal');
            renderRiesgo(riesgo);           hideSpin('spinnerRiesgo');
            renderTicket(ticket);           hideSpin('spinnerTicket');
            renderCiclo(ciclo);             hideSpin('spinnerCiclo');
            renderRecompra(recompra);       hideSpin('spinnerRecompra');
            renderConcentracion(concentracion); hideSpin('spinnerConcentracion');
            renderZona(zona);               hideSpin('spinnerZona');
            renderMix(mix);
        } catch (err) {
            console.error('Error cargando dashboard:', err);
            ['spinnerEstado','spinnerEvolucion','spinnerClientes',
             'spinnerArticulos','spinnerVendedor','spinnerMoneda','spinnerDespachos',
             'spinnerSucursal','spinnerRiesgo',
             'spinnerTicket','spinnerCiclo','spinnerRecompra',
             'spinnerConcentracion','spinnerZona',
             'spinnerMixFibra','spinnerMixColor','spinnerMixPres'].forEach(hideSpin);
        }
    }

    /* ── Limpiar filtros y recargar ─────────────────── */
    window.clearFilters = function () {
        setDefaultDates();
        document.getElementById('topN').value = '10';
        loadAll();
    };

    window.loadAll = loadAll;

    /* ── Init ───────────────────────────────────────── */
    document.addEventListener('DOMContentLoaded', function () {
        setDefaultDates();
        loadAll();
    });
}());
</script>
}
