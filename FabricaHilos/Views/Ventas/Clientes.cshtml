@model IEnumerable<FabricaHilos.Models.Ventas.Cliente>

@{
    ViewData["Title"] = "Clientes";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Ventas</a></li>
    <li class="breadcrumb-item active">Clientes</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-people me-2"></i>Clientes</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
    {
        <a asp-action="CrearCliente" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Cliente
        </a>
    }
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control form-control-sm" placeholder="Buscar por nombre o RUC/DNI..." style="max-width: 300px;" />
            <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(ViewBag.Buscar as string))
            {
                <a asp-action="Clientes" class="btn btn-sm btn-outline-secondary">Limpiar</a>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nombre / Razón Social</th>
                        <th>RUC / DNI</th>
                        <th>Teléfono</th>
                        <th>Correo</th>
                        <th>Dirección</th>
                        <th>Estado</th>
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Nombre</td>
                            <td>@(item.RucDni ?? "-")</td>
                            <td>@(item.Telefono ?? "-")</td>
                            <td>@(item.Correo ?? "-")</td>
                            <td>@(item.Direccion ?? "-")</td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
                            {
                                <td>
                                    <a asp-action="EditarCliente" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary btn-accion">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay clientes registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
