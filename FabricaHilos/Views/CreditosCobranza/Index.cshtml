@using FabricaHilos.Services
@inject IMenuService MenuService
@{
    ViewData["Title"] = "Créditos y Cobranzas";
    var menus = MenuService.GetMenusActuales();
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Créditos y Cobranzas</li>
}

<div class="container-fluid px-4 py-3">
    <div class="row g-3">
        @if (menus.CcNivelMorosidad)
        {
        <div class="col-12 col-sm-6 col-lg-4">
            <a asp-controller="CreditosCobranza" asp-action="NivelMorosidad" class="text-decoration-none">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body text-center py-4">
                        <i class="bi bi-graph-down-arrow fs-1 text-danger"></i>
                        <h6 class="mt-3 fw-bold text-dark">Nivel de Morosidad</h6>
                        <p class="text-muted small">Indicador de riesgo de carteras vencidas sobre el total de carteras de clientes.</p>
                    </div>
                </div>
            </a>
        </div>
        }
    </div>
</div>
