@model IEnumerable<FabricaHilos.Services.Produccion.PreparatoriaListDto>
@using FabricaHilos.Helpers

@{
    ViewData["Title"] = "Registro de Preparatoria";
    var navToken = ViewBag.NavToken as string;
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Produccion" asp-action="Index">Producción</a></li>
    <li class="breadcrumb-item active">Registro de Preparatoria</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-gear-wide-connected me-2"></i>Registro de Preparatoria</h4>
    <a asp-action="Crear" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nuevo
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control form-control-sm" placeholder="Buscar por lote..." style="max-width: 220px;" />
            <select name="tipoMaquina" class="form-select form-select-sm" style="max-width: 220px;"
                    onchange="document.querySelector('[name=maquina]').value=''; document.getElementById('hiddenPage').value='1'; this.form.submit();">
                <option value="">Todos los tipos</option>
                @if (ViewBag.TiposMaquinasFiltro != null)
                {
                    @foreach (var tipo in ViewBag.TiposMaquinasFiltro)
                    {
                        <option value="@tipo.TipoMaquina" selected="@(ViewBag.TipoMaquinaFiltro == tipo.TipoMaquina)">@tipo.TextoCompleto</option>
                    }
                }
            </select>
            <select name="maquina" class="form-select form-select-sm" style="max-width: 220px;">
                <option value="">Todas las máquinas</option>
                @if (ViewBag.Maquinas != null)
                {
                    @foreach (var maq in ViewBag.Maquinas)
                    {
                        <option value="@maq.Codigo" selected="@(ViewBag.MaquinaFiltro == maq.Codigo)">@maq.Descripcion</option>
                    }
                }
            </select>
            @{
                var estadosFiltro = ViewBag.EstadoFiltro as List<string> ?? new List<string> { "1" };
            }
            <div class="position-relative" id="divEstado">
                <button type="button" class="form-select form-select-sm text-start d-flex justify-content-between align-items-center"
                        id="btnEstado" style="min-width:150px; max-width:190px; cursor:pointer; user-select:none;">
                    <span id="spanEstadoTexto" class="text-truncate"></span>
                    <i class="bi bi-chevron-down ms-1" style="font-size:.7rem; flex-shrink:0;"></i>
                </button>
                <div id="panelEstado" class="border rounded bg-white shadow-sm py-1"
                     style="display:none; position:absolute; z-index:1050; min-width:150px; top:100%; left:0; margin-top:2px;">
                    <label class="d-flex align-items-center gap-2 px-3 py-1 panel-estado-item" style="cursor:pointer; white-space:nowrap; margin-bottom:0;">
                        @if (estadosFiltro.Contains("1"))
                        {
                            <input type="checkbox" name="estado" value="1" class="estado-chk form-check-input mt-0" checked />
                        }
                        else
                        {
                            <input type="checkbox" name="estado" value="1" class="estado-chk form-check-input mt-0" />
                        }
                        En Proceso
                    </label>
                    <label class="d-flex align-items-center gap-2 px-3 py-1 panel-estado-item" style="cursor:pointer; white-space:nowrap; margin-bottom:0;">
                        @if (estadosFiltro.Contains("3"))
                        {
                            <input type="checkbox" name="estado" value="3" class="estado-chk form-check-input mt-0" checked />
                        }
                        else
                        {
                            <input type="checkbox" name="estado" value="3" class="estado-chk form-check-input mt-0" />
                        }
                        Terminado
                    </label>
                    <label class="d-flex align-items-center gap-2 px-3 py-1 panel-estado-item" style="cursor:pointer; white-space:nowrap; margin-bottom:0;">
                        @if (estadosFiltro.Contains("9"))
                        {
                            <input type="checkbox" name="estado" value="9" class="estado-chk form-check-input mt-0" checked />
                        }
                        else
                        {
                            <input type="checkbox" name="estado" value="9" class="estado-chk form-check-input mt-0" />
                        }
                        Anulado
                    </label>
                </div>
            </div>
            <input type="hidden" name="page" id="hiddenPage" value="@(ViewBag.Page ?? 1)" />
            <button type="submit" class="btn btn-sm btn-outline-primary" onclick="document.getElementById('hiddenPage').value='1';"><i class="bi bi-search"></i> Filtrar</button>
            @if (!string.IsNullOrEmpty(ViewBag.Buscar as string) || !string.IsNullOrEmpty(ViewBag.TipoMaquinaFiltro as string) || !string.IsNullOrEmpty(ViewBag.MaquinaFiltro as string))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary" title="Limpiar filtros"><i class="bi bi-x-circle me-1"></i>Limpiar filtros</a>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th>Receta</th>
                        <th>Lote</th>
                        <th>Material</th>
                        <th>Máquina</th>
                        <th>Título</th>
                        <th>Fecha Inicial</th>
                        <th>Turno</th>
                        <th style="display:none;">Operario</th>
                        <th>Paso</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @* Datos de la base de datos *@
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Receta</td>
                                <td>@(item.Lote ?? "-")</td>
                                <td>@(item.Material ?? "-")</td>
                                <td>@(string.IsNullOrEmpty(item.DescripcionMaquina) ? "-" : item.DescripcionMaquina)</td>
                                <td>@(string.IsNullOrEmpty(item.DescripcionTitulo) ? "-" : item.DescripcionTitulo)</td>
                                <td>@item.FechaInicio.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@(item.Turno == null ? "-" : ProduccionLookups.GetTurno(item.Turno))</td>
                                <td style="display:none;">@(string.IsNullOrEmpty(item.NombreOperario) ? "-" : item.NombreOperario)</td>
                                @if (item.TipoMaquina == "B")
                                {
                                    var _netoFmt = item.TotalNeto.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
                                    <td>R: @item.CantRollos / PN: @_netoFmt</td>
                                }
                                else
                                {
                                    <td>@(item.PasoManual == null ? "-" : ProduccionLookups.GetPaso(item.PasoManual))</td>
                                }
                                <td>
                                    @{
                                        var estadoClass = item.Estado switch
                                        {
                                            "1" => new { Class = "bg-primary", Icon = "bi-gear-fill", Text = "En Proceso" },
                                            "3" => new { Class = "bg-success", Icon = "bi-check-circle", Text = "Terminado" },
                                            "9" => new { Class = "bg-danger", Icon = "bi-x-circle", Text = "Anulado" },
                                            _ => new { Class = "bg-secondary", Icon = "bi-question-circle", Text = "Desconocido" }
                                        };
                                    }
                                    <span class="badge @estadoClass.Class">
                                        <i class="bi @estadoClass.Icon me-1"></i>@estadoClass.Text
                                    </span>
                                </td>
                                <td>
                                    @if (item.LocalId.HasValue && item.Estado == "1")
                                        {
                                            <a asp-action="Editar" asp-route-id="@item.LocalId" asp-route-returnUrl="@navToken" class="btn btn-sm btn-outline-primary me-1" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @if (item.TipoMaquina != "B")
                                            {
                                                <a asp-action="DetalleProduccion" asp-route-id="@item.LocalId" asp-route-returnUrl="@navToken" class="btn btn-sm btn-outline-info me-1" title="Detalle de Producción">
                                                    <i class="bi bi-bar-chart-line"></i>
                                                </a>
                                            }
                                            @if (item.TipoMaquina == "B")
                                            {
                                                var _ftDate = item.FechaInicio.Hour < 7 ? item.FechaInicio.Date.AddDays(-1) : item.FechaInicio.Date;
                                                var _totalNetoStr = item.TotalNeto.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
                                                <button type="button" class="btn btn-sm btn-outline-success me-1 btn-agregar-rollo" title="Agregar Rollo"
                                                        data-tp-maq="@item.TipoMaquina"
                                                        data-cod-maq="@item.CodigoMaquina"
                                                        data-turno="@item.Turno"
                                                        data-fecha-turno="@_ftDate.ToString("yyyy-MM-dd")"
                                                        data-cant-rollos="@item.CantRollos"
                                                        data-total-neto="@_totalNetoStr">
                                                    <i class="bi bi-plus-circle"></i>
                                                </button>
                                            }
                                            <button type="button" class="btn btn-sm btn-outline-warning me-1 btn-registrar-paro" title="Registrar Paro"
                                                    data-tp-maq="@item.TipoMaquina"
                                                    data-cod-maq="@item.CodigoMaquina"
                                                    data-turno="@item.Turno"
                                                    data-maquina="@(string.IsNullOrEmpty(item.DescripcionMaquina) ? item.CodigoMaquina : item.DescripcionMaquina)">
                                                <i class="bi bi-pause-circle"></i>
                                            </button>
                                            @if (item.TipoMaquina == "B")
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-success me-1 btn-cerrar-batan" title="Cerrar Preparatoria"
                                                        data-id="@item.LocalId">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            }
                                        }
                                        @if (item.LocalId.HasValue)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-secondary btn-ver-detalle"
                                                    data-id="@item.LocalId" title="Ver Detalle">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        }
                                        @if ((item.Estado == "3" || item.Estado == "9") && item.TieneParos)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-info ms-1 btn-ver-paros" title="Ver Paros"
                                                    data-tp-maq="@item.TipoMaquina"
                                                    data-cod-maq="@item.CodigoMaquina"
                                                    data-maquina="@(string.IsNullOrEmpty(item.DescripcionMaquina) ? item.CodigoMaquina : item.DescripcionMaquina)">
                                                <i class="bi bi-pause-fill"></i>
                                            </button>
                                        }
                                        @if (item.LocalId.HasValue && item.Estado == "1")
                                        {
                                            <form asp-action="Anular" asp-route-id="@item.LocalId" method="post" class="d-inline" id="formAnular_@item.LocalId">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="returnUrl" value="@navToken" />
                                                <button type="button" class="btn btn-sm btn-outline-danger btn-anular" title="Anular Preparatoria"
                                                        data-form-id="formAnular_@item.LocalId">
                                                    <i class="bi bi-slash-circle"></i>
                                                </button>
                                            </form>
                                        }
                                        </td>
                                    </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                @if (!string.IsNullOrEmpty(ViewBag.Buscar as string) || !string.IsNullOrEmpty(ViewBag.TipoMaquinaFiltro as string) || !string.IsNullOrEmpty(ViewBag.MaquinaFiltro as string))
                                {
                                    <span>No hay registros con los filtros aplicados.</span>
                                    <br />
                                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary mt-2"><i class="bi bi-arrow-clockwise me-1"></i>Ver todos</a>
                                }
                                else
                                {
                                    <span>No hay registros de preparatoria.</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@{
    int currentPage = ViewBag.Page != null ? Convert.ToInt32(ViewBag.Page) : 1;
    int totalPages  = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
    int totalCount  = ViewBag.TotalCount != null ? Convert.ToInt32(ViewBag.TotalCount) : 0;
    int pgSize      = ViewBag.PageSize != null ? Convert.ToInt32(ViewBag.PageSize) : 10;
    int startItem   = totalCount == 0 ? 0 : (currentPage - 1) * pgSize + 1;
    int endItem     = Math.Min(currentPage * pgSize, totalCount);
}
<div class="d-flex justify-content-between align-items-center mt-2 px-1">
    <small class="text-muted">
        @(totalCount == 0 ? "Sin registros" : $"Mostrando {startItem}\u2013{endItem} de {totalCount} registros")
    </small>
    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <button type="button" class="page-link btn-pagina" data-page="@(currentPage - 1)"><i class="bi bi-chevron-left"></i></button>
                </li>
                @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
                {
                    <li class="page-item @(pg == currentPage ? "active" : "")">
                        <button type="button" class="page-link btn-pagina" data-page="@pg">@pg</button>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <button type="button" class="page-link btn-pagina" data-page="@(currentPage + 1)"><i class="bi bi-chevron-right"></i></button>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- Modal de Confirmación Anular -->
<div class="modal fade" id="modalConfirmarAnular" tabindex="-1" aria-labelledby="modalConfirmarAnularLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalConfirmarAnularLabel">Confirmar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                ¿Está seguro que desea anular esta preparatoria?
            </div>
            <div class="modal-footer">
                <button type="button" id="btnCancelarAnularModal" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnAceptarAnularModal" class="btn btn-danger">Aceptar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Confirmar Cerrar Preparatoria -->
<div class="modal fade" id="modalConfirmarCerrarBatan" tabindex="-1" aria-labelledby="modalConfirmarCerrarBatanLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title" id="modalConfirmarCerrarBatanLabel"><i class="bi bi-exclamation-triangle me-2"></i>Confirmar cierre</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                ¿Está seguro que desea cerrar esta preparatoria? El estado se actualizará a <strong>Terminado</strong> en Oracle.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnAceptarCerrarBatan" class="btn btn-warning"><i class="bi bi-check-circle me-1"></i>Cerrar Preparatoria</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Ver Detalle -->
<div class="modal fade" id="modalVerDetalle" tabindex="-1" aria-labelledby="modalVerDetalleLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalVerDetalleLabel"><i class="bi bi-eye me-2"></i>Detalle de Preparatoria</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div id="modalVerDetalleLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div>
                    <p class="mt-2 text-muted">Cargando información...</p>
                </div>
                <div id="modalVerDetalleContent" style="display:none;">
                    <!-- Sección Preparatoria -->
                    <h6 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-gear-wide-connected me-2"></i>Información de Preparatoria</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Receta</span>
                            <span id="det_receta">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Lote</span>
                            <span id="det_lote">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Material</span>
                            <span id="det_material">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Tipo Máquina</span>
                            <span id="det_tipoMaquina">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Máquina</span>
                            <span id="det_maquina">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Título</span>
                            <span id="det_titulo">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Fecha de Inicio</span>
                            <span id="det_fechaInicio">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Estado</span>
                            <span id="det_estado">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Operario</span>
                            <span id="det_operario">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Turno</span>
                            <span id="det_turno">-</span>
                        </div>
                        <div id="det_grupoPasoManuar" class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Paso Manuar</span>
                            <span id="det_pasoManuar">-</span>
                        </div>
                    </div>
                    <!-- Sección Detalle de Producción (oculta para tipo B) -->
                    <div id="det_seccionProduccion">
                    <h6 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-bar-chart-line me-2"></i>Detalle de Producción</h6>
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Velocidad</span>
                            <span id="det_velocidad">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Metraje</span>
                            <span id="det_metraje">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Rollo / Tacho</span>
                            <span id="det_rolloTacho">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Kg Neto</span>
                            <span id="det_kgNeto">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Fecha Final</span>
                            <span id="det_fechaFin">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Produc. Teórico</span>
                            <span id="det_producTeorico">-</span>
                        </div>
                        <div class="col-md-4">
                            <span class="form-label fw-semibold small text-muted d-block mb-0">Eficienc. Teórico</span>
                            <span id="det_eficiencTeorico">-</span>
                        </div>
                    </div>
                    <!-- Sección Pabilera (condicional) -->
                    <div id="det_seccionPabilera" style="display:none;">
                        <h6 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-layers me-2"></i>Datos de Pabilera</h6>
                        <div class="row g-3">
                            <div class="col-md-3">
                                <span class="form-label fw-semibold small text-muted d-block mb-0">Contador Inicial</span>
                                <span id="det_contadorInicial">-</span>
                            </div>
                            <div class="col-md-3">
                                <span class="form-label fw-semibold small text-muted d-block mb-0">Husos Inactivos (HI)</span>
                                <span id="det_husosInactivas">-</span>
                            </div>
                            <div class="col-md-3">
                                <span class="form-label fw-semibold small text-muted d-block mb-0">Contador Final</span>
                                <span id="det_contadorFinal">-</span>
                            </div>
                            <div class="col-md-3">
                                <span class="form-label fw-semibold small text-muted d-block mb-0">Nro. Parada</span>
                                <span id="det_nroParada">-</span>
                            </div>
                        </div>
                    </div>
                    </div>
                    <!-- Sección Rollos BATAN (solo tipo B) -->
                    <div id="det_seccionRollos" style="display:none;">
                        <h6 class="fw-bold border-bottom pb-2 mb-3"><i class="bi bi-list-ol me-2"></i>Rollos</h6>
                        <div id="det_rollosLoading" class="text-center py-3" style="display:none;">
                            <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                            <span class="ms-2 text-muted">Cargando rollos...</span>
                        </div>
                        <div style="max-height:260px; overflow-y:auto;">
                            <table class="table table-sm table-hover table-corporate mb-0" id="det_tablaRollos">
                                <thead class="table-light sticky-top">
                                        <tr>
                                            <th style="width:60px;">#</th>
                                            <th class="text-end">Kg Neto</th>
                                            <th class="text-end">Diferencia</th>
                                        </tr>
                                    </thead>
                                <tbody id="det_tablaRollosCuerpo"></tbody>
                            </table>
                        </div>
                        <div class="mt-2 text-end">
                            <span class="text-muted small">Total Kg Neto: <strong id="det_rollosTotalNeto">-</strong></span>
                        </div>
                    </div>
                </div>
                <div id="modalVerDetalleError" class="alert alert-danger" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-circle me-1"></i>Cerrar</button>
