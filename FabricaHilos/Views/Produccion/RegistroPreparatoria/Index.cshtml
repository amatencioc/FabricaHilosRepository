                <!-- Filtro de turno -->
                <div class="row g-2 mb-3">
                    <div class="col-12">
                        <label class="form-label fw-semibold mb-1">Filtrar por Turno</label>
                        <div class="d-flex flex-wrap gap-2" id="filtroTurnoParos">
                            <div class="form-check">
                                <input class="form-check-input turno-filtro-chk" type="checkbox" value="1" id="chkTurno1" checked />
                                <label class="form-check-label" for="chkTurno1">1er Turno</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input turno-filtro-chk" type="checkbox" value="2" id="chkTurno2" checked />
                                <label class="form-check-label" for="chkTurno2">2do Turno</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input turno-filtro-chk" type="checkbox" value="3" id="chkTurno3" checked />
                                <label class="form-check-label" for="chkTurno3">3er Turno</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input turno-filtro-chk" type="checkbox" value="4" id="chkTurno4" checked />
                                <label class="form-check-label" for="chkTurno4">12 Hrs Da</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input turno-filtro-chk" type="checkbox" value="5" id="chkTurno5" checked />
                                <label class="form-check-label" for="chkTurno5">12 Hrs Noche</label>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Campos del paro -->
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Motivo <span class="text-danger">*</span></label>
                        <div class="position-relative">
                            <input type="text" id="paroMotivoInput" class="form-control" placeholder="Buscar motivo..." autocomplete="off" />
                            <input type="hidden" id="paroMotivo" />
                            <ul id="paroMotivoDropdown" class="list-group mt-1 shadow-sm" style="display:none;position:absolute;z-index:1050;width:100%;max-height:200px;overflow-y:auto;"></ul>
                        </div>
                        <div id="errParoMotivo" class="text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Fecha Inicio <span class="text-danger">*</span></label>
                        <input type="datetime-local" id="paroFechaIni" class="form-control" step="60" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                        <div id="errParoFechaIni" class="text-danger small mt-1" style="display:none;"></div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Fecha Fin <span class="text-muted small">(opcional)</span></label>
                        <input type="datetime-local" id="paroFechaFin" class="form-control" step="60" />
                        <div id="errParoFechaFin" class="text-danger small mt-1" style="display:none;"></div>
                    </div>
                </div>
                <div class="d-flex gap-2 mb-3">
                    <button type="button" id="btnParoAgregar" class="btn btn-sm btn-primary">
                        <i class="bi bi-plus-circle me-1"></i><span id="spanBtnParoTexto">Agregar</span>
                    </button>
                    <button type="button" id="btnParoCancelarEdicion" class="btn btn-sm btn-outline-secondary" style="display:none;">
                        <i class="bi bi-x me-1"></i>Cancelar edición
                    </button>
                </div>
                <div id="paroAlerta" class="alert alert-danger py-2" style="display:none;"></div>
                <!-- Grilla de paros -->
                <div class="table-responsive">
                    <table class="table table-sm table-hover table-corporate mb-0" id="tablaParos">
                            <tr>
                                <th style="width:30px;">#</th>
                                <th>Motivo</th>
                                <th>Turno</th>
                                <th class="text-nowrap">Fecha Inicio</th>
                                <th class="text-nowrap">Fecha Fin</th>
                                <th style="width:110px;"></th>
                            </tr>
                        </thead>
                        <tbody id="tablaParosCuerpo">
                            <tr id="paroFilaVacia">
                                <td colspan="6" class="text-center text-muted py-3"><i class="bi bi-inbox me-1"></i>Sin paros agregados</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><i class="bi bi-x-circle me-1"></i>Cancelar</button>
                <button type="button" id="btnParoGuardar" class="btn btn-success"><i class="bi bi-save me-1"></i>Guardar</button>
            </div>
        </div>
    </div>
</div>

