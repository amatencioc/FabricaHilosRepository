@{
    ViewData["Title"] = "Dashboard";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Dashboard</li>
}

<h4 class="section-title"><i class="bi bi-speedometer2 me-2"></i>Panel Principal</h4>

<!-- Tarjetas de resumen -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card card-dashboard h-100" style="border-left: 4px solid var(--color-primary);">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Productos en Inventario</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalProductos</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-circle p-3">
                        <i class="bi bi-boxes fs-4 text-primary"></i>
                    </div>
                </div>
                <a asp-controller="Inventario" asp-action="ProductoTerminado" class="small text-muted mt-2 d-block">Ver inventario →</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card card-dashboard h-100" style="border-left: 4px solid var(--color-secondary);">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Órdenes Activas</p>
                        <h3 class="fw-bold mb-0">@ViewBag.OrdenesActivas</h3>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-circle p-3">
                        <i class="bi bi-gear-wide-connected fs-4 text-warning"></i>
                    </div>
                </div>
                <a asp-controller="Produccion" asp-action="Index" class="small text-muted mt-2 d-block">Ver producción →</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card card-dashboard h-100" style="border-left: 4px solid var(--color-primary-light);">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Ventas del Mes</p>
                        <h3 class="fw-bold mb-0">S/ @ViewBag.VentasMes.ToString("N2")</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-circle p-3">
                        <i class="bi bi-cash-coin fs-4 text-success"></i>
                    </div>
                </div>
                <a asp-controller="Ventas" asp-action="Pedidos" class="small text-muted mt-2 d-block">Ver ventas →</a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="card card-dashboard h-100" style="border-left: 4px solid var(--color-accent);">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted small mb-1">Empleados Activos</p>
                        <h3 class="fw-bold mb-0">@ViewBag.TotalEmpleados</h3>
                    </div>
                    <div class="bg-purple bg-opacity-10 rounded-circle p-3">
                        <i class="bi bi-people fs-4" style="color: var(--color-accent);"></i>
                    </div>
                </div>
                <a asp-controller="RecursosHumanos" asp-action="Empleados" class="small text-muted mt-2 d-block">Ver empleados →</a>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.StockBajo > 0)
{
    <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
        <div>
            <strong>Alerta de Stock:</strong> Hay <strong>@ViewBag.StockBajo</strong> materia(s) prima(s) con stock por debajo del mínimo.
            <a asp-controller="Inventario" asp-action="MateriaPrima" class="ms-2 alert-link">Ver detalles</a>
        </div>
    </div>
}

<!-- Gráficos y accesos rápidos -->
<div class="row g-4">
    @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
    {
        <div class="col-md-8">
            <div class="card card-dashboard">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-bar-chart me-2"></i>Resumen de Actividad</h6>
                </div>
                <div class="card-body">
                    <canvas id="graficoResumen" height="200"></canvas>
                </div>
            </div>
        </div>
    }

    <div class="col-md-@(User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor") ? "4" : "12")">
        <div class="card card-dashboard h-100">
            <div class="card-header bg-white border-bottom">
                <h6 class="mb-0 fw-bold"><i class="bi bi-lightning me-2"></i>Acceso Rápido</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-controller="Inventario" asp-action="MateriaPrima" class="btn btn-outline-primary text-start">
                        <i class="bi bi-archive me-2"></i>Materia Prima
                    </a>
                    <a asp-controller="Inventario" asp-action="ProductoTerminado" class="btn btn-outline-primary text-start">
                        <i class="bi bi-boxes me-2"></i>Productos Terminados
                    </a>
                    <a asp-controller="Produccion" asp-action="Index" class="btn btn-outline-warning text-start">
                        <i class="bi bi-gear-wide-connected me-2"></i>Órdenes de Producción
                    </a>
                    <a asp-controller="Ventas" asp-action="Pedidos" class="btn btn-outline-success text-start">
                        <i class="bi bi-cart3 me-2"></i>Pedidos
                    </a>
                    <a asp-controller="RecursosHumanos" asp-action="Asistencia" class="btn btn-outline-secondary text-start">
                        <i class="bi bi-calendar-check me-2"></i>Registrar Asistencia
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ============================================================
        // MOSTRAR DATOS DE ORACLE EN CONSOLA DEL NAVEGADOR
        // ============================================================
        @if (TempData["OracleLoginSuccess"] != null)
        {
            <text>
            console.log('%c ═══════════════════════════════════════════════════', 'color: #1B4D3E; font-weight: bold;');
            console.log('%c 🔐 DATOS DE LOGIN - ORACLE DATABASE', 'color: #C8A951; font-weight: bold; font-size: 14px;');
            console.log('%c ═══════════════════════════════════════════════════', 'color: #1B4D3E; font-weight: bold;');
            console.log('%c 👤 Usuario Oracle:', 'color: #2D7A5F; font-weight: bold;', '@TempData["OracleUser"]');
            console.log('%c 🏢 Centro de Costo:', 'color: #2D7A5F; font-weight: bold;', '@TempData["OracleCentroCosto"]');
            console.log('%c ✅ Login exitoso desde Oracle Database', 'color: #2D7A5F; font-style: italic;');
            console.log('%c ═══════════════════════════════════════════════════', 'color: #1B4D3E; font-weight: bold;');

            // Objeto completo para inspección
            console.log('%c 📦 Objeto Usuario Oracle:', 'color: #3D4451; font-weight: bold;');
            console.table({
                'Usuario': '@TempData["OracleUser"]',
                'Centro de Costo': '@TempData["OracleCentroCosto"]',
                'Origen': 'Oracle Database',
                'Tabla': 'cs_user'
            });
            </text>
        }

        @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
        {
            <text>
            const ctx = document.getElementById('graficoResumen');
            if (ctx) {
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ['Materia Prima', 'Productos', 'Órdenes Activas', 'Empleados'],
                        datasets: [{
                            label: 'Cantidad',
                            data: [@ViewBag.StockBajo, @ViewBag.TotalProductos, @ViewBag.OrdenesActivas, @ViewBag.TotalEmpleados],
                            backgroundColor: ['#C0392B', '#1B4D3E', '#C8A951', '#3D4451'],
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                    }
                });
            }
            </text>
        }
    </script>
}
