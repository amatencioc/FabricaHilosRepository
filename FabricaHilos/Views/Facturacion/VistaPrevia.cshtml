@model FabricaHilos.Models.Facturacion.DocumentoExtraido

@{
    ViewData["Title"] = "Vista Previa del Documento";
    int confianzaPct = (int)(Model.Confianza * 100);
    string badgeClass = confianzaPct >= 80 ? "bg-success" : confianzaPct >= 50 ? "bg-warning text-dark" : "bg-danger";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="RegistroPreparatoria" asp-action="Index">Inicio</a></li>
    <li class="breadcrumb-item"><a asp-controller="Facturacion" asp-action="Index">Facturación</a></li>
    <li class="breadcrumb-item"><a asp-controller="Facturacion" asp-action="ImportarFacturas">Importar Facturas</a></li>
    <li class="breadcrumb-item active">Vista Previa</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">
        <i class="bi bi-file-earmark-check me-2"></i>Vista Previa del Documento
    </h4>
    <span class="badge @badgeClass fs-6">
        <i class="bi bi-graph-up me-1"></i>Confianza: @confianzaPct%
    </span>
</div>

@if (Model.MensajeError != null)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-circle me-2"></i><strong>Advertencia:</strong> @Model.MensajeError
    </div>
}

<form asp-action="ConfirmarImportacion" method="post">
    @Html.AntiForgeryToken()

    <!-- Campos ocultos -->
    <input type="hidden" asp-for="NombreArchivo" />
    <input type="hidden" asp-for="FuenteExtraccion" />
    <input type="hidden" asp-for="Estado" />
    <input type="hidden" asp-for="FechaProcesamiento" />
    <input type="hidden" asp-for="Confianza" />
    <input type="hidden" asp-for="MensajeError" />

    <div class="row g-4">
        <!-- Card Identificación -->
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-card-text me-2"></i>Identificación del Documento
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="TipoDocumento" class="form-label fw-semibold">Tipo Documento</label>
                            <input asp-for="TipoDocumento" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Serie" class="form-label fw-semibold">Serie</label>
                            <input asp-for="Serie" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Correlativo" class="form-label fw-semibold">Correlativo</label>
                            <input asp-for="Correlativo" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="NumeroDocumento" class="form-label fw-semibold">N° Documento</label>
                            <input asp-for="NumeroDocumento" class="form-control" readonly />
                        </div>
                        <div class="col-md-2">
                            <label asp-for="Moneda" class="form-label fw-semibold">Moneda</label>
                            <select asp-for="Moneda" class="form-select">
                                <option value="PEN">PEN (Soles)</option>
                                <option value="USD">USD (Dólares)</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="FechaEmision" class="form-label fw-semibold">Fecha Emisión</label>
                            <input asp-for="FechaEmision" type="date" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="FechaVencimiento" class="form-label fw-semibold">Fecha Vencimiento</label>
                            <input asp-for="FechaVencimiento" type="date" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="NumeroPedido" class="form-label fw-semibold">N° Pedido / O.C.</label>
                            <input asp-for="NumeroPedido" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="NumeroGuia" class="form-label fw-semibold">N° Guía de Remisión</label>
                            <input asp-for="NumeroGuia" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card Emisor -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-secondary text-white">
                    <i class="bi bi-building me-2"></i>Datos del Emisor
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="RucEmisor" class="form-label fw-semibold">RUC Emisor</label>
                        <input asp-for="RucEmisor" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="RazonSocialEmisor" class="form-label fw-semibold">Razón Social</label>
                        <input asp-for="RazonSocialEmisor" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="DireccionEmisor" class="form-label fw-semibold">Dirección</label>
                        <input asp-for="DireccionEmisor" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Card Receptor -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-secondary text-white">
                    <i class="bi bi-person-vcard me-2"></i>Datos del Receptor
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="RucReceptor" class="form-label fw-semibold">RUC Receptor</label>
                        <input asp-for="RucReceptor" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="RazonSocialReceptor" class="form-label fw-semibold">Razón Social</label>
                        <input asp-for="RazonSocialReceptor" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="DireccionReceptor" class="form-label fw-semibold">Dirección</label>
                        <input asp-for="DireccionReceptor" class="form-control" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Card Montos -->
        <div class="col-12">
            <div class="card shadow-sm border-success border-2">
                <div class="card-header bg-success text-white">
                    <i class="bi bi-cash-stack me-2"></i>Montos
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label asp-for="BaseImponible" class="form-label fw-semibold">Base Imponible</label>
                            <input asp-for="BaseImponible" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="TotalIgv" class="form-label fw-semibold">IGV</label>
                            <input asp-for="TotalIgv" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="TotalExonerado" class="form-label fw-semibold">Total Exonerado</label>
                            <input asp-for="TotalExonerado" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="TotalInafecto" class="form-label fw-semibold">Total Inafecto</label>
                            <input asp-for="TotalInafecto" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="TotalDescuento" class="form-label fw-semibold">Total Descuento</label>
                            <input asp-for="TotalDescuento" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="TotalAnticipos" class="form-label fw-semibold">Total Anticipos</label>
                            <input asp-for="TotalAnticipos" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="FormaPago" class="form-label fw-semibold">Forma de Pago</label>
                            <input asp-for="FormaPago" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label asp-for="MontoNetoPendiente" class="form-label fw-semibold">Monto Neto Pendiente</label>
                            <input asp-for="MontoNetoPendiente" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="TotalPagar" class="form-label fw-bold fs-5">Total a Pagar</label>
                            <input asp-for="TotalPagar" type="number" step="0.01" class="form-control form-control-lg fw-bold text-success" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de Ítems -->
        @if (Model.Items != null && Model.Items.Any())
        {
            <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-info text-white">
                        <i class="bi bi-table me-2"></i>Detalle de Ítems
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Descripción</th>
                                        <th>Unidad</th>
                                        <th class="text-end">Cantidad</th>
                                        <th class="text-end">Valor Unitario</th>
                                        <th class="text-end">Valor Venta</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Items.Count; i++)
                                    {
                                        <tr>
                                            <td>@Model.Items[i].Descripcion</td>
                                            <td>@Model.Items[i].UnidadMedida</td>
                                            <td class="text-end">@Model.Items[i].Cantidad</td>
                                            <td class="text-end">@Model.Items[i].ValorUnitario</td>
                                            <td class="text-end">@Model.Items[i].ValorVenta</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Observaciones -->
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <label asp-for="Observaciones" class="form-label fw-semibold">
                        <i class="bi bi-chat-left-text me-1"></i>Observaciones
                    </label>
                    <input asp-for="Observaciones" class="form-control" />
                </div>
            </div>
        </div>

        <!-- Botones -->
        <div class="col-12">
            <div class="d-flex gap-3">
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-check-circle me-2"></i>✅ Confirmar y Registrar
                </button>
                <a asp-action="ImportarFacturas" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-arrow-left me-1"></i>← Volver
                </a>
            </div>
        </div>
    </div>
</form>
