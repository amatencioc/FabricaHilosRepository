@using FabricaHilos.Config
@{
    ViewData["Title"] = "Inicio";
    var menus = ViewBag.MenusActuales as MenuOptions ?? new MenuOptions();
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Inicio</li>
}

<div class="d-flex align-items-center gap-2 mb-4">
    <i class="bi bi-grid-1x2-fill fs-4" style="color: var(--color-secondary);"></i>
    <h4 class="mb-0 fw-bold">Acceso Rápido</h4>
</div>

<div class="row g-3">
    @if (menus.Produccion)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <a asp-controller="Produccion" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm quick-access-card" style="border-left: 5px solid #C8A951 !important;">
                    <div class="card-body d-flex align-items-center gap-3 py-4">
                        <div class="rounded p-3 d-flex align-items-center justify-content-center" style="background: rgba(200,169,81,0.12); min-width: 56px; min-height: 56px;">
                            <i class="bi bi-gear-wide-connected fs-2" style="color: #C8A951;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-6 text-dark">Producción</div>
                            <small class="text-muted">Gestión de órdenes y procesos</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (menus.Sgc)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <a asp-controller="Sgc" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm quick-access-card" style="border-left: 5px solid #2D7A5F !important;">
                    <div class="card-body d-flex align-items-center gap-3 py-4">
                        <div class="rounded p-3 d-flex align-items-center justify-content-center" style="background: rgba(45,122,95,0.10); min-width: 56px; min-height: 56px;">
                            <i class="bi bi-file-earmark-check fs-2" style="color: #2D7A5F;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-6 text-dark">SGC</div>
                            <small class="text-muted">Pedidos y despachos</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (menus.Logistica)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <a asp-controller="Logistica" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm quick-access-card" style="border-left: 5px solid #8B5E3C !important;">
                    <div class="card-body d-flex align-items-center gap-3 py-4">
                        <div class="rounded p-3 d-flex align-items-center justify-content-center" style="background: rgba(139,94,60,0.10); min-width: 56px; min-height: 56px;">
                            <i class="bi bi-box-seam fs-2" style="color: #8B5E3C;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-6 text-dark">Logística</div>
                            <small class="text-muted">Requerimientos y compras</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (menus.Facturacion)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <a asp-controller="Facturacion" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm quick-access-card" style="border-left: 5px solid #3D4451 !important;">
                    <div class="card-body d-flex align-items-center gap-3 py-4">
                        <div class="rounded p-3 d-flex align-items-center justify-content-center" style="background: rgba(61,68,81,0.10); min-width: 56px; min-height: 56px;">
                            <i class="bi bi-receipt-cutoff fs-2" style="color: #3D4451;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-6 text-dark">Facturación</div>
                            <small class="text-muted">Documentos y facturas</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (menus.Ventas)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <a asp-controller="Ventas" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm quick-access-card" style="border-left: 5px solid #1B6CA8 !important;">
                    <div class="card-body d-flex align-items-center gap-3 py-4">
                        <div class="rounded p-3 d-flex align-items-center justify-content-center" style="background: rgba(27,108,168,0.10); min-width: 56px; min-height: 56px;">
                            <i class="bi bi-graph-up-arrow fs-2" style="color: #1B6CA8;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-6 text-dark">Ventas</div>
                            <small class="text-muted">Indicadores y dashboards</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (menus.Seguridad)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <a asp-controller="Inspeccion" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm quick-access-card" style="border-left: 5px solid #0B7CBF !important;">
                    <div class="card-body d-flex align-items-center gap-3 py-4">
                        <div class="rounded p-3 d-flex align-items-center justify-content-center" style="background: rgba(11,124,191,0.10); min-width: 56px; min-height: 56px;">
                            <i class="bi bi-shield-check fs-2" style="color: #0B7CBF;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-6 text-dark">Seguridad</div>
                            <small class="text-muted">Inspecciones de seguridad</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (menus.RecursosHumanos)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <a href="/RecursosHumanos/Aquarius/Marcaciones" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm quick-access-card" style="border-left: 5px solid #5A5A8A !important;">
                    <div class="card-body d-flex align-items-center gap-3 py-4">
                        <div class="rounded p-3 d-flex align-items-center justify-content-center" style="background: rgba(90,90,138,0.10); min-width: 56px; min-height: 56px;">
                            <i class="bi bi-people-fill fs-2" style="color: #5A5A8A;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-6 text-dark">Recursos Humanos</div>
                            <small class="text-muted">Marcaciones y personal</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
    @if (menus.CreditosCobranza)
    {
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <a asp-controller="CreditosCobranza" asp-action="Index" class="text-decoration-none">
                <div class="card h-100 border-0 shadow-sm quick-access-card" style="border-left: 5px solid #C0392B !important;">
                    <div class="card-body d-flex align-items-center gap-3 py-4">
                        <div class="rounded p-3 d-flex align-items-center justify-content-center" style="background: rgba(192,57,43,0.10); min-width: 56px; min-height: 56px;">
                            <i class="bi bi-graph-down-arrow fs-2" style="color: #C0392B;"></i>
                        </div>
                        <div>
                            <div class="fw-bold fs-6 text-dark">Créditos y Cobranzas</div>
                            <small class="text-muted">Indicadores de morosidad</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        @if (TempData["OracleLoginSuccess"] != null)
        {
            <text>
            console.log('%c ═══════════════════════════════════════════════════', 'color: #1B4D3E; font-weight: bold;');
            console.log('%c 🔐 DATOS DE LOGIN - ORACLE DATABASE', 'color: #C8A951; font-weight: bold; font-size: 14px;');
            console.log('%c ═══════════════════════════════════════════════════', 'color: #1B4D3E; font-weight: bold;');
            console.log('%c 👤 Usuario Oracle:', 'color: #2D7A5F; font-weight: bold;', '@TempData["OracleUser"]');
            console.log('%c 🏢 Centro de Costo:', 'color: #2D7A5F; font-weight: bold;', '@TempData["OracleCentroCosto"]');
            console.log('%c ✅ Login exitoso desde Oracle Database', 'color: #2D7A5F; font-style: italic;');
            console.log('%c ═══════════════════════════════════════════════════', 'color: #1B4D3E; font-weight: bold;');
            console.table({
                'Usuario': '@TempData["OracleUser"]',
                'Centro de Costo': '@TempData["OracleCentroCosto"]',
                'Origen': 'Oracle Database',
                'Tabla': 'cs_user'
            });
            </text>
        }
    </script>
}


    @section Styles {
        <style>
            .quick-access-card {
                transition: transform 0.15s ease, box-shadow 0.15s ease;
                cursor: pointer;
            }
            .quick-access-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
            }
        </style>
    }
