@model IEnumerable<FabricaHilos.Models.Sgc.ItemPedDto>
@using FabricaHilos.Models.Sgc

@{
    ViewData["Title"] = "Detalle de Pedido";
    var pedido = ViewBag.Pedido as PedidoSgcDto;
    string? buscar      = ViewBag.Buscar      as string;
    string? fechaInicio = ViewBag.FechaInicio as string;
    string? fechaFin    = ViewBag.FechaFin    as string;
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item"><a asp-action="Pedidos" asp-route-buscar="@buscar" asp-route-fechaInicio="@fechaInicio" asp-route-fechaFin="@fechaFin">Pedidos</a></li>
    <li class="breadcrumb-item active">Pedido @pedido?.NumPed</li>
}

<div class="mb-3">
    <h4 class="section-title mb-1"><i class="bi bi-list-ul me-2"></i>Detalle del Pedido</h4>
    <a asp-action="Pedidos" asp-route-buscar="@buscar" asp-route-fechaInicio="@fechaInicio" asp-route-fechaFin="@fechaFin" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver a pedidos
    </a>
</div>

@if (pedido != null)
{
    <div class="card mb-3">
        <div class="card-header fw-semibold bg-light">
            <i class="bi bi-cart-check me-1"></i>
            Serie <strong>@pedido.Serie</strong> — Pedido N° <strong>@pedido.NumPed</strong>
        </div>
        <div class="card-body py-2">
            @{ var monedaLabel = pedido.Moneda == "D" ? "Dólares ($)" : pedido.Moneda == "S" ? "Soles (S/)" : (pedido.Moneda ?? "-"); }
            <div class="row row-cols-2 row-cols-md-4 g-2 small">
                <div><span class="text-muted">RUC:</span> @(pedido.Ruc ?? "-")</div>
                <div><span class="text-muted">Cliente:</span> <span class="fw-semibold">@(pedido.Nombre ?? pedido.CodCliente)</span></div>
                <div><span class="text-muted">Fecha de Pedido:</span> @(pedido.Fecha?.ToString("dd/MM/yyyy") ?? "-")</div>
                <div><span class="text-muted">Moneda:</span> @monedaLabel</div>
                <div><span class="text-muted">Total Pedido:</span> <span class="fw-semibold">@(pedido.TotalPedido?.ToString("N2") ?? "-")</span></div>
                <div><span class="text-muted">Total Facturado:</span> <span class="fw-semibold">@(pedido.TotalFacturado?.ToString("N2") ?? "-")</span></div>
                <div><span class="text-muted">Detalle:</span> @(pedido.Detalle ?? "-")</div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center">Ítem</th>
                        <th class="text-center">Cód. Art.</th>
                        <th class="text-center">Descripción</th>
                        <th class="text-center">Color</th>
                        <th class="text-center">Unidad</th>
                        <th class="text-end">Cant. Pedido</th>
                        <th class="text-end">Precio</th>
                        <th class="text-end">Cant. Despacho</th>
                        <th class="text-end">Dif. Despacho</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var saldo = (item.SaldoR.HasValue && item.SaldoR != 0) ? item.SaldoR : item.Saldo;
                        var cantDespacho = (item.Cantidad.HasValue && saldo.HasValue) ? (item.Cantidad - saldo) : null;
                        <tr>
                            <td class="text-center">@item.Nro</td>
                            <td class="fw-semibold">@(item.CodArt ?? "-")</td>
                            <td>@(item.Descripcion ?? "-")</td>
                            <td>@(item.ColorDet ?? item.HiloDet ?? "-")</td>
                            <td class="text-center">@(item.Unidad ?? "-")</td>
                            <td class="text-end">@(item.Cantidad?.ToString("N2") ?? "-")</td>
                            <td class="text-end">@(item.Precio?.ToString("N2") ?? "-")</td>
                            <td class="text-end">@(cantDespacho?.ToString("N2") ?? "-")</td>
                            <td class="text-end">@(saldo?.ToString("N2") ?? "-")</td>
                            <td class="text-center">
                                @if (ViewBag.TieneGuias == true)
                                {
                                    <a asp-action="Guias"
                                       asp-route-pedSerie="@item.Serie"
                                       asp-route-numPed="@item.NumPed"
                                       asp-route-nro="@item.Nro"
                                       asp-route-buscar="@buscar"
                                       class="btn btn-sm btn-outline-info btn-accion"
                                       title="Ver guías asociadas">
                                        <i class="bi bi-truck"></i> Guías
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                    @if (Model.Any())
                    {
                        decimal sumCant   = (decimal)(ViewBag.SumCantidad     ?? 0m);
                        decimal sumPrec   = (decimal)(ViewBag.SumPrecio       ?? 0m);
                        decimal sumDesp   = (decimal)(ViewBag.SumCantDespacho ?? 0m);
                        decimal sumDif    = (decimal)(ViewBag.SumDifDespacho  ?? 0m);
                        <tr class="table-secondary fw-semibold border-top">
                            <td colspan="5" class="text-end pe-3">Totales:</td>
                            <td class="text-end">@sumCant.ToString("N2")</td>
                            <td class="text-end">@sumPrec.ToString("N2")</td>
                            <td class="text-end">@sumDesp.ToString("N2")</td>
                            <td class="text-end">@sumDif.ToString("N2")</td>
                            <td></td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                <i class="bi bi-inbox me-2"></i>No se encontraron ítems para este pedido.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer py-2">
        @{
            int currentPage = ViewBag.Page       != null ? Convert.ToInt32(ViewBag.Page)       : 1;
            int totalPages  = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
            int totalCount  = ViewBag.TotalCount != null ? Convert.ToInt32(ViewBag.TotalCount) : 0;
            int pgSize      = ViewBag.PageSize   != null ? Convert.ToInt32(ViewBag.PageSize)   : 10;
            int startItem   = totalCount == 0 ? 0 : (currentPage - 1) * pgSize + 1;
            int endItem     = Math.Min(currentPage * pgSize, totalCount);
        }
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @(totalCount == 0 ? "Sin registros" : $"Mostrando {startItem}\u2013{endItem} de {totalCount} registros")
            </small>
            @if (totalPages > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="DetallePedido"
                               asp-route-serie="@pedido?.Serie" asp-route-numPed="@pedido?.NumPed"
                               asp-route-buscar="@buscar"
                               asp-route-page="@(currentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                        </li>
                        @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
                        {
                            <li class="page-item @(pg == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="DetallePedido"
                                   asp-route-serie="@pedido?.Serie" asp-route-numPed="@pedido?.NumPed"
                                   asp-route-buscar="@buscar"
                                   asp-route-page="@pg">@pg</a>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="DetallePedido"
                               asp-route-serie="@pedido?.Serie" asp-route-numPed="@pedido?.NumPed"
                               asp-route-buscar="@buscar"
                               asp-route-page="@(currentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
