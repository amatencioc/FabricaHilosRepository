                ctx.textBaseline = 'top';
                for (var g = 0; g < groupInfoImp.length; g++) {
                    var gi = groupInfoImp[g];
                    var firstBar = xScale.getPixelForValue(gi.startIdx);
                    var lastBar = xScale.getPixelForValue(gi.endIdx);
                    var xCenter = (firstBar + lastBar) / 2;
                    ctx.fillText(gi.asesor, xCenter, yLabel);
                }
                ctx.restore();
            }
        };

        /* Year legend plugin (only when multiple years) */
        var yearLegendPluginImp = {
            id: 'yearLegendPluginImp',
            afterDraw: function(chart) {
                if (!multiYear) return;
                var ctx = chart.ctx;
                var area = chart.chartArea;
                ctx.save();
                var x = area.right - 10;
                var y = area.top + 10;
                ctx.font = 'bold 11px "Segoe UI", sans-serif';
                ctx.textAlign = 'right';
                ctx.textBaseline = 'top';
                for (var i = 0; i < years.length; i++) {
                    var color = YEAR_COLORS[i % YEAR_COLORS.length];
                    ctx.fillStyle = color;
                    ctx.fillRect(x - 50, y + i * 20, 14, 14);
                    ctx.fillStyle = '#333';
                    ctx.fillText(years[i].toString(), x, y + i * 20 + 2);
                }
                ctx.restore();
            }
        };

        charts['topImporte'] = new Chart(document.getElementById('chartTopImporte').getContext('2d'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Importe',
                    data: dataImp,
                    backgroundColor: bgColors,
                    borderRadius: 4,
                    maxBarThickness: 55,
                    barPercentage: 0.9,
                    categoryPercentage: 0.85
                }]
            },
            plugins: [topGroupPluginImp, yearLegendPluginImp],
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { top: 30, bottom: 28 } },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        filter: function(item) { return item.raw != null; },
                        callbacks: {
                            title: function(items) {
                                var i = items[0].dataIndex;
                                var base = (labels[i] || '').replace(/\n\(\d+\)/, '');
                                for (var g = 0; g < groupInfoImp.length; g++) {
                                    if (i >= groupInfoImp[g].startIdx && i <= groupInfoImp[g].endIdx) {
                                        return base + ' — ' + groupInfoImp[g].asesor;
                                    }
                                }
                                return base;
                            },
                            label: function(c) { return monLabel + ' ' + fmt(c.raw); }
                        }
                    },
                    datalabels: {
                        display: function(ctx) { return ctx.dataset.data[ctx.dataIndex] != null && ctx.dataset.data[ctx.dataIndex] > 0; },
                        anchor: 'end', align: 'top',
                        font: { size: 10, weight: '700' },
                        color: '#333',
                        formatter: function(v) { return monLabel + ' ' + fmtMil(v); }
                    }
                },
                scales: {
                    x: {
                        ticks: {
                            font: { size: 9 },
                            autoSkip: false,
                            maxRotation: 0,
                            padding: 4,
                            callback: function(value, index) {
                                var lbl = labels[index] || '';
                                if (!lbl) return '';
                                /* Split on \n first (for year suffix) then word-wrap */
                                var parts = lbl.split('\n');
                                var lines = [];
                                parts.forEach(function(part) {
                                    var words = part.split(' ');
                                    var line = '';
                                    for (var w = 0; w < words.length; w++) {
                                        if (line.length + words[w].length > 12) {
                                            if (line.trim()) lines.push(line.trim());
                                            line = '';
                                        }
                                        line += words[w] + ' ';
                                    }
                                    if (line.trim()) lines.push(line.trim());
                                });
                                return lines;
                            }
                        },
                        grid: { display: false }
                    },
                    y: { beginAtZero: true, ticks: { callback: function(v) { return monLabel + ' ' + fmtMil(v); } } }
                }
            }
        });
    }

    /* ═════════════════════════════════════════════════
       CARGAR TODOS LOS DATOS
       ═════════════════════════════════════════════════ */
    window.loadAll = async function () {
        const p = buildParams();

        showSpin('spinnerTopKg');
        showSpin('spinnerTopImporte');

        const errors = [];

        const [impRes, kgRes, cliRes, topRes] = await Promise.allSettled([
            apiFetch('@Url.Action("DatosImportePorAsesor", "DashboardComercial")?' + p),
            apiFetch('@Url.Action("DatosCantidadKgPorAsesor", "DashboardComercial")?' + p),
            apiFetch('@Url.Action("DatosNroClientesPorAsesor", "DashboardComercial")?' + p),
            apiFetch('@Url.Action("DatosTopClientesPorAsesor", "DashboardComercial")?' + p + '&top=3')
        ]);

        if (impRes.status === 'fulfilled') {
            importeData = impRes.value;
        }
        else { console.error(impRes.reason); errors.push('Importe'); }

        if (kgRes.status === 'fulfilled') {
            kgData = kgRes.value;
        }
        else { console.error(kgRes.reason); errors.push('Cantidad KG'); }

        if (cliRes.status === 'fulfilled') {
            clientesData = cliRes.value;
        }
        else { console.error(cliRes.reason); errors.push('Nro Clientes'); }

        if (topRes.status === 'fulfilled') { topClientesData = topRes.value; renderTopKg(); renderTopImporte(); }
        else { console.error(topRes.reason); errors.push('Top Clientes'); }
        hideSpin('spinnerTopKg');
        hideSpin('spinnerTopImporte');

        if (errors.length > 0) {
            showToast('Error al cargar: ' + errors.join(', ') + '. Verifique su conexión.', 'danger');
        }

        // Gráficos de resumen (calculados client-side)
        renderResumen();
    };

    /* ── Limpiar filtros ──────────────────────────── */
    window.clearFilters = function () {
        document.getElementById('moneda').value = 'D';
        const curYear = new Date().getFullYear();
        document.querySelectorAll('#yearCheckBar input').forEach(cb => { cb.checked = parseInt(cb.value) === curYear; });
        fpSetDisabled('#fechaInicio', false);
        fpSetDisabled('#fechaFin', false);
        setDefaultDates();
        loadAll();
    };

    /* ── Inicio ───────────────────────────────────── */
    buildYearCheckboxes();
    setDefaultDates();
    loadAll();
})();
</script>
}
