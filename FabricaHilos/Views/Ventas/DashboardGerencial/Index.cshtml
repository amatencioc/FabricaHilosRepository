    initMap();
    /* Leyenda inicial del mapa (se actualiza dinámicamente con datos reales) */
    (function () { var el = document.getElementById('mapLegend'); if (el) { var lh = ''; ['Perú','LATAM','Global'].forEach(function (m) { lh += '<span class="legend-item" style="background:rgba(0,0,0,.18);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:.2rem .7rem;color:#e8f4fd;"><span class="legend-dot" style="background:' + MERCADO_COLORS[m] + ';box-shadow:0 0 6px ' + MERCADO_COLORS[m] + '88"></span>' + m + '</span>'; }); lh += '<span class="legend-item" style="background:rgba(0,0,0,.18);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:.2rem .7rem;color:#90a4ae;"><span class="legend-dot" style="background:#263d50"></span>Sin datos</span>'; el.innerHTML = lh; } })();

    function handleDonutClick(evt, elements) { if (!elements || elements.length === 0) return; const idx = elements[0].index; const mercado = charts['mercado'].data.labels[idx]; loadDetallePais(mercado); if (mercado === 'Perú') { loadDetalleDpto(); } else { document.getElementById('detalleDptoPanel').style.display = 'none'; } }
    /* Mapear mercado en drill-down: Global agrupa Europa,Asia,Oceanía,Otros */
    const GLOBAL_MERCADOS = ['Europa', 'Asia', 'Oceanía', 'Otros'];

    /* ── Detalle por País ── */
    let _detallePaisData = []; let _detallePaisMercado = '';
    async function loadDetallePais(mercado, highlightPais) {
        document.getElementById('detallePaisPanel').style.display = 'block'; document.getElementById('detallePaisTitulo').textContent = mercado; document.getElementById('detalleCiudadPaisPanel').style.display = 'none'; _detallePaisMercado = mercado; showSpin('spinnerDetallePais');
        const hlNorm = (highlightPais ?? '').toUpperCase().trim();
