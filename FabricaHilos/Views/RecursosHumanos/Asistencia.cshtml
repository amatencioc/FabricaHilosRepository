@model IEnumerable<FabricaHilos.Models.RecursosHumanos.Asistencia>
@using FabricaHilos.Models.RecursosHumanos

@{
    ViewData["Title"] = "Asistencia";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Recursos Humanos</a></li>
    <li class="breadcrumb-item active">Asistencia</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-calendar-check me-2"></i>Control de Asistencia</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Gerencia") || User.IsInRole("Supervisor"))
    {
        <a asp-action="RegistrarAsistencia" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Registrar Asistencia
        </a>
    }
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2 flex-wrap">
            <select name="empleadoId" class="form-select form-select-sm" style="max-width: 220px;">
                <option value="">Todos los empleados</option>
                @if (ViewBag.Empleados != null)
                {
                    @foreach (var emp in ViewBag.Empleados)
                    {
                        <option value="@emp.Id" selected="@(ViewBag.EmpleadoId?.ToString() == emp.Id.ToString())">@emp.NombreCompleto</option>
                    }
                }
            </select>
            <input type="date" name="fecha" class="form-control form-control-sm" style="max-width: 160px;"
                   value="@(((DateTime)ViewBag.Fecha).ToString("yyyy-MM-dd"))" />
            <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-search"></i> Filtrar</button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th>Empleado</th>
                        <th>Fecha</th>
                        <th>Hora Entrada</th>
                        <th>Hora Salida</th>
                        <th>Estado</th>
                        <th>Observaciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@(item.Empleado?.NombreCompleto ?? "-")</td>
                            <td>@item.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@(item.HoraEntrada?.ToString(@"hh\:mm") ?? "-")</td>
                            <td>@(item.HoraSalida?.ToString(@"hh\:mm") ?? "-")</td>
                            <td>
                                @{
                                    var estadoClass = item.Estado switch
                                    {
                                        EstadoAsistencia.Presente => "bg-success",
                                        EstadoAsistencia.Falta => "bg-danger",
                                        EstadoAsistencia.Tardanza => "bg-warning text-dark",
                                        EstadoAsistencia.PermisoJustificado => "bg-info text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @estadoClass">@item.Estado</span>
                            </td>
                            <td>@(item.Observaciones ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay registros de asistencia para este filtro.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
