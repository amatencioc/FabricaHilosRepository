@model LaColonial.Models.ContactoForm
@{
    ViewData["Title"] = "Contacto";
    ViewData["ActivePage"] = "Contacto";
    ViewData["Description"] = "Contacte a La Colonial Fábrica de Hilos S.A. — Av. Argentina 4151, Callao, Perú. Tel: (511) 613-0200.";
    bool mensajeEnviado = TempData["MensajeEnviado"]?.ToString() == "true";
}

<!-- HERO CONTACTO -->
<section style="
    position:relative;
    margin-top:var(--navbar-height-mobile);
    background:var(--gradient-primary);
    padding:var(--spacing-2xl) 0 var(--spacing-xl);
    text-align:center;overflow:hidden;"
    aria-labelledby="contacto-hero-heading">
    <div class="container" style="position:relative;z-index:1;">
        <div class="section-divider centered"></div>
        <h1 id="contacto-hero-heading" style="font-size:clamp(2rem,5vw,3.5rem);font-weight:700;color:var(--color-white);margin-bottom:var(--spacing-sm);">
            Contáctenos
        </h1>
        <p style="color:rgba(255,255,255,0.85);max-width:520px;margin:0 auto;font-size:var(--font-size-md);">
            Nuestro equipo de ventas le atenderá personalmente
        </p>
    </div>
</section>

<!-- CONTACTO PRINCIPAL -->
<section class="contacto-section section-pad" aria-labelledby="contacto-form-heading">
    <div class="container">

        @if (mensajeEnviado)
        {
            <div style="
                background:#d4edda;border:1.5px solid #28a745;
                border-radius:var(--border-radius-lg);
                padding:var(--spacing-md);
                margin-bottom:var(--spacing-xl);
                display:flex;align-items:center;gap:var(--spacing-sm);"
                role="alert">
                <i class="fa-solid fa-circle-check" style="color:#28a745;font-size:1.5rem;" aria-hidden="true"></i>
                <div>
                    <strong style="color:#155724;">¡Mensaje enviado con éxito!</strong>
                    <p style="color:#155724;margin:0;font-size:var(--font-size-sm);">Nos pondremos en contacto con usted a la brevedad posible.</p>
                </div>
            </div>
        }

        <div class="contacto-inner">

            <!-- INFO -->
            <aside class="contacto-info" data-aos="fade-up">
                <div>
                    <div class="section-divider"></div>
                    <h2 class="section-title" id="contacto-form-heading">Información de contacto</h2>
                    <p class="section-subtitle">Estamos disponibles de lunes a viernes para atender su consulta.</p>
                </div>

                <div class="contacto-item">
                    <div class="contacto-icon-wrap"><i class="fa-solid fa-location-dot" aria-hidden="true"></i></div>
                    <div class="contacto-item-body">
                        <h4>Dirección</h4>
                        <p>Av. Argentina 4151<br>Callao, Perú</p>
                    </div>
                </div>
                <div class="contacto-item">
                    <div class="contacto-icon-wrap"><i class="fa-solid fa-phone" aria-hidden="true"></i></div>
                    <div class="contacto-item-body">
                        <h4>Teléfonos</h4>
                        <p>Central: <a href="tel:+5116130200">(511) 613-0200</a></p>
                        <p>Alfredo A.: <a href="tel:+51983285824">983 285 824</a></p>
                        <p>Diana M.: <a href="tel:+51944574034">944 574 034</a></p>
                    </div>
                </div>
                <div class="contacto-item">
                    <div class="contacto-icon-wrap"><i class="fa-solid fa-envelope" aria-hidden="true"></i></div>
                    <div class="contacto-item-body">
                        <h4>Email</h4>
                        <a href="mailto:ventas@@colonial.com.pe">ventas@@colonial.com.pe</a>
                    </div>
                </div>
                <div class="contacto-item">
                    <div class="contacto-icon-wrap"><i class="fa-solid fa-clock" aria-hidden="true"></i></div>
                    <div class="contacto-item-body">
                        <h4>Horario de atención</h4>
                        <p>Lunes a Viernes: 8:00 am – 6:00 pm</p>
                        <p>Sábado: 8:00 am – 1:00 pm</p>
                    </div>
                </div>

                <!-- REDES SOCIALES -->
                <div>
                    <h4 style="font-size:var(--font-size-sm);font-weight:700;color:var(--color-primary);margin-bottom:var(--spacing-xs);">Síguenos</h4>
                    <div class="footer-social">
                        <a href="https://www.facebook.com/lacolonialsa" target="_blank" rel="noopener" aria-label="Facebook" style="background:var(--color-bg-medium);">
                            <i class="fa-brands fa-facebook-f" style="color:var(--color-primary);" aria-hidden="true"></i>
                        </a>
                        <a href="https://twitter.com/lacolonialsa" target="_blank" rel="noopener" aria-label="Twitter" style="background:var(--color-bg-medium);">
                            <i class="fa-brands fa-x-twitter" style="color:var(--color-primary);" aria-hidden="true"></i>
                        </a>
                        <a href="https://www.youtube.com/LaColonialSA" target="_blank" rel="noopener" aria-label="YouTube" style="background:var(--color-bg-medium);">
                            <i class="fa-brands fa-youtube" style="color:var(--color-primary);" aria-hidden="true"></i>
                        </a>
                    </div>
                </div>
            </aside>

            <!-- FORMULARIO -->
            <div class="contacto-form-wrap" data-aos="fade-up" data-aos-delay="100">
                <div style="background:var(--color-white);border-radius:var(--border-radius-xl);padding:var(--spacing-xl);box-shadow:var(--shadow-lg);">
                    <h3 style="font-size:var(--font-size-lg);font-weight:700;color:var(--color-primary);margin-bottom:var(--spacing-lg);">
                        <i class="fa-solid fa-paper-plane" style="color:var(--color-secondary);margin-right:8px;" aria-hidden="true"></i>
                        Envíenos un mensaje
                    </h3>

                    <form asp-action="Contacto" asp-controller="Home" method="post" class="contacto-form" id="contactoForm" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Nombre">Nombre completo <span style="color:var(--color-accent)">*</span></label>
                                <input asp-for="Nombre" class="form-control-col" placeholder="Su nombre" autocomplete="name" />
                                <span asp-validation-for="Nombre" style="color:var(--color-accent);font-size:var(--font-size-xs);"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Email">Correo electrónico <span style="color:var(--color-accent)">*</span></label>
                                <input asp-for="Email" type="email" class="form-control-col" placeholder="correo@empresa.com" autocomplete="email" />
                                <span asp-validation-for="Email" style="color:var(--color-accent);font-size:var(--font-size-xs);"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Telefono">Teléfono</label>
                                <input asp-for="Telefono" type="tel" class="form-control-col" placeholder="+51 999 000 000" autocomplete="tel" />
                            </div>
                            <div class="form-group">
                                <label asp-for="Asunto">Asunto</label>
                                <input asp-for="Asunto" class="form-control-col" placeholder="Ej: Cotización hilados" />
                            </div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Mensaje">Mensaje <span style="color:var(--color-accent)">*</span></label>
                            <textarea asp-for="Mensaje" class="form-control-col" rows="5"
                                      placeholder="Describa su consulta, producto de interés o solicitud..."></textarea>
                            <span asp-validation-for="Mensaje" style="color:var(--color-accent);font-size:var(--font-size-xs);"></span>
                        </div>

                        <button type="submit" class="btn-colonial btn-primary-col" style="width:100%;justify-content:center;">
                            <i class="fa-solid fa-paper-plane" aria-hidden="true"></i> Enviar mensaje
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- MAPA -->
<section class="section-pad" style="padding-top:0;" aria-label="Ubicación en mapa">
    <div class="container">
        <div style="border-radius:var(--border-radius-xl);overflow:hidden;box-shadow:var(--shadow-lg);aspect-ratio:16/9;max-height:450px;">
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3901.0!2d-77.0850!3d-12.0550!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105c7b8b8b8b8b8%3A0x0!2sAv.+Argentina+4151%2C+Callao!5e0!3m2!1ses!2spe!4v1700000000000!5m2!1ses!2spe"
                width="100%" height="100%"
                style="border:0;display:block;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Ubicación La Colonial Fábrica de Hilos — Av. Argentina 4151, Callao, Perú">
            </iframe>
        </div>
    </div>
</section>

@section Scripts {
<style>
    .field-error { border-color: var(--color-accent) !important; box-shadow: 0 0 0 3px rgba(230,62,42,0.12) !important; }
</style>
}
