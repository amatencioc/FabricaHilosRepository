    /* ═════════════════════════════════════════════════
       CHART 9 & 10: Top 3 Clientes por Asesor (Kilos e Importe)
       ═════════════════════════════════════════════════ */
    let topClientesData = [];

    function renderTopKg() {
        destroyChart('topKg');
        if (topClientesData.length === 0) return;

        /* Detect unique years */
        const yearsSet = new Set(topClientesData.map(d => d.anio));
        const years = [...yearsSet].sort();
        const multiYear = years.length > 1;

        /* Group by asesor, then by year */
        const grupos = {};
        topClientesData.forEach(function(d) {
            if (!grupos[d.asesor]) grupos[d.asesor] = {};
            var yr = d.anio || 0;
            if (!grupos[d.asesor][yr]) grupos[d.asesor][yr] = [];
            grupos[d.asesor][yr].push(d);
        });
        const asesores = Object.keys(grupos).sort();

        const labels = [];
        const dataKg = [];
        const bgColors = [];
        const groupInfoKg = [];

        asesores.forEach(function(asesor, ai) {
            /* spacer between groups */
            if (ai > 0) { labels.push(''); dataKg.push(null); bgColors.push('transparent'); }
            var startIdx = labels.length;
            var yrKeys = Object.keys(grupos[asesor]).sort();
            yrKeys.forEach(function(yr, yi) {
                /* spacer between years within same asesor */
                if (yi > 0 && multiYear) { labels.push(''); dataKg.push(null); bgColors.push('transparent'); }
                var clientes = grupos[asesor][yr].slice().sort(function(a, b) { return (b.cantidadKg || 0) - (a.cantidadKg || 0); });
                clientes.forEach(function(c) {
                    var lbl = c.razonSocial || '';
                    if (multiYear) lbl = lbl + '\n(' + yr + ')';
                    labels.push(lbl);
                    dataKg.push(c.cantidadKg || 0);
                    bgColors.push(multiYear ? YEAR_COLORS[years.indexOf(parseInt(yr)) % YEAR_COLORS.length] : COLORS[ai % COLORS.length]);
                });
            });
            groupInfoKg.push({ startIdx: startIdx, endIdx: labels.length - 1, asesor: asesor });
        });

        var chartH = Math.max(500, labels.length * 40);
        document.getElementById('chartTopKg').parentElement.style.height = chartH + 'px';

        var topGroupPluginKg = {
            id: 'topGroupPluginKg',
            afterDraw: function(chart) {
                var ctx = chart.ctx;
                var xScale = chart.scales.x;
                var area = chart.chartArea;
                ctx.save();
                /* Build separator positions between groups */
                var separators = [];
                for (var g = 0; g < groupInfoKg.length; g++) {
                    var gi = groupInfoKg[g];
                    if (gi.startIdx > 0) {
                        var xPrev = xScale.getPixelForValue(gi.startIdx - 1);
                        var xCur = xScale.getPixelForValue(gi.startIdx);
                        separators.push((xPrev + xCur) / 2);
                    }
                }
                var yLabel = area.bottom + (xScale.height - 4);
                /* Draw separator lines */
                for (var s = 0; s < separators.length; s++) {
                    ctx.strokeStyle = '#ccc';
                    ctx.lineWidth = 1;
                    ctx.setLineDash([4, 3]);
                    ctx.beginPath();
                    ctx.moveTo(separators[s], area.top);
                    ctx.lineTo(separators[s], yLabel - 2);
                    ctx.stroke();
                    ctx.setLineDash([]);
                }
                ctx.font = 'bold 12px "Segoe UI", sans-serif';
                ctx.fillStyle = '#1B4D3E';
                ctx.textAlign = 'center';
                ctx.textBaseline = 'top';
                for (var g = 0; g < groupInfoKg.length; g++) {
                    var gi = groupInfoKg[g];
                    var firstBar = xScale.getPixelForValue(gi.startIdx);
                    var lastBar = xScale.getPixelForValue(gi.endIdx);
                    var xCenter = (firstBar + lastBar) / 2;
                    ctx.fillText(gi.asesor, xCenter, yLabel);
                }
                ctx.restore();
            }
        };

        /* Year legend plugin (only when multiple years) */
        var yearLegendPluginKg = {
            id: 'yearLegendPluginKg',
            afterDraw: function(chart) {
                if (!multiYear) return;
                var ctx = chart.ctx;
                var area = chart.chartArea;
                ctx.save();
                var x = area.right - 10;
                var y = area.top + 10;
                ctx.font = 'bold 11px "Segoe UI", sans-serif';
                ctx.textAlign = 'right';
                ctx.textBaseline = 'top';
                for (var i = 0; i < years.length; i++) {
                    var color = YEAR_COLORS[i % YEAR_COLORS.length];
                    ctx.fillStyle = color;
                    ctx.fillRect(x - 50, y + i * 20, 14, 14);
                    ctx.fillStyle = '#333';
                    ctx.fillText(years[i].toString(), x, y + i * 20 + 2);
                }
                ctx.restore();
            }
        };

        charts['topKg'] = new Chart(document.getElementById('chartTopKg').getContext('2d'), {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Kilos',
                    data: dataKg,
                    backgroundColor: bgColors,
                    borderRadius: 4,
                    maxBarThickness: 55,
                    barPercentage: 0.9,
                    categoryPercentage: 0.85
                }]
            },
            plugins: [topGroupPluginKg, yearLegendPluginKg],
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { top: 30, bottom: 28 } },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        filter: function(item) { return item.raw != null; },
                        callbacks: {
                            title: function(items) {
                                var i = items[0].dataIndex;
                                var base = (labels[i] || '').replace(/\n\(\d+\)/, '');
                                for (var g = 0; g < groupInfoKg.length; g++) {
                                    if (i >= groupInfoKg[g].startIdx && i <= groupInfoKg[g].endIdx) {
                                        return base + ' — ' + groupInfoKg[g].asesor;
                                    }
                                }
                                return base;
                            },
                            label: function(c) { return fmt(c.raw) + ' KG'; }
                        }
                    },
                    datalabels: {
                        display: function(ctx) { return ctx.dataset.data[ctx.dataIndex] != null && ctx.dataset.data[ctx.dataIndex] > 0; },
                        anchor: 'end', align: 'top',
                        font: { size: 10, weight: '700' },
                        color: '#333',
                        formatter: function(v) { return fmtMil(v) + ' kg'; }
                    }
                },
                scales: {
                    x: {
                        ticks: {
                            font: { size: 9 },
                            autoSkip: false,
                            maxRotation: 0,
                            padding: 4,
                            callback: function(value, index) {
                                var lbl = labels[index] || '';
                                if (!lbl) return '';
                                /* Split on \n first (for year suffix) then word-wrap */
                                var parts = lbl.split('\n');
                                var lines = [];
                                parts.forEach(function(part) {
                                    var words = part.split(' ');
                                    var line = '';
                                    for (var w = 0; w < words.length; w++) {
                                        if (line.length + words[w].length > 12) {
                                            if (line.trim()) lines.push(line.trim());
                                            line = '';
                                        }
                                        line += words[w] + ' ';
                                    }
                                    if (line.trim()) lines.push(line.trim());
                                });
                                return lines;
                            }
                        },
                        grid: { display: false }
                    },
                    y: { beginAtZero: true, ticks: { callback: function(v) { return fmtMil(v); } } }
                }
            }
        });
    }

