@model FabricaHilos.Models.Produccion.RegistroAutoconer
@using FabricaHilos.Models.Produccion

@{
    ViewData["Title"] = "Nuevo Registro Autoconer";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Produccion" asp-action="Index">Producción</a></li>
    <li class="breadcrumb-item"><a asp-action="Index">Control Autoconer</a></li>
    <li class="breadcrumb-item active">Nuevo Registro</li>
}

<div class="d-flex align-items-center mb-4" style="border-bottom: 3px solid var(--color-secondary); padding-bottom: 10px;">
    <i class="bi bi-speedometer2 fs-3 me-3 text-success"></i>
    <h4 class="mb-0 fw-bold">Nuevo Registro Autoconer</h4>
</div>

<div class="row justify-content-center">
    <div class="col-12">
        <form asp-action="Crear" method="post" id="formCrear">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <!-- ===== CABECERA ===== -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-info-circle me-2"></i>Cabecera
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <!-- Autoconer N° -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Autoconer N° <span class="text-danger">*</span></label>
                            <select asp-for="NumeroAutoconer" id="autoconerSelect" class="form-select">
                                <option value="">Cargando...</option>
                            </select>
                            <span asp-validation-for="NumeroAutoconer" class="text-danger small"></span>
                        </div>

                        <!-- Operador -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Operador N° <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="text" id="operarioInput" class="form-control"
                                       placeholder="Últimos 4 dígitos" autocomplete="off" />
                                <button type="button" id="btnBuscarOperario" class="btn btn-outline-secondary" title="Buscar operario">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                            <input asp-for="CodigoOperador" id="operadorHidden" type="hidden" />
                            <span asp-validation-for="CodigoOperador" class="text-danger small"></span>
                            <small id="operarioStatus" class="text-muted"></small>
                            <small class="text-muted d-block">El prefijo 03 se agrega automáticamente.</small>
                        </div>

                        <!-- Fecha -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Fecha</label>
                            <input type="text" id="fechaDisplay" class="form-control" readonly
                                   style="background-color: var(--color-bg-light);" />
                            <input asp-for="Fecha" id="fechaHidden" type="hidden" />
                        </div>

                        <!-- Turno -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Turno <span class="text-danger">*</span></label>
                            <select asp-for="Turno" class="form-select">
                                <option value="">Seleccione un turno</option>
                                <option value="1">1er Turno</option>
                                <option value="2">2do Turno</option>
                                <option value="3">3er Turno</option>
                                <option value="4">12 Hrs Dia</option>
                                <option value="5">12 Hrs Noche</option>
                            </select>
                            <span asp-validation-for="Turno" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== DATOS DE PRODUCCIÓN ===== -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-clipboard-data me-2"></i>Datos de Producción
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <!-- Fila 1: Nº Partida | Receta | Lote -->
                        <!-- Nº Partida -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Nº Partida</label>
                            <div class="input-group">
                                <input asp-for="Guia" id="guiaInput" class="form-control"
                                       placeholder="Nº Partida" autocomplete="off" />
                                <button type="button" id="btnBuscarPartida" class="btn btn-outline-secondary" title="Buscar partida">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                            <small id="partidaStatus" class="text-muted"></small>
                        </div>

                        <!-- Receta (opcional) -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Receta <span class="text-muted small">(opcional)</span></label>
                            <div class="input-group">
                                <input asp-for="CodigoReceta" id="recetaInput" class="form-control"
                                       placeholder="Código de receta" autocomplete="off" />
                                <button type="button" id="btnBuscarReceta" class="btn btn-outline-secondary" title="Buscar receta">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                            <small id="recetaStatus" class="text-muted"></small>
                        </div>

                        <!-- Lote -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Lote / Partida <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Lote" id="loteInput" class="form-control"
                                       placeholder="Código de lote" autocomplete="off" />
                                <button type="button" id="btnBuscarLote" class="btn btn-outline-secondary" title="Buscar lote">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Lote" class="text-danger small"></span>
                            <small id="loteStatus" class="text-muted"></small>
                        </div>

                        <!-- Material -->
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Material <span class="text-danger">*</span></label>
                            <input asp-for="DescripcionMaterial" id="materialInput" class="form-control"
                                   placeholder="Se completará al buscar Nº Partida, receta o lote" readonly
                                   style="background-color: var(--color-bg-light);" />
                            <span asp-validation-for="DescripcionMaterial" class="text-danger small"></span>
                        </div>

                        <!-- Título -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Título <span class="text-danger">*</span></label>
                            <select asp-for="Titulo" class="form-select">
                                <option value="">Seleccione un título</option>
                                @if (ViewBag.Titulos != null)
                                {
                                    @foreach (var titulo in ViewBag.Titulos)
                                    {
                                        <option value="@titulo.Titulo">@titulo.TextoCompleto</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="Titulo" class="text-danger small"></span>
                        </div>

                        <!-- V (m/min) -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">V (m/min)</label>
                            <input asp-for="VelocidadMMin" class="form-control" type="number" step="0.01" min="0"
                                   placeholder="Velocidad" />
                        </div>

                        <!-- Fecha Inicio -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Fecha Inicio</label>
                            <input asp-for="HoraInicio" class="form-control" type="datetime-local" />
                        </div>

                        <!-- Fecha Fin -->
                        <div class="col-md-3">
                            <label class="form-label fw-semibold">Fecha Fin</label>
                            <input asp-for="HoraFinal" class="form-control" type="datetime-local" />
                        </div>

                        <!-- Destino -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Destino</label>
                            <select asp-for="Destino" id="destinoSelect" class="form-select">
                                <option value="">Cargando...</option>
                            </select>
                        </div>

                        <!-- Tramos -->
                        <div class="col-md-8">
                            <label class="form-label fw-semibold">Tramos</label>
                            <div class="d-flex gap-4 flex-wrap">
                                <div class="form-check">
                                    <input asp-for="Tramo1" class="form-check-input" type="checkbox" />
                                    <label asp-for="Tramo1" class="form-check-label fw-semibold">1</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="Tramo2" class="form-check-input" type="checkbox" />
                                    <label asp-for="Tramo2" class="form-check-label fw-semibold">2</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="Tramo3" class="form-check-input" type="checkbox" />
                                    <label asp-for="Tramo3" class="form-check-label fw-semibold">3</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="Tramo4" class="form-check-input" type="checkbox" />
                                    <label asp-for="Tramo4" class="form-check-label fw-semibold">4</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="Tramo5" class="form-check-input" type="checkbox" />
                                    <label asp-for="Tramo5" class="form-check-label fw-semibold">5</label>
                                </div>
                                <div class="form-check">
                                    <input asp-for="Tramo6" class="form-check-input" type="checkbox" />
                                    <label asp-for="Tramo6" class="form-check-label fw-semibold">6</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===== RESULTADOS ===== -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-bar-chart-line me-2"></i>Resultados
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        <!-- Conos o Rodetes -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Conos o Rodetes</label>
                            <input asp-for="Cantidad" id="conosMadejasInput" class="form-control" type="number" step="1" min="0"
                                   placeholder="0" />
                        </div>

                        <!-- Kg x Unidad -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Kg x Unidad</label>
                            <input asp-for="PesoBruto" id="kgUnidadInput" class="form-control" type="number" step="0.01" min="0"
                                   placeholder="0.00" />
                        </div>

                        <!-- Peso Neto -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Peso Neto</label>
                            <input id="pesoNetoDisplay" class="form-control" type="number" step="0.01" readonly
                                   placeholder="0.00" style="background-color: var(--color-bg-light);" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Campos ocultos -->
            <input type="hidden" asp-for="Estado" value="@EstadoOrden.EnProceso" />
            <input type="hidden" asp-for="Cerrado" value="false" />

            <div class="mt-4 d-flex gap-2">
                <button type="button" id="btnGuardar" class="btn btn-success px-4">
                    <i class="bi bi-save me-2"></i>Guardar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>

<!-- Modal de Confirmación -->
<div class="modal fade" id="modalConfirmar" tabindex="-1" aria-labelledby="modalConfirmarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalConfirmarLabel">Confirmar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                ¿Está seguro que desea guardar el registro Autoconer?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnAceptarModal" class="btn btn-success">Aceptar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // === Fecha en tiempo real ===
        function formatearFecha() {
            const now = new Date();
            const yyyy = now.getFullYear();
            const mm   = String(now.getMonth() + 1).padStart(2, '0');
            const dd   = String(now.getDate()).padStart(2, '0');
            const hh   = String(now.getHours()).padStart(2, '0');
            const mi   = String(now.getMinutes()).padStart(2, '0');
            const ss   = String(now.getSeconds()).padStart(2, '0');
            return { iso: `${yyyy}-${mm}-${dd}T${hh}:${mi}:${ss}`, display: `${dd}/${mm}/${yyyy} ${hh}:${mi}:${ss}` };
        }

        function actualizarFecha() {
            const f = formatearFecha();
            document.getElementById('fechaHidden').value  = f.iso;
            document.getElementById('fechaDisplay').value = f.display;
        }

        actualizarFecha();
        setInterval(actualizarFecha, 1000);

        function ahoraLocal() {
            const now = new Date();
            return [now.getFullYear(), String(now.getMonth()+1).padStart(2,'0'), String(now.getDate()).padStart(2,'0')].join('-')
                 + 'T' + [String(now.getHours()).padStart(2,'0'), String(now.getMinutes()).padStart(2,'0')].join(':');
        }

        function validarFechas() {
            const inicio = document.getElementById('HoraInicio').value;
            const fin    = document.getElementById('HoraFinal').value;
            if (inicio && fin) {
                if (fin < inicio) {
                    alert('La Fecha Fin no puede ser menor a la Fecha Inicio.');
                    return false;
                }
                if (fin > ahoraLocal()) {
                    alert('La Fecha Fin no puede ser mayor a la fecha actual del sistema.');
                    return false;
                }
            }
            return true;
        }

        // === Cargar máquinas Autoconer ===
        async function cargarMaquinas() {
            const sel = document.getElementById('autoconerSelect');
            try {
                const resp = await fetch('@Url.Action("ObtenerMaquinasAutoconer", "Autoconer")');
                const data = await resp.json();
                sel.innerHTML = '<option value="">Seleccione Autoconer</option>';
                if (data.success && data.maquinas) {
                    data.maquinas.forEach(m => {
                        const opt = document.createElement('option');
                        opt.value       = m.codigo;
                        opt.textContent = m.descripcion || m.codigo;
                        sel.appendChild(opt);
                    });
                }
            } catch (e) {
                sel.innerHTML = '<option value="">Error al cargar</option>';
            }
        }

        cargarMaquinas();

        // === Cargar destinos Autoconer ===
        async function cargarDestinos() {
            const sel = document.getElementById('destinoSelect');
            try {
                const resp = await fetch('@Url.Action("ObtenerDestinosAutoconer", "Autoconer")');
                const data = await resp.json();
                sel.innerHTML = '<option value="">Seleccione destino</option>';
                if (data.success && data.destinos) {
                    data.destinos.forEach(d => {
                        const opt = document.createElement('option');
                        opt.value       = d.codigo;
                        opt.textContent = d.codigo + ' - ' + d.descripcion;
                        sel.appendChild(opt);
                    });
                }
            } catch (e) {
                sel.innerHTML = '<option value="">Error al cargar</option>';
            }
        }

        cargarDestinos();

        // === Calcular Peso Neto ===
        function calcularPesoNeto() {
            const conos  = parseFloat(document.getElementById('conosMadejasInput').value) || 0;
            const kgUnit = parseFloat(document.getElementById('kgUnidadInput').value)     || 0;
            document.getElementById('pesoNetoDisplay').value = (conos * kgUnit).toFixed(2);
        }
        // === Búsqueda de Nº Partida ===
        function seleccionarTitulo(titulo, bloquear = false) {
            const sel = document.getElementById('Titulo');
            if (!sel) return;
            if (titulo) {
                const opt = Array.from(sel.options).find(o => o.value === titulo.trim());
                if (opt) sel.value = opt.value;
            }
            if (bloquear) {
                sel.style.pointerEvents    = 'none';
                sel.style.opacity          = '0.65';
                sel.style.backgroundColor  = 'var(--color-bg-light)';
            } else {
                sel.style.pointerEvents    = '';
                sel.style.opacity          = '';
                sel.style.backgroundColor  = '';
            }
        }

        let _titulosRestringidosHtml = '';

        function bloquearCamposPartida(bloquear) {
            ['recetaInput', 'btnBuscarReceta', 'loteInput', 'btnBuscarLote'].forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                if (bloquear) {
                    el.style.pointerEvents   = 'none';
                    el.style.opacity         = '0.65';
                    if (el.tagName === 'INPUT') el.style.backgroundColor = 'var(--color-bg-light)';
                } else {
                    el.style.pointerEvents   = '';
                    el.style.opacity         = '';
                    el.style.backgroundColor = '';
                }
            });
        }

        async function cargarTitulosPartida() {
            const sel = document.getElementById('Titulo');
            if (!sel) return;
            try {
                const resp = await fetch('@Url.Action("ObtenerTitulos", "Autoconer")');
                const data = await resp.json();
                if (data.success && data.titulos) {
                    sel.innerHTML = '<option value="">Seleccione un título</option>';
                    data.titulos.forEach(t => {
                        const opt = document.createElement('option');
                        opt.value       = t.codigo;
                        opt.textContent = t.descripcion;
                        sel.appendChild(opt);
                    });
                }
            } catch (e) { /* mantener opciones actuales */ }
        }

        function restaurarTitulosRestringidos() {
            const sel = document.getElementById('Titulo');
            if (sel && _titulosRestringidosHtml) {
                sel.innerHTML = _titulosRestringidosHtml;
                sel.value = '';
            }
        }

        async function buscarPartida() {
            const guia   = document.getElementById('guiaInput').value.trim();
            const status = document.getElementById('partidaStatus');
            const btn    = document.getElementById('btnBuscarPartida');
            if (!guia) { status.textContent = 'Ingrese un Nº Partida'; status.className = 'text-danger small'; return; }

            btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';
            status.textContent = 'Buscando...'; status.className = 'text-info small';

            try {
                const resp   = await fetch(`@Url.Action("BuscarPartida", "Autoconer")?guia=${encodeURIComponent(guia)}`);
                const result = await resp.json();
                if (result.success && result.data) {
                    document.getElementById('guiaInput').value     = result.data.guia;
                    document.getElementById('loteInput').value     = result.data.lote;
                    document.getElementById('materialInput').value = result.data.material;
                    document.getElementById('recetaInput').value   = '';
                    await cargarTitulosPartida();
                    seleccionarTitulo(result.data.titulo, true);
                    bloquearCamposPartida(true);
                    status.textContent = '✓ Partida encontrada'; status.className = 'text-success small';
                    document.getElementById('loteStatus').textContent    = '';
                    document.getElementById('recetaStatus').textContent  = '';
                    realzarCampo('materialInput');
                } else if (result.success && result.multiple) {
                    mostrarLista('partidaDropdownList', result.items.map(i => ({
                        texto: i.guia
                            + (i.titulo  ? ' [' + i.titulo + ']' : '')
                            + (i.lote    ? ' — Lote: ' + i.lote  : '')
                            + (i.cliente ? ' | ' + i.cliente      : ''),
                        accion: async () => {
                            document.getElementById('guiaInput').value     = i.guia;
                            document.getElementById('loteInput').value     = i.lote;
                            document.getElementById('materialInput').value = i.material;
                            document.getElementById('recetaInput').value   = '';
                            await cargarTitulosPartida();
                            seleccionarTitulo(i.titulo, true);
                            bloquearCamposPartida(true);
                            status.textContent = '✓ Partida seleccionada'; status.className = 'text-success small';
                            document.getElementById('loteStatus').textContent   = '';
                            document.getElementById('recetaStatus').textContent = '';
                            realzarCampo('materialInput');
                        }
                    })), document.getElementById('guiaInput'));
                    status.textContent = result.items.length + ' partidas encontradas.'; status.className = 'text-info small';
                } else {
                    status.textContent = '✗ ' + (result.message || 'No encontrada'); status.className = 'text-warning small';
                }
            } catch { status.textContent = '✗ Error al buscar'; status.className = 'text-danger small'; }
            finally   { btn.disabled = false; btn.innerHTML = '<i class="bi bi-search"></i>'; }
        }

        async function buscarReceta() {
            const codigo = document.getElementById('recetaInput').value.trim();
            const status = document.getElementById('recetaStatus');
            const btn    = document.getElementById('btnBuscarReceta');
            if (!codigo) { status.textContent = 'Ingrese un código'; status.className = 'text-danger small'; return; }

            btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';
            status.textContent = 'Buscando...'; status.className = 'text-info small';

            try {
                const resp   = await fetch(`@Url.Action("BuscarReceta", "Autoconer")?codigo=${encodeURIComponent(codigo)}`);
                const result = await resp.json();
                if (result.success && result.data) {
                    document.getElementById('recetaInput').value   = result.data.numero;
                    document.getElementById('loteInput').value     = result.data.lote;
                    document.getElementById('materialInput').value = result.data.material;
                    restaurarTitulosRestringidos();
                    bloquearCamposPartida(false);
                    seleccionarTitulo(null, false);
                    status.textContent = '✓ Receta encontrada'; status.className = 'text-success small';
                    document.getElementById('loteStatus').textContent = '';
                    realzarCampo('materialInput');
                } else if (result.success && result.multiple) {
                    mostrarLista('recetaDropdownList', result.items.map(i => ({
                        texto: i.numero + (i.material ? ' — ' + i.material : ''),
                        accion: () => {
                            document.getElementById('recetaInput').value   = i.numero;
                            document.getElementById('loteInput').value     = i.lote;
                            document.getElementById('materialInput').value = i.material;
                            restaurarTitulosRestringidos();
                            bloquearCamposPartida(false);
                            seleccionarTitulo(null, false);
                            status.textContent = '✓ Receta seleccionada'; status.className = 'text-success small';
                            realzarCampo('materialInput');
                        }
                    })), document.getElementById('recetaInput'));
                    status.textContent = result.items.length + ' recetas encontradas.'; status.className = 'text-info small';
                } else {
                    status.textContent = '✗ ' + (result.message || 'No encontrada'); status.className = 'text-warning small';
                }
            } catch { status.textContent = '✗ Error al buscar'; status.className = 'text-danger small'; }
            finally   { btn.disabled = false; btn.innerHTML = '<i class="bi bi-search"></i>'; }
        }

        // === Búsqueda de Lote ===
        async function buscarLote() {
            const codigo = document.getElementById('loteInput').value.trim();
            const status = document.getElementById('loteStatus');
            const btn    = document.getElementById('btnBuscarLote');
            if (!codigo) { status.textContent = 'Ingrese un código'; status.className = 'text-danger small'; return; }

            btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';
            status.textContent = 'Buscando...'; status.className = 'text-info small';

            try {
                const resp   = await fetch(`@Url.Action("BuscarLote", "Autoconer")?codigo=${encodeURIComponent(codigo)}`);
                const result = await resp.json();
                if (result.success && result.data) {
                    document.getElementById('loteInput').value     = result.data.lote;
                    document.getElementById('recetaInput').value   = '';
                    document.getElementById('guiaInput').value     = '';
                    document.getElementById('materialInput').value = result.data.material;
                    document.getElementById('recetaStatus').textContent  = '';
                    document.getElementById('partidaStatus').textContent = '';
                    restaurarTitulosRestringidos();
                    bloquearCamposPartida(false);
                    seleccionarTitulo(null, false);
                    status.textContent = '✓ Lote encontrado'; status.className = 'text-success small';
                    realzarCampo('materialInput');
                } else if (result.success && result.multiple) {
                    mostrarLista('loteDropdownList', result.items.map(i => ({
                        texto: i.lote + (i.material ? ' — ' + i.material : ''),
                        accion: () => {
                            document.getElementById('loteInput').value     = i.lote;
                            document.getElementById('recetaInput').value   = '';
                            document.getElementById('guiaInput').value     = '';
                            document.getElementById('materialInput').value = i.material;
                            document.getElementById('recetaStatus').textContent  = '';
                            document.getElementById('partidaStatus').textContent = '';
                            restaurarTitulosRestringidos();
                            bloquearCamposPartida(false);
                            seleccionarTitulo(null, false);
                            status.textContent = '✓ Lote seleccionado'; status.className = 'text-success small';
                            realzarCampo('materialInput');
                        }
                    })), document.getElementById('loteInput'));
                    status.textContent = result.items.length + ' lotes encontrados.'; status.className = 'text-info small';
                } else {
                    status.textContent = '✗ ' + (result.message || 'No encontrado'); status.className = 'text-warning small';
                }
            } catch { status.textContent = '✗ Error al buscar'; status.className = 'text-danger small'; }
            finally   { btn.disabled = false; btn.innerHTML = '<i class="bi bi-search"></i>'; }
        }

        // === Búsqueda de Operario ===
        async function buscarOperario() {
            const digitos = document.getElementById('operarioInput').value.trim();
            const status  = document.getElementById('operarioStatus');
            const btn     = document.getElementById('btnBuscarOperario');
            if (!digitos) { status.textContent = 'Ingrese los últimos 4 dígitos'; status.className = 'text-danger small'; return; }

            const codigo = '03' + digitos;
            btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i>';
            status.textContent = 'Buscando...'; status.className = 'text-info small';

            try {
                const resp   = await fetch(`@Url.Action("BuscarOperario", "Autoconer")?codigo=${encodeURIComponent(codigo)}`);
                const result = await resp.json();
                if (result.success && result.items && result.items.length === 1) {
                    seleccionarOperario(result.items[0]);
                } else if (result.success && result.items && result.items.length > 1) {
                    mostrarLista('operarioDropdownList', result.items.map(i => ({
                        texto: i.codigo + ' — ' + i.nombre,
                        accion: () => seleccionarOperario(i)
                    })), document.getElementById('operarioInput'));
                    status.textContent = result.items.length + ' encontrados.'; status.className = 'text-info small';
                } else {
                    status.textContent = '✗ ' + (result.message || 'No encontrado'); status.className = 'text-warning small';
                    document.getElementById('operadorHidden').value = '';
                }
            } catch { status.textContent = '✗ Error al buscar'; status.className = 'text-danger small'; }
            finally   { btn.disabled = false; btn.innerHTML = '<i class="bi bi-search"></i>'; }
        }

        function seleccionarOperario(item) {
            cerrarLista('operarioDropdownList');
            document.getElementById('operarioInput').value  = item.nombre + ' (' + item.codigo + ')';
            document.getElementById('operadorHidden').value = item.codigo;
            const status = document.getElementById('operarioStatus');
            status.textContent = '✓ Operario seleccionado'; status.className = 'text-success small';
        }

        // === Helpers ===
        function realzarCampo(id) {
            const el = document.getElementById(id);
            el.style.backgroundColor = 'var(--color-success-light)';
            setTimeout(() => { el.style.backgroundColor = 'var(--color-bg-light)'; }, 2000);
        }

        function cerrarLista(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }

        function mostrarLista(listId, items, anchorEl) {
            cerrarLista(listId);
            const ul = document.createElement('ul');
            ul.id        = listId;
            ul.className = 'list-group mt-1 shadow-sm';
            ul.style.cssText = 'max-height:200px;overflow-y:auto;cursor:pointer;position:relative;z-index:1000;';
            items.forEach(item => {
                const li = document.createElement('li');
                li.className = 'list-group-item list-group-item-action py-1 px-2 small';
                li.textContent = item.texto;
                li.addEventListener('click', () => { cerrarLista(listId); item.accion(); });
                ul.appendChild(li);
            });
            anchorEl.closest('.input-group, .col-md-6, .col-md-4, .col-md-3').appendChild(ul);
            const cerrar = e => {
                if (!ul.contains(e.target) && e.target !== anchorEl) { cerrarLista(listId); document.removeEventListener('click', cerrar); }
            };
            setTimeout(() => document.addEventListener('click', cerrar), 0);
        }

        // === Eventos ===
        document.addEventListener('DOMContentLoaded', function () {
            // Cache de títulos restringidos (para flujo Receta / Lote)
            const tituloSel = document.getElementById('Titulo');
            if (tituloSel) _titulosRestringidosHtml = tituloSel.innerHTML;

            // Valores por defecto para fechas
            const ahora = ahoraLocal();
            if (!document.getElementById('HoraInicio').value) document.getElementById('HoraInicio').value = ahora;
            if (!document.getElementById('HoraFinal').value) document.getElementById('HoraFinal').value = ahora;

            // Nº Partida
            document.getElementById('btnBuscarPartida').addEventListener('click', buscarPartida);
            document.getElementById('guiaInput').addEventListener('keypress', e => { if (e.key === 'Enter') { e.preventDefault(); buscarPartida(); } });
            document.getElementById('guiaInput').addEventListener('input', () => {
                document.getElementById('partidaStatus').textContent = '';
                cerrarLista('partidaDropdownList');
                bloquearCamposPartida(false);
                seleccionarTitulo(null, false);
                restaurarTitulosRestringidos();
                document.getElementById('loteInput').value      = '';
                document.getElementById('materialInput').value  = '';
                document.getElementById('loteStatus').textContent = '';
            });

            // Receta
            document.getElementById('btnBuscarReceta').addEventListener('click', buscarReceta);
            document.getElementById('recetaInput').addEventListener('keypress', e => { if (e.key === 'Enter') { e.preventDefault(); buscarReceta(); } });
            document.getElementById('recetaInput').addEventListener('input', () => { document.getElementById('recetaStatus').textContent = ''; cerrarLista('recetaDropdownList'); });

            // Lote
            document.getElementById('btnBuscarLote').addEventListener('click', buscarLote);
            document.getElementById('loteInput').addEventListener('keypress', e => { if (e.key === 'Enter') { e.preventDefault(); buscarLote(); } });
            document.getElementById('loteInput').addEventListener('input', () => { document.getElementById('loteStatus').textContent = ''; cerrarLista('loteDropdownList'); });

            // Operario
            document.getElementById('btnBuscarOperario').addEventListener('click', buscarOperario);
            document.getElementById('operarioInput').addEventListener('keypress', e => { if (e.key === 'Enter') { e.preventDefault(); buscarOperario(); } });
            document.getElementById('operarioInput').addEventListener('input', () => {
                document.getElementById('operarioStatus').textContent = '';
                cerrarLista('operarioDropdownList');
                document.getElementById('operadorHidden').value = '';
            });

            // Guardar con confirmación
            document.getElementById('btnGuardar').addEventListener('click', function () {
                if (!validarFechas()) return;
                const modal = new bootstrap.Modal(document.getElementById('modalConfirmar'));
                modal.show();
            });

            document.getElementById('btnAceptarModal').addEventListener('click', function () {
                bootstrap.Modal.getInstance(document.getElementById('modalConfirmar'))?.hide();
                document.getElementById('formCrear').submit();
            });

            // Conos Madejas / Kg x Unidad → Peso Neto
            document.getElementById('conosMadejasInput').addEventListener('input', calcularPesoNeto);
            document.getElementById('kgUnidadInput').addEventListener('input', calcularPesoNeto);
            calcularPesoNeto();
        });
    </script>
}
