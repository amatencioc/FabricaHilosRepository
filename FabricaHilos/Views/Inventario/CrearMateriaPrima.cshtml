@model FabricaHilos.Models.Inventario.MateriaPrima

@{
    ViewData["Title"] = "Nueva Materia Prima";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Inventario" asp-action="Index">Inventario</a></li>
    <li class="breadcrumb-item"><a asp-action="MateriaPrima">Materia Prima</a></li>
    <li class="breadcrumb-item active">Nueva</li>
}

<h4 class="section-title"><i class="bi bi-plus-circle me-2"></i>Nueva Materia Prima</h4>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="CrearMateriaPrima" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Nombre" class="form-label fw-semibold"></label>
                            <input asp-for="Nombre" class="form-control" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Tipo" class="form-label fw-semibold"></label>
                            <select asp-for="Tipo" class="form-select">
                                <option value="">-- Seleccionar --</option>
                                <option>Fibra Natural</option>
                                <option>Fibra Sintética</option>
                                <option>Colorante</option>
                                <option>Aditivo</option>
                                <option>Otro</option>
                            </select>
                            <span asp-validation-for="Tipo" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="UnidadMedida" class="form-label fw-semibold"></label>
                            <select asp-for="UnidadMedida" class="form-select">
                                <option value="">-- Seleccionar --</option>
                                <option>kg</option>
                                <option>lt</option>
                                <option>unid</option>
                                <option>m</option>
                            </select>
                            <span asp-validation-for="UnidadMedida" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="CantidadDisponible" class="form-label fw-semibold"></label>
                            <input asp-for="CantidadDisponible" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="CantidadDisponible" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StockMinimo" class="form-label fw-semibold"></label>
                            <input asp-for="StockMinimo" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="StockMinimo" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Proveedor" class="form-label fw-semibold"></label>
                            <input asp-for="Proveedor" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="FechaUltimoIngreso" class="form-label fw-semibold"></label>
                            <input asp-for="FechaUltimoIngreso" class="form-control" type="date" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Observaciones" class="form-label fw-semibold"></label>
                            <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Guardar
                        </button>
                        <a asp-action="MateriaPrima" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
