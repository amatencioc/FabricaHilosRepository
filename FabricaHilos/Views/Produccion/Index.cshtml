@{
    ViewData["Title"] = "Producción";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Producción</li>
}

<h4 class="section-title"><i class="bi bi-gear-wide-connected me-2"></i>Módulo de Producción</h4>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card card-dashboard h-100">
            <div class="card-body text-center p-5">
                <i class="bi bi-clipboard-data display-4 text-primary mb-3"></i>
                <h5 class="fw-bold">Registro de Preparatoria</h5>
                <p class="text-muted">Gestión de órdenes de producción, seguimiento de procesos y control de cantidades.</p>
                <a asp-controller="RegistroPreparatoria" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Registro de Preparatoria
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-dashboard h-100">
            <div class="card-body text-center p-5">
                <i class="bi bi-speedometer2 display-4 text-success mb-3"></i>
                <h5 class="fw-bold">Control Autoconer</h5>
                <p class="text-muted">Control de producción de máquinas Autoconer, registro de tramos, destinos y reprocesos.</p>
                <a asp-controller="Autoconer" asp-action="Index" class="btn btn-success">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Control Autoconer
                </a>
            </div>
        </div>
    </div>
</div>
