@{
    ViewData["Title"] = "Ventas";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Ventas</li>
}

<h4 class="section-title"><i class="bi bi-cash-coin me-2"></i>Módulo de Ventas</h4>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card card-dashboard h-100">
            <div class="card-body text-center p-5">
                <i class="bi bi-people display-4 text-primary mb-3"></i>
                <h5 class="fw-bold">Clientes</h5>
                <p class="text-muted">Gestión de clientes y datos de contacto.</p>
                <a asp-controller="Ventas" asp-action="Clientes" class="btn btn-primary">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Clientes
                </a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card card-dashboard h-100">
            <div class="card-body text-center p-5">
                <i class="bi bi-cart3 display-4 text-success mb-3"></i>
                <h5 class="fw-bold">Pedidos</h5>
                <p class="text-muted">Registro y seguimiento de pedidos de clientes.</p>
                <a asp-controller="Ventas" asp-action="Pedidos" class="btn btn-success">
                    <i class="bi bi-arrow-right me-1"></i>Ir a Pedidos
                </a>
            </div>
        </div>
    </div>
</div>
