@model IEnumerable<FabricaHilos.Models.Sgc.KardexDDto>
@using FabricaHilos.Models.Sgc
@inject FabricaHilos.Services.INavTokenService NavToken

@{
    ViewData["Title"] = "Detalle de Guía";
    var guia    = ViewBag.Guia as KardexGDto;
    int pedSerie = ViewBag.PedSerie;
    int numPed   = ViewBag.NumPed;
    int itemNro  = ViewBag.ItemNro;
    string? codArt = ViewBag.CodArt as string;
    string? buscar = ViewBag.Buscar as string;
    string navToken = ViewBag.NavToken as string ?? "";
    string pedidosToken = NavToken.Protect(new Dictionary<string, string?> {
        ["buscar"] = buscar
    });
    string detPedToken = NavToken.Protect(new Dictionary<string, string?> {
        ["serie"]  = pedSerie.ToString(),
        ["numPed"] = numPed.ToString(),
        ["buscar"] = buscar
    });
    string guiasToken = NavToken.Protect(new Dictionary<string, string?> {
        ["pedSerie"] = pedSerie.ToString(),
        ["numPed"]   = numPed.ToString(),
        ["nro"]      = itemNro.ToString(),
        ["buscar"]   = buscar
    });
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item"><a asp-action="Pedidos" asp-route-t="@pedidosToken">Pedidos</a></li>
    <li class="breadcrumb-item">
        <a asp-action="DetallePedido" asp-route-t="@detPedToken">
            Pedido @numPed
        </a>
    </li>
    <li class="breadcrumb-item">
        <a asp-action="Guias" asp-route-t="@guiasToken">
            Guías (Ítem @itemNro)
        </a>
    </li>
    <li class="breadcrumb-item active">Guía @guia?.Numero</li>
}

<div class="mb-3">
    <h4 class="section-title mb-1"><i class="bi bi-list-columns-reverse me-2"></i>Detalle de Guía</h4>
    <a asp-action="Guias" asp-route-t="@guiasToken" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver a guías
    </a>
</div>

@if (guia != null)
{
    <div class="card mb-3">
        <div class="card-header fw-semibold bg-light">
            <i class="bi bi-truck me-1"></i>
            Guía @guia.TpTransac — Serie <strong>@guia.Serie</strong> N° <strong>@guia.Numero</strong>
            (Almacén: @guia.CodAlm)
        </div>
        <div class="card-body py-2">
            <div class="row row-cols-2 row-cols-md-3 g-2 small">
                <div><span class="text-muted">RUC:</span> @(guia.Ruc ?? "-")</div>
                <div><span class="text-muted">Cliente:</span> <span class="fw-semibold">@(guia.Nombre ?? "-")</span></div>
                <div><span class="text-muted">Fecha de Transacción:</span> @(guia.FchTransac?.ToString("dd/MM/yyyy") ?? "-")</div>
                <div><span class="text-muted">Glosa:</span> @(guia.Glosa ?? "-")</div>
                <div>
                    <span class="text-muted">Factura ref.:</span>
                    @if (!string.IsNullOrEmpty(guia.TipRef))
                    {
                        <span class="fw-semibold">@guia.TipRef @guia.SerRef-@guia.NroRef</span>
                    }
                    else
                    {
                        <span class="text-muted">Sin factura</span>
                    }
                </div>
                <div><span class="text-muted">Peso Total:</span> @(guia.PesoTotal?.ToString("N4") ?? "-")</div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center">Ítem</th>
                        <th class="text-center">Cód. Art.</th>
                        <th class="text-center">Descripción</th>
                        <th class="text-center">Color</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@item.Nro</td>
                            <td class="fw-semibold">@(item.CodArt ?? "-")</td>
                            <td>@(item.Descripcion ?? "-")</td>
                            <td>@(item.ColorDet ?? "-")</td>
                            <td class="text-center">
                                @if (guia != null && !string.IsNullOrEmpty(guia.TipRef))
                                                {
                                                    var facToken = NavToken.Protect(new Dictionary<string, string?> {
                                                        ["cTipo"]     = guia.TipRef,
                                                        ["cSerie"]    = guia.SerRef,
                                                        ["cNumero"]   = guia.NroRef,
                                                        ["codAlm"]    = item.CodAlm,
                                                        ["tpTransac"] = item.TpTransac,
                                                        ["guiaSerie"] = item.Serie.ToString(),
                                                        ["guiaNumero"]= item.Numero.ToString(),
                                                        ["pedSerie"]  = pedSerie.ToString(),
                                                        ["numPed"]    = numPed.ToString(),
                                                        ["itemNro"]   = itemNro.ToString(),
                                                        ["kdNro"]     = item.Nro.ToString(),
                                                        ["codArt"]    = item.CodArt,
                                                        ["buscar"]    = buscar
                                                    });
                                                    <a asp-action="Facturas"
                                                       asp-route-t="@facToken"
                                                       class="btn btn-sm btn-outline-success btn-accion"
                                                       title="Ver facturas asociadas">
                                        <i class="bi bi-receipt"></i> Facturas
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted small">Sin factura</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                <i class="bi bi-inbox me-2"></i>No se encontraron ítems para esta guía.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer py-2">
        @{
            int currentPage = ViewBag.Page       != null ? Convert.ToInt32(ViewBag.Page)       : 1;
            int totalPages  = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
            int totalCount  = ViewBag.TotalCount != null ? Convert.ToInt32(ViewBag.TotalCount) : 0;
            int pgSize      = ViewBag.PageSize   != null ? Convert.ToInt32(ViewBag.PageSize)   : 10;
            int startItem   = totalCount == 0 ? 0 : (currentPage - 1) * pgSize + 1;
            int endItem     = Math.Min(currentPage * pgSize, totalCount);
        }
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @(totalCount == 0 ? "Sin registros" : $"Mostrando {startItem}\u2013{endItem} de {totalCount} registros")
            </small>
            @if (totalPages > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="DetalleGuia" asp-route-t="@navToken" asp-route-page="@(currentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                        </li>
                        @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
                        {
                            <li class="page-item @(pg == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="DetalleGuia" asp-route-t="@navToken" asp-route-page="@pg">@pg</a>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="DetalleGuia" asp-route-t="@navToken" asp-route-page="@(currentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
