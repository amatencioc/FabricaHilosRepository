                        tip.html(
                            '<div style="min-width:170px;">'
                            + '<div style="font-size:.95rem;font-weight:700;color:#e8f4fd;margin-bottom:.35rem;border-bottom:1px solid rgba(255,255,255,.12);padding-bottom:.3rem">' + nombreES + '</div>'
                            + '<div style="display:flex;align-items:center;gap:.4rem;margin-bottom:.25rem"><span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:' + hex + ';box-shadow:0 0 5px ' + hex + '"></span><span style="color:#90caf9;font-size:.78rem">Mercado: <b style="color:#e3f2fd">' + mapped + '</b></span></div>'
                            + '<div style="font-size:1.05rem;font-weight:800;color:#4fc3f7;margin:.2rem 0">' + ml + ' ' + fmt(info.importe) + '</div>'
                            + '<div style="color:#80cbc4;font-size:.75rem">' + pct + '% del total global</div>'
