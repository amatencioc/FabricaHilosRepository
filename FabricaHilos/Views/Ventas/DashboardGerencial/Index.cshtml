    async function loadTopHiladosImporte() {
        showSpin('spinnerTopHiladosImporte');
        try { const p = buildParams(); p.set('top', '5'); const data = await apiFetch('/DashboardGerencial/DatosTopHiladosImporte?' + p); renderTopHiladosImporte(data); } catch (e) { showToast('Error al cargar top hilados importe: ' + e.message); } finally { hideSpin('spinnerTopHiladosImporte'); }
    }
    function renderTopHiladosImporte(data) {
        destroyChart('topHiladosImporte');
        if (!data || data.length === 0) return;
        const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        const BAR_COLORS    = ['#1B4D3E','#1565C0','#6a1b9a','#e65100','#00838f'];
        const BAR_COLORS_BG = ['rgba(27,77,62,.13)','rgba(21,101,192,.13)','rgba(106,27,154,.13)','rgba(230,81,0,.13)','rgba(0,131,143,.13)'];
        const total = data.reduce((s, d) => s + (d.importe ?? 0), 0);

        const chartData = {
            labels: data.map(d => {
                const lbl = (d.familia ?? '');
                const words = lbl.split(' ');
                const lines = []; let cur = '';
                words.forEach(w => {
                    if (cur && (cur + ' ' + w).length > 14) { lines.push(cur); cur = w; }
                    else { cur = cur ? cur + ' ' + w : w; }
                });
                if (cur) lines.push(cur);
                return lines.length > 1 ? lines : lbl;
            }),
            datasets: [{
                label: 'Importe',
                data: data.map(d => d.importe ?? 0),
                backgroundColor: data.map((_, i) => BAR_COLORS_BG[i % BAR_COLORS_BG.length]),
                borderColor:     data.map((_, i) => BAR_COLORS[i % BAR_COLORS.length]),
                borderWidth: 2,
                borderRadius: 8,
                barPercentage: 0.68,
                categoryPercentage: 0.82
            }]
        };

        charts['topHiladosImporte'] = new Chart(document.getElementById('chartTopHiladosImporte').getContext('2d'), {
            type: 'bar',
            data: chartData,
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { top: 36, left: 4, right: 4 } },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: c => monLabel + ' ' + fmt(c.raw),
                            afterLabel: c => total > 0 ? ((c.raw / total) * 100).toFixed(1) + '% del total' : ''
                        }
                    },
                    datalabels: {
                        anchor: 'end', align: 'top', clip: false,
                        font: { size: 12, weight: '700', family: "'Segoe UI', Arial, sans-serif" },
                        color: function(ctx) { return BAR_COLORS[ctx.dataIndex % BAR_COLORS.length]; },
                        textStrokeColor: 'rgba(255,255,255,.7)',
                        textStrokeWidth: 3,
                        formatter: v => monLabel + ' ' + fmtMil(v)
                    }
                },
                scales: {
                    x: {
                        border: { display: false },
                        grid: { display: false },
                        ticks: { font: { size: 10, weight: '600' }, color: '#374151', maxRotation: 0 }
                    },
                    y: { display: false, beginAtZero: true }
                }
            }
        });
    }

    /* ── Ventas por Giro (barras horizontales Chart.js) ── */
    async function loadVentasGiro() {
        showSpin('spinnerVentasGiro');
        try { const data = await apiFetch('/DashboardGerencial/DatosVentasPorGiro?' + buildParams()); renderVentasGiro(data); } catch (e) { showToast('Error al cargar ventas por giro: ' + e.message); } finally { hideSpin('spinnerVentasGiro'); }
    }
    function renderVentasGiro(data) {
        destroyChart('ventasGiro');
        if (!data || data.length === 0) return;
        const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        const items = data.slice(0, 8);
        const total = data.reduce((s, d) => s + (d.importe ?? 0), 0);
        const COLORS    = ['#1B4D3E','#1565C0','#6a1b9a','#c62828','#e65100','#00838f','#283593','#4e342e'];
        const COLORS_BG = COLORS.map(c => c + '18');
        charts['ventasGiro'] = new Chart(document.getElementById('chartVentasGiro').getContext('2d'), {
            type: 'bar',
            data: {
                labels: items.map(d => (d.descGiro ?? d.codigoGiro ?? 'Sin Giro')),
                datasets: [{
                    label: 'Importe',
                    data: items.map(d => d.importe ?? 0),
                    backgroundColor: items.map((_, i) => COLORS_BG[i % COLORS_BG.length]),
                    borderColor:     items.map((_, i) => COLORS[i % COLORS.length]),
                    borderWidth: 2,
                    borderRadius: 6,
                    borderSkipped: false,
                    barPercentage: 0.72,
                    categoryPercentage: 0.85
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { right: 75 } },
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: c => ' ' + monLabel + ' ' + fmt(c.raw) + ' (' + (total > 0 ? ((c.raw / total) * 100).toFixed(1) : 0) + '%)' } },
                    datalabels: { anchor: 'end', align: 'right', clip: false, font: { size: 10, weight: '700', family: "'Segoe UI', Arial, sans-serif" }, color: ctx => COLORS[ctx.dataIndex % COLORS.length], textStrokeColor: 'rgba(255,255,255,.8)', textStrokeWidth: 3, formatter: (v, ctx) => { const pct = total > 0 ? ((v / total) * 100).toFixed(1) : '0.0'; return monLabel + ' ' + fmtMil(v) + '  ' + pct + '%'; } }
                },
                scales: {
                    x: { display: false, beginAtZero: true },
                    y: { border: { display: false }, grid: { display: false }, ticks: { font: { size: 11, weight: '600' }, color: '#374151' } }
                }
            }
        });
    }

    /* ── TOP 5 Hilados por KG (barras horizontales Chart.js) ── */
    async function loadTopHiladosKg() {
