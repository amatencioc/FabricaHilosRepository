@model IEnumerable<FabricaHilos.Models.Sgc.ReqCertDto>

@{
    ViewData["Title"] = "Cargar TC - Requerimientos de Certificados";
    string? buscar      = ViewBag.Buscar      as string;
    string? fechaInicio = ViewBag.FechaInicio as string;
    string? fechaFin    = ViewBag.FechaFin    as string;
    string? navToken    = ViewBag.NavToken    as string;
    int page            = ViewBag.Page        ?? 1;
    int pageSize        = ViewBag.PageSize    ?? 10;
    int totalCount      = ViewBag.TotalCount  ?? 0;
    int totalPages      = ViewBag.TotalPages  ?? 1;
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item">Despachos</li>
    <li class="breadcrumb-item active">Cargar TC</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0">
        <i class="bi bi-file-earmark-text me-2"></i>
        Cargar TC - Requerimientos de Certificados
    </h4>
    <span class="badge bg-primary">Total: @totalCount registros</span>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" asp-action="Index" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">Buscar</label>
                <input type="text" name="buscar" value="@buscar" class="form-control form-control-sm" placeholder="Buscar (NUM_CER, Razón Social, RUC)..." style="width: 280px;" />
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">Fecha Inicio</label>
                <input type="text" name="fechaInicio" value="@fechaInicio" class="form-control form-control-sm" placeholder="dd/mm/aaaa" autocomplete="off" data-flatpickr="date" style="width: 145px;" />
            </div>
            <div class="col-auto">
                <label class="form-label form-label-sm mb-0">Fecha Fin</label>
                <input type="text" name="fechaFin" value="@fechaFin" class="form-control form-control-sm" placeholder="dd/mm/aaaa" autocomplete="off" data-flatpickr="date" style="width: 145px;" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-search me-1"></i>Filtrar
                </button>
            </div>
            @if (!string.IsNullOrEmpty(buscar) || !string.IsNullOrEmpty(fechaInicio) || !string.IsNullOrEmpty(fechaFin))
            {
                <div class="col-auto">
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary" title="Limpiar filtros">
                        <i class="bi bi-x-circle me-1"></i>Limpiar filtros
                    </a>
                </div>
            }
        </form>
    </div>
</div>
                            <!-- Tabla de Requerimientos -->
                            @if (Model.Any())
                            {
                                <div class="card shadow-sm">
                                    <div class="card-body p-0">
                                        <div class="table-responsive">
                                            <table class="table table-corporate table-hover mb-0">
                                                <thead>
                                                    <tr>
                                                        <th class="text-center">#</th>
                                                        <th>Nº Req.</th>
                                                        <th>Fecha</th>
                                                        <th>Tipo de Certificado</th>
                                                        <th>Nº Certificado</th>
                                                        <th>Razón Social</th>
                                                        <th>RUC</th>
                                                        <th>Documento</th>
                                                        <th>Usuario</th>
                                                        <th class="text-center">Acciones</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @{
                                                        int contador = (page - 1) * pageSize;
                                                    }
                                                    @foreach (var req in Model)
                                                    {
                                                        contador++;
                                                        <tr class="cursor-pointer" data-numreq="@req.NumReq">
                                                            <td class="text-center">@contador</td>
                                                            <td><strong>@req.NumReq</strong></td>
                                                            <td>@req.Fecha?.ToString("dd/MM/yyyy")</td>
                                                            <td>
                                                                @if (!string.IsNullOrEmpty(req.CodArt))
                                                                {
                                                                    if (req.CodArt == "CERTGOTS")
                                                                    {
                                                                        <span class="badge bg-success">GOTS</span>
                                                                    }
                                                                    else if (req.CodArt == "CERTOCS")
                                                                    {
                                                                        <span class="badge bg-info">OCS</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge bg-secondary">@req.CodArt</span>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <span class="text-muted">-</span>
                                                                }
                                                            </td>
                                                            <td>
                                                                @{
                                                                    bool hayCertificado = !string.IsNullOrEmpty(req.NumCer);
                                                                }

                                                                @if (hayCertificado)
                                                                {
                                                                    <a href="@Url.Action("VisualizarPdf", "CargaTc", new { numReq = req.NumReq })" 
                                                                       target="_blank" 
                                                                       class="me-2" 
                                                                       title="Visualizar certificado PDF">
                                                                        <i class="bi bi-file-pdf-fill text-danger" style="font-size: 1.2rem;"></i>
                                                                    </a>
                                                                    <span class="badge bg-success">@req.NumCer</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-secondary">Sin certificado</span>
                                                                }
                                                            </td>
                                                            <td>@req.RazonSocial</td>
                                                            <td>@req.Ruc</td>
                                                            <td>
                                                                @{
                                                                    bool hayDocumento = !string.IsNullOrEmpty(req.TipoDoc) && 
                                                                                        !string.IsNullOrEmpty(req.Serie) && 
                                                                                        !string.IsNullOrEmpty(req.Numero);
                                                                }

                                                                @if (hayDocumento)
                                                                {
                                                                    <span>@req.TipoDoc-@req.Serie-@req.Numero</span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="text-muted">-</span>
                                                                }
                                                            </td>
                                                            <td>
                                                                <small class="text-muted">
                                                                    @if (req.AMduser != null)
                                                                    {
                                                                        <span>Mod: @req.AMduser (@req.AMdfecha?.ToString("dd/MM/yyyy"))</span>
                                                                    }
                                                                    else if (req.AAduser != null)
                                                                    {
                                                                        <span>Cre: @req.AAduser (@req.AAdfecha?.ToString("dd/MM/yyyy"))</span>
                                                                    }
                                                                </small>
                                                            </td>
                                                            <td class="text-center">
                                                                <a href="@Url.Action("Detalle", new { numReq = req.NumReq, t = navToken })" 
                                                                   class="btn btn-sm btn-primary me-1" 
                                                                   data-bs-toggle="tooltip" 
                                                                   data-bs-placement="top" 
                                                                   title="Ver detalle">
                                                                    <i class="bi bi-eye-fill"></i>
                                                                </a>
                                                                @if (!string.IsNullOrEmpty(req.NumCer))
                                                                {
                                                                    if (req.Estado == 2)
                                                                    {
                                                                        <button type="button" 
                                                                                class="btn btn-sm btn-secondary" 
                                                                                data-bs-toggle="tooltip" 
                                                                                data-bs-placement="top" 
                                                                                title="Correo a facturación enviado"
                                                                                disabled>
                                                                            <i class="bi bi-check-circle-fill"></i>
                                                                        </button>
                                                                    }
                                                                    else
                                                                    {
                                                                        <button type="button" 
                                                                                class="btn btn-sm btn-success" 
                                                                                data-bs-toggle="tooltip" 
                                                                                data-bs-placement="top" 
                                                                                title="Enviar a Facturación"
                                                                                onclick="enviarAFacturacion(@req.NumReq, '@req.NumCer')">
                                                                            <i class="bi bi-send-fill"></i>
                                                                        </button>
                                                                    }
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <!-- Paginación -->
                                @if (totalPages > 1)
                                {
                                    <nav aria-label="Navegación de páginas" class="mt-3">
                                        <ul class="pagination justify-content-center">
                                            <li class="page-item @(page == 1 ? "disabled" : "")">
                                                <a class="page-link" href="@Url.Action("Index", new { t = navToken, page = page - 1 })">Anterior</a>
                                            </li>

                                            @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                                            {
                                                <li class="page-item @(i == page ? "active" : "")">
                                                    <a class="page-link" href="@Url.Action("Index", new { t = navToken, page = i })">@i</a>
                                                </li>
                                            }

                                            <li class="page-item @(page == totalPages ? "disabled" : "")">
                                                <a class="page-link" href="@Url.Action("Index", new { t = navToken, page = page + 1 })">Siguiente</a>
                                            </li>
                                        </ul>
                                    </nav>
                                }
                            }
                            else
                            {
                                <div class="alert alert-info text-center">
                                    <i class="bi bi-info-circle me-2"></i>
                                    No se encontraron requerimientos con los filtros especificados.
                                    </div>
                                }

                                <!-- Modal de Confirmación -->
                                <div class="modal fade" id="modalConfirmarEnvio" tabindex="-1" aria-labelledby="modalConfirmarEnvioLabel" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title" id="modalConfirmarEnvioLabel">
                                                    <i class="bi bi-send-fill me-2"></i>Confirmar Envío a Facturación
                                                </h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p class="mb-0">¿Está seguro de enviar el certificado <strong id="modalNumCer"></strong> a Facturación?</p>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                    <i class="bi bi-x-circle me-1"></i>Cancelar
                                                </button>
                                                <button type="button" class="btn btn-success" id="btnConfirmarEnvio">
                                                    <i class="bi bi-send-fill me-1"></i>Aceptar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                @section Scripts {
    <script>
        $(document).ready(function () {
            // Inicializar tooltips de Bootstrap
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // Click en la fila para ir al detalle
            $('tr.cursor-pointer').click(function (e) {
                if (!$(e.target).closest('button, a').length) {
                    const numReq = $(this).data('numreq');
                    const url = '@Url.Action("Detalle", "CargaTc")' + '?numReq=' + numReq + '&t=@navToken';
                    window.location.href = url;
                }
            });
        });

        // Variables globales para el modal
        let currentNumReq = 0;

        // Función para enviar certificado a facturación
        function enviarAFacturacion(numReq, numCer) {
            currentNumReq = numReq;
            $('#modalNumCer').text(numCer);

            const modal = new bootstrap.Modal(document.getElementById('modalConfirmarEnvio'));
            modal.show();
        }

        // Evento del botón Aceptar en el modal
        $('#btnConfirmarEnvio').click(function() {
            const button = $(this);
            const originalHtml = button.html();
            button.prop('disabled', true).html('<i class="spinner-border spinner-border-sm me-1"></i>Enviando...');

            $.ajax({
                url: '@Url.Action("EnviarAFacturacion", "CargaTc")',
                type: 'POST',
                data: { 
                    numReq: currentNumReq,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    if (response.success) {
                        bootstrap.Modal.getInstance(document.getElementById('modalConfirmarEnvio')).hide();
                        window.location.href = response.redirectUrl;
                    } else {
                        alert(response.message || 'No se pudo enviar el certificado a Facturación.');
                        button.prop('disabled', false).html(originalHtml);
                    }
                },
                error: function (xhr) {
                    let errorMsg = 'Error al enviar el certificado a Facturación.';
                    if (xhr.responseJSON && xhr.responseJSON.message) {
                        errorMsg = xhr.responseJSON.message;
                    }
                    alert(errorMsg);
                    button.prop('disabled', false).html(originalHtml);
                }
            });
        });
    </script>
}

@section Styles {
    <style>
        .cursor-pointer {
            cursor: pointer;
        }
        .cursor-pointer:hover {
            background-color: rgba(0, 0, 0, 0.075) !important;
        }
    </style>
}
