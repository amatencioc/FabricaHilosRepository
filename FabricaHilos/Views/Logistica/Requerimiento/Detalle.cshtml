@model FabricaHilos.Models.Logistica.RequisicionDetalleViewModel
@using FabricaHilos.Models.Logistica
@using System.IO

@{
    ViewData["Title"] = $"Requerimiento {Model.Cabecera.TipDoc}-{Model.Cabecera.Serie:D3}-{Model.Cabecera.NumReq}";
    var cab      = Model.Cabecera;
    var archivos = ViewBag.ArchivosExistentes as List<ArchivoRequisicionDto> ?? new();
    var nombres  = ViewBag.Nombres as Dictionary<string, string> ?? new Dictionary<string, string>();
    var descsArt = ViewBag.DescripcionesArticulos as Dictionary<string, string> ?? new Dictionary<string, string>();
    var destinos     = ViewBag.Destinos    as Dictionary<string, string> ?? new Dictionary<string, string>();
    var prioridades  = ViewBag.Prioridades as Dictionary<string, string> ?? new Dictionary<string, string>();
    var destinosItem   = ViewBag.DestinosItem   as Dictionary<string, string> ?? new Dictionary<string, string>();
    var centrosCostoCab = ViewBag.CentrosCostoCab as Dictionary<string, string> ?? new Dictionary<string, string>();
    _ = nombres.TryGetValue(cab.Responsable ?? "", out var nomResp);

    // Navegación de regreso al listado
    string? navToken = ViewBag.NavToken as string;
    int     retPage  = ViewBag.ReturnPage != null ? (int)ViewBag.ReturnPage : 1;
    _ = nombres.TryGetValue(cab.Autoriza ?? "", out var nomAutoriza);

    string[] _coloresGrupo = { "primary", "success", "danger", "warning", "info", "secondary", "dark" };
    var grupoColorMap = Model.Items
        .Where(i => i.IdGrupo.HasValue)
        .Select(i => i.IdGrupo!.Value)
        .Distinct()
        .OrderBy(g => g)
        .Select((g, idx) => (g, _coloresGrupo[idx % _coloresGrupo.Length]))
        .ToDictionary(x => x.g, x => x.Item2);

    var (badgeClass, estadoTexto) = cab.Estado switch
    {
        "0" => ("bg-secondary", "Emitida"),
        "1" => ("bg-success",   "Autorizada"),
        "2" => ("bg-primary",   "Recibida"),
        "6" => ("bg-dark",      "Cerrada"),
        "9" => ("bg-danger",    "Cancelada"),
        _   => ("bg-light text-dark", cab.Estado ?? "-")
    };

    Func<string, string> IconoArchivo = nombre =>
    {
        var ext = System.IO.Path.GetExtension(nombre).ToLower();
        if (ext == ".pdf")  return "bi-file-earmark-pdf text-danger";
        if (ext == ".doc" || ext == ".docx") return "bi-file-earmark-word text-primary";
        if (ext == ".xls" || ext == ".xlsx") return "bi-file-earmark-excel text-success";
        if (ext == ".jpg" || ext == ".jpeg" || ext == ".png" || ext == ".gif" || ext == ".bmp")
            return "bi-file-earmark-image text-warning";
        if (ext == ".zip" || ext == ".rar") return "bi-file-earmark-zip text-secondary";
        return "bi-file-earmark text-muted";
    };
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Logistica" asp-action="Index">Logística</a></li>
    <li class="breadcrumb-item">
        <a asp-action="Index"
           asp-route-t="@navToken"
           asp-route-page="@retPage">Requerimientos</a>
    </li>
    <li class="breadcrumb-item active">@cab.TipDoc-@cab.Serie.ToString("D3")-@cab.NumReq</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0">
        <i class="bi bi-clipboard-check me-2"></i>
        Requerimiento &nbsp;<span class="fw-bold">@cab.TipDoc-@cab.Serie.ToString("D3")-@cab.NumReq</span>
        &nbsp;<span class="badge @badgeClass">@estadoTexto</span>
    </h4>
    <a asp-action="Index"
       asp-route-t="@navToken"
       asp-route-page="@retPage"
       class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Volver al listado
    </a>
</div>

<!-- ═══════════════════════════════════════════════════════════ CABECERA ══ -->
<div class="card shadow-sm mb-3">
    <div class="card-header py-2 fw-semibold">
        <i class="bi bi-info-circle me-1"></i> Datos del Requerimiento
    </div>
    <div class="card-body py-3">
        <div class="row g-2 row-cols-2 row-cols-md-3 row-cols-lg-4" style="--bs-gutter-x:1rem;">
            <div class="col">
                <label class="form-label small text-muted mb-0">Tipo Doc.</label>
                <div class="fw-semibold">@(cab.TipDoc ?? "-")</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Serie</label>
                <div class="fw-semibold">@cab.Serie</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">N° Requerimiento</label>
                <div class="fw-semibold">@cab.NumReq</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Centro de Costo</label>
                <div>
                    @{
                        var ccCabDesc = !string.IsNullOrEmpty(cab.CentroCosto) && centrosCostoCab.TryGetValue(cab.CentroCosto, out var ccCabD) && !string.IsNullOrWhiteSpace(ccCabD) ? ccCabD : null;
                    }
                    @(ccCabDesc ?? cab.CentroCosto ?? "-")
                    @if (ccCabDesc != null)
                    {
                        <br /><small class="text-muted">@cab.CentroCosto</small>
                    }
                </div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Proveedor(es)</label>
                <div>@(cab.Proveedores ?? "-")</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Fecha</label>
                <div>@(cab.Fecha?.ToString("dd/MM/yyyy") ?? "-")</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">F. Entrega</label>
                <div>@(cab.FEntrega?.ToString("dd/MM/yyyy") ?? "-")</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Responsable</label>
                <div class="text-truncate" style="max-width:220px;" title="@(cab.Responsable) @nomResp">@(cab.Responsable ?? "-")@if (!string.IsNullOrEmpty(nomResp)) { <span class="text-muted small ms-1">@nomResp</span> }</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Prioridad</label>
                <div>@((!string.IsNullOrWhiteSpace(cab.Prioridad) && prioridades.TryGetValue(cab.Prioridad, out var descPrio) && !string.IsNullOrWhiteSpace(descPrio)) ? descPrio : (cab.Prioridad ?? "-"))</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Destino</label>
                <div>@((!string.IsNullOrWhiteSpace(cab.Destino) && destinos.TryGetValue(cab.Destino, out var descDest) && !string.IsNullOrWhiteSpace(descDest)) ? descDest : (cab.Destino ?? "-"))</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Ind. Servicio</label>
                <div>@(cab.IndServ == "S" ? "Sí" : cab.IndServ == "N" ? "No" : (cab.IndServ ?? "-"))</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">F. Entrega Logística</label>
                <div>@(cab.FchEntregaLogist?.ToString("dd/MM/yyyy") ?? "-")</div>
            </div>
            @if (cab.Impsto.HasValue && cab.Impsto > 0)
            {
            <div class="col">
                <label class="form-label small text-muted mb-0">Impuesto</label>
                <div>@cab.Impsto?.ToString("N2")%</div>
            </div>
            }
            <div class="col">
                <label class="form-label small text-muted mb-0">Afecto IGV</label>
                <div>@(cab.AfectoIgv == "S" ? "Sí" : cab.AfectoIgv == "N" ? "No" : (cab.AfectoIgv ?? "-"))</div>
            </div>
            <div class="col">
                <label class="form-label small text-muted mb-0">Afecto Imp. Renta</label>
                <div>@(cab.AfectoIrenta == "S" ? "Sí" : cab.AfectoIrenta == "N" ? "No" : (cab.AfectoIrenta ?? "-"))</div>
            </div>
            @if (!string.IsNullOrEmpty(cab.TipRef))
            {
            <div class="col">
                <label class="form-label small text-muted mb-0">Referencia</label>
                <div>@cab.TipRef-@cab.SerRef?.ToString("D3")-@cab.NroRef</div>
            </div>
            }
            @if (!string.IsNullOrEmpty(cab.Autoriza) || !string.IsNullOrEmpty(cab.UserAutoriza))
            {
            <div class="col" style="min-width:200px;">
                <label class="form-label small text-muted mb-0">Autoriza</label>
                <div class="text-truncate" style="max-width:240px;"
                     title="@cab.Autoriza @nomAutoriza @(cab.UserAutoriza != null ? "- " + cab.UserAutoriza : "") @(cab.FAutoriza.HasValue ? cab.FAutoriza.Value.ToString("dd/MM/yyyy") : "")">
                    @if (!string.IsNullOrEmpty(cab.Autoriza))
                    {
                        <span>@cab.Autoriza</span>
                        @if (!string.IsNullOrEmpty(nomAutoriza)) { <span class="text-muted small ms-1">@nomAutoriza</span> }
                    }
                    @if (!string.IsNullOrEmpty(cab.UserAutoriza))
                    {
                        <span class="ms-1">- @cab.UserAutoriza</span>
                    }
                    @if (cab.FAutoriza.HasValue)
                    {
                        <span class="text-muted small ms-1">@cab.FAutoriza.Value.ToString("dd/MM/yyyy")</span>
                    }
                </div>
            </div>
            }
            @if (!string.IsNullOrEmpty(cab.Recibe))
            {
            <div class="col">
                <label class="form-label small text-muted mb-0">Recibe</label>
                <div>@cab.Recibe &nbsp;<span class="text-muted small">@(cab.FRecibe?.ToString("dd/MM/yyyy"))</span></div>
            </div>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(cab.Observacion))
        {
            <div class="mt-2">
                <label class="form-label small text-muted mb-0">Observación</label>
                <div class="border rounded px-2 py-1 bg-light small">@cab.Observacion</div>
            </div>
        }
        @if (cab.Estado == "A" && !string.IsNullOrWhiteSpace(cab.NotaAnulacion))
        {
            <div class="mt-2">
                <label class="form-label small text-muted mb-0">Nota de Anulación</label>
                <div class="border rounded px-2 py-1 bg-danger bg-opacity-10 text-danger small">@cab.NotaAnulacion</div>
            </div>
        }
    </div>
</div>

<!-- ════════════════════════════════════════════════════════════ DETALLE ══ -->
<div class="card shadow-sm mb-3">
    <div class="card-header py-2 fw-semibold">
        <i class="bi bi-list-ul me-1"></i> Ítems del Requerimiento
        <span class="badge bg-secondary ms-2">@Model.Items.Count</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover table-sm mb-0">
                <thead>
                    <tr>
                        <th class="text-center" style="width:38px;">
                            <input type="checkbox" id="chkTodos" class="form-check-input" title="Seleccionar todos" />
                        </th>
                        <th class="text-center">#</th>
                        <th>Cód. Artículo</th>
                        <th>Descripción</th>
                        <th class="text-center">Unidad</th>
                        <th class="text-end">Cantidad</th>
                        <th class="text-end">Saldo</th>
                        <th class="text-end">Stk. Mín.</th>
                        <th class="text-end">Stk. Hist.</th>
                        <th class="text-end">Precio</th>
                        <th class="text-center">Moneda</th>
                        <th>Marca</th>
                        <th>Solicitante</th>
                        <th>Destino</th>
                        <th class="text-center">F. Aprobado</th>
                        <th class="text-center">Grupo</th>
                        <th class="text-center" title="Número de Orden de Compra">O/C</th>
                        <th>Observaciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="text-center">
                                <input type="checkbox" class="form-check-input chk-item"
                                       value="@item.Orden"
                                       data-idgrupo="@(item.IdGrupo?.ToString() ?? "")" />
                            </td>
                            <td class="text-center">@item.Orden</td>
                            <td>@(item.CodArt ?? "-")</td>
                            <td>@((!string.IsNullOrWhiteSpace(item.CodArt) && descsArt.TryGetValue(item.CodArt, out var descArt) && !string.IsNullOrWhiteSpace(descArt)) ? descArt : (item.Detalle ?? "-"))</td>
                            <td class="text-center">@(item.Unidad ?? "-")</td>
                            <td class="text-end">@item.Cantidad.ToString("N2")</td>
                            <td class="text-end">@item.Saldo.ToString("N2")</td>
                            <td class="text-end text-muted">@(item.StkMin.HasValue ? item.StkMin.Value.ToString("N2") : "-")</td>
                            <td class="text-end text-muted">@(item.StkHist.HasValue ? item.StkHist.Value.ToString("N2") : "-")</td>
                            <td class="text-end">@(item.Precio > 0 ? item.Precio.ToString("N2") : "-")</td>
                            <td class="text-center">
                                @(item.Moneda == "D" ? "USD" : item.Moneda == "S" ? "PEN" : (item.Moneda ?? "-"))
                            </td>
                            <td>@(item.Marca ?? "-")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.CodSolicita))
                                {
                                    <span title="@item.CodSolicita">
                                        @(nombres.TryGetValue(item.CodSolicita, out var nomSol) && !string.IsNullOrEmpty(nomSol) ? nomSol : item.CodSolicita)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@((!string.IsNullOrWhiteSpace(item.Destino) && destinosItem.TryGetValue(item.Destino, out var descDestItem) && !string.IsNullOrWhiteSpace(descDestItem)) ? descDestItem : (item.Destino ?? "-"))</td>
                            <td class="text-center small">
                                @if (item.FAprobado.HasValue)
                                {
                                    <span class="text-success" title="Aprobado"><i class="bi bi-check-circle me-1"></i>@item.FAprobado.Value.ToString("dd/MM/yyyy")</span>
                                }
                                else { <span class="text-muted">-</span> }
                            </td>
                            <td class="text-center">
                                @if (item.IdGrupo.HasValue)
                                {
                                    var _c = grupoColorMap.TryGetValue(item.IdGrupo.Value, out var _cv) ? _cv : "secondary";
                                    <span class="badge bg-@_c" title="ID Grupo: @item.IdGrupo">@item.IdGrupo</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (!string.IsNullOrWhiteSpace(item.NroDocRef))
                                {
                                    <span class="badge bg-info text-dark" style="font-size:.7rem;" title="Orden de compra: @item.NroDocRef">@item.NroDocRef</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="small text-muted">@(item.Observaciones ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr>
                            <td colspan="17" class="text-center text-muted py-3">
                                <i class="bi bi-inbox d-block mb-1"></i> Sin ítems registrados.
                            </td>
                        </tr>
                    }
                </tbody>
                @if (Model.Items.Any())
                {
                    <tfoot class="table-light fw-semibold">
                        <tr>
                            <td colspan="5" class="text-end small">Totales:</td>
                                <td class="text-end">@Model.Items.Sum(i => i.Cantidad).ToString("N2")</td>
                                <td class="text-end">@Model.Items.Sum(i => i.Saldo).ToString("N2")</td>
                                <td colspan="9"></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>

<!-- ═══════════════════════════════════════════════════════════ ARCHIVOS ══ -->
<div class="card shadow-sm">
    <div class="card-header py-2 fw-semibold">
        <i class="bi bi-paperclip me-1"></i> Archivos Adjuntos
        @if (archivos.Any())
        {
            <span class="badge bg-secondary ms-2">@archivos.Count</span>
        }
    </div>
    <div class="card-body">

        <!-- Subir nuevos archivos -->
        <form asp-controller="Requisicion"
              asp-action="SubirArchivos"
              method="post"
              enctype="multipart/form-data"
              class="mb-3"
              id="formSubirArchivos">
            @Html.AntiForgeryToken()
            <input type="hidden" name="TipDoc" value="@cab.TipDoc" />
            <input type="hidden" name="Serie"  value="@cab.Serie" />
            <input type="hidden" name="NumReq" value="@cab.NumReq" />
            <input type="hidden" name="ReturnBuscar" value="@navToken" />
            <input type="hidden" name="ReturnPage"    value="@retPage" />
            <div id="hiddenOrdenesContainer"></div>

            <div class="alert alert-info py-2 small mb-2">
                <i class="bi bi-info-circle me-1"></i>
                Seleccione uno o más ítems en la tabla y luego elija los archivos a adjuntar.
                Se generará un código de grupo único que quedará registrado en los ítems seleccionados.
            </div>

            <div class="d-flex gap-2 align-items-center flex-wrap">
                <div class="flex-grow-1">
                    <input type="file"
                           name="Archivos"
                           id="inputArchivos"
                           class="form-control form-control-sm"
                           multiple
                           accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.gif,.bmp,.txt,.zip,.rar" />
                    <div class="form-text text-muted">
                        Formatos permitidos: PDF, Word, Excel, imágenes (JPG/PNG/GIF/BMP), TXT, ZIP, RAR.
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-primary" id="btnCargar" disabled>
                    <i class="bi bi-upload me-1"></i> Cargar
                    <span id="lblItemsSel" class="badge bg-light text-dark ms-1">0 ítems</span>
                </button>
            </div>
        </form>

        <!-- Listado de archivos existentes agrupados por ID_GRUPO -->
        @if (archivos.Any())
        {
            var gruposArchivos  = archivos.GroupBy(a => a.IdGrupo).OrderBy(g => g.Key).ToList();

            // Tipos visualizables en el visor
            var extVisualizables = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                { ".pdf", ".jpg", ".jpeg", ".png", ".gif", ".bmp" };

            // La aprobación es POR GRUPO: si un grupo ya tiene un archivo aprobado,
            // se oculta el botón Aprobar solo en ese grupo.

            <div class="table-responsive">
                <table class="table table-sm table-hover table-corporate mb-0">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th class="text-end">Tamaño</th>
                            <th class="text-center">Fecha de carga</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var grupo in gruposArchivos)
                        {
                            var color = grupoColorMap.TryGetValue(grupo.Key, out var _gc) ? _gc : "secondary";
                            bool grupoAprobado = grupo.Any(a => a.NombreArchivo.StartsWith("APROBADO_", StringComparison.OrdinalIgnoreCase));
                            <tr class="table-secondary">
                                <td colspan="4" class="py-1 px-2">
                                    <span class="badge bg-@color me-2" style="font-size:.8rem;">Grupo @grupo.Key</span>
                                    <small class="text-muted">@grupo.Count() archivo(s)</small>
                                </td>
                            </tr>
                            @foreach (var archivo in grupo.OrderBy(a => a.NombreArchivo))
                            {
                                bool esAprobado    = archivo.NombreArchivo.StartsWith("APROBADO_", StringComparison.OrdinalIgnoreCase);
                                var  extArch       = System.IO.Path.GetExtension(archivo.NombreArchivo);
                                bool esVisualizble = extVisualizables.Contains(extArch);
                                var  icon          = IconoArchivo(archivo.NombreArchivo);
                                var  urlVer        = Url.Action("Ver",       "Requisicion", new { idGrupo = archivo.IdGrupo, nombreArchivo = archivo.NombreArchivo });
                                var  urlDesc       = Url.Action("Descargar", "Requisicion", new { idGrupo = archivo.IdGrupo, nombreArchivo = archivo.NombreArchivo });

                                <tr class="@(esAprobado ? "table-success" : "")">
                                    <td class="ps-4">
                                        @if (esAprobado)
                                        {
                                            <i class="bi bi-check-circle-fill text-success me-1"></i>
                                        }
                                        else
                                        {
                                            <i class="bi @icon me-1"></i>
                                        }
                                        @if (esVisualizble)
                                        {
                                            <a href="#" class="link-primary text-decoration-none btn-ver-archivo @(esAprobado ? "fw-semibold" : "")"
                                               data-url="@urlVer"
                                               data-nombre="@archivo.NombreArchivo"
                                               data-tipo="@(extArch.TrimStart('.').ToLower())"
                                               title="Haz clic para ver @archivo.NombreArchivo">
                                                @archivo.NombreArchivo
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="@urlDesc" target="_blank" class="link-secondary text-decoration-none @(esAprobado ? "fw-semibold" : "")"
                                               title="Descargar @archivo.NombreArchivo">
                                                @archivo.NombreArchivo
                                            </a>
                                        }
                                    </td>
                                    <td class="text-end small text-muted">
                                        @(archivo.TamanioBytes < 1024
                                            ? $"{archivo.TamanioBytes} B"
                                            : archivo.TamanioBytes < 1048576
                                                ? $"{archivo.TamanioBytes / 1024.0:N1} KB"
                                                : $"{archivo.TamanioBytes / 1048576.0:N1} MB")
                                    </td>
                                    <td class="text-center small">@archivo.FechaCarga.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            @if (!grupoAprobado && !esAprobado)
                                            {
                                                <form asp-controller="Requisicion" asp-action="AprobarArchivo"
                                                      method="post" class="d-inline form-confirmar"
                                                      data-titulo="Aprobar archivo"
                                                      data-mensaje="&iquest;Aprobar el archivo &laquo;@archivo.NombreArchivo&raquo;? Esta acci&oacute;n no se puede deshacer.">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="idGrupo"       value="@archivo.IdGrupo" />
                                                    <input type="hidden" name="nombreArchivo" value="@archivo.NombreArchivo" />
                                                    <input type="hidden" name="tipDoc"        value="@cab.TipDoc" />
                                                    <input type="hidden" name="serie"         value="@cab.Serie" />
                                                    <input type="hidden" name="numReq"        value="@cab.NumReq" />
                                                    <input type="hidden" name="retNavToken" value="@navToken" />
                                                    <input type="hidden" name="retPage"     value="@retPage" />
                                                    <button type="button" class="btn btn-sm btn-outline-success btn-abrir-confirmar"
                                                            title="Aprobar este archivo">
                                                        <i class="bi bi-check-circle me-1"></i>Aprobar
                                                    </button>
                                                </form>
                                            }
                                            <form asp-controller="Requisicion"
                                                  asp-action="EliminarArchivo"
                                                  method="post"
                                                  class="form-confirmar"
                                                  data-titulo="Eliminar archivo"
                                                  data-mensaje="&iquest;Eliminar el archivo &laquo;@archivo.NombreArchivo&raquo;? Esta acci&oacute;n es irreversible.">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="idGrupo"        value="@archivo.IdGrupo" />
                                                <input type="hidden" name="nombreArchivo"  value="@archivo.NombreArchivo" />
                                                <input type="hidden" name="tipDoc"         value="@cab.TipDoc" />
                                                <input type="hidden" name="serie"          value="@cab.Serie" />
                                                <input type="hidden" name="numReq"         value="@cab.NumReq" />
                                                <input type="hidden" name="retNavToken" value="@navToken" />
                                                <input type="hidden" name="retPage"     value="@retPage" />
                                                <button type="button" class="btn btn-sm btn-outline-danger btn-abrir-confirmar" title="Eliminar">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted small py-2">
                <i class="bi bi-folder2-open me-1"></i> Aún no se han adjuntado archivos.
            </div>
        }
    </div>
</div>

@section Scripts {

<!-- ── Modal de confirmación genérico ───────────────────────────────────── -->
<div class="modal fade" id="modalConfirmar" tabindex="-1" aria-labelledby="modalConfirmarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="modalConfirmarLabel">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>
                    <span id="modalConfirmarTitulo"></span>
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body" id="modalConfirmarMensaje"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="modalConfirmarOk">Confirmar</button>
            </div>
        </div>
    </div>
</div>

<!-- ── Modal visor de archivos ────────────────────────────────────────── -->
<div class="modal fade" id="modalVisorArchivo" tabindex="-1" aria-labelledby="modalVisorLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="height:90vh;">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="modalVisorLabel">
                    <i class="bi bi-file-earmark me-1"></i><span id="modalVisorNombre"></span>
                </h6>
                <div class="ms-auto d-flex gap-2 align-items-center">
                    <a id="modalBtnDescargar" href="#" class="btn btn-sm btn-outline-primary" target="_blank" title="Descargar">
                        <i class="bi bi-download"></i>
                    </a>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
            </div>
            <div class="modal-body p-0 d-flex align-items-center justify-content-center" style="overflow:hidden;height:100%;">
                <iframe  id="visorIframe" src=""  style="width:100%;height:100%;border:0;display:none;"></iframe>
                <img     id="visorImg"    src=""  class="img-fluid" style="max-height:100%;object-fit:contain;display:none;" alt="Vista previa" />
                <div id="visorSpinner" class="text-center text-muted py-5">
                    <div class="spinner-border text-primary mb-2"></div><br/>Cargando…
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    // ── Modal de confirmación genérico ───────────────────────────────────────
    var modalConfirmar    = new bootstrap.Modal(document.getElementById('modalConfirmar'));
    var modalTitulo       = document.getElementById('modalConfirmarTitulo');
    var modalMensaje      = document.getElementById('modalConfirmarMensaje');
    var modalOk           = document.getElementById('modalConfirmarOk');
    var _formPendiente    = null;

    document.querySelectorAll('.btn-abrir-confirmar').forEach(function (btn) {
        btn.addEventListener('click', function () {
            _formPendiente = btn.closest('.form-confirmar');
            modalTitulo.textContent  = _formPendiente.dataset.titulo  || 'Confirmar';
            modalMensaje.innerHTML   = _formPendiente.dataset.mensaje  || '¿Desea continuar?';
            // color del botón según contexto (danger para eliminar, success para aprobar)
            modalOk.className = btn.classList.contains('btn-outline-danger')
                ? 'btn btn-danger'
                : 'btn btn-success';
            modalConfirmar.show();
        });
    });

    modalOk.addEventListener('click', function () {
        modalConfirmar.hide();
        if (_formPendiente) {
            _formPendiente.submit();
            _formPendiente = null;
        }
    });

    // ── Visor de archivos ────────────────────────────────────────────────────
    var modal          = new bootstrap.Modal(document.getElementById('modalVisorArchivo'));
    var modalNombre    = document.getElementById('modalVisorNombre');
    var modalDescarga  = document.getElementById('modalBtnDescargar');
    var visorIframe    = document.getElementById('visorIframe');
    var visorImg       = document.getElementById('visorImg');
    var visorSpinner   = document.getElementById('visorSpinner');

    var extImagen = ['jpg','jpeg','png','gif','bmp'];

    document.querySelectorAll('.btn-ver-archivo').forEach(function (a) {
        a.addEventListener('click', function (e) {
            e.preventDefault();
            var url    = this.dataset.url;
            var nombre = this.dataset.nombre;
            var tipo   = this.dataset.tipo;   // extensión sin punto, en minúsculas
            var urlDesc= url.replace('/Ver/', '/Descargar/');

            modalNombre.textContent  = nombre;
            modalDescarga.href       = urlDesc;

            // Ocultar todo, mostrar spinner
            visorIframe.style.display = 'none';
            visorImg.style.display    = 'none';
            visorSpinner.style.display= 'block';
            visorIframe.src = '';
            visorImg.src    = '';

            modal.show();

            if (extImagen.indexOf(tipo) !== -1) {
                // Imagen
                var img = new Image();
                img.onload = function () {
                    visorSpinner.style.display = 'none';
                    visorImg.src               = url;
                    visorImg.style.display     = 'block';
                };
                img.onerror = function () {
                    visorSpinner.innerHTML = '<span class="text-danger">No se pudo cargar la imagen.</span>';
                };
                img.src = url;
            } else {
                // PDF (u otro visualizable)
                visorSpinner.style.display = 'none';
                visorIframe.src            = url;
                visorIframe.style.display  = 'block';
            }
        });
    });

    // Limpiar al cerrar el modal
    document.getElementById('modalVisorArchivo').addEventListener('hidden.bs.modal', function () {
        visorIframe.src = '';
        visorImg.src    = '';
    });

    // ── Upload: selección de ítems y carga ───────────────────────────────────
    var chkTodos   = document.getElementById('chkTodos');
    var btnCargar  = document.getElementById('btnCargar');
    var lblItems   = document.getElementById('lblItemsSel');
    var container  = document.getElementById('hiddenOrdenesContainer');
    var form       = document.getElementById('formSubirArchivos');
    var inputFiles = document.getElementById('inputArchivos');

    function getSeleccionados() {
        return Array.from(document.querySelectorAll('.chk-item:checked'))
                    .map(function (c) { return c.value; });
    }

    function actualizarBoton() {
        var sel = getSeleccionados();
        var tieneArchivos = inputFiles.files && inputFiles.files.length > 0;
        btnCargar.disabled = (sel.length === 0 || !tieneArchivos);
        lblItems.textContent = sel.length + ' ítem' + (sel.length !== 1 ? 's' : '');
    }

    chkTodos.addEventListener('change', function () {
        document.querySelectorAll('.chk-item').forEach(function (c) {
            c.checked = chkTodos.checked;
        });
        actualizarBoton();
    });

    document.querySelectorAll('.chk-item').forEach(function (c) {
        c.addEventListener('change', function () {
            var total    = document.querySelectorAll('.chk-item').length;
            var marcados = document.querySelectorAll('.chk-item:checked').length;
            chkTodos.indeterminate = marcados > 0 && marcados < total;
            chkTodos.checked       = marcados === total;
            actualizarBoton();
        });
    });

    inputFiles.addEventListener('change', actualizarBoton);

    btnCargar.addEventListener('click', function () {
        container.innerHTML = '';

        var seleccionados = Array.from(document.querySelectorAll('.chk-item:checked'));

        seleccionados.forEach(function (chk) {
            var inp   = document.createElement('input');
            inp.type  = 'hidden';
            inp.name  = 'OrdenesItems';
            inp.value = chk.value;
            container.appendChild(inp);
        });

        var gruposConValor = seleccionados
            .map(function (chk) { return chk.dataset.idgrupo; })
            .filter(function (g) { return g && g !== ''; });

        var grupoUnico = gruposConValor.length > 0 &&
                         gruposConValor.every(function (g) { return g === gruposConValor[0]; })
                         ? gruposConValor[0]
                         : null;

        if (grupoUnico) {
            var inpGrupo   = document.createElement('input');
            inpGrupo.type  = 'hidden';
            inpGrupo.name  = 'ExistingIdGrupo';
            inpGrupo.value = grupoUnico;
            container.appendChild(inpGrupo);
        }

        form.submit();
    });
})();
</script>
}