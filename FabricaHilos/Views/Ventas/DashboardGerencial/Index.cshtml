                onRegionClick: function (e, code) { var info = getCountryInfo(code); if (!info) return; var mercado = mapMercado(info.mercado); var paisBD = info.pais; var codPais = info.codigoPais; loadDetallePais(mercado, paisBD); document.getElementById('detalleDistritoPanel').style.display = 'none'; if (mercado === 'Perú') { loadDetalleDpto(); } else { document.getElementById('detalleDptoPanel').style.display = 'none'; if (codPais && codPais !== '01') { loadCiudadesPais(codPais, paisBD); } } }
