    function getCountryInfo(isoCode) { const codBD = ISO_TO_BD[isoCode]; if (!codBD) return null; return _mapPaisData.find(d => d.codigoPais === codBD) || null; }

    /* Convierte hex + alpha → rgba */
    function hexAlpha(hex, a) { const r2=parseInt(hex.slice(1,3),16), g2=parseInt(hex.slice(3,5),16), b2=parseInt(hex.slice(5,7),16); return 'rgba('+r2+','+g2+','+b2+','+a+')'; }
    /* Calcula color con intensidad proporcional al importe del país vs máximo de su mercado */
    function colorByIntensity(hex, ratio) {
        const minA = 0.35, maxA = 1.0;
        const a = minA + (maxA - minA) * Math.pow(ratio, 0.45);
        return hexAlpha(hex, a);
    }

    function updateMap(dataMercado, monLabel, total) {
        const p = buildParams();
        apiFetch('/DashboardGerencial/DatosDetallePorPais?' + p).then(function (paisData) {
            _mapPaisData = paisData || [];

            /* Máximo importe por mercado para normalizar intensidad */
            const maxByMercado = {};
            _mapPaisData.forEach(d => { const m = mapMercado(d.mercado); maxByMercado[m] = Math.max(maxByMercado[m] || 0, d.importe ?? 0); });

            /* Total por mercado para leyenda */
            const totByMercado = {};
            _mapPaisData.forEach(d => { const m = mapMercado(d.mercado); totByMercado[m] = (totByMercado[m] || 0) + (d.importe ?? 0); });

            /* Ranking global de países */
            const sortedForRank = [..._mapPaisData].sort((a, b) => (b.importe ?? 0) - (a.importe ?? 0));
            const rankMap = {}; sortedForRank.forEach((d, i) => { rankMap[d.codigoPais] = i + 1; });

            /* Colores con intensidad por volumen */
            const regionColors = {};
            _mapPaisData.forEach(d => {
                const iso = BD_TO_ISO[d.codigoPais]; if (!iso) return;
                const m = mapMercado(d.mercado);
                const baseHex = MERCADO_COLORS[m] || '#546e7a';
                const ratio = maxByMercado[m] > 0 ? (d.importe ?? 0) / maxByMercado[m] : 0;
                regionColors[iso] = colorByIntensity(baseHex, ratio);
            });

            /* ── Leyenda enriquecida con importes ── */
            const mapMercadosPresentes = new Set(); _mapPaisData.forEach(d => mapMercadosPresentes.add(mapMercado(d.mercado)));
            const legendEl = document.getElementById('mapLegend');
            if (legendEl) {
                let lh = '';
                ['Perú','LATAM','Global'].forEach(m => {
                    if (!mapMercadosPresentes.has(m)) return;
                    const imp = totByMercado[m] || 0;
                    const pct = total > 0 ? ((imp/total)*100).toFixed(1) : '0.0';
                    lh += '<span class="legend-item" style="background:rgba(0,0,0,.18);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:.2rem .7rem;color:#e8f4fd;">'
                        + '<span class="legend-dot" style="background:' + MERCADO_COLORS[m] + ';box-shadow:0 0 6px ' + MERCADO_COLORS[m] + '88"></span>'
                        + '<span>' + m + '</span>'
                        + '<span style="font-weight:700;margin-left:.4rem;color:#4fc3f7">' + monLabel + ' ' + fmtMil(imp) + '</span>'
                        + '<span style="opacity:.55;font-size:.7rem;margin-left:.3rem">(' + pct + '%)</span>'
                        + '</span>';
                });
                lh += '<span class="legend-item" style="background:rgba(0,0,0,.18);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:.2rem .7rem;color:#90a4ae;"><span class="legend-dot" style="background:#263d50"></span>Sin datos</span>';
                legendEl.innerHTML = lh;
            }

            /* ── Overlay: Top 3 países ── */
            const statsEl = document.getElementById('mapStatsOverlay');
            if (statsEl) {
                let sh = '';
                sortedForRank.slice(0, 3).forEach((d, i) => {
                    const m = mapMercado(d.mercado);
                    const hex = MERCADO_COLORS[m] || '#546e7a';
                    const medals = ['🥇','🥈','🥉'];
                    sh += '<div class="map-stat-badge">'
                        + '<span style="font-size:1rem">' + medals[i] + '</span>'
                        + '<span class="stat-dot" style="background:' + hex + ';box-shadow:0 0 5px ' + hex + '88"></span>'
                        + '<span><div class="stat-val">' + (d.pais ?? d.codigoPais) + '</div><div class="stat-lbl">' + monLabel + ' ' + fmtMil(d.importe) + '</div></span>'
                        + '</div>';
                });
                statsEl.innerHTML = sh;
            }

            /* ── Inicializar/recrear mapa ── */
            if (_mapInstance) { _mapInstance.destroy(); _mapInstance = null; }
            _mapInstance = new jsVectorMap({
                selector: '#worldMap', map: 'world', zoomOnScroll: true, zoomButtons: true, showTooltip: true,
                regionStyle: {
                    initial: { fill: '#1c3048', fillOpacity: 1, stroke: '#0d1b2a', strokeWidth: 0.7 },
