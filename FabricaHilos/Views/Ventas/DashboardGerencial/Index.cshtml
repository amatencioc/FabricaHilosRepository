@{
    ViewData["Title"] = "Dashboard Gerencial";
}

@section Styles {
<style>
    .chart-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 2px 10px rgba(0,0,0,.08);
        height: 100%;
        background: #f5f5f2;
    }
    .chart-card .card-body {
        background: #f0f0ec;
        border-radius: 0 0 12px 12px;
    }
    .chart-card .card-header {
        background: transparent;
        color: #1B4D3E;
        font-weight: 600;
        border-bottom: 1px solid #e0e0e0;
        border-radius: 12px 12px 0 0 !important;
    }
    .chart-spinner {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,.75);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        z-index: 10;
    }
    .filter-bar {
        background: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 8px rgba(0,0,0,.07);
        padding: .85rem 1.25rem;
        margin-bottom: 1.4rem;
    }
    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1B4D3E;
        margin: 1.2rem 0 .4rem;
        border-left: 4px solid #1B4D3E;
        padding-left: .5rem;
    }
    .report-desc {
        font-size: .78rem;
        color: #637381;
        margin: 0 0 .9rem .65rem;
        line-height: 1.55;
    }

    .kpi-card {
        border-radius: 14px;
        color: #fff;
        box-shadow: 0 6px 20px rgba(0,0,0,.22);
        padding: 1.35rem 1.6rem;
        display: flex;
        align-items: center;
        gap: 1.1rem;
        border-bottom: 4px solid rgba(255,255,255,.25);
        transition: transform .15s, box-shadow .15s;
    }
    .kpi-card:hover { transform: translateY(-3px); box-shadow: 0 10px 28px rgba(0,0,0,.28); }
    .kpi-card .kpi-icon { font-size: 2.6rem; opacity: .9; }
    .kpi-card .kpi-label { font-size: .75rem; opacity: .8; text-transform: uppercase; letter-spacing: .7px; }
    .kpi-card .kpi-value { font-size: 1.65rem; font-weight: 800; line-height: 1.1; letter-spacing: -.5px; }
    .kpi-card .kpi-sub   { font-size: .73rem; opacity: .75; margin-top: 3px; }
    .bg-kpi-total  { background: linear-gradient(135deg, #1B4D3E 0%, #2e7d5e 100%); }
    .bg-kpi-peru   { background: linear-gradient(135deg, #1a237e 0%, #3949ab 100%); }
    .bg-kpi-latam  { background: linear-gradient(135deg, #bf360c 0%, #f4511e 100%); }
    .bg-kpi-global { background: linear-gradient(135deg, #0d47a1 0%, #1976d2 100%); }

    #worldMap { background: linear-gradient(180deg, #0d1b2a 0%, #1a2f45 35%, #162535 70%, #0f1e2e 100%); border-radius: 12px; border: 1px solid #1e3a5f; box-shadow: inset 0 0 60px rgba(0,20,60,.6); }
    .jvectormap-tip { background: rgba(15,25,40,.97) !important; color: #e8f4fd !important; border: 1px solid rgba(100,180,255,.25) !important; border-radius: 10px !important; font-size: .82rem !important; padding: .65rem 1rem !important; font-family: inherit !important; box-shadow: 0 8px 24px rgba(0,0,0,.5), 0 0 0 1px rgba(100,180,255,.1) !important; min-width: 180px !important; }
    .jvectormap-zoomin, .jvectormap-zoomout { background: rgba(27,77,62,.9) !important; border: 1px solid rgba(255,255,255,.2) !important; width: 30px !important; height: 30px !important; line-height: 30px !important; font-size: 18px !important; border-radius: 6px !important; color: #fff !important; }
    .map-stats-overlay { position:absolute; top:14px; left:14px; z-index:5; display:flex; flex-direction:column; gap:6px; pointer-events:none; }
    .map-stat-badge { background:rgba(15,25,40,.85); border:1px solid rgba(100,180,255,.2); border-radius:8px; padding:.35rem .7rem; color:#e8f4fd; font-size:.75rem; display:flex; align-items:center; gap:.5rem; backdrop-filter:blur(4px); }
    .map-stat-badge .stat-dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; }
    .map-stat-badge .stat-val { font-weight:700; font-size:.82rem; }
    .map-stat-badge .stat-lbl { opacity:.7; font-size:.7rem; }

    #chartMercado { cursor: pointer; }

    .legend-item {
        display: inline-flex;
        align-items: center;
        margin-right: 1.2rem;
        font-size: .82rem;
        font-weight: 500;
        color: #333;
    }
    .legend-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        margin-right: .4rem;
        display: inline-block;
    }

    .clickable-row {
        cursor: pointer;
        transition: background .2s;
    }
    .clickable-row:hover {
        background: #e8f5e9 !important;
    }
    .clickable-row td:first-child::before {
        content: '▸ ';
        color: #1B4D3E;
        font-weight: 700;
    }
    .highlight-row {
        background: #fff3e0 !important;
        box-shadow: inset 4px 0 0 #fb8c00;
        animation: highlightFade 4s ease forwards;
    }
    @@keyframes highlightFade {
        0%   { background: #ffe0b2 !important; }
        70%  { background: #fff3e0 !important; }
        100% { background: transparent !important; }
    }

    .year-check-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .5rem;
        margin-top: .6rem;
        padding-top: .6rem;
        border-top: 1px solid #e9ecef;
    }
    .year-check-bar .form-check-input:checked {
        background-color: #1B4D3E;
        border-color: #1B4D3E;
    }
</style>
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Ventas" asp-action="Index">Ventas</a></li>
    <li class="breadcrumb-item active">Dashboard Gerencial</li>
}

<!-- ── Filtros ─────────────────────────────────────────── -->
<div class="filter-bar">
    <div class="d-flex flex-wrap align-items-end gap-3">
        <div>
            <label class="form-label mb-1 small fw-semibold">Fecha Inicio</label>
            <input type="date" id="fechaInicio" class="form-control form-control-sm" style="min-width:135px">
        </div>
        <div>
            <label class="form-label mb-1 small fw-semibold">Fecha Fin</label>
            <input type="date" id="fechaFin" class="form-control form-control-sm" style="min-width:135px">
        </div>
        <div>
            <label class="form-label mb-1 small fw-semibold">Moneda</label>
            <select id="moneda" class="form-select form-select-sm" style="min-width:110px">
                <option value="D" selected>Dólares (USD)</option>
                <option value="S">Soles (PEN)</option>
            </select>
        </div>
        <button class="btn btn-sm btn-success" onclick="loadAll()">
            <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
        </button>
        <button class="btn btn-sm btn-outline-secondary" onclick="clearFilters()">
            <i class="bi bi-x-circle me-1"></i>Limpiar
        </button>
    </div>
    <div class="year-check-bar" id="yearCheckBar"></div>
</div>

<!-- ── KPI Resumen ────────────────────────────────────── -->
<div class="row g-2 mb-3" id="kpiRow">
    <div class="col-6 col-md-4 col-xl"><div class="kpi-card bg-kpi-total"><i class="bi bi-currency-dollar kpi-icon"></i><div><div class="kpi-label">Total Ventas</div><div class="kpi-value" id="kpiTotal">—</div><div class="kpi-sub">en el período</div></div></div></div>
    <div class="col-6 col-md-4 col-xl"><div class="kpi-card bg-kpi-peru"><i class="bi bi-geo-alt-fill kpi-icon"></i><div><div class="kpi-label">Perú</div><div class="kpi-value" id="kpiPeru">—</div><div class="kpi-sub" id="kpiPeruPct">—</div></div></div></div>
    <div class="col-6 col-md-4 col-xl"><div class="kpi-card bg-kpi-latam"><i class="bi bi-globe-americas kpi-icon"></i><div><div class="kpi-label">LATAM</div><div class="kpi-value" id="kpiLatam">—</div><div class="kpi-sub" id="kpiLatamPct">—</div></div></div></div>
    <div class="col-6 col-md-4 col-xl"><div class="kpi-card bg-kpi-global"><i class="bi bi-globe2 kpi-icon"></i><div><div class="kpi-label">Global</div><div class="kpi-value" id="kpiGlobal">—</div><div class="kpi-sub" id="kpiGlobalPct">—</div></div></div></div>
</div>

<!-- ── Sección Principal: Mapa + Donut ────────────────── -->
<div class="section-title"><i class="bi bi-globe-americas me-1"></i>Ventas por Mercado</div>
<p class="report-desc">Distribución de ventas por mercado geográfico. <strong>Haga clic en el donut o en el mapa</strong> para ver el detalle por país.</p>
<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <div class="card chart-card position-relative">
            <div class="card-header small" style="background:#162535; color:#a8d5f0; border-bottom:1px solid #1e3a5f;"><i class="bi bi-globe2 me-1" style="color:#4fc3f7"></i>Distribución Geográfica — <span style="opacity:.75">haga clic en un país para ver el detalle</span></div>
            <div class="card-body d-flex flex-column align-items-center justify-content-center position-relative" style="min-height:500px; background:#0d1b2a; border-radius:0 0 12px 12px;">
                <div class="map-stats-overlay" id="mapStatsOverlay"></div>
                <div id="worldMap" style="width:100%; height:450px;"></div>
                <div id="mapLegend" class="mt-2 d-flex flex-wrap justify-content-center gap-2"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card chart-card position-relative">
            <div id="spinnerMercado" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Participación por Mercado</div>
            <div class="card-body d-flex align-items-center justify-content-center" style="height:460px">
                <canvas id="chartMercado"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 2: Detalle por País (drill-down) ── -->
<div id="detallePaisPanel" style="display:none">
    <div class="section-title"><i class="bi bi-list-ul me-1"></i>Detalle por País — <span id="detallePaisTitulo"></span></div>
    <p class="report-desc">Lista de países y el importe vendido en cada uno. <strong>Haga clic en un país extranjero</strong> para ver las ciudades/distritos.</p>
    <div class="row g-3 mb-3">
        <div class="col-lg-7">
            <div class="card chart-card position-relative">
                <div id="spinnerDetallePais" class="chart-spinner" style="display:none"><div class="spinner-border text-primary"></div></div>
                <div class="card-header small d-flex justify-content-between align-items-center">
                    <span>Importe por País</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="cerrarDetallePais()"><i class="bi bi-x-lg me-1"></i>Cerrar</button>
                </div>
                <div class="card-body p-0" style="max-height:400px; overflow-y:auto; overflow-x:auto">
                    <table class="table table-hover table-sm table-corporate mb-0 detail-table">
                        <tbody id="tablaDetallePais"></tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card chart-card position-relative">
                <div class="card-header small">Distribución por País</div>
                <div class="card-body d-flex align-items-center justify-content-center" style="height:350px"><canvas id="chartDetallePais"></canvas></div>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 2b: Ciudades de un País Extranjero ── -->
<div id="detalleCiudadPaisPanel" style="display:none">
    <div class="section-title"><i class="bi bi-building me-1"></i>Ciudades/Distritos — <span id="detalleCiudadPaisTitulo"></span></div>
    <p class="report-desc">Detalle de ciudades/distritos del país seleccionado.</p>
    <div class="row g-3 mb-3">
        <div class="col-lg-7">
            <div class="card chart-card position-relative">
                <div id="spinnerDetalleCiudadPais" class="chart-spinner" style="display:none"><div class="spinner-border text-primary"></div></div>
                <div class="card-header small d-flex justify-content-between align-items-center">
                    <span>Importe por Ciudad</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="cerrarDetalleCiudadPais()"><i class="bi bi-x-lg me-1"></i>Cerrar</button>
                </div>
                <div class="card-body p-0" style="max-height:400px; overflow-y:auto; overflow-x:auto">
                    <table class="table table-hover table-sm table-corporate mb-0 detail-table">
                        <thead><tr><th>#</th><th>País</th><th>Ciudad / Distrito</th><th class="text-end">Importe</th><th class="text-end">%</th></tr></thead>
                        <tbody id="tablaDetalleCiudadPais"></tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card chart-card position-relative">
                <div class="card-header small">Distribución por Ciudad</div>
                <div class="card-body d-flex align-items-center justify-content-center" style="height:350px"><canvas id="chartDetalleCiudadPais"></canvas></div>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 3: Detalle por Departamento (Perú) ── -->
<div id="detalleDptoPanel" style="display:none">
    <div class="section-title"><i class="bi bi-geo-alt me-1"></i>Detalle por Departamento — Perú</div>
    <p class="report-desc">Distribución de ventas nacionales por departamento. <strong>Haga clic en un departamento</strong> para ver los distritos.</p>
    <div class="row g-3 mb-3">
        <div class="col-lg-7">
            <div class="card chart-card position-relative">
                <div id="spinnerDetalleDpto" class="chart-spinner" style="display:none"><div class="spinner-border text-primary"></div></div>
                <div class="card-header small d-flex justify-content-between align-items-center">
                    <span>Importe por Departamento</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="cerrarDetalleDpto()"><i class="bi bi-x-lg me-1"></i>Cerrar</button>
                </div>
                <div class="card-body p-0" style="max-height:400px; overflow-y:auto; overflow-x:auto">
                    <table class="table table-hover table-sm table-corporate mb-0 detail-table">
                        <thead><tr><th>#</th><th>Departamento</th><th class="text-end">Importe</th><th class="text-end">%</th></tr></thead>
                        <tbody id="tablaDetalleDpto"></tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card chart-card position-relative">
                <div class="card-header small">Top Departamentos</div>
                <div class="card-body" style="height:350px"><canvas id="chartDetalleDpto"></canvas></div>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 3b: Detalle por Distrito ── -->
<div id="detalleDistritoPanel" style="display:none">
    <div class="section-title"><i class="bi bi-pin-map me-1"></i>Distritos — <span id="detalleDistritoTitulo"></span></div>
    <p class="report-desc">Distribución de ventas por distrito dentro del departamento seleccionado.</p>
    <div class="row g-3 mb-3">
        <div class="col-lg-7">
            <div class="card chart-card position-relative">
                <div id="spinnerDetalleDistrito" class="chart-spinner" style="display:none"><div class="spinner-border text-primary"></div></div>
                <div class="card-header small d-flex justify-content-between align-items-center">
                    <span>Importe por Distrito</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="cerrarDetalleDistrito()"><i class="bi bi-x-lg me-1"></i>Cerrar</button>
                </div>
                <div class="card-body p-0" style="max-height:400px; overflow-y:auto; overflow-x:auto">
                    <table class="table table-hover table-sm table-corporate mb-0 detail-table">
                        <thead><tr><th>#</th><th>Distrito</th><th class="text-end">Importe</th><th class="text-end">%</th></tr></thead>
                        <tbody id="tablaDetalleDistrito"></tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card chart-card position-relative">
                <div class="card-header small">Top Distritos</div>
                <div class="card-body" style="height:350px"><canvas id="chartDetalleDistrito"></canvas></div>
            </div>
        </div>
    </div>
</div>

<!-- ── Sección 4: Evolución Mensual por Mercado ── -->
<div class="section-title"><i class="bi bi-graph-up me-1"></i>Evolución Mensual de Ventas</div>
<p class="report-desc">Tendencia mensual de ventas por mercado geográfico.</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerEvolucion" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Importe Mensual por Mercado</div>
            <div class="card-body" style="height:350px"><canvas id="chartEvolucion"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 4b: Importe Total por Mes / Año ── -->
<div class="section-title"><i class="bi bi-bar-chart-line me-1"></i>Importe Total por Mes / Año</div>
<p class="report-desc">Comparativa año a año del importe total mensual (todos los mercados).</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerImporteTotalMes" class="chart-spinner" style="display:none"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Importe Total por Mes / Año</div>
            <div class="card-body" style="height:350px"><canvas id="chartImporteTotalMes"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 4c: KG Total por Mes / Año ── -->
<div class="section-title"><i class="bi bi-box-seam me-1"></i>KG Total por Mes / Año</div>
<p class="report-desc">Comparativa año a año de la cantidad de kilogramos vendidos por mes.</p>
<div class="row g-3 mb-3">
    <div class="col-12">
        <div class="card chart-card position-relative">
            <div id="spinnerKgTotalMes" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">KG Total por Mes / Año</div>
            <div class="card-body" style="height:350px"><canvas id="chartKgTotalMes"></canvas></div>
        </div>
    </div>
</div>

<!-- ── Sección 4d: Top 5 Hilados más Facturados + Ventas por Giro + Top 5 Hilados por KG ── -->
<div class="section-title"><i class="bi bi-bar-chart-fill me-1"></i>Análisis de Hilados y Giros</div>
<p class="report-desc">Top familias de hilados por importe facturado, distribución por giro de cliente, y top artículos por kilogramos.</p>
<div class="row g-3 mb-3">
    <div class="col-lg-4">
        <div class="card chart-card position-relative">
            <div id="spinnerTopHiladosImporte" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">TOP 5 Hilados más Facturados</div>
            <div class="card-body" style="height:380px"><canvas id="chartTopHiladosImporte"></canvas></div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card chart-card position-relative">
            <div id="spinnerVentasGiro" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">Ventas por Giro</div>
            <div class="card-body" style="height:380px">
                <canvas id="chartVentasGiro"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card chart-card position-relative">
            <div id="spinnerTopHiladosKg" class="chart-spinner"><div class="spinner-border text-success"></div></div>
            <div class="card-header small">TOP 5 Hilados por KG</div>
            <div class="card-body" style="height:380px">
                <canvas id="chartTopHiladosKg"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<link rel="stylesheet" href="~/lib/jsvectormap/dist/jsvectormap.css" asp-append-version="true" />
<script src="~/lib/jsvectormap/dist/jsvectormap.min.js" asp-append-version="true"></script>
<script src="~/lib/jsvectormap/dist/maps/world.js" asp-append-version="true"></script>
<script src="~/lib/chartjs-plugin-datalabels/dist/chartjs-plugin-datalabels.min.js" asp-append-version="true"></script>
<script>
(function () {
    'use strict';

    if (typeof ChartDataLabels !== 'undefined') { Chart.register(ChartDataLabels); }

    Chart.defaults.font.family = "'Segoe UI', 'Helvetica Neue', Arial, sans-serif";
    Chart.defaults.font.size   = 12;
    Chart.defaults.color       = '#374151';

    const fmtPE = new Intl.NumberFormat('es-PE', { minimumFractionDigits: 2 });
    const fmt  = n => fmtPE.format(n ?? 0);
    const fmtMil = n => { n = n ?? 0; if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M'; if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K'; return fmt(n); };

    const MERCADO_COLORS = { 'Perú': '#1a237e', 'LATAM': '#fb8c00', 'Global': '#1565c0' };
    function mapMercado(m) { return (m === 'Perú' || m === 'LATAM') ? m : 'Global'; }
    function aggregateByMappedMercado(data) { const agg = {}; data.forEach(d => { const m = mapMercado(d.mercado); agg[m] = (agg[m] || 0) + (d.importe ?? 0); }); return Object.entries(agg).map(([mercado, importe]) => ({ mercado, importe })); }
    const PAIS_COLORS = ['#1B4D3E','#1565C0','#2e7d32','#e65100','#6a1b9a','#00838f','#c62828','#4e342e','#37474f','#f9a825','#00695c','#ad1457','#283593','#ef6c00','#2e7d5e'];

    const charts = {};
    function destroyChart(key) { if (charts[key]) { charts[key].destroy(); delete charts[key]; } }
    function showSpin(id) { const el = document.getElementById(id); if (el) el.style.display = 'flex'; }
    function hideSpin(id) { const el = document.getElementById(id); if (el) el.style.display = 'none'; }

    function showToast(msg, type) {
        type = type || 'danger';
        let container = document.getElementById('toastContainer');
        if (!container) { container = document.createElement('div'); container.id = 'toastContainer'; container.style.cssText = 'position:fixed;top:1rem;right:1rem;z-index:9999;'; document.body.appendChild(container); }
        const toast = document.createElement('div');
        toast.className = 'alert alert-' + type + ' alert-dismissible fade show shadow';
        toast.style.cssText = 'min-width:300px;font-size:.85rem;margin-bottom:.5rem;';
        toast.innerHTML = msg + '<button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert"></button>';
        container.appendChild(toast);
        setTimeout(function () { if (toast.parentNode) toast.remove(); }, 6000);
    }

    function setDefaultDates() { const hoy = new Date(); const ini = new Date(hoy.getFullYear(), 0, 1); const toISO = d => d.toISOString().slice(0, 10); fpSetDate('#fechaInicio', toISO(ini)); fpSetDate('#fechaFin', toISO(hoy)); }

    /* ── Años: generar checkboxes ─────────────────── */
    function buildYearCheckboxes() {
        const bar = document.getElementById('yearCheckBar');
        const currentYear = new Date().getFullYear();
        let html = '<span class="small fw-semibold text-muted me-1"><i class="bi bi-calendar3 me-1"></i>Comparar Años:</span>';
        for (let y = currentYear; y >= currentYear - 5; y--) {
            const chk = y === currentYear ? 'checked' : '';
            html += '<div class="form-check form-check-inline mb-0">'
                  + '<input class="form-check-input" type="checkbox" id="year' + y + '" value="' + y + '" ' + chk + ' onchange="onYearsChanged()">'
                  + '<label class="form-check-label small" for="year' + y + '">' + y + '</label></div>';
        }
        bar.innerHTML = html;
    }

    function getSelectedYears() {
        return Array.from(document.querySelectorAll('#yearCheckBar input:checked')).map(c => parseInt(c.value)).sort();
    }

    window.onYearsChanged = function () {
        const years = getSelectedYears();
        const fi = document.getElementById('fechaInicio');
        const ff = document.getElementById('fechaFin');
        if (years.length === 0) { fpSetDisabled(fi, false); fpSetDisabled(ff, false); return; }
        const hoy = new Date();
        if (years.length === 1) {
            const y = years[0];
            fpSetDate(fi, y + '-01-01');
            fpSetDate(ff, y === hoy.getFullYear() ? hoy.toISOString().slice(0,10) : y + '-12-31');
            fpSetDisabled(fi, false); fpSetDisabled(ff, false);
            loadAll();
            return;
        }
        const minY = Math.min(...years), maxY = Math.max(...years);
        fpSetDate(fi, minY + '-01-01');
        fpSetDate(ff, maxY === hoy.getFullYear() ? hoy.toISOString().slice(0,10) : maxY + '-12-31');
        fpSetDisabled(fi, true); fpSetDisabled(ff, true);
        loadAll();
    };

    function buildParams() { const fi = document.getElementById('fechaInicio').value; const ff = document.getElementById('fechaFin').value; const mon = document.getElementById('moneda').value; const p = new URLSearchParams(); if (fi) p.set('fechaInicio', fi); if (ff) p.set('fechaFin', ff); if (mon) p.set('moneda', mon); return p; }

    async function apiFetch(url) { const r = await fetch(url); if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); }

    /* ── DONUT: Ventas por Mercado ── */
    function renderMercado(data) {
