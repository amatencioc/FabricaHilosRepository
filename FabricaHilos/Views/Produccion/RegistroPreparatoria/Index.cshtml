<!-- Modal Registrar Paro -->
<div class="modal fade" id="modalRegistrarParo" tabindex="-1" aria-labelledby="modalRegistrarParoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalRegistrarParoLabel"><i class="bi bi-pause-circle me-2"></i>Registrar Paro — <span id="paroCabMaquina"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
