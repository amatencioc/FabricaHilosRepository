@model FabricaHilos.Services.Produccion.AutoconerDetalleOracleDto
@using FabricaHilos.Helpers
@using FabricaHilos.Models.Produccion

@{
    ViewData["Title"] = "Detalle Registro Autoconer";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Produccion" asp-action="Index">Producción</a></li>
    <li class="breadcrumb-item"><a asp-action="Index">Control Autoconer</a></li>
    <li class="breadcrumb-item active">Detalle</li>
}

<div class="d-flex align-items-center mb-4" style="border-bottom: 3px solid var(--color-secondary); padding-bottom: 10px;">
    <i class="bi bi-eye fs-3 me-3 text-success"></i>
    <h4 class="mb-0 fw-bold">Detalle de Registro</h4>
</div>

@{
    // Estado viene de Oracle como string: "1"=EnProceso, "3"=Terminado, "9"=Anulado
    var estadoBadge = Model.Estado switch
    {
        "1" => new { Clase = "bg-primary",   Texto = "En Proceso",  Icono = "bi-gear-fill" },
        "3" => new { Clase = "bg-success",   Texto = "Terminado",   Icono = "bi-check-circle" },
        "9" => new { Clase = "bg-danger",    Texto = "Anulado",     Icono = "bi-x-circle" },
        _   => new { Clase = "bg-secondary", Texto = "Desconocido", Icono = "bi-question-circle" }
    };

    var tramosMarcados = new List<int>();
    if (Model.Tramo1.HasValue && Model.Tramo1.Value > 0) tramosMarcados.Add(1);
    if (Model.Tramo2.HasValue && Model.Tramo2.Value > 0) tramosMarcados.Add(2);
    if (Model.Tramo3.HasValue && Model.Tramo3.Value > 0) tramosMarcados.Add(3);
    if (Model.Tramo4.HasValue && Model.Tramo4.Value > 0) tramosMarcados.Add(4);
    if (Model.Tramo5.HasValue && Model.Tramo5.Value > 0) tramosMarcados.Add(5);
    if (Model.Tramo6.HasValue && Model.Tramo6.Value > 0) tramosMarcados.Add(6);
}

<!-- Estado actual -->
<div class="mb-3">
    <span class="badge @estadoBadge.Clase fs-6 px-3 py-2">
        <i class="bi @estadoBadge.Icono me-2"></i>@estadoBadge.Texto
    </span>
    @if (Model.Estado == "3")
    {
        <span class="badge bg-secondary fs-6 px-3 py-2 ms-2">
            <i class="bi bi-lock-fill me-1"></i>Cerrado
        </span>
    }
</div>

<!-- ===== CABECERA ===== -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white fw-bold">
        <i class="bi bi-info-circle me-2"></i>Cabecera
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-3">
                <div class="text-muted small">Autoconer N°</div>
                <div class="fw-semibold">
                    @if (!string.IsNullOrEmpty(ViewBag.DescripcionMaquina as string))
                    {
                        <span>@ViewBag.DescripcionMaquina</span>
                    }
                    else
                    {
                        <span>@(Model.NumeroAutoconer ?? "-")</span>
                    }
                </div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Operador</div>
                <div class="fw-semibold">
                    @if (!string.IsNullOrEmpty(ViewBag.NombreOperario as string))
                    {
                        <span>@ViewBag.NombreOperario</span>
                        <span class="text-muted"> (@Model.CodigoOperador)</span>
                    }
                    else
                    {
                        <span>@(Model.CodigoOperador ?? "-")</span>
                    }
                </div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Fecha</div>
                <div class="fw-semibold">@Model.Fecha.ToString("dd/MM/yyyy HH:mm:ss")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Turno</div>
                <div class="fw-semibold">@ProduccionLookups.GetTurno(Model.Turno)</div>
            </div>
        </div>
    </div>
</div>

<!-- ===== DATOS DE PRODUCCIÓN ===== -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white fw-bold">
        <i class="bi bi-clipboard-data me-2"></i>Datos de Producción
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-muted small">Nº Partida</div>
                <div class="fw-semibold">@(Model.Guia ?? "-")</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Receta</div>
                <div class="fw-semibold">@(Model.CodigoReceta ?? "-")</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Lote / Partida</div>
                <div class="fw-semibold">@(Model.Lote ?? "-")</div>
            </div>
            <div class="col-md-12">
                <div class="text-muted small">Material</div>
                <div class="fw-semibold">@(Model.DescripcionMaterial ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Título</div>
                <div class="fw-semibold">
                    @if (!string.IsNullOrEmpty(ViewBag.DescripcionTitulo as string))
                    {
                        <span>@ViewBag.DescripcionTitulo</span>
                    }
                    else
                    {
                        <span>@(Model.Titulo ?? "-")</span>
                    }
                </div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">V (m/min)</div>
                <div class="fw-semibold">@(Model.VelocidadMMin?.ToString("0.00") ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Fecha Inicio</div>
                <div class="fw-semibold">@(Model.FechaInicio?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted small">Fecha Fin</div>
                <div class="fw-semibold">@(Model.FechaFinal?.ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Destino</div>
                <div class="fw-semibold">
                    @if (!string.IsNullOrEmpty(ViewBag.DescripcionDestino as string))
                    {
                        <span>@ViewBag.DescripcionDestino</span>
                    }
                    else
                    {
                        <span>@(Model.Destino ?? "-")</span>
                    }
                </div>
            </div>
            <div class="col-md-12">
                <div class="text-muted small mb-2">Tramos</div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (Model.Tramo1.HasValue && Model.Tramo1.Value > 0)
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-1-circle me-1"></i>T1: @Model.Tramo1
                        </span>
                    }
                    @if (Model.Tramo2.HasValue && Model.Tramo2.Value > 0)
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-2-circle me-1"></i>T2: @Model.Tramo2
                        </span>
                    }
                    @if (Model.Tramo3.HasValue && Model.Tramo3.Value > 0)
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-3-circle me-1"></i>T3: @Model.Tramo3
                        </span>
                    }
                    @if (Model.Tramo4.HasValue && Model.Tramo4.Value > 0)
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-4-circle me-1"></i>T4: @Model.Tramo4
                        </span>
                    }
                    @if (Model.Tramo5.HasValue && Model.Tramo5.Value > 0)
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-5-circle me-1"></i>T5: @Model.Tramo5
                        </span>
                    }
                    @if (Model.Tramo6.HasValue && Model.Tramo6.Value > 0)
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-6-circle me-1"></i>T6: @Model.Tramo6
                        </span>
                    }
                    @if (!tramosMarcados.Any())
                    {
                        <span class="text-muted">-</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== RESULTADOS ===== -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-success text-white fw-bold">
        <i class="bi bi-bar-chart-line me-2"></i>Resultados
    </div>
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-muted small">Conos o Rodetes</div>
                <div class="fw-semibold">@(Model.Cantidad?.ToString() ?? "-")</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Kg x Unidad</div>
                <div class="fw-semibold">@(Model.PesoBruto?.ToString("0.00") ?? "-")</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small">Peso Neto</div>
                <div class="fw-semibold">@(Model.Puntaje?.ToString("0.00") ?? "-")</div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Index" class="btn btn-outline-secondary px-4">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    @if (Model.Estado == "3")
    {
        <a asp-action="Editar" 
           asp-route-receta="@Model.CodigoReceta" 
           asp-route-lote="@Model.Lote" 
           asp-route-codMaq="@Model.NumeroAutoconer" 
           asp-route-titulo="@Model.Titulo" 
           asp-route-fechaIni="@Model.Fecha.ToString("yyyy-MM-dd HH:mm:ss")"
           class="btn btn-warning px-4">
            <i class="bi bi-pencil-square me-1"></i>Editar
        </a>
    }
</div>
