@model FabricaHilos.Models.Seguridad.FotoSeguridadViewModel

@{
    ViewData["Title"] = "Registrar Hallazgo";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Seguridad</a></li>
    <li class="breadcrumb-item active">Registrar Hallazgo</li>
}

<style>
    /* Estilos optimizados para móviles */
    .mobile-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem;
        margin: -1rem -1rem 1rem -1rem;
        border-radius: 0.5rem 0.5rem 0 0;
    }
    .form-group-mobile {
        margin-bottom: 1.25rem;
    }
    .form-label-mobile {
        font-weight: 600;
        color: #495057;
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }
    .preview-container {
        position: relative;
        border: 2px dashed #dee2e6;
        border-radius: 0.5rem;
        padding: 1rem;
        text-align: center;
        background: #f8f9fa;
        min-height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .preview-container.has-image {
        border-color: #28a745;
        background: #fff;
    }
    .camera-icon {
        font-size: 3rem;
        color: #6c757d;
    }
    @@media (max-width: 576px) {
        .container-fluid {
            padding-left: 0.5rem !important;
            padding-right: 0.5rem !important;
        }
    }
</style>

<div class="container-fluid px-2 px-md-4">
    <div class="d-flex justify-content-between align-items-center mb-3 d-none d-md-flex">
        <h5 class="mb-0">
            <i class="bi bi-camera-fill me-2"></i>Registrar Hallazgo (H)
        </h5>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>

    <!-- Header móvil -->
    <div class="d-md-none mb-3">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-2">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
        <h5><i class="bi bi-camera-fill me-2"></i>Nuevo Hallazgo</h5>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-3 p-md-4">
            <form asp-action="Crear" asp-controller="Seguridad" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- Responsables -->
                <div class="form-group-mobile">
                    <label asp-for="ResponsableArea" class="form-label form-label-mobile">
                        <i class="bi bi-person-badge"></i> Responsable de Área
                    </label>
                    <select asp-for="ResponsableArea" 
                            class="form-select form-select-lg" 
                            asp-items="@ViewBag.ResponsablesArea">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="ResponsableArea" class="text-danger small"></span>
                </div>

                <div class="form-group-mobile">
                    <label asp-for="ResponsableInspeccion" class="form-label form-label-mobile">
                        <i class="bi bi-person-check"></i> Responsable de Inspección
                    </label>
                    <select asp-for="ResponsableInspeccion" 
                            class="form-select form-select-lg" 
                            asp-items="@ViewBag.ResponsablesInspeccion">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="ResponsableInspeccion" class="text-danger small"></span>
                </div>

                <!-- Centro de Costo y Tipo -->
                <div class="form-group-mobile">
                    <label asp-for="CentroCosto" class="form-label form-label-mobile">
                        <i class="bi bi-building"></i> Centro de Costo
                    </label>
                    <select asp-for="CentroCosto" 
                            class="form-select form-select-lg" 
                            asp-items="@ViewBag.CentrosCosto">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="CentroCosto" class="text-danger small"></span>
                </div>

                <div class="form-group-mobile">
                    <label asp-for="TipoInspeccion" class="form-label form-label-mobile">
                        <i class="bi bi-clipboard-check"></i> Tipo de Inspección
                    </label>
                    <select asp-for="TipoInspeccion" 
                            class="form-select form-select-lg" 
                            asp-items="@ViewBag.TiposInspeccion">
                        <option value="">-- Seleccione --</option>
                    </select>
                    <span asp-validation-for="TipoInspeccion" class="text-danger small"></span>
                </div>

                <hr class="my-4" />

                <!-- Ubicación del Hallazgo -->
                <div class="form-group-mobile">
                    <label asp-for="UbicacionFoto" class="form-label form-label-mobile">
                        <i class="bi bi-geo-alt"></i> Ubicación del Hallazgo
                    </label>
                    <input asp-for="UbicacionFoto" 
                           type="text" 
                           class="form-control form-control-lg" 
                           placeholder="Ej: Área de Producción - Máquina 5" 
                           maxlength="100" />
                    <div class="form-text">
                        Describa dónde se encontró el hallazgo (máx. 100 caracteres)
                    </div>
                    <span asp-validation-for="UbicacionFoto" class="text-danger small"></span>
                </div>

                <!-- Foto a subir -->
                <div class="form-group-mobile">
                    <label asp-for="Foto" class="form-label form-label-mobile">
                        <i class="bi bi-camera"></i> Foto del Hallazgo
                    </label>
                    <input asp-for="Foto"
                           type="file"
                           class="form-control form-control-lg"
                           accept="image/*"
                           id="inputFoto" />
                    <div class="form-text">
                        JPG, JPEG, PNG o WebP. La imagen se optimizará automáticamente.
                    </div>
                    <span asp-validation-for="Foto" class="text-danger small"></span>
                </div>

                <!-- Vista previa optimizada -->
                <div id="previewContainer" class="preview-container d-none">
                    <img id="previewImg" src="#" alt="Vista previa" class="img-fluid rounded" style="max-height: 400px;" />
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <i class="bi bi-cloud-upload me-2"></i>Registrar Hallazgo
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i>Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('inputFoto').addEventListener('change', function () {
            const file = this.files[0];
            const container = document.getElementById('previewContainer');
            const img = document.getElementById('previewImg');

            if (file && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    img.src = e.target.result;
                    container.classList.remove('d-none');
                    container.classList.add('has-image');
                };
                reader.readAsDataURL(file);
            } else {
                container.classList.add('d-none');
                container.classList.remove('has-image');
            }
        });
    </script>
}
