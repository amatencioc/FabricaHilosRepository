@{
    ViewData["Title"] = "Importar Facturas";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="RegistroPreparatoria" asp-action="Index">Inicio</a></li>
    <li class="breadcrumb-item"><a asp-controller="Facturacion" asp-action="Index">Facturación</a></li>
    <li class="breadcrumb-item active">Importar Facturas</li>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-file-earmark-arrow-up me-2"></i>Importar Facturas</h4>
    <a asp-controller="Facturacion" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white">
        <i class="bi bi-upload me-2"></i>Subir Documento
    </div>
    <div class="card-body p-4">
        <p class="text-muted mb-4">
            Seleccione un archivo PDF, PNG o JPEG de una factura electrónica SUNAT o recibo de servicios.
            El sistema extraerá automáticamente los datos del documento para que pueda revisarlos y confirmar el registro.
        </p>
        <form asp-action="ImportarFacturas" method="post" enctype="multipart/form-data" id="formImportar">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="archivoPdf" class="form-label fw-semibold">
                    <i class="bi bi-file-earmark-pdf me-1 text-danger"></i>Archivo del documento
                </label>
                <input type="file" class="form-control" id="archivoPdf" name="archivoPdf"
                       accept=".pdf,.jpg,.jpeg,.png" required />
                <div class="form-text">Formatos aceptados: PDF, JPG, PNG. Tamaño máximo: 10 MB.</div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" id="btnSubir">
                    <span id="btnTexto"><i class="bi bi-cloud-upload me-1"></i>Extraer Datos</span>
                    <span id="btnSpinner" class="d-none">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>Procesando...
                    </span>
                </button>
                <a asp-controller="Facturacion" asp-action="Index" class="btn btn-outline-secondary">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('formImportar').addEventListener('submit', function () {
            document.getElementById('btnTexto').classList.add('d-none');
            document.getElementById('btnSpinner').classList.remove('d-none');
            document.getElementById('btnSubir').disabled = true;
        });
    </script>
}
