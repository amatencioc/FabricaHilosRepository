@model IEnumerable<FabricaHilos.Models.RecursosHumanos.Empleado>

@{
    ViewData["Title"] = "Empleados";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Recursos Humanos</a></li>
    <li class="breadcrumb-item active">Empleados</li>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="section-title mb-0"><i class="bi bi-person-lines-fill me-2"></i>Empleados</h4>
    @if (User.IsInRole("Admin") || User.IsInRole("Gerencia"))
    {
        <a asp-action="CrearEmpleado" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Empleado
        </a>
    }
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control form-control-sm" placeholder="Buscar por nombre, DNI o cargo..." style="max-width: 300px;" />
            <button type="submit" class="btn btn-sm btn-outline-primary"><i class="bi bi-search"></i></button>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th>Nombre Completo</th>
                        <th>DNI</th>
                        <th>Cargo</th>
                        <th>Área</th>
                        <th>Fecha Ingreso</th>
                        <th>Salario</th>
                        <th>Estado</th>
                        @if (User.IsInRole("Admin") || User.IsInRole("Gerencia"))
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.NombreCompleto</td>
                            <td>@item.Dni</td>
                            <td>@(item.Cargo ?? "-")</td>
                            <td>@(item.Area ?? "-")</td>
                            <td>@item.FechaIngreso.ToString("dd/MM/yyyy")</td>
                            <td>S/ @item.Salario.ToString("N2")</td>
                            <td>
                                <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">
                                    @(item.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            @if (User.IsInRole("Admin") || User.IsInRole("Gerencia"))
                            {
                                <td>
                                    <a asp-action="EditarEmpleado" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary btn-accion">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            }
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-3 d-block mb-2"></i>No hay empleados registrados.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
