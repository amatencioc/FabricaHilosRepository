        const COLORS_BG = COLORS.map(c => c + '18');
        charts['topHiladosKg'] = new Chart(document.getElementById('chartTopHiladosKg').getContext('2d'), {
            type: 'bar',
            data: {
                labels: data.map(d => {
                    const lbl = (d.familia ?? '');
                    const words = lbl.split(' ');
                    const lines = []; let cur = '';
                    words.forEach(w => {
                        if (cur && (cur + ' ' + w).length > 18) { lines.push(cur); cur = w; }
                        else { cur = cur ? cur + ' ' + w : w; }
                    });
                    if (cur) lines.push(cur);
                    return lines.length > 1 ? lines : lbl;
                }),
                datasets: [{
                    label: 'KG',
                    data: data.map(d => d.kilos ?? 0),
                    backgroundColor: data.map((_, i) => COLORS_BG[i % COLORS_BG.length]),
                    borderColor:     data.map((_, i) => COLORS[i % COLORS.length]),
                    borderWidth: 2,
                    borderRadius: 6,
                    borderSkipped: false,
                    barPercentage: 0.72,
                    categoryPercentage: 0.85
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { right: 80 } },
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: c => ' ' + fmtMil(c.raw) + ' KG (' + (totalKg > 0 ? ((c.raw / totalKg) * 100).toFixed(1) : 0) + '%)' } },
                    datalabels: { anchor: 'end', align: 'right', clip: false, font: { size: 10, weight: '700', family: "'Segoe UI', Arial, sans-serif" }, color: ctx => COLORS[ctx.dataIndex % COLORS.length], textStrokeColor: 'rgba(255,255,255,.8)', textStrokeWidth: 3, formatter: (v, ctx) => { const pct = totalKg > 0 ? ((v / totalKg) * 100).toFixed(1) : '0.0'; return fmtMil(v) + ' KG  ' + pct + '%'; } }
                },
                scales: {
                    x: { display: false, beginAtZero: true },
                    y: { border: { display: false }, grid: { display: false }, ticks: { font: { size: 10, weight: '600' }, color: '#374151' } }
                }
            }
        });
    }

    /* ── Load all ── */
    async function loadMercado() { showSpin('spinnerMercado'); try { const data = await apiFetch('/DashboardGerencial/DatosVentasPorMercado?' + buildParams()); renderMercado(data); } catch (e) { showToast('Error al cargar datos de mercado: ' + e.message); } finally { hideSpin('spinnerMercado'); } }

    window.loadAll = function () { cerrarDetallePais(); cerrarDetalleDpto(); cerrarDetalleDistrito(); cerrarDetalleCiudadPais(); loadMercado(); loadEvolucion(); loadKgMensual(); loadTopHiladosImporte(); loadVentasGiro(); loadTopHiladosKg(); };
    window.clearFilters = function () { setDefaultDates(); document.getElementById('moneda').value = 'D'; buildYearCheckboxes(); loadAll(); };

    /* ── Inicio ── */
    buildYearCheckboxes();
    setDefaultDates();
    (async function () { await cargarMapeoPaises(); loadAll(); })();
})();
</script>
