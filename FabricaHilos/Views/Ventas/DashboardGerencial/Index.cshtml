    /* ── MAPA ── */
    const BD_TO_ISO_FALLBACK = { '01':'PE','02':'US','03':'PA','04':'DE','05':'EC','06':'BO','07':'CH','08':'GB','09':'NZ','10':'CA','11':'VE','12':'MX','13':'IT','14':'BR','15':'JP','16':'CN','17':'CL','18':'RU','19':'KR','20':'AR','21':'FR','22':'CO','23':'TW','24':'DO','25':'UY','27':'ES','28':'IN','29':'PK','30':'CZ','31':'HN','32':'GT','33':'IE','34':'LT','35':'AT','36':'SG','37':'VN','38':'TR','39':'IL','40':'EE' };
