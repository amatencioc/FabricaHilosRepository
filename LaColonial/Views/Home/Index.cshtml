@section Scripts {
<script>
    // Swiper Hero
    new Swiper('.hero-swiper', {
        loop: true,
        autoplay: { delay: 5000, disableOnInteraction: false },
        speed: 800,
        effect: 'fade',
        fadeEffect: { crossFade: true },
        pagination: {
            el: '.swiper-pagination-hero',
            clickable: true
        },
        a11y: {
            prevSlideMessage: 'Diapositiva anterior',
            nextSlideMessage: 'Siguiente diapositiva'
        }
    });

    // ===== MODAL VIDEO YOUTUBE =====
    (function () {
        const YT_EMBED = 'https://www.youtube.com/embed/tJeWPYvEJ28?autoplay=1&rel=0&modestbranding=1';
        const modal    = document.getElementById('videoModal');
        const iframe   = document.getElementById('videoIframe');
        const btnPlay  = document.getElementById('videoPlayBtn');
        const btnClose = document.getElementById('videoModalClose');
        if (!modal || !iframe || !btnPlay) return;

        const openModal = () => {
            iframe.src = YT_EMBED;
            modal.style.display = 'flex';
            document.body.style.overflow = 'hidden';
            btnClose && btnClose.focus();
        };
        const closeModal = () => {
            modal.style.display = 'none';
            iframe.src = '';
            document.body.style.overflow = '';
        };

        btnPlay.addEventListener('click', openModal);
        btnClose && btnClose.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal.style.display === 'flex') closeModal(); });

        // Hover: agranda el botón play
        const overlay = btnPlay.querySelector('.video-overlay');
        const playCircle = overlay && overlay.querySelector('span');
        if (playCircle) {
            btnPlay.addEventListener('mouseenter', () => { playCircle.style.transform = 'scale(1.12)'; playCircle.style.boxShadow = '0 12px 40px rgba(0,0,0,0.4)'; });
            btnPlay.addEventListener('mouseleave', () => { playCircle.style.transform = ''; playCircle.style.boxShadow = ''; });
        }
    })();
</script>
}
