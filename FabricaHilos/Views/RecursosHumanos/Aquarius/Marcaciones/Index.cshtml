@using FabricaHilos.Models.RecursosHumanos
@model List<EmpleadoDto>
@{
    ViewData["Title"] = "Empleados — Aquarius";
    var buscar     = (string)ViewBag.Buscar;
    var page       = (int)ViewBag.Page;
    var pageSize   = (int)ViewBag.PageSize;
    var total      = (int)ViewBag.Total;
    var totalPages = (int)ViewBag.TotalPages;

    string Url(int p, string? q = null) =>
        $"/RecursosHumanos/Aquarius/Marcaciones?page={p}" +
        (string.IsNullOrEmpty(q ?? buscar) ? "" : $"&buscar={Uri.EscapeDataString(q ?? buscar)}");
}

@section Breadcrumb {
    <li class="breadcrumb-item">Recursos Humanos</li>
    <li class="breadcrumb-item">Aquarius</li>
    <li class="breadcrumb-item active">Empleados</li>
}

@section Styles {
<style>
    :root { --rh-primary: #1B4D3E; --rh-primary-light: #e8f5e9; }

    .rh-header {
        background: linear-gradient(135deg, var(--rh-primary) 0%, #2d6a4f 100%);
        color: #fff;
        border-radius: .5rem .5rem 0 0;
        padding: 1.1rem 1.4rem;
    }
    .rh-header h5 { margin: 0; font-weight: 600; letter-spacing: .3px; }
    .rh-header p  { margin: 0; opacity: .8; font-size: .82rem; }

    .search-bar { background: #f8f9fa; border-bottom: 1px solid #dee2e6; padding: .85rem 1.4rem; }
    .search-bar .form-control { border-radius: .4rem 0 0 .4rem; }
    .search-bar .btn-search    { border-radius: 0 .4rem .4rem 0; background: var(--rh-primary); border: none; color: #fff; }
    .search-bar .btn-search:hover { background: #2d6a4f; }
    .search-bar .btn-clear { background: transparent; border-color: #adb5bd; }

    .emp-table { margin: 0; }
    .emp-table thead th {
        background: #f1f3f5;
        color: #495057;
        font-size: .75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .5px;
        border-bottom: 2px solid #dee2e6;
        white-space: nowrap;
        padding: .65rem 1rem;
    }
    .emp-table tbody tr { transition: background .12s; }
    .emp-table tbody tr:hover { background: var(--rh-primary-light); }
    .emp-table tbody td { vertical-align: middle; padding: .6rem 1rem; font-size: .87rem; }

    .avatar {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: var(--rh-primary);
        color: #fff;
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: .8rem;
        flex-shrink: 0;
    }
    .emp-nombre { font-weight: 500; color: #212529; }
    .emp-codigo { font-size: .78rem; color: #6c757d; }

    .badge-activo    { background: #d1fae5; color: #065f46; font-size: .72rem; }
    .badge-inactivo  { background: #fee2e2; color: #991b1b; font-size: .72rem; }
    .badge-otro      { background: #e0e7ff; color: #3730a3; font-size: .72rem; }

    .btn-horarios {
        font-size: .78rem; padding: .3rem .7rem;
        border-color: var(--rh-primary); color: var(--rh-primary);
        border-radius: .35rem;
    }
    .btn-horarios:hover { background: var(--rh-primary); color: #fff; }

    .autocomplete-wrap { position: relative; }
    .autocomplete-list {
        position: absolute; top: 100%; left: 0; right: 0; z-index: 1050;
        background: #fff; border: 1px solid #dee2e6; border-top: none;
        border-radius: 0 0 .4rem .4rem; box-shadow: 0 4px 12px rgba(0,0,0,.12);
        max-height: 260px; overflow-y: auto; display: none;
    }
    .autocomplete-list .ac-item {
        padding: .55rem .9rem; cursor: pointer; font-size: .85rem;
        display: flex; align-items: center; gap: .6rem;
        border-bottom: 1px solid #f1f3f5;
    }
    .autocomplete-list .ac-item:last-child { border-bottom: none; }
    .autocomplete-list .ac-item:hover, .autocomplete-list .ac-item.ac-active {
        background: var(--rh-primary-light);
    }
    .autocomplete-list .ac-item .avatar {
        width: 28px; height: 28px; font-size: .65rem;
    }
    .autocomplete-list .ac-name { font-weight: 500; }
    .autocomplete-list .ac-code { font-size: .75rem; color: #6c757d; margin-left: auto; }

    .pagination-bar {
        padding: .75rem 1.4rem;
        border-top: 1px solid #dee2e6;
        background: #fafafa;
        border-radius: 0 0 .5rem .5rem;
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: .5rem;
    }
    .pagination-info { font-size: .82rem; color: #6c757d; }
    .pagination .page-link { color: var(--rh-primary); font-size: .82rem; padding: .3rem .6rem; }
    .pagination .page-item.active .page-link { background: var(--rh-primary); border-color: var(--rh-primary); color: #fff; }
    .pagination .page-item.disabled .page-link { color: #adb5bd; }

    .empty-state { padding: 3rem 1rem; text-align: center; color: #adb5bd; }
    .empty-state i { font-size: 2.8rem; display: block; margin-bottom: .6rem; }
</style>
}

<div class="container-fluid px-2 px-md-4 py-3">
<div class="card shadow-sm" style="border-radius:.5rem; overflow:hidden; border:none;">

    <!-- Encabezado -->
    <div class="rh-header d-flex justify-content-between align-items-center">
        <div>
            <h5><i class="bi bi-people-fill me-2"></i>Empleados</h5>
            <p>
                @if (total > 0)
                {
                    @($"{total} empleados encontrados — Página {page} de {totalPages}")
                }
                else
                {
                    @("Sin resultados")
                }
            </p>
        </div>
        <span class="badge bg-white text-dark fw-semibold px-3 py-2" style="font-size:.82rem;">
            <i class="bi bi-building me-1"></i>Aquarius
        </span>
    </div>

    <!-- Barra de búsqueda -->
    <div class="search-bar">
        <form method="get" action="/RecursosHumanos/Aquarius/Marcaciones" class="d-flex gap-2 align-items-center">
            <input type="hidden" name="page" value="1" />
            <div class="autocomplete-wrap" style="max-width:420px; flex:1;">
                <div class="input-group">
                    <input type="text" name="buscar" id="txtBuscar" value="@buscar"
                           class="form-control"
                           placeholder="Buscar por nombre o código..."
                           autocomplete="off" />
                    <button type="submit" class="btn btn-search px-3">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
                <div class="autocomplete-list" id="acList"></div>
            </div>
            @if (!string.IsNullOrEmpty(buscar))
            {
                <a href="/RecursosHumanos/Aquarius/Marcaciones" class="btn btn-clear btn-sm">
                    <i class="bi bi-x-lg me-1"></i>Limpiar
                </a>
            }
        </form>
    </div>

    <!-- Tabla -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="table-responsive">
            <table class="table emp-table table-hover table-corporate mb-0">
                <thead>
                    <tr>
                        <th style="width:46px;"></th>
                        <th>Empleado</th>
                        <th>Código</th>
                        <th>Fotocheck</th>
                        <th>Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model)
                    {
                        var iniciales = string.Join("", (emp.Empleado ?? "?")
                            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                            .Take(2)
                            .Select(w => w[0].ToString().ToUpper()));

                        var estadoBadgeClass = emp.TipEstado switch {
                            "A" => "badge-activo",
                            "I" => "badge-inactivo",
                            _   => "badge-otro"
                        };
                        var estadoLabel = emp.TipEstado switch {
                            "A" => "Activo",
                            "I" => "Inactivo",
                            _   => emp.TipEstado ?? "—"
                        };

                        <tr>
                            <td class="text-center">
                                <span class="avatar">@iniciales</span>
                            </td>
                            <td>
                                <div class="emp-nombre">@emp.Empleado</div>
                            </td>
                            <td>
                                <span class="emp-codigo fw-semibold">@emp.Personal</span>
                            </td>
                            <td>
                                <span class="emp-codigo">@(emp.Fotocheck ?? "—")</span>
                            </td>
                            <td>
                                <span class="badge rounded-pill @estadoBadgeClass px-2 py-1">@estadoLabel</span>
                            </td>
                            <td class="text-center">
                                <a href="/RecursosHumanos/Aquarius/Marcaciones/Horarios?codPersonal=@Uri.EscapeDataString(emp.Personal ?? "")&nombre=@Uri.EscapeDataString(emp.Empleado ?? "")"
                                   class="btn btn-outline-secondary btn-horarios">
                                    <i class="bi bi-calendar-week me-1"></i>Ver Horarios
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-person-x"></i>
            @if (!string.IsNullOrEmpty(buscar))
            {
                <p class="mb-1 fw-semibold">Sin resultados para "<strong>@buscar</strong>"</p>
                <p class="small">Intente con otro nombre o código.</p>
            }
            else
            {
                <p class="mb-1 fw-semibold">No hay empleados disponibles</p>
            }
        </div>
    }

    <!-- Paginación -->
    @if (totalPages > 1)
    {
        <div class="pagination-bar">
            <span class="pagination-info">
                Mostrando @((page - 1) * pageSize + 1)–@Math.Min(page * pageSize, total) de @total empleados
            </span>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url(page - 1)"><i class="bi bi-chevron-left"></i></a>
                    </li>
                    @{
                        int start = Math.Max(1, page - 2);
                        int end   = Math.Min(totalPages, start + 4);
                        start     = Math.Max(1, end - 4);
                    }
                    @if (start > 1)
                    {
                        <li class="page-item"><a class="page-link" href="@Url(1)">1</a></li>
                        @if (start > 2) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                    }
                    @for (int i = start; i <= end; i++)
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link" href="@Url(i)">@i</a>
                        </li>
                    }
                    @if (end < totalPages)
                    {
                        @if (end < totalPages - 1) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                        <li class="page-item"><a class="page-link" href="@Url(totalPages)">@totalPages</a></li>
                    }
                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url(page + 1)"><i class="bi bi-chevron-right"></i></a>
                    </li>
                </ul>
            </nav>
        </div>
    }

</div>
</div>

@section Scripts {
<script>
(function () {
    'use strict';
    const input  = document.getElementById('txtBuscar');
    const list   = document.getElementById('acList');
    let timer    = null;
    let idx      = -1;

    input.addEventListener('input', () => {
        clearTimeout(timer);
        const q = input.value.trim();
        if (q.length < 2) { cerrar(); return; }
        timer = setTimeout(() => buscar(q), 300);
    });

    async function buscar(q) {
        try {
            const res  = await fetch(`/RecursosHumanos/Aquarius/Marcaciones/BuscarEmpleado?nombre=${encodeURIComponent(q)}`);
            const json = await res.json();
            if (!json.ok || !json.data?.length) { cerrar(); return; }
            const items = json.data.slice(0, 5);
            idx = -1;
            list.innerHTML = items.map((e, i) => {
                const ini = (e.empleado || '?').split(' ').filter(Boolean).slice(0, 2).map(w => w[0].toUpperCase()).join('');
                return `<div class="ac-item" data-idx="${i}" data-code="${e.personal}" data-name="${e.empleado}">`
                    + `<span class="avatar">${ini}</span>`
                    + `<span class="ac-name">${resaltar(e.empleado, q)}</span>`
                    + `<span class="ac-code">${e.personal}</span>`
                    + `</div>`;
            }).join('');
            list.style.display = 'block';
            list.querySelectorAll('.ac-item').forEach(el => {
                el.addEventListener('mousedown', (ev) => {
                    ev.preventDefault();
                    input.value = el.dataset.name;
                    cerrar();
                    input.closest('form').submit();
                });
            });
        } catch { cerrar(); }
    }

    function resaltar(text, q) {
        const re = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
        return (text || '').replace(re, '<mark>$1</mark>');
    }

    function cerrar() { list.style.display = 'none'; list.innerHTML = ''; idx = -1; }

    input.addEventListener('keydown', (e) => {
        const items = list.querySelectorAll('.ac-item');
        if (!items.length) return;
        if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); marcar(items); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx - 1, 0); marcar(items); }
        else if (e.key === 'Enter' && idx >= 0) { e.preventDefault(); items[idx].dispatchEvent(new Event('mousedown')); }
        else if (e.key === 'Escape') { cerrar(); }
    });

    function marcar(items) {
        items.forEach((el, i) => el.classList.toggle('ac-active', i === idx));
    }

    document.addEventListener('click', (e) => { if (!e.target.closest('.autocomplete-wrap')) cerrar(); });
})();
</script>
}


