@model IEnumerable<FabricaHilos.Models.Sgc.ItemDocuDto>
@using FabricaHilos.Models.Sgc

@{
    ViewData["Title"] = "Detalle de Factura";
    var  factura    = ViewBag.Factura   as DocuVentDto;
    string codAlm   = ViewBag.CodAlm    ?? string.Empty;
    string tpTransac= ViewBag.TpTransac ?? string.Empty;
    int  guiaSerie  = ViewBag.GuiaSerie;
    int  guiaNumero = ViewBag.GuiaNumero;
    int  pedSerie   = ViewBag.PedSerie;
    int  numPed     = ViewBag.NumPed;
    int  itemNro    = ViewBag.ItemNro;
    string? buscar  = ViewBag.Buscar as string;
    bool fromPacking  = ViewBag.FromPacking == true;
    int? packingSerie  = ViewBag.PackingSerie  != null ? Convert.ToInt32(ViewBag.PackingSerie)  : (int?)null;
    int? packingNumero = ViewBag.PackingNumero != null ? Convert.ToInt32(ViewBag.PackingNumero) : (int?)null;
    string? cTipo      = ViewBag.CTipo as string;
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item"><a asp-action="Pedidos" asp-route-buscar="@buscar">Pedidos</a></li>
    @if (fromPacking)
    {
        <li class="breadcrumb-item">
            <a asp-action="Packing" asp-route-pedSerie="@pedSerie" asp-route-numPed="@numPed" asp-route-buscar="@buscar">
                Packing — Pedido @numPed
            </a>
        </li>
    }
    else
    {
        <li class="breadcrumb-item">
            <a asp-action="DetallePedido" asp-route-serie="@pedSerie" asp-route-numPed="@numPed" asp-route-buscar="@buscar">
                Pedido @numPed
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Guias" asp-route-pedSerie="@pedSerie" asp-route-numPed="@numPed" asp-route-nro="@itemNro" asp-route-buscar="@buscar">
                Guías (Ítem @itemNro)
            </a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="DetalleGuia"
               asp-route-codAlm="@codAlm"
               asp-route-tpTransac="@tpTransac"
               asp-route-serie="@guiaSerie"
               asp-route-numero="@guiaNumero"
               asp-route-pedSerie="@pedSerie"
               asp-route-numPed="@numPed"
               asp-route-nro="@itemNro"
               asp-route-buscar="@buscar">
                Guía @guiaNumero
            </a>
        </li>
    }
    <li class="breadcrumb-item">
        <a asp-action="Facturas"
           asp-route-cTipo="@cTipo"
           asp-route-pedSerie="@pedSerie"
           asp-route-numPed="@numPed"
           asp-route-buscar="@buscar"
           asp-route-fromPacking="@fromPacking"
           asp-route-packingSerie="@packingSerie"
           asp-route-packingNumero="@packingNumero"
           asp-route-codAlm="@codAlm"
           asp-route-tpTransac="@tpTransac"
           asp-route-guiaSerie="@guiaSerie"
           asp-route-guiaNumero="@guiaNumero"
           asp-route-itemNro="@itemNro">
            Facturas
        </a>
    </li>
    <li class="breadcrumb-item active">Factura @factura?.Numero</li>
}

<div class="mb-3">
    <h4 class="section-title mb-1"><i class="bi bi-list-ul me-2"></i>Detalle de Factura</h4>
    <a asp-action="Facturas"
       asp-route-cTipo="@cTipo"
       asp-route-cSerie="@factura?.Serie"
       asp-route-cNumero="@factura?.Numero"
       asp-route-codAlm="@codAlm"
       asp-route-tpTransac="@tpTransac"
       asp-route-guiaSerie="@guiaSerie"
       asp-route-guiaNumero="@guiaNumero"
       asp-route-pedSerie="@pedSerie"
       asp-route-numPed="@numPed"
       asp-route-itemNro="@itemNro"
       asp-route-kdNro="0"
       asp-route-buscar="@buscar"
       asp-route-fromPacking="@fromPacking"
       asp-route-packingSerie="@packingSerie"
       asp-route-packingNumero="@packingNumero"
       class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Volver a facturas
    </a>
</div>

@if (factura != null)
{
    <div class="card mb-3">
        <div class="card-header fw-semibold bg-light">
            <i class="bi bi-receipt me-1"></i>
            @factura.Tipodoc — Serie <strong>@factura.Serie</strong> N° <strong>@factura.Numero</strong>
        </div>
        <div class="card-body py-2">
            <div class="row row-cols-2 row-cols-md-4 g-2 small">
                <div><span class="text-muted">RUC:</span> @(factura.Ruc ?? "-")</div>
                <div><span class="text-muted">Cliente:</span> <span class="fw-semibold">@(factura.Nombre ?? factura.CodCliente)</span></div>
                <div><span class="text-muted">Fecha:</span> @(factura.Fecha?.ToString("dd/MM/yyyy") ?? "-")</div>
                <div><span class="text-muted">Moneda:</span> @(factura.Moneda == "D" ? "Dólares ($)" : factura.Moneda == "S" ? "Soles (S/)" : (factura.Moneda ?? "-"))</div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-corporate table-hover mb-0">
                <thead>
                    <tr>
                        <th class="text-center">Ítem</th>
                        <th class="text-center">Cód. Art.</th>
                        <th class="text-center">Descripción</th>
                        <th class="text-end">Cantidad</th>
                        <th class="text-end">Valor Venta</th>
                        <th class="text-end">Importe</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center">@item.Nro</td>
                            <td class="fw-semibold">@(item.CodArt ?? "-")</td>
                            <td>@(item.Detalle ?? "-")</td>
                            <td class="text-end">@(item.Cantidad?.ToString("N2") ?? "-")</td>
                            <td class="text-end">@(item.Precio?.ToString("N2") ?? "-")</td>
                            <td class="text-end fw-semibold text-success">@(item.Importe?.ToString("N2") ?? "-")</td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="bi bi-inbox me-2"></i>No se encontraron ítems para esta factura.
                            </td>
                        </tr>
                    }
                </tbody>
                @if (Model.Any())
                {
                    <tfoot class="table-light fw-semibold">
                        <tr>
                            <td colspan="5" class="text-end">Total:</td>
                            <td class="text-end text-success">
                                @(Model.Sum(x => x.Importe ?? 0).ToString("N2"))
                            </td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
    <div class="card-footer py-2">
        @{
            int currentPage = ViewBag.Page       != null ? Convert.ToInt32(ViewBag.Page)       : 1;
            int totalPages  = ViewBag.TotalPages != null ? Convert.ToInt32(ViewBag.TotalPages) : 1;
            int totalCount  = ViewBag.TotalCount != null ? Convert.ToInt32(ViewBag.TotalCount) : 0;
            int pgSize      = ViewBag.PageSize   != null ? Convert.ToInt32(ViewBag.PageSize)   : 10;
            int startItem   = totalCount == 0 ? 0 : (currentPage - 1) * pgSize + 1;
            int endItem     = Math.Min(currentPage * pgSize, totalCount);
        }
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @(totalCount == 0 ? "Sin registros" : $"Mostrando {startItem}\u2013{endItem} de {totalCount} registros")
            </small>
            @if (totalPages > 1)
            {
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="DetalleFactura"
                               asp-route-tipo="@factura?.Tipodoc" asp-route-serie="@factura?.Serie" asp-route-numero="@factura?.Numero"
                               asp-route-codAlm="@codAlm" asp-route-tpTransac="@tpTransac"
                               asp-route-guiaSerie="@guiaSerie" asp-route-guiaNumero="@guiaNumero"
                               asp-route-pedSerie="@pedSerie" asp-route-numPed="@numPed" asp-route-itemNro="@itemNro"
                               asp-route-buscar="@buscar"
                               asp-route-page="@(currentPage - 1)"><i class="bi bi-chevron-left"></i></a>
                        </li>
                        @for (int pg = Math.Max(1, currentPage - 2); pg <= Math.Min(totalPages, currentPage + 2); pg++)
                        {
                            <li class="page-item @(pg == currentPage ? "active" : "")">
                                <a class="page-link" asp-action="DetalleFactura"
                                   asp-route-tipo="@factura?.Tipodoc" asp-route-serie="@factura?.Serie" asp-route-numero="@factura?.Numero"
                                   asp-route-codAlm="@codAlm" asp-route-tpTransac="@tpTransac"
                                   asp-route-guiaSerie="@guiaSerie" asp-route-guiaNumero="@guiaNumero"
                                   asp-route-pedSerie="@pedSerie" asp-route-numPed="@numPed" asp-route-itemNro="@itemNro"
                                   asp-route-buscar="@buscar"
                                   asp-route-page="@pg">@pg</a>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="DetalleFactura"
                               asp-route-tipo="@factura?.Tipodoc" asp-route-serie="@factura?.Serie" asp-route-numero="@factura?.Numero"
                               asp-route-codAlm="@codAlm" asp-route-tpTransac="@tpTransac"
                               asp-route-guiaSerie="@guiaSerie" asp-route-guiaNumero="@guiaNumero"
                               asp-route-pedSerie="@pedSerie" asp-route-numPed="@numPed" asp-route-itemNro="@itemNro"
                               asp-route-buscar="@buscar"
                               asp-route-page="@(currentPage + 1)"><i class="bi bi-chevron-right"></i></a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
