    /* ═══════════════════════════════════════════════
       CHART: Ranking de Asesores
       ═══════════════════════════════════════════════ */
    function renderRanking() {
        destroyChart('ranking');

        var monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        var map = {};
        clientesTodosData.forEach(function(d) {
            var key = (d.asesor && d.asesor !== 'null') ? d.asesor : 'Sin Asesor';
            map[key] = (map[key] || 0) + (d.total || 0);
        });
        if (Object.keys(map).length === 0) return;

        var sorted = Object.entries(map)
            .map(function([a, t]) { return { asesor: a, total: t }; })
            .sort(function(a, b) { return a.total - b.total; });

        var fmtMil = function(n) {
            n = n || 0;
            if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M';
            if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K';
            return fmtPE.format(n);
        };

        charts['ranking'] = new Chart(
            document.getElementById('chartRanking').getContext('2d'), {
            type: 'bar',
            data: {
                labels: sorted.map(r => r.asesor),
                datasets: [{
                    label: 'Importe Total',
                    data: sorted.map(r => r.total),
                    backgroundColor: sorted.map(function(_, i) { return COLORS[i % COLORS.length]; }),
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: function(c) { return monLabel + ' ' + fmtPE.format(c.raw); } } },
                    datalabels: {
                        display: function(ctx) { return ctx.dataset.data[ctx.dataIndex] > 0; },
                        anchor: 'end', align: 'right',
                        font: { size: 12, weight: '700', family: "'Segoe UI', Arial, sans-serif" },
                        color: '#374151',
                        textStrokeColor: 'rgba(255,255,255,.8)',
                        textStrokeWidth: 3,
                        formatter: function(v, ctx) {
                            return monLabel + ' ' + fmtMil(v);
                        }
                    }
                },
                layout: { padding: { right: 200 } },
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: { callback: function(v) { return fmtMil(v); }, font: { size: 11 } }
                    }
                }
            }
        });
    }

    /* ═══════════════════════════════════════════════
       DETALLE: Clientes del Asesor
       ═══════════════════════════════════════════════ */
    async function loadDetalleClientesAsesor(asesor) {
        var panel = document.getElementById('panelClientesAsesor');
        var lbl   = document.getElementById('lblAsesorDetalle');
        var body  = document.getElementById('bodyClientesAsesor');
        var spin  = document.getElementById('spinnerClientesAsesor');

        panel.style.display = 'block';
        lbl.textContent = asesor;
        body.innerHTML  = '';
        spin.style.display = 'flex';
        panel.scrollIntoView({ behavior: 'smooth', block: 'start' });

        var monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';

        try {
            var rows = (clientesTodosData || []).filter(function(r) {
                return (r.asesor || '').toUpperCase() === asesor.toUpperCase();
            });

            if (!rows || rows.length === 0) {
                body.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-3">Sin datos para el período seleccionado.</td></tr>';
            } else {
                const fmtKg = new Intl.NumberFormat('es-PE', { minimumFractionDigits: 2 });
                rows.forEach(function(row, i) {
                    var igv   = row.igv   ?? 0;
                    var total = row.total ?? 0;
                    body.innerHTML += '<tr>'
                        + '<td>' + (i + 1) + '</td>'
                        + '<td>' + (row.ruc || '') + '</td>'
                        + '<td>' + (row.razonSocial || '') + '</td>'
                        + '<td>' + (row.giro || '') + '</td>'
                        + '<td class="text-end">' + (row.nroDoc ?? '') + '</td>'
                        + '<td class="text-end">' + fmtKg.format(row.cantidadKg ?? 0) + '</td>'
                        + '<td class="text-end fw-semibold">' + monLabel + ' ' + fmt(row.importe) + '</td>'
                        + '<td class="text-end">' + monLabel + ' ' + fmt(igv) + '</td>'
                        + '<td class="text-end fw-bold">' + monLabel + ' ' + fmt(total) + '</td>'
                        + '</tr>';
                });
            }
        } catch (e) {
            console.error(e);
            body.innerHTML = '<tr><td colspan="9" class="text-center text-danger py-3">Error al cargar los datos.</td></tr>';
        } finally {
            spin.style.display = 'none';
        }
    }

    window.cerrarDetalleClientes = function () {
        document.getElementById('panelClientesAsesor').style.display = 'none';
        document.getElementById('bodyClientesAsesor').innerHTML = '';
    };

    /* ═══════════════════════════════════════════════
       CARGAR TODOS LOS DATOS
       ═══════════════════════════════════════════════ */
    window.loadAll = async function () {
        var lbl = { textContent: '', className: '' }; // diagnóstico deshabilitado

        var p = buildParams();

        try {
            var r    = await fetch('@Url.Action("DatosDashboard", "DashboardComercialMaestro")?' + p.toString() + '&top=3');
            var data = await r.json();

            clientesTodosData = data.clientesTodos ?? [];
            topClientesData   = data.topClientes   ?? [];
            window._clientesTodosData = clientesTodosData;

            try { renderCartera();       } catch(e) { console.warn('renderCartera:', e); }
            try { renderClientesPie();   } catch(e) { console.warn('renderClientesPie:', e); }
            try { renderClientesPct();   } catch(e) { console.warn('renderClientesPct:', e); }
            try { renderRanking();       } catch(e) { console.warn('renderRanking:', e); }
            try { renderParticipacion(); } catch(e) { console.warn('renderParticipacion:', e); }
            try { renderTopImporte();    } catch(e) { console.warn('renderTopImporte:', e); }
            try { renderTopKg();         } catch(e) { console.warn('renderTopKg:', e); }

        } catch (e) {
            console.error(e);
            showToast('Error al cargar el dashboard. Verifique su conexión.', 'danger');
        }
    };

    /* ── Limpiar filtros ───────────────────────────── */
    window.clearFilters = function () {
        document.getElementById('moneda').value = 'D';
        setDefaultDates();
        loadAll();
    };

    /* ── Inicio ────────────────────────────────────── */
    setDefaultDates();
    loadAll();
})();
</script>
}
