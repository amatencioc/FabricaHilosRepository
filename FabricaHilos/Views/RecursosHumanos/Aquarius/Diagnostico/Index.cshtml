@{
    ViewData["Title"] = "Diagnóstico Aquarius";
}

@section Breadcrumb {
    <li class="breadcrumb-item">Recursos Humanos</li>
    <li class="breadcrumb-item">Aquarius</li>
    <li class="breadcrumb-item active">Diagnóstico de Conexión</li>
}

<div class="container-fluid px-2 px-md-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0" style="color: var(--color-primary, #1B4D3E);">
            <i class="bi bi-database-check me-2"></i>Diagnóstico de Conexión — Aquarius
        </h5>
        <button id="btnTestear" class="btn btn-primary btn-sm">
            <i class="bi bi-play-circle me-1"></i>Ejecutar prueba
        </button>
    </div>

    <div id="panelEspera" class="text-center text-muted py-5" style="display:none;">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Conectando con el servidor Oracle…</p>
    </div>

    <div id="panelResultado" style="display:none;">

        <!-- Datos de conexión -->
        <div class="card mb-3">
            <div class="card-header fw-semibold">
                <i class="bi bi-info-circle me-1"></i>Parámetros de conexión utilizados
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-6">
                        <span class="text-muted small">Data Source:</span>
                        <code id="lblDataSource" class="d-block fs-6"></code>
                    </div>
                    <div class="col-md-6">
                        <span class="text-muted small">Usuario Oracle (sesión activa):</span>
                        <code id="lblUsuario" class="d-block fs-6"></code>
                    </div>
                </div>
            </div>
        </div>

        <!-- Resultados de las pruebas -->
        <div class="card">
            <div class="card-header fw-semibold">
                <i class="bi bi-clipboard2-pulse me-1"></i>Resultados
            </div>
            <ul class="list-group list-group-flush" id="listaResultados"></ul>
        </div>

    </div>

</div>

@section Scripts {
<script>
(function () {

    function badge(ok, textoOk, textoFail) {
        return ok
            ? `<span class="badge bg-success"><i class="bi bi-check-lg me-1"></i>${textoOk}</span>`
            : `<span class="badge bg-danger"><i class="bi bi-x-lg me-1"></i>${textoFail}</span>`;
    }

    function agregarItem(icono, titulo, contenido) {
        const li = document.createElement('li');
        li.className = 'list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2';
        li.innerHTML = `<span><i class="bi bi-${icono} me-2"></i>${titulo}</span>${contenido}`;
        document.getElementById('listaResultados').appendChild(li);
    }

    document.getElementById('btnTestear').addEventListener('click', async function () {
        this.disabled = true;
        document.getElementById('panelEspera').style.display = 'block';
        document.getElementById('panelResultado').style.display = 'none';
        document.getElementById('listaResultados').innerHTML = '';

        try {
            const resp = await fetch('/RecursosHumanos/Aquarius/Diagnostico/TestConexion');
            const d = await resp.json();

            document.getElementById('lblDataSource').textContent = d.dataSource ?? '(desconocido)';
            document.getElementById('lblUsuario').textContent    = d.usuario    ?? '(no hay sesión Oracle activa)';

            if (!d.pingOk) {
                agregarItem('wifi-off', 'Conexión al servidor Oracle',
                    `<span class="badge bg-danger"><i class="bi bi-x-lg me-1"></i>FALLIDA</span>`);
                agregarItem('exclamation-triangle-fill text-danger', 'Error',
                    `<span class="text-danger small font-monospace">${d.error ?? ''}</span>`);
            } else {
                agregarItem('wifi', 'Ping al servidor Oracle (SELECT 1 FROM DUAL)',
                    badge(true, 'OK', 'FALLIDO'));

                agregarItem('server', 'Versión del servidor',
                    `<span class="badge bg-secondary">${d.versionBd ?? 'N/D'}</span>`);

                agregarItem('table', 'Tablas de AQUARIUS visibles para este usuario',
                    badge(d.accesoAquariusOk,
                        `${d.tablasVisibles} tabla(s) accesibles`,
                        '0 tablas — sin permisos'));

                if (!d.accesoAquariusOk && d.errorAquarius) {
                    agregarItem('exclamation-triangle text-warning', 'Detalle',
                        `<span class="text-danger small font-monospace">${d.errorAquarius}</span>`);
                }

                const pkgColor = d.estadoPaquete === 'VALID' ? 'bg-success'
                               : d.estadoPaquete === 'NO ENCONTRADO' ? 'bg-danger' : 'bg-warning text-dark';
                agregarItem('box-seam', 'PKG_SCA_DEPURA_TAREO existe en ALL_OBJECTS',
                    `<span class="badge ${pkgColor}">${d.estadoPaquete ?? 'N/D'}</span>`);

                agregarItem('play-circle', 'EXECUTE real sobre BUSCAR_EMPLEADO',
                    badge(d.ejecucionPaqueteOk, 'EJECUTADO OK', 'SIN PERMISO / ERROR'));

                if (d.ejecucionPaqueteDetalle) {
                    const clsDetalle = d.ejecucionPaqueteOk ? 'text-success' : 'text-danger';
                    agregarItem('chat-left-text', 'Detalle ejecución',
                        `<span class="${clsDetalle} small font-monospace">${d.ejecucionPaqueteDetalle}</span>`);
                }
            }

        } catch (e) {
            agregarItem('wifi-off', 'Error de red',
                `<span class="text-danger small">${e.message}</span>`);
        } finally {
            document.getElementById('panelEspera').style.display = 'none';
            document.getElementById('panelResultado').style.display = 'block';
            document.getElementById('btnTestear').disabled = false;
        }
    });

})();
</script>
}
