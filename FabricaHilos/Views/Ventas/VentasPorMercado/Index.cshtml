    function renderDocumentos(data) {
        const monLabel = document.getElementById('moneda').value === 'S' ? 'S/' : 'USD';
        document.getElementById('badgeTotalDocs').textContent = (data ? data.length : 0) + ' registros';

        const tbody = document.getElementById('tablaDocumentosBody');
        if (!data || data.length === 0) {
            tbody.innerHTML = '<tr><td colspan="21" class="text-center text-muted py-3">Sin datos</td></tr>';
            return;
        }

        const fmtDate = d => {
            if (!d) return '';
            const dt = new Date(d);
            return dt.toLocaleDateString('es-PE');
        };

        tbody.innerHTML = data.map((d, i) => {
            // Interpretar campos según UBIGEO.PAIS:
            // '01' = Perú → departamento y distrito reales
            // ≠'01' → NOM_DPT=país extranjero, NOM_DTT=ciudad de ese país
            const esPeru = (d.ubigeoPais ?? '01') === '01';
            const colDpto = esPeru
                ? (d.departamento ?? '')
                : '<span class="text-info" title="País (UBIGEO.PAIS≠01)">' + (d.departamento ?? '') + '</span>';
            const colDist = esPeru
                ? (d.distrito ?? '')
                : '<span class="text-info" title="Ciudad (UBIGEO.PAIS≠01)">' + (d.distrito ?? '') + '</span>';

            return '<tr>'
            + '<td>' + (i + 1) + '</td>'
            + '<td>' + (d.tipoDoc ?? '') + '</td>'
            + '<td>' + (d.serie ?? '') + '</td>'
            + '<td>' + (d.numero ?? '') + '</td>'
            + '<td>' + fmtDate(d.fecha) + '</td>'
            + '<td>' + (d.moneda ?? '') + '</td>'
            + '<td>' + (d.codCliente ?? '') + '</td>'
            + '<td>' + (d.nomCliente ?? '') + '</td>'
            + '<td>' + (d.pais ?? '') + '</td>'
            + '<td>' + (d.exportacion ?? '') + '</td>'
            + '<td><span class="badge" style="background:' + (MERCADO_COLORS[d.mercado] || '#999') + ';font-size:.7rem">' + (d.mercado ?? '') + '</span></td>'
            + '<td class="text-end">' + fmt(d.importCam) + '</td>'
            + '<td class="text-end">' + fmt(d.valVenta) + '</td>'
            + '<td class="text-end">' + fmt(d.impDescto) + '</td>'
            + '<td class="text-end">' + fmt(d.impAnticipo) + '</td>'
            + '<td class="text-end">' + fmt(d.impInteres) + '</td>'
            + '<td class="text-end fw-semibold">' + fmt(d.impNeto) + '</td>'
            + '<td class="text-end">' + fmt(d.impIgv) + '</td>'
            + '<td class="text-end">' + fmt(d.precioVta) + '</td>'
            + '<td>' + colDpto + '</td>'
            + '<td>' + colDist + '</td>'
            + '</tr>';
        }).join('');
    }

    /* ══════════════════════════════════════════════════
       EXPORTAR A EXCEL (CSV con BOM UTF-8)
       ══════════════════════════════════════════════════ */
    window.exportarExcel = function () {
        if (!_docsData || _docsData.length === 0) {
            showToast('No hay datos para exportar.', 'warning');
            return;
        }

        const monLabel = document.getElementById('moneda').value === 'S' ? 'PEN' : 'USD';
        const fmtDate = d => {
            if (!d) return '';
            const dt = new Date(d);
            return dt.toLocaleDateString('es-PE');
        };

        const headers = ['#','Tipo','Serie','Número','Fecha','Moneda','Cód.Cliente','Razón Social',
                         'País','Exp','Mercado','T.C.','Val.Venta','Descto','Anticipo','Interés',
                         'Neto','IGV','Precio Vta','Dpto/País','Distrito/Ciudad'];

        const rows = _docsData.map((d, i) => [
            i + 1, d.tipoDoc, d.serie, d.numero, fmtDate(d.fecha), d.moneda,
            d.codCliente, d.nomCliente, d.pais, d.exportacion, d.mercado,
            d.importCam, d.valVenta, d.impDescto, d.impAnticipo, d.impInteres,
            d.impNeto, d.impIgv, d.precioVta, d.departamento, d.distrito
        ]);

        const csvContent = [headers, ...rows]
            .map(r => r.map(v => '"' + String(v ?? '').replace(/"/g, '""') + '"').join(','))
            .join('\n');

        const BOM = '\uFEFF';
        const blob = new Blob([BOM + csvContent], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'VentasPorMercado_' + monLabel + '_' + new Date().toISOString().slice(0,10) + '.csv';
        a.click();
        URL.revokeObjectURL(url);
    };

    /* ══════════════════════════════════════════════════
       Load all data
       ══════════════════════════════════════════════════ */
    async function loadMercado() {
        showSpin('spinnerMercado');
        try {
            const data = await apiFetch('/VentasPorMercado/DatosVentasPorMercado?' + buildParams());
            renderMercado(data);
        } catch (e) {
            showToast('Error al cargar datos de mercado: ' + e.message);
        } finally {
            hideSpin('spinnerMercado');
        }
    }

    window.loadAll = function () {
        cerrarDetallePais();
        cerrarDetalleDpto();
        cerrarDetalleDistrito();
        cerrarDetalleCiudadPais();
        loadMercado();
        loadEvolucion();
        loadTopClientes();
        loadDocumentos();
    };

    window.clearFilters = function () {
        setDefaultDates();
        document.getElementById('moneda').value = 'D';
        document.getElementById('filtroMercadoClientes').value = '';
        document.getElementById('filtroMercadoDocs').value = '';
        loadAll();
    };

    /* ── Inicialización ─────────────────────────────── */
    document.addEventListener('DOMContentLoaded', async function () {
        setDefaultDates();
        // Cargar mapeo BD→ISO desde la BD antes de renderizar el mapa
        await cargarMapeoPaises();
        loadAll();
    });
})();
</script>
}
