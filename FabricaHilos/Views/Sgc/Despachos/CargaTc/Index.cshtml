@model IEnumerable<FabricaHilos.Models.Sgc.ReqCertDto>

@{
    ViewData["Title"] = "Cargar TC - Requerimientos de Certificados";
    string? buscar      = ViewBag.Buscar      as string;
    string? fechaInicio = ViewBag.FechaInicio as string;
    string? fechaFin    = ViewBag.FechaFin    as string;
    string? navToken    = ViewBag.NavToken    as string;
    int page            = ViewBag.Page        ?? 1;
    int pageSize        = ViewBag.PageSize    ?? 10;
    int totalCount      = ViewBag.TotalCount  ?? 0;
    int totalPages      = ViewBag.TotalPages  ?? 1;
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Sgc" asp-action="Index">SGC</a></li>
    <li class="breadcrumb-item">Despachos</li>
    <li class="breadcrumb-item active">Cargar TC</li>
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-file-certificate me-2"></i>
                        Cargar TC - Requerimientos de Certificados
                    </h5>
                    <span class="badge bg-light text-dark">Total: @totalCount registros</span>
                </div>
                <div class="card-body">
                    @Html.AntiForgeryToken()
                    
                    <!-- Filtros -->
                    <form method="get" asp-action="Index" class="mb-4">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label for="buscar" class="form-label">Buscar (NUM_CER, Razón Social, RUC)</label>
                                <input type="text" class="form-control" id="buscar" name="buscar" value="@buscar" placeholder="Ingrese texto...">
                            </div>
                            <div class="col-md-3">
                                <label for="fechaInicio" class="form-label">Fecha Inicio</label>
                                <input type="date" class="form-control" id="fechaInicio" name="fechaInicio" value="@fechaInicio">
                            </div>
                            <div class="col-md-3">
                                <label for="fechaFin" class="form-label">Fecha Fin</label>
                                <input type="date" class="form-control" id="fechaFin" name="fechaFin" value="@fechaFin">
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-search me-1"></i>Buscar
                                </button>
                            </div>
                        </div>
                    </form>

                    <!-- Tabla de Requerimientos -->
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-striped align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th class="text-center">#</th>
                                        <th>Nº Req.</th>
                                        <th>Fecha</th>
                                        <th>Tipo de Certificado</th>
                                        <th>Nº Certificado</th>
                                        <th>Razón Social</th>
                                        <th>RUC</th>
                                        <th>Documento</th>
                                        <th>Usuario</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int contador = (page - 1) * pageSize;
                                    }
                                    @foreach (var req in Model)
                                    {
                                        contador++;
                                        <tr class="cursor-pointer" data-numreq="@req.NumReq">
                                            <td class="text-center">@contador</td>
                                            <td><strong>@req.NumReq</strong></td>
                                            <td>@req.Fecha?.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(req.CodArt))
                                                {
                                                    if (req.CodArt == "CERTGOTS")
                                                    {
                                                        <span class="badge bg-success">GOTS</span>
                                                    }
                                                    else if (req.CodArt == "CERTOCS")
                                                    {
                                                        <span class="badge bg-info">OCS</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@req.CodArt</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @{
                                                    bool hayCertificado = !string.IsNullOrEmpty(req.NumCer);
                                                }

                                                @if (hayCertificado)
                                                {
                                                    <a href="@Url.Action("VisualizarPdf", "CargaTc", new { numReq = req.NumReq })" 
                                                       target="_blank" 
                                                       class="me-2" 
                                                       title="Visualizar certificado PDF">
                                                        <i class="bi bi-file-pdf-fill text-danger" style="font-size: 1.2rem;"></i>
                                                    </a>
                                                    <span class="badge bg-success">@req.NumCer</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Sin certificado</span>
                                                }
                                            </td>
                                            <td>@req.RazonSocial</td>
                                            <td>@req.Ruc</td>
                                            <td>
                                                @{
                                                    bool hayDocumento = !string.IsNullOrEmpty(req.TipoDoc) && 
                                                                        !string.IsNullOrEmpty(req.Serie) && 
                                                                        !string.IsNullOrEmpty(req.Numero);
                                                }

                                                @if (hayDocumento)
                                                {
                                                    <span>@req.TipoDoc-@req.Serie-@req.Numero</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @if (req.AMduser != null)
                                                    {
                                                        <span>Mod: @req.AMduser (@req.AMdfecha?.ToString("dd/MM/yyyy"))</span>
                                                    }
                                                    else if (req.AAduser != null)
                                                    {
                                                        <span>Cre: @req.AAduser (@req.AAdfecha?.ToString("dd/MM/yyyy"))</span>
                                                    }
                                                </small>
                                            </td>
                                            <td class="text-center">
                                                <a href="@Url.Action("Detalle", new { numReq = req.NumReq, t = navToken })" 
                                                   class="btn btn-sm btn-primary me-1" title="Ver detalle">
                                                    <i class="bi bi-eye-fill"></i>
                                                </a>
                                                
                                                @if (!string.IsNullOrEmpty(req.NumCer))
                                                {
                                                    <button type="button" 
                                                            class="btn btn-sm btn-success btn-enviar-facturacion" 
                                                            data-numreq="@req.NumReq"
                                                            title="Enviar a Facturación">
                                                        <i class="bi bi-send-fill"></i>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Paginación -->
                        @if (totalPages > 1)
                        {
                            <nav aria-label="Navegación de páginas">
                                <ul class="pagination justify-content-center">
                                    <li class="page-item @(page == 1 ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { t = navToken, page = page - 1 })">Anterior</a>
                                    </li>

                                    @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                                    {
                                        <li class="page-item @(i == page ? "active" : "")">
                                            <a class="page-link" href="@Url.Action("Index", new { t = navToken, page = i })">@i</a>
                                        </li>
                                    }

                                    <li class="page-item @(page == totalPages ? "disabled" : "")">
                                        <a class="page-link" href="@Url.Action("Index", new { t = navToken, page = page + 1 })">Siguiente</a>
                                    </li>
                                </ul>
                            </nav>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <i class="fas fa-info-circle me-2"></i>
                            No se encontraron requerimientos con los filtros especificados.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Click en la fila para ir al detalle
            $('tr.cursor-pointer').click(function (e) {
                if (!$(e.target).closest('button, a').length) {
                    const numReq = $(this).data('numreq');
                    const url = '@Url.Action("Detalle", "CargaTc")' + '?numReq=' + numReq + '&t=@navToken';
                    window.location.href = url;
                }
            });

            // Botón "Enviar a Facturación"
            $('.btn-enviar-facturacion').click(function(e) {
                e.stopPropagation();
                const numReq = $(this).data('numreq');
                mostrarModalEnvioFacturacion(numReq);
            });
        });

        function mostrarModalEnvioFacturacion(numReq) {
            Swal.fire({
                title: 'Enviar a Facturación',
                html: `
                    <div class="text-start">
                        <p class="mb-3">Ingrese el correo electrónico del destinatario:</p>
                        <div class="mb-3">
                            <label for="correoDestinatario" class="form-label">Correo Destinatario <span class="text-danger">*</span></label>
                            <input type="email" 
                                   class="form-control" 
                                   id="correoDestinatario" 
                                   placeholder="facturacion@colonial.com.pe"
                                   required>
                        </div>
                        <div class="mb-3">
                            <label for="nombreDestinatario" class="form-label">Nombre Destinatario (opcional)</label>
                            <input type="text" 
                                   class="form-control" 
                                   id="nombreDestinatario" 
                                   placeholder="Equipo de Facturación">
                        </div>
                    </div>
                `,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: '<i class="bi bi-send-fill me-1"></i>Enviar',
                cancelButtonText: 'Cancelar',
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                focusConfirm: false,
                preConfirm: () => {
                    const correo = document.getElementById('correoDestinatario').value;
                    const nombre = document.getElementById('nombreDestinatario').value;

                    if (!correo) {
                        Swal.showValidationMessage('Por favor ingrese el correo destinatario');
                        return false;
                    }

                    // Validar formato de correo
                    const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
                    if (!emailRegex.test(correo)) {
                        Swal.showValidationMessage('Por favor ingrese un correo válido');
                        return false;
                    }

                    return { correo, nombre };
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    enviarAFacturacion(numReq, result.value.correo, result.value.nombre);
                }
            });
        }

        function enviarAFacturacion(numReq, correoDestinatario, nombreDestinatario) {
            // Mostrar loading
            Swal.fire({
                title: 'Enviando notificación...',
                html: 'Por favor espere',
                allowOutsideClick: false,
                allowEscapeKey: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            // Obtener el token antifalsificación
            var token = $('input[name="__RequestVerificationToken"]').val();

            // Realizar la petición AJAX
            $.ajax({
                url: '@Url.Action("EnviarAFacturacion", "CargaTc")',
                type: 'POST',
                contentType: 'application/json',
                headers: {
                    'RequestVerificationToken': token
                },
                data: JSON.stringify({
                    numReq: numReq,
                    correoDestinatario: correoDestinatario,
                    nombreDestinatario: nombreDestinatario || 'Equipo de Facturación'
                }),
                success: function(response) {
                    Swal.close();
                    
                    if (response.tipo === 'Exito') {
                        Swal.fire({
                            icon: 'success',
                            title: 'Enviado',
                            text: response.mensaje,
                            confirmButtonColor: '#198754'
                        });
                    } else if (response.tipo === 'Advertencia') {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Advertencia',
                            text: response.mensaje,
                            confirmButtonColor: '#ffc107'
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.mensaje,
                            confirmButtonColor: '#dc3545'
                        });
                    }
                },
                error: function(xhr, status, error) {
                    Swal.close();
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Error al enviar la notificación: ' + error,
                        confirmButtonColor: '#dc3545'
                    });
                }
            });
        }
    </script>
}

@section Styles {
    <style>
        .cursor-pointer {
            cursor: pointer;
        }
        .cursor-pointer:hover {
            background-color: #f8f9fa !important;
        }
    </style>
}
